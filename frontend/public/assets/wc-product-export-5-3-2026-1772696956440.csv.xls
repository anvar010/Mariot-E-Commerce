12865,simple,,,"GAS PASTA COOKER E-RQY-900S",1,0,visible,"The Gas Pasta Cooker E-RQY-900S is a professional-grade kitchen appliance designed for efficient pasta preparation in commercial settings. With its robust construction and high-performance burners, this gas pasta cooker provides quick and precise boiling of pasta. The E-RQY-900S features user-friendly controls, allowing chefs to achieve optimal cooking results. The durable design and spacious cooking area make it suitable for high-demand environments. Easy to operate and maintain, this gas pasta cooker is a reliable solution for commercial kitchens seeking an efficient and durable appliance for large-scale pasta cooking.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(339px, 12px);"" aria-expanded=""false""></div>",". GAS PASTA COOKER E-RQY-900S\n. cap: 1 tank of 40 ltr.\n. under closed cabinet.\n. water filling with handle located on control panel.\n. construction scotch bright finish 18/10 aisi 304.\n. Power: 7.5 kw.\n. net weight: 63 kg.\n. dim: 400 x 900 x 850+120 mm.\n. Italy SIT valve w/ CE certification &amp; CE approved.\n. E-RQY-900S",,,taxable,,1,,,0,0,,,,,0,,,3059,"COOKING LINE, COOKING LINE > Pasta Cooker",,,https://mariotstore.com/wp-content/uploads/2024/10/E-RQY-900S.png,,,,,,,,,0,,Stilco,"Type of Product","Gas Pasta Cooker",1,1,Brand,Stilco,1,1,default,1,1,202,index,79,380,0,,"GAS PASTA,GAS PASTA COOKER E-RQY-900S",,,,,,,,field_60befc9fc0fb7,E-RQY-900S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110110011011010000010110010100010110010111100110,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12867,simple,,,"ELECTRIC PASTA COOKER (CAP: 1 TANK OF 40 LTR) E-DYF-900S",1,0,visible,"The Electric Pasta Cooker E-DYF-900S is a professional-grade kitchen appliance designed for efficient pasta preparation in commercial settings. Featuring a generous 40-liter capacity in a single tank, this electric pasta cooker allows for large-scale cooking of pasta or other similar items. The appliance is equipped with precise temperature controls to ensure optimal cooking results. Its durable construction and user-friendly design make it suitable for high-demand environments. With easy-to-clean components, the E-DYF-900S Electric Pasta Cooker is a reliable choice for businesses seeking a robust and efficient solution for mass pasta production in professional kitchens.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",". ELECTRIC PASTA COOKER (CAP: 1 TANK OF 40 LTR) E-DYF-900S\n. cap: 1 tank of 40 ltr.\n. under closed cabinet.\n. water filling with handle located on control panel.\n. construction scotch bright finish 18/10 aisi 304.\n. Power: 6 kw.\n. voltage: 380V / 50 hz\n. net weight: 55 kg.\n. dim: 400 x 900 x 850+120 mm.\n. Italy SIT valve w/ CE certification &amp; CE approved.\n. E-DY-900S / E-DYF-900S",,,taxable,,1,,,0,0,,,,,0,,,2874,"COOKING LINE, COOKING LINE > Pasta Cooker",,,https://mariotstore.com/wp-content/uploads/2024/10/E-DYF-900S.png,,,,,,,,,0,,Stilco,"Type of Product","Electric Pasta Cooker",1,1,Brand,Stilco,1,1,default,1,1,0,index,80,380,0,,"ELECTRIC PASTA COOKER,ELECTRIC PASTA COOKER (CAP: 1 TANK OF 40 LTR) E-DYF-900S",,,,,,,,field_60befc9fc0fb7,E-DYF-900S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110110011011010010010110010100010110010101100110,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12869,simple,,,"GAS LAVA STONE GRILL E-RQH-12",1,0,visible,"The Gas Lava Stone Grill E-RQH-12 is a powerful and efficient outdoor cooking appliance designed for grilling enthusiasts. With its durable construction and lava stone cooking surface, this gas grill delivers even heat distribution, ensuring a unique and flavorful grilling experience. The E-RQH-12 is equipped with user-friendly controls, making it suitable for various grilling applications. The lava stone not only imparts a distinctive smoky flavor to the food but also provides excellent heat retention. Whether you're grilling meats, vegetables, or other favorites, the Gas Lava Stone Grill E-RQH-12 provides a reliable and versatile solution for outdoor cooking with an authentic touch.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(39px, 17px);"" aria-expanded=""false""></div>",". GAS LAVA STONE GRILL E-RQH-12\n. American style 12"""" Charbroiler\n. Stainless steel 430\n. temp: 50 ~ 300 °c.\n. power: 8.5 kw\n. weight: 55 kg.\n. dimension: 306 x 700 x 385 mm.\n. E-RQH-12 """,,,taxable,,1,,,0,0,,,,,0,,,1354,"COOKING LINE, COOKING LINE > Grills",,,"https://mariotstore.com/wp-content/uploads/2024/10/E-RQH-12.png, https://mariotstore.com/wp-content/uploads/2024/10/E-RQH-36.png, https://mariotstore.com/wp-content/uploads/2024/10/E-RQH-48.png",,,,,,,,,0,,Stilco,"Type of Product","Gas Lava Stone Grill",1,1,Brand,Stilco,1,1,default,1,1,129,index,72,380,0,,"GAS LAVA STONE GRILL,GAS LAVA STONE GRILL E-RQH-12",,,,,,,,field_60befc9fc0fb7,E-RQH-12,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110100011000111000111001010100110110011101001010,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12873,simple,,,"GAS GRILL E-RQP-400",1,0,visible,"The Gas Grill E-RQP-400 is a robust commercial-grade grill designed for high-capacity cooking. Featuring a large grilling surface, it allows for extensive grilling of meats, vegetables, and more, making it ideal for busy restaurants and catering services. The grill is equipped with powerful gas burners that ensure rapid heating and even heat distribution, resulting in consistent and efficient cooking. Its durable stainless steel construction ensures longevity and ease of maintenance. With adjustable temperature controls and a user-friendly design, the E-RQP-400 is perfect for delivering high-quality grilled dishes in demanding environments.",". GAS GRILL E-RQP-400\n. 1 low pressure valves.\n. grease collection drawer.\n. power: 5 kw.\n. Net weight: 42 kg.\n. 12-16 mm thickness for the griddle.\n. Gas or lpg all available Italy valve.\n. Dim: 400 x 600 x 285 mm.\n. E-RQP-400 .""",,,taxable,,1,,,0,0,,,,,0,,,1960,"COOKING LINE, COOKING LINE > Grills",,,https://mariotstore.com/wp-content/uploads/2024/10/e_rqh_400g_commercial_restaurant_kitchen_equipment_countertop_gas_lava_stone-1.jpg,,,,,,,,,0,,Stilco,"Type of Product","Gas Grill",1,1,Brand,Stilco,1,1,default,1,1,199,index,77,380,0,,"GAS GRILL,GAS GRILL E-RQP-400",,,,,,,,field_60befc9fc0fb7,E-RQP-400,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110111110010010010000010111100100110110011001001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
