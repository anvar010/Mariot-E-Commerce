14664,simple,,,"FILTERING MACHINE - TMFS‐45",1,0,visible,,,,,taxable,,1,,,0,0,,,,,0,,,,Uncategorized,,,,,,,,,,,,0,,,,,,,,,,,default,1,0,,,,,,,,,,,,,,,field_60befc9fc0fb7,TMFS‐45,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14665,simple,,,"FILTERING MACHINE -  TMFS‐45",1,0,visible,"The TMFS-45 Filtering Machine is a robust and efficient filtration solution designed for medium-scale industrial applications. It offers high-performance filtering capabilities to remove impurities from liquids, ensuring a clean and pure output. The compact design, coupled with durable construction, makes it easy to integrate into existing systems while ensuring low maintenance and reliable operation.","<p style=""margin-bottom: 0; margin-top: 0px;"">• FILTERING MACHINE - TMFS‐45</p>\n<p style=""margin: 0; padding-top: 0;"">• Toastmaster (Middleby) Model No. TMFS‐45 FILTERING MACHINE</p>\n<p style=""margin: 0; padding-top: 0;"">• STANDARD FEATURES:</p>\n<p style=""margin: 0; padding-top: 0;"">• MODELTMFS-45 LENGTH 468(18.4) WIDTH728(28.6) HEIGHT 543(21.3) KW SHIP WEIGHT (Kilos) 0.4 44</p>\n<p style=""margin: 0; padding-top: 0;"">• MODELTMFS-65 LENGTH 510(20.0) WIDTH808(31.8) HEIGHT 604(23.7) KW SHIP WEIGHT (Kilos) 0.4 51</p>\n<p style=""margin: 0; padding-top: 0;"">• All stainless steel lo-profile construction</p>\n<p style=""margin: 0; padding-top: 0;"">• ON/OFF switch and quick disconnect hose fittings</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel filter framing, stainless filter grate and strainer</p>\n<p style=""margin: 0; padding-top: 0;"">• Equipped with a 5-feet flush hose assembly</p>\n<p style=""margin: 0; padding-top: 0;"">• Rests on 2"" caster wheels, two (2) with brakes</p>\n<p style=""margin: 0; padding-top: 0;"">• Includes 10 pieces filter media</p>",,,taxable,,1,,,0,0,,,,,1,,9989,11099,"COOKING LINE, Kitchen Equipment, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/Toastmaster-Middleby-Model-No.-TMFS‐65.png,,,,,,,,,0,,Toastmaster,Brand,Toastmaster,1,1,,,,,default,1,1,0,,76,0,,,"FILTERING MACHINE - TMFS‐45",,,,,,,,field_60befc9fc0fb7,TMFS‐45,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_65701746799