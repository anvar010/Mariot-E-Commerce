13864,simple,,,"ELECTRIC CONTACT GRILL PS - 2010 R",1,0,visible,"The ELECTRIC CONTACT GRILL PS-2010 R is a versatile kitchen appliance designed to simplify and enhance your cooking experience. This electric contact grill is equipped with a range of features that make it ideal for grilling, toasting, and cooking a variety of foods.","Grooved electric grooved upper plate\nLayout: 1 x 3 kw\nGriddle dimensions: 260 x 240 mm\nExcellent heat conduction temp: 50 - 3000C\nPower / voltage: 3 kw / 230 V / 1N - 50 Hz\nN/G Weight: 15 - 16 kg\nDim: 304 x 407 x 189 mm\nPS - 2010 R / RM GASTRO / italy made",,,taxable,,1,,,0,0,,,,,1,,,2527.84,"COOKING LINE, Kitchen Equipment, Offer, COOKING LINE > Sandwich Maker",,,https://mariotstore.com/wp-content/uploads/2024/10/r.jpg,,,,,,,,,0,,"RM Gastro",Electric/Gas,Electric,1,1,Brand,"RM Gastro",1,1,default,1,1,0,,62,0,0,,"ELECTRIC CONTACT GRILL",,,,,,,,field_60befc9fc0fb7,"PS - 2010 R",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15743,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011000110000110011010011110110000100110110011110,true,backend,,,,,,,salescountdowntimer,,,,,,,,,10:00,10:00,,,,,,,,,1895.88,,,,,,,,,,,,,,,,,,,,,,,,
13866,simple,,,"PLANETARY MIXER - PL30VAR",1,0,visible,"The PL30AR is a powerful planetary mixer designed to meet all your mixing needs in the kitchen. With its variable speed control, it allows you to achieve the perfect consistency for a wide range of recipes. Its robust construction and durable components ensure reliable performance, making it an essential tool for both professional chefs and home cooks. Whether you're mixing dough, batters, or other culinary delights, the PL30VAR is the ideal companion to make your cooking experience effortless and enjoyable.","<p style=""margin-bottom: 0; margin-top: 0px;"">• PLANETARY MIXER - PL30VAR</p>\n<p style=""margin: 0; padding-top: 0;"">• Bowl capacity 30 liters</p>\n<p style=""margin: 0; padding-top: 0;"">• With variable speed</p>\n<p style=""margin: 0; padding-top: 0;"">• supplied w/ 4 accesorries (1)fine wire whisk (2)heavy whisk (3)hook (4)spatula</p>\n<p style=""margin: 0; padding-top: 0;"">• special designed, sturdy &amp; robust constraction of thick stamped steel, ensures maximum durability &amp; silent working. variator control gradual speed change, belt transmission the machine the most silent of it's type.</p>\n<p style=""margin: 0; padding-top: 0;"">• power: 400 v /3 phase/ 50 hz / 1.1 kw</p>\n<p style=""margin: 0; padding-top: 0;"">• Net weight: 225 kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 730 x 870 x 1450 mm.</p>\n<p style=""margin: 0; padding-top: 0;"">• PL30VAR / MACPAN / italy made.</p>",,,taxable,,1,,,0,0,,,,,0,,,21050,"BAKERY LINE, BAKERY LINE > Bakery Mixers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/PLANETARY-MIXER-–-PL30VAR.png,,,,,,,,,0,,"Mac Pan",Brand,"Mac Pan",1,1,"Type of Product","Planetary Mixers",1,1,default,1,1,0,,81,0,0,,"PLANETARY MIXER",,,,,,,,field_60befc9fc0fb7,PL30VAR,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default