14356,simple,,,"DOUGH KNEADING MACHINE - HY.25",1,0,visible,"The HY.25 Dough Kneading Machine is an industrial-grade appliance engineered for high-volume dough preparation in commercial kitchens and bakeries. With its robust construction and powerful motor, it effortlessly mixes and kneads large quantities of dough with precision and efficiency. Featuring advanced controls and a user-friendly interface, it offers customizable settings to suit various dough types and recipes. The HY.25 is the ideal solution for businesses requiring reliable performance and consistent dough quality, ensuring streamlined operations and exceptional culinary\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">•</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 30 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 0.55 kW - 0.75 Hp - 220 V - 50 HZ</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless Bowl</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless dough fork</p>\n<p style=""margin: 0; padding-top: 0;"">• Easy to use and clean.</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 840 x 590 x 760 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model No. HY.25 / Mestro Horeca / Make in Turkey</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(715px, 191px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,2175,2627,"BAKERY LINE, BAKERY LINE > Bakery Mixers, Kitchen Equipment, Special Offer",,,"https://mariotstore.com/wp-content/uploads/2024/10/8-3.png, https://mariotstore.com/wp-content/uploads/2024/10/9-3.png, https://mariotstore.com/wp-content/uploads/2024/10/7-3.png",,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,default,1,1,0,,44,0,,,"DOUGH KNEADING MACHINE - HY.25,الة عجن العجينة,آلة عجن العجين",,,,,,0,,field_60befc9fc0fb7,HY.25,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_65701746799