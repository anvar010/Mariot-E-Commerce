12805,simple,,,"GAS COUNTERTOP COOKER 604HF",1,0,visible,"The GAS COUNTERTOP COOKER 604HF is a robust and efficient cooking appliance crafted for commercial kitchens. Made from durable stainless steel, it ensures longevity and easy cleaning. Equipped with high-powered gas burners, this cooker delivers quick and precise heating, making it perfect for a wide range of cooking applications. Its compact countertop design helps conserve kitchen space while maintaining high performance. The 604HF is an excellent choice for professional chefs who need reliable and powerful cooking equipment to handle the demands of a busy kitchen.","<p style=""margin-bottom: 0px; margin-top: 0px;"">• Capacity: 4 burners</p>\n<p style=""margin: 0px; padding-top: 0px;"">• With 4 control knobs</p>\n<p style=""margin: 0px; padding-top: 0px;"">• High performance 25,000 BTU cast iron burners provide\nmaximum heat distribution &amp; control. All S/S front panel</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Heavy-duty metal knobs look great &amp; are designed to last</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Heavy-duty cast iron grates stand up to constant use</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Standing pilot for each burner for easy ignition</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Manual on/off control valve has 1/4 turn for easy temperature control</p>\n<p style=""margin: 0px; padding-top: 0px;"">• welded steel frame with S/S front, 4"" legs</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Natural gas includes LP conversion kit</p>\n<p style=""margin: 0px; padding-top: 0px;"">• N. G. weight: 50 kg - 56.8 kg</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Dim: 610 x 737 x 391 mm</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Star Model No. 604HF / USA made</p>",,,taxable,,1,,,0,0,,,,,0,,,5074,"COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 700",,,,,,,,,,,,0,,"Star Manufacturing USA","Type of Product","Gas Countertop Cooker",1,1,Brand,"Star Manufacturing, Star Manufacturing USA",1,1,default,1,1,129,index,63,163,0,,"GAS COUNTERTOP COOKER 604HF",,,,,,,,field_60befc9fc0fb7,604HF,field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110101011100111010001000010100001111001010011101,false,,,,,,,,,Electric/Gas,Gas,1,1,Series,"Series 70 Table Top",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12807,simple,,,"GAS COUNTERTOP COOKER 602HF",1,0,visible,"The GAS COUNTERTOP COOKER 602HF is a versatile and efficient cooking appliance tailored for commercial kitchens. Constructed with high-quality stainless steel, it offers durability and easy maintenance. This cooker features powerful gas burners that provide rapid heating and precise temperature control, making it suitable for a variety of cooking tasks. Its compact countertop design saves valuable kitchen space while delivering exceptional performance. Ideal for professional chefs, the 602HF is designed to meet the rigorous demands of a busy kitchen environment.","<p style=""margin-bottom: 0px; margin-top: 0px;"">• Capacity: 2 burners</p>\n<p style=""margin: 0px; padding-top: 0px;"">• With 2 control knobs</p>\n<p style=""margin: 0px; padding-top: 0px;"">• High performance 25,000 BTU cast iron burners provide</p>\n<p style=""margin: 0px; padding-top: 0px;"">• maximum heat distribution &amp; control. All S/S front panel</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Heavy-duty metal knobs look great &amp; are designed to last</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Heavy-duty cast iron grates stand up to constant use</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Standing pilot for each burner for easy ignition</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Manual on/off control valve has 1/4 turn for easy temperature control</p>\n<p style=""margin: 0px; padding-top: 0px;"">• welded steel frame with S/S front, 4"" legs</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Natural gas includes LP conversion kit</p>\n<p style=""margin: 0px; padding-top: 0px;"">• N. G. weight: 34.1 kg - 60 kg</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Dim: 310 x 737 x 391 mm</p>\n<p style=""margin: 0px; padding-top: 0px;"">• Star Model No. 602HF / USA made</p>",,,taxable,,1,,,0,0,,,,,0,,,3192,"COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 700",,,,,,,,,,,,0,,"Star Manufacturing USA","Type of Product","Gas Countertop Cooker",1,1,Brand,"Star Manufacturing, Star Manufacturing USA",1,1,default,1,1,0,index,63,163,0,,"GAS COUNTERTOP COOKER 602HF",,,,,,,,field_60befc9fc0fb7,602HF,field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010111011010111000001001011100001110010100011110,false,,,,,,,,,Electric/Gas,Gas,1,1,Series,"Series 70 Table Top",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12809,simple,,,"BUNN TOASTER CONVEYOR TYPE QCS2-600H",1,0,visible,"<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• Star QCS® Conveyor Toaster, electric, 600 slices/hr., horizontal conveyor, analog speed, standby switch, independent controls for top &amp; bottom quartz sheathed heater elements, 3"" opening x 10"" W belt (2 slice) w/ loading rack, S/S construction w/ smooth cool touch exterior, cULus, UL EPH</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Power: 2.8 kw / 11.7 AMPS / NEMA 6-20P</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Voltage: 240 V/ 50 hz / 1 - ph</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Net weight: 29 kg / 64 lbs</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Dim: 368 x 568 x 397 mm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Star Model No.QCS2-600H / USA made</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(1075px, 0px); text-align: left;"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""text-align: left;"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• Star QCS® Conveyor Toaster, electric, 600 slices/hr., horizontal conveyor, analog speed, standby switch, independent controls for top &amp; bottom quartz sheathed heater elements, 3"" opening x 10"" W belt (2 slice) w/ loading rack, S/S construction w/ smooth cool touch exterior, cULus, UL EPH</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Power: 2.8 kw / 11.7 AMPS / NEMA 6-20P</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Voltage: 240 V/ 50 hz / 1 - ph</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Net weight: 29 kg / 64 lbs</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Dim: 368 x 568 x 397 mm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Star Model No.QCS2-600H / USA made</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(264px, 179px); text-align: left;"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(63px, 27px); text-align: left;"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,12325,"COOKING LINE, COOKING LINE > Sandwich Maker",,,https://mariotstore.com/wp-content/uploads/2024/10/QCS1500B.jpg,,,,,,,,,0,,"Star Manufacturing USA","Type of Product","Bun Toaster",1,1,Brand,"Star Manufacturing, Star Manufacturing USA",1,1,default,1,1,129,index,10,163,0,,,,,,,,,,field_60befc9fc0fb7,QCS2-600H,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595325,011111110100011000000011111100100010001111100010,,,,,,,,,,Electric/Gas,Electric,1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12811,simple,,,"BREAD TOASTER CONVEYOR TYPE QCS1-350",1,0,visible,"<div aria-expanded=""false"">\n<h5 class=""serp-title"">BREAD TOASTER CONVEYOR TYPE QCS1-350</h5>\n</div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(76px, 135px); text-align: left;"" aria-expanded=""false"">Forced convection system keeps the toaster cool to the touch and extends the life of critical components. The forced convection system increases productivity by circulating pre-heated air into toasting chamber. Quartz infrared heaters provide faster, more consistent heating than traditional heating elements.</div>","<strong>Description</strong>\nStar QCS1 series conveyor toasters require only 14.25” of counter space and features a product opening height of 1.5”, forced convection system that extends the life of critical components, extended conveyor belt, crumb tray, heated holding area, variable speed control, and a full width burn guard. The heavy-duty motor uses a drive chain for superior reliability.\n<ul>\n 	<li>Forced convection system keeps the toaster cool-to-the-touch and increases productivity by circulating preheated air into toasting chamber</li>\n 	<li>10” wide belt for up to 2-slices of bread, side-by-side</li>\n 	<li>Quartz infrared heaters provide faster, more consistent heating than traditional heating elements</li>\n 	<li>Long lasting, heavy-duty metal knobs and 1” non-skid heavy-duty rubber feet</li>\n 	<li>Easy-to-use analog controls</li>\n 	<li>Power saver switch that reduces electricity consumption by 75%</li>\n 	<li>Extended conveyor belt for easy loading and large warming area for higher production</li>\n 	<li>Safe load-up area with full width coated front burn guard and cool-to-the-touch exterior</li>\n 	<li>Heated holding area to keep toast at the perfect temperature</li>\n 	<li>Hi-limit switch prevents toaster from overheating protecting critical component parts</li>\n 	<li>Variable speed control for perfect color and texture of bread, bagels, english muffins and more</li>\n 	<li>120V – plugs in anywhere</li>\n</ul>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Net weight: 20 kg. / 44 lbs</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Dim: 362 x 479 x 336 mm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Star Model No.QCS1-350 / USA made</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(647px, 49px); text-align: left;"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,5945,"COOKING LINE, COOKING LINE > Sandwich Maker",,,,,,,,,,,,0,,"Star Manufacturing USA","Type of Product","Bread Toaster",1,1,Brand,"Star Manufacturing, Star Manufacturing USA",1,1,default,1,1,129,index,64,163,0,,"BREAD TOASTER CONVEYOR TYPE QCS1-350",,,,,,,,field_60befc9fc0fb7,QCS1-350,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595325,011111110111011000000011101100101110001001100000,false,,,,,,,,,Electric/Gas,Electric,1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
