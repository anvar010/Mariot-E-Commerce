12760,simple,,,"ICE CREAM MACHINE WITH STAND MK618CB",1,0,visible,"The ICE CREAM MACHINE WITH STAND MK618CB is a versatile and efficient appliance designed for commercial use in ice cream shops, cafes, and restaurants. Equipped with a sturdy stand for stability and convenience, this machine is perfect for high-volume production of delicious frozen treats. The MK618CB model features user-friendly controls and durable construction, ensuring reliable performance and easy operation. Its advanced freezing technology allows for quick and consistent production of premium-quality ice cream, making it an essential addition to any professional kitchen.","ICE CREAM MACHINE WITH STAND MK618CB\nMODEL:MK-618CB\nCAPACITY:25-28L/H\nPOWER:1600W\nVOLTAGE:220V/50HZ, 220V/60HZ,110V/60HZ\nCOMPRESSOR:GMCC/ PANASONIC/EMBRACO\nCOOLANT:R22/R410a/ R404a\nSIZE:71.5*56*138\nICECREAM\nPACK SIZE:84*52*148CM",,,taxable,,1,,,0,0,,,,,0,,,5359,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,"https://mariotstore.com/wp-content/uploads/2024/10/MK618-ice-cream-machine.png, https://mariotstore.com/wp-content/uploads/2024/10/e1785422-574a-4cab-9c21-649fb2918839.jpg, https://mariotstore.com/wp-content/uploads/2024/10/ICE-CREAM-MACHINE-WITH-STAND-MK618CB.png",,,,,,,,,0,,MKE-MATIC,Brand,"MKE MATIC",1,1,,,,,default,1,1,130,index,72,376,0,,"ICE CREAM MACHINE WITH STAND",,,,,,,,field_60befc9fc0fb7,MK618CB,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011000011000011001001000111100110110011111100011,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
