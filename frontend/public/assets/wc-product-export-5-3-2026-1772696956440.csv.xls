14414,simple,,,"ICE CREAM FREEZER DISPLAY - ICFD10X1-4",1,0,visible,"The ICE CREAM FREEZER DISPLAY (Model: ICFD10X1-4) is a cutting-edge refrigeration appliance designed specifically for showcasing a diverse selection of frozen treats. Crafted with both functionality and aesthetics in mind, this freezer is an ideal addition to various commercial settings, including ice cream parlors, cafes, supermarkets, and convenience stores.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(710px, 148px);"" aria-expanded=""true"">\n<div id=""tippy-1"" style=""z-index: 100000200; visibility: visible; position: absolute; inset: auto auto 0px 0px; margin: 0px; transform: translate(399px, -20px);"" data-tippy-root="""">\n<div class=""tippy-box"" style=""max-width: 350px; transition-duration: 300ms;"" tabindex=""-1"" role=""mtttooltip"" data-state=""visible"" data-theme=""custom"" data-animation=""fade"" data-placement=""top"">\n<div class=""tippy-content"" style=""transition-duration: 300ms;"" data-state=""visible""><span dir=""rtl"">تم تصميم هذا الفريزر مع وضع الوظيفة والجمال في الاعتبار، وهو إضافة مثالية لمختلف البيئات التجارية، بما في ذلك محلات الآيس كريم والمقاهي ومحلات السوبر ماركت والمتاجر الصغيرة.</span></div>\n<div class=""tippy-arrow"" style=""position: absolute; left: 0px; transform: translate(92px, 0px);""></div>\n</div>\n</div>\n</div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(114px, 91px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• ICE CREAM FREEZER DISPLAY - ICFD10X1-4</p>\n<p style=""margin: 0; padding-top: 0;"">• 10 X GN 1/3</p>\n<p style=""margin: 0; padding-top: 0;"">• Europe brand controller &amp; compressor.</p>\n<p style=""margin: 0; padding-top: 0;"">• All copper tube manufacturing.</p>\n<p style=""margin: 0; padding-top: 0;"">• Strong refrigeration, air cooling and frost free.</p>\n<p style=""margin: 0; padding-top: 0;"">• Heating wire, degree film, hot gas demisting.</p>\n<p style=""margin: 0; padding-top: 0;"">• High quality marble base, Universal caster, LED lighting</p>\n<p style=""margin: 0; padding-top: 0;"">• Impact resistant double layer explosion-proof glass.</p>\n<p style=""margin: 0; padding-top: 0;"">• Internal configuration GN1/3 pan designed.</p>\n<p style=""margin: 0; padding-top: 0;"">• Internal temperature display, Glass movable door with handle.</p>\n<p style=""margin: 0; padding-top: 0;"">• Thickened explosion-proof glass.</p>\n<p style=""margin: 0; padding-top: 0;"">• temperature: -16 ~ -20</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: Dim: 1030 * 900 * 1250 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: ICFD10X1-4 / Inofrigo made/Italian Technology</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(511px, 392px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(876px, 9px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,12886,15076,"REFRIGERATION LINE > Display Chiller, Kitchen Equipment, REFRIGERATION LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/ICE-CREAM-FREEZER-DISPLAY-ICFD14X1-4.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,,,,,default,1,1,0,,71,0,,,"ICE CREAM FREEZER DISPLAY - ICFD10X1-4,اسعار ثلاجة عرض ايس كريم,ثلاجة عرض ايس كريم",,,,,,,,field_60befc9fc0fb7,ICFD10X1-4,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011111001101011100001100100110110001101011000010,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14415,simple,,,"ICE CREAM FREEZER DISPLAY - ICFD7X1-3",1,0,visible,"The ICE CREAM FREEZER DISPLAY (Model: ICFD7X1-3) is an innovative refrigeration unit tailored to showcase a delightful assortment of frozen treats while enhancing the visual appeal of any retail space. Its sleek design and efficient cooling system make it a perfect choice for various establishments, including ice cream shops, cafes, and convenience stores.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(751px, 182px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• ICE CREAM FREEZER DISPLAY - ICFD7X1-3</p>\n<p style=""margin: 0; padding-top: 0;"">• 7 X GN 1/3</p>\n<p style=""margin: 0; padding-top: 0;"">• Europe brand controller &amp; compressor.</p>\n<p style=""margin: 0; padding-top: 0;"">• All copper tube manufacturing.</p>\n<p style=""margin: 0; padding-top: 0;"">• Strong refrigeration, air cooling and frost free.</p>\n<p style=""margin: 0; padding-top: 0;"">• Heating wire, degree film, hot gas demisting.</p>\n<p style=""margin: 0; padding-top: 0;"">• High quality marble base, Universal caster, LED lighting</p>\n<p style=""margin: 0; padding-top: 0;"">• Impact resistant double layer explosion-proof glass.</p>\n<p style=""margin: 0; padding-top: 0;"">• Internal configuration GN1/3 pan designed.</p>\n<p style=""margin: 0; padding-top: 0;"">• Internal temperature display, Glass movable door with handle.</p>\n<p style=""margin: 0; padding-top: 0;"">• Thickened explosion-proof glass.</p>\n<p style=""margin: 0; padding-top: 0;"">• temperature: -16 ~ -20</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1431 * 725 * 1250 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: ICFD7X1-3 / Inofrigo made/Italian Technology</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(621px, 42px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,9696,11344,"REFRIGERATION LINE > Ice Cream Di