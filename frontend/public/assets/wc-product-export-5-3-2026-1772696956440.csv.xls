12063,simple,,,"Solstice Bread And Batter Cabinet Fry Dump Station - SE-BNB-14",1,0,visible,"The Solstice Bread and Batter Cabinet Fry Dump Station SE-BNB-14 is a specialized commercial kitchen appliance designed to optimize the frying process, particularly for breaded and battered foods. This station is a valuable addition to restaurants, fast-food establishments, and catering operations, helping to maintain the quality and presentation of fried items.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Fryer Drain Cabinet, open cabinet base with door, fryer-match design with top drainer section, 15-1/2"" overall width, stainless steel front and sides</p>\n<p style=""margin: 0; padding-top: 0;"">• Heat Lamp, 26"" long, table mount, two bulbs, adjustable height, w/out pan and screen, S/S</p>\n<p style=""margin: 0; padding-top: 0;"">• heat power: 750 watts; 3.6 amps</p>\n<p style=""margin: 0; padding-top: 0;"">• voltage: 240v/ 50 hz/ 1-ph</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight 150 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 401 x 889 x 990</p>\n<p style=""margin: 0; padding-top: 0;"">• Model No. SE-BNB-14 /PITCO Frialator / USA made</p>",,,taxable,,0,,,0,0,,,,,0,,,5896,"COOKING LINE, COOKING LINE > Fryers",,,https://mariotstore.com/wp-content/uploads/2024/10/SE-BNB-14.jpg,,,,,,,,,0,,Pitco,Brand,Pitco,1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,65,0,0,,"Solstice Bread And Batter Cabinet Fry Dump Station",,,,,,,,field_60befc9fc0fb7,SE-BNB-14,field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595402,110001001100110011001000110110011011001100110011,,,,,,,,,,"Type of Product","Cabinat Fry Dump Station",1,1,,,,,,,,,,,,,,,,,
12065,simple,,,"PITCO ELECTRIC FRYER-SE14X",1,0,visible,"The Pitco SE14X Electric Fryer is a high-quality and efficient commercial kitchen appliance designed for reliable deep frying. This fryer is a popular choice for restaurants, fast-food establishments, and various foodservice operations, thanks to its dependable performance and user-friendly features.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Cap: 2 basket</p>\n<p style=""margin: 0; padding-top: 0;"">• Basket dim: 165 x 324 x133 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Oil cap: 40-50 lbs</p>\n<p style=""margin: 0; padding-top: 0;"">• Frying area: 356 x 356 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Thermostat: snap acting 200oF - 4000F (93oC - 204oC)</p>\n<p style=""margin: 0; padding-top: 0;"">• Electric power: 14 kw / 380V / 3 hp / 33.72 amps</p>\n<p style=""margin: 0; padding-top: 0;"">• Ship weight: 221 lbs. (100 kg)</p>\n<p style=""margin: 0; padding-top: 0;"">• Legs: 6"" (152 mm) stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 385 x 990 x 1194 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model No. SE14X /PITCO Frialator / USA made</p>",,,taxable,,0,,,0,0,,,,,0,,,15000,"COOKING LINE, COOKING LINE > Fryers",,,https://mariotstore.com/wp-content/uploads/2024/10/SE14X.jpg,,,,,,,,,0,,Pitco,Brand,Pitco,1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,65,0,0,,"ELECTRIC FRYER",,,,,,,,field_60befc9fc0fb7,SE14X,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011000100110011001110110011100110001100111001100,,,,,,,,,,"Type of Product","Electric Fryer",1,1,,,,,,,,,,,,,,,,,
12067,simple,01,,"PITCO COMPUTER CONTROLLER ELECTRIC FRYER-SE14XC",1,0,visible,"The Pitco SE14XC Electric Fryer with Computer Controller is a cutting-edge commercial kitchen appliance designed for precision frying, ease of use, and consistent results. This fryer is ideal for restaurants, fast food establishments, and other foodservice operations that require reliable and efficient deep frying.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Computer controller</p>\n<p style=""margin: 0; padding-top: 0;"">• Cap: 2 basket</p>\n<p style=""margin: 0; padding-top: 0;"">• Basket dim: 165 x 324 x133 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Oil cap: 40 - 50 lbs</p>\n<p style=""margin: 0; padding-top: 0;"">• Frying area: 356 x 356 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Thermostat: snap acting 200oF - 4000F (93oC-204oC)</p>\n<p style=""margin: 0; padding-top: 0;"">• Electric power: 14 kw / 240V / 3 hp / 33.72 amps</p>\n<p style=""margin: 0; padding-top: 0;"">• Ship weight: 221 lbs. (100 kg)</p>\n<p style=""margin: 0; padding-top: 0;"">• Legs: 6"" (152 mm) stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 385 x 990 x 1194 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model No. SE14XC /PITCO Frialator / USA made</p>",,,taxable,,0,,,0,0,,,,,0,,,23500,"COOKING LINE, COOKING LINE > Fryers",,,https://mariotstore.com/wp-content/uploads/2024/10/SE14XC.jpg,,,,,,,,,0,,Pitco,Brand,Pitco,1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,65,0,0,,"ELECTRIC FRYER",,,,,,,,field_60befc9fc0fb7,SE14XC,field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595055,110000011001111001111001101100110001101000110010,,,,,,,,,,"Type of Product","Electric Fryer",1,1,,,,,,,,,,,,,,,,,
12069,simple,,,"CONVEYOR TOASTER-TQ10",1,0,visible,"The TQ10 Conveyor Toaster is a sleek and efficient kitchen appliance designed to make your toasting process a breeze. With its stainless steel construction, it not only adds a touch of modernity to your kitchen but also ensures durability and easy maintenance.\n\nThis toaster is equipped with a conveyor belt system that allows for a continuous toasting process, making it ideal for busy kitchens or breakfast buffets. The adjustable conveyor speed gives you control over the toasting time, allowing you to achieve the perfect level of crispiness for your bread, bagels, or other breakfast items.\n\nThe TQ10 features variable heat controls, ensuring that you can customize the toasting temperature based on your preferences. Whether you like a lightly toasted slice or a golden brown crunch, this toaster has you covered.\n\nCleaning up is a breeze with the removable crumb tray, preventing any messes or burnt crumbs from accumulating. The compact design of the TQ10 makes it a space-saving solution for any kitchen setup.\n\nWith its combination of functionality, durability, and style, the TQ10 Conveyor Toaster is a reliable companion for anyone looking to streamline their toasting process in a busy kitchen environment.","<p style=""margin-bottom: 0; margin-top: 0px;"">• 4-position toast selector switch</p>\n<p style=""margin: 0; padding-top: 0;"">• off / toast / buns / stand-by mode</p>\n<p style=""margin: 0; padding-top: 0;"">• 89 mm 3½"") clearance to accommodate</p>\n<p style=""margin: 0; padding-top: 0;"">• high profile bread products</p>\n<p style=""margin: 0; padding-top: 0;"">• Easy-to-load rack w/ front or rea discharging</p>\n<p style=""margin: 0; padding-top: 0;"">• Permanently lubricated 50/60 Hz motor</p>\n<p style=""margin: 0; padding-top: 0;"">• V-shaped reflectors help capture &amp; redirect heat</p>\n<p style=""margin: 0; padding-top: 0;"">• Long lasting serpentine metal sheathed</p>\n<p style=""margin: 0; padding-top: 0;"">• heating elements</p>\n<p style=""margin: 0; padding-top: 0;"">• 102 mm (4"") adjustable legs</p>\n<p style=""margin: 0; padding-top: 0;"">• Pilot light that signals unit is in operation</p>\n<p style=""margin: 0; padding-top: 0;"">• Discharge and crumb trays are removable\nfor easy cleaning</p>\n<p style=""margin: 0; padding-top: 0;"">• Amps: 8.8-9.6</p>\n<p style=""margin: 0; padding-top: 0;"">• Power:220-240/ 1940-2300/ 50-60HZ</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 368 W x 419 D x 387 H mm</p>\n<p style=""margin: 0; padding-top: 0;"">• TQ10/ HATCO / USA made</p>",,,taxable,,1,,,0,0,,,,,0,,,4200,"COOKING LINE, COOKING LINE > Sandwich Maker",,,https://mariotstore.com/wp-content/uploads/2024/10/hatco-Conveyor-Toaster.png,,,,,,,,,0,,Hatco,Brand,Hatco,1,1,"Type of Product","Conveyor Bread Toaster",1,1,default,1,1,0,index,5,0,0,,,,,,,,,,field_60befc9fc0fb7,TQ10,field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110100001111110010101100000110011111000010110100,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12071,simple,,,"GLO-RAY HIGH WATTAGE INFRARED FOOD WARMER-GRAH-60",1,0,visible,"<strong>GLO-RAY HIGH WATTAGE INFRARED FOOD WARMER - GRAH-60</strong>\nThe GRAH-60 Glo-Ray High Wattage Infrared Food Warmer provides efficient and even heat distribution to keep food warm and fresh. With adjustable temperature settings and durable construction, it ensures optimal performance in busy foodservice environments, perfect for maintaining hot meals at buffets and events.","<p style=""margin-bottom: 0; margin-top: 0px;"">• GLO-RAY HIGH WATTAGE INFRARED FOOD WARMER WITH TOGGLE CONTROLS LIGHT</p>\n<p style=""margin: 0; padding-top: 0;"">• Safely hold the temperature of your product without drying or further cooking</p>\n<p style=""margin: 0; padding-top: 0;"">• Continuous aluminum housing and heavy-duty mountings ensure durability and quality</p>\n<p style=""margin: 0; padding-top: 0;"">• Even heat distribution - no cold spots</p>\n<p style=""margin: 0; padding-top: 0;"">• Reflector does not blacken, maintains a consistent heat pattern</p>\n<p style=""margin: 0; padding-top: 0;"">• Reinforced wire guard provides operator safety</p>\n<p style=""margin: 0; padding-top: 0;"">• Pre-focused heat pattern</p>\n<p style=""margin: 0; padding-top: 0;"">• Amps: 11.7 Amps</p>\n<p style=""margin: 0; padding-top: 0;"">• Power wattage: 1,400Watts/ 220V / 50/60hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1524 x 152 x 165 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• GRAH-60 / HATCO / USA made</p>",,,taxable,,1,,,0,0,,,,,0,,,2307,"COOKING LINE, COOKING LINE > Food Warmers",,,https://mariotstore.com/wp-content/uploads/2024/10/GRAH-60.png,,,,,,,,,0,,Hatco,Brand,Hatco,1,1,"Type of Product","Infrared Food Warmer",1,1,default,1,1,0,index,79,0,0,,"GLO-RAY HIGH WATTAGE INFRARED FOOD WARMER,GLO-RAY HIGH WATTAGE INFRARED FOOD WARMER-GRAH-60",,,,,,,,field_60befc9fc0fb7,GRAH-60,field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679