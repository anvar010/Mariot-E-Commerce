14621,simple,,,"Upright chiller / single glass door -  GN650TN/G",1,0,visible,"Upright Chiller / Single Glass Door - GN650TN/G\n\nThe GN650TN/G is a commercial-grade upright chiller designed for optimal storage and display of chilled products. Featuring a single glass door, it allows for easy visibility and accessibility of stored items. With robust construction and advanced cooling technology, this chiller ensures consistent temperature control and energy efficiency, making it an ideal choice for restaurants, cafes, and other foodservice establishments. The sleek design and spacious interior provide both aesthetic appeal and functional convenience.",""" Upright chiller / single glass door\n. AISI 304 18/10 S/S interior &amp; exterior w/ sanitary corner except rear panel &amp; part of bottom.\n. automatic closing door w/ magnetic gasket, 90° reversible.\n. injected polyurethane insulation, CFC free, density: 40 kgs / m3\n. Cap: 580 ltr.\n. w/ 3 shelf &amp; 1 drs + 4 castor wheels.\n. working Temp: +0˚ ~ +5° at 32° temp.\n. Power Supply: 230v / 50 Hz / 1Ph.\n. frige power: 460 Watt\n. refrigerant : R290\n. Net Weight: 130 Kg\n. Dimensions: 740 x 830 x 2010 mm (WxDxH)\n. Digital : DIXELL / ITALY MADE .\n. compressor : ASPERA / EMBRACO / EU made\nGN650TN/G Made for MARIOT/ ISO9001, CE&amp;ROHS approved""",,,taxable,,1,,,0,0,,,,,1,,,4201,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/Upright-chiller-single-glass-door.png,,,,,,,,,0,,Mariot,Brand,Mariot,1,1,,,,,default,1,1,0,,16,0,,,"Upright chiller / single glass door - GN650TN/G",,,,,,,,field_60befc9fc0fb7,GN650TN/G,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010100110010011011001100100110101100101100011,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14623,simple,,,"Upright Freezer / single glass door - GN650BT/G",1,0,visible,"Upright Freezer / Single Glass Door - GN650BT/G\n\nThe GN650BT/G is a high-performance upright freezer designed for efficient storage and display of frozen goods. Equipped with a single glass door, it offers clear visibility and easy access to its contents. This commercial-grade freezer features advanced freezing technology to maintain consistent, low temperatures, ensuring the longevity and quality of stored items. Its durable construction and energy-efficient operation make it a reliable choice for restaurants, cafes, and other foodservice environments. The stylish design and ample storage space provide both practical functionality and aesthetic appeal.",""" Upright Freezer / single glass door\n. AISI 304 18/10 S/S interior &amp; exterior w/ sanitary corner except rear panel &amp; part of bottom.\n. automatic closing door w/ magnetic gasket, 90° reversible.\n. injected polyurethane insulation, CFC free, density: 40 kgs / m3\n. Cap: 580 ltr.\n. w/ 3 shelf &amp; 1 drs + 4 castor wheels.\n. working Temp: -18˚ ~ -22° at 32° temp.\n. Power Supply: 230v / 50 Hz / 1Ph.\n. frige power: 520 Watt\n. refrigerant : R404a\n. Net Weight: 122 Kg\n. Dim: 830 x 740 x 2010mm (WxDxH)\n. Digital : DIXELL / ITALY MADE .\n. compressor : ASPERA / EMBRACO / EU made\nGN650BT/G Made for MARIOT/ ISO9001, CE&amp;ROHS approved """,,,taxable,,1,,,0,0,,,,,1,,,4923,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/Upright-chiller-single-glass-door.png,,,,,,,,,0,,Mariot,Brand,Mariot,1,1,,,,,default,1,1,0,,53,0,,,"Upright Freezer / single glass door - GN650BT/G",,,,,,,,field_60befc9fc0fb7,GN650BT/G,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596731,110010100110010011011001100100110101100101100011,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14624,simple,,,"Speed Queen Homestyle Top Load Washer - LWN311SP301NW22",1,0,visible,"The Speed Queen Homestyle Top Load Washer (Model LWN311SP301NW22) is a reliable and efficient washing machine designed for residential use. Featuring a durable stainless steel tub and commercial-grade components, this washer ensures long-lasting performance and superior cleaning power. Its user-friendly controls and multiple wash cycles provide versatility for various fabric types and soil levels. With a high-speed spin cycle, the Speed Queen Homestyle Washer effectively reduces drying time, making it an excellent choice for busy households.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Speed Queen Homestyle Top Load Washer - LWN311SP301NW22</p>\n<p style=""margin: 0; padding-top: 0;"">• SPEED QUEEN, USA</p>\n<p style=""margin: 0; padding-top: 0;"">• MODEL: LWN311SP301NW22</p>\n<p style=""margin: 0; padding-top: 0;"">• CAPACITY KG : UPTO 10 KGS</p>\n<p style=""margin: 0; padding-top: 0;"">• TOPLOAD WASHER EXTRACTOR</p>\n<p style=""margin: 0; padding-top: 0;"">• MECHANICAL TIMER CONTROL</p>\n<p style=""margin: 0; padding-top: 0;"">• REAR CONTROL LOCATION</p>\n<p style=""margin: 0; padding-top: 0;"">• STAINLESS STEEL BASKET</p>\n<p style=""margin: 0; padding-top: 0;"">• ELECTRIC HEATING, 2 kW</p>\n<p style=""margin: 0; padding-top: 0;"">• VOLTAGE: 240V/50HZ/1PH</p>\n<p style=""margin: 0; padding-top: 0;"">• FOR COMMERCIAL USE ONLY, NOT FOR RESIDENTIAL USE</p>",,,taxable,,1,,,0,0,,,,,1,,,6880,"Kitchen Equipment, LAUNDRY & DISH WASHER, LAUNDRY & DISH WASHER > Laundry Machines",,,https://mariotstore.com/wp-content/uploads/2024/10/Speed-Queen-Homestyle-Top-Load-Washer-LWN311SP301NW22.png,,,,,,,,,0,,"Speed Queen",Brand,"Speed Queen",1,1,,,,,default,1,1,0,,53,0,,,"Speed Queen Homestyle Top Load Washer - LWN311SP301NW22",,,,,,,,field_60befc9fc0fb7,LWN311SP301NW22,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15779,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110110011001001100101110010110001111000011001001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14626,simple,,,"Speed Queen Homestyle Dryer - LES17AWF3022",1,0,visible,"The Speed Queen Homestyle Dryer (Model LES17AWF3022) is a high-performance and dependable electric dryer designed for residential use. It features a large capacity drum and commercial-grade components for enhanced durability and efficiency. With multiple drying cycles and temperature settings, this dryer offers flexibility to accommodate various fabric types and drying needs. Its user-friendly controls make operation simple, while the advanced moisture sensing technology ensures clothes are dried evenly and efficiently. The Speed Queen Homestyle Dryer is an excellent addition to any home, providing reliable and efficient drying performance.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Speed Queen Homestyle Dryer - LES17AWF3022</p>\n<p style=""margin: 0; padding-top: 0;"">• SPEED QUEEN, USA</p>\n<p style=""margin: 0; padding-top: 0;"">• MODEL: LES17AWF3022</p>\n<p style=""margin: 0; padding-top: 0;"">• CAPACITY KG : UPTO 10 KGS</p>\n<p style=""margin: 0; padding-top: 0;"">• SINGLE DRYER ELECTRIC</p>\n<p style=""margin: 0; padding-top: 0;"">• MECHANICAL TIMER CONTROL</p>\n<p style=""margin: 0; padding-top: 0;"">• REAR CONTROL LOCATION</p>\n<p style=""margin: 0; padding-top: 0;"">• GALVANIZED BASKET</p>\n<p style=""margin: 0; padding-top: 0;"">• ELECTRIC HEATING, 5.5kW</p>\n<p style=""margin: 0; padding-top: 0;"">• VENT TYPE DRYER</p>\n<p style=""margin: 0; padding-top: 0;"">• FOR COMMERCIAL USE ONLY, NOT FOR RESIDENTIAL USE</p>\n<p style=""margin: 0; padding-top: 0;"">• VOLTAGE: 240V/50HZ/1PH</p>\n<p style=""margin: 0; padding-top: 0;"">• COUNTRY OF ORIGIN: USA</p>",,,taxable,,1,,,0,0,,,,,1,,,5830,"Kitchen Equipment, LAUNDRY & DISH WASHER, LAUNDRY & DISH WASHER > Laundry Machines",,,https://mariotstore.com/wp-content/uploads/2024/10/Speed-Queen-Homestyle-Dryer.png,,,,,,,,,0,,"Speed Queen",Brand,"Speed Queen",1,1,,,,,default,1,1,0,,51,0,,,"Speed Queen Homestyle Dryer - LES17AWF3022",,,,,,,,field_60befc9fc0fb7,LES17AWF3022,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15780,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110110011001001100100110010110001110010111001001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14628,simple,,,"FORM FINISHER WITH BUILT-IN STEAM GENERATOR  - QAD 2",1,0,visible,"The Form Finisher with Built-in Steam Generator (Model QAD 2) is a professional-grade garment finishing machine designed for optimal performance in commercial settings. This versatile unit features an integrated steam generator, providing consistent and high-quality steam for efficient wrinkle removal and garment shaping. Its adjustable form allows for the finishing of various garment types and sizes, while the user-friendly controls ensure ease of operation. The durable construction and reliable performance of the QAD 2 make it an essential tool for dry cleaners, laundries, and garment manufacturing facilities, delivering impeccable results with every use.","<p style=""margin-bottom: 0; margin-top: 0px;"">• FORM FINISHER WITH BUILT-IN STEAM GENERATOR - QAD 2</p>\n<p style=""margin: 0; padding-top: 0;"">• MODEL: QAD 2 1 18,950.00 18,950.00</p>\n<p style=""margin: 0; padding-top: 0;"">• FORM FINISHER WITH BUILT-IN STEAM GENERATOR</p>\n<p style=""margin: 0; padding-top: 0;"">• 20 LT,10 KW AND 1,7 HP VENTILATOR 380/3/50</p>\n<p style=""margin: 0; padding-top: 0;"">• TIME SWITCH PROGRAMMED THROUGH DIGITAL ELECTRONIC</p>\n<p style=""margin: 0; padding-top: 0;"">• CONTROL PANEL . FINISHING DEVICE 150 CM HEIGHT</p>\n<p style=""margin: 0; padding-top: 0;"">• COMPLETE OF STRETCHERS AND CLAMPS</p>\n<p style=""margin: 0; padding-top: 0;"">• TECHNICAL SPECIFICATION:</p>\n<p style=""margin: 0; padding-top: 0;"">• ELECTRIC POWER 380 V / 3 PH / 50 HZ</p>\n<p style=""margin: 0; padding-top: 0;"">• MOTOR EXHAUST FAN HP 1,0 / KW 0.75</p>\n<p style=""margin: 0; padding-top: 0;"">• BOILER CAPACITY 20 LT</p>\n<p style=""margin: 0; padding-top: 0;"">• BOILER HEATING ELEMENT 10 KW</p>\n<p style=""margin: 0; padding-top: 0;"">• STEAM OUTPUT 15 KG / H</p>\n<p style=""margin: 0; padding-top: 0;"">• STEAM PRESSURE 5 BAR</p>\n<p style=""margin: 0; padding-top: 0;"">• WATER PUMP POWER HP 0.70 / KW 0.50</p>\n<p style=""margin: 0; padding-top: 0;"">• POWER CONSUMPTIONS 11 KW</p>\n<p style=""margin: 0; padding-top: 0;"">• WATER INLET 3/8”</p>\n<p style=""margin: 0; padding-top: 0;"">• WATER OUTLET ½”</p>\n<p style=""margin: 0; padding-top: 0;"">• OVERALL DIMENSION 800L X 1200D X 1900H MM</p>\n<p style=""margin: 0; padding-top: 0;"">• GROSS WEIGHT 200 KG</p>\n<p style=""margin: 0; padding-top: 0;"">• ROTONDI ITALY</p>",,,taxable,,1,,,0,0,,,,,1,,,26530,"Kitchen Equipment, LAUNDRY & DISH WASHER, LAUNDRY & DISH WASHER > Laundry Machines",,,https://mariotstore.com/wp-content/uploads/2024/10/FORM-FINISHER.png,,,,,,,,,0,,"Rotondi Group",Brand,"Rotondi Group",1,1,,,,,default,1,1,0,,68,0,,,"FORM FINISHER WITH BUILT-IN STEAM GENERATOR - QAD 2",,,,,,,,field_60befc9fc0fb7,"QAD 2",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15781,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011001001100111001110110100100111010001101100001,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14630,simple,,,"MANUAL PRESS - BX CO 90/AUT",1,0,visible,"The Manual Press (Model BX CO 90/AUT) is a robust and efficient pressing machine designed for professional use in commercial laundry and dry-cleaning operations. This versatile press features a manually operated mechanism that provides precise control over pressure and temperature, ensuring optimal results for a wide range of fabrics. Its sturdy construction and ergonomic design ensure durability and ease of use, making it ideal for high-volume environments. The BX CO 90/AUT is equipped with advanced safety features and intuitive controls, offering a reliable and efficient solution for achieving perfectly pressed garments every time.","<p style=""margin-bottom: 0; margin-top: 0px;"">• MANUAL PRESS - BX CO 90/AUT</p>\n<p style=""margin: 0; padding-top: 0;"">• ROTONDI (ITALY)</p>\n<p style=""margin: 0; padding-top: 0;"">• UTILITY, MANUAL OPERATED</p>\n<p style=""margin: 0; padding-top: 0;"">• MODEL: BX CO 90/AUT</p>\n<p style=""margin: 0; padding-top: 0;"">• MANUAL OPERATED, STEAM PRESS</p>\n<p style=""margin: 0; padding-top: 0;"">• WITH BUILT IN STEAM GENERATOR</p>\n<p style=""margin: 0; padding-top: 0;"">• VACUUM MOTOR AND WATER FEED PUMP</p>\n<p style=""margin: 0; padding-top: 0;"">• UTILITY BUCK, SHAPE WITH HAND &amp; FOOT</p>\n<p style=""margin: 0; padding-top: 0;"">• OPERATED PRESS HEAD, 24 LT, 12 KW</p>\n<p style=""margin: 0; padding-top: 0;"">• ELECTRIC HEATED (NO SLEEVE ARM INCLUDED)</p>\n<p style=""margin: 0; padding-top: 0;"">• VOLTAGE:415V/50HZ/3PH</p>\n<p style=""margin: 0; padding-top: 0;"">• RSC10- ELECTRIC STEAMIRON GROUP WITH SILICON REST</p>\n<p style=""margin: 0; padding-top: 0;"">• INCLUDES EXPORT CRATING</p>",,,taxable,,1,,,0,0,,,,,1,,,44506,"Kitchen Equipment, LAUNDRY & DISH WASHER, LAUNDRY & DISH WASHER > Laundry Machines",,,https://mariotstore.com/wp-content/uploads/2024/10/MANUAL-PRESS.png,,,,,,,,,0,,"Rotondi Group",Brand,"Rotondi Group",1,1,,,,,default,1,1,0,,71,0,,,"MANUAL PRESS - BX CO 90/AUT",,,,,,,,field_60befc9fc0fb7,"BX CO 90/AUT",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15782,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011110011001111010001100001110010000011011100011,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14632,simple,,,"Dry cleaning machine - XL8010E, SLIM MODEL",1,0,visible,"The XL8010E Slim Model Dry Cleaning Machine is a state-of-the-art appliance designed for commercial dry cleaning operations. This slim model is engineered to fit in compact spaces while still delivering high-performance cleaning. It features advanced solvent management and efficient cleaning cycles, ensuring garments are cleaned thoroughly and gently. With its user-friendly interface, operators can easily control and monitor the cleaning process. The XL8010E also boasts energy-efficient operation and robust construction, making it a reliable and economical choice for dry cleaners looking to maximize space and efficiency without compromising on quality.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Dry cleaning machine - XL8010E, SLIM MODEL</p>\n<p style=""margin: 0; padding-top: 0;"">• UNION ITALY</p>\n<p style=""margin: 0; padding-top: 0;"">• DRYCLEANING MACHINE</p>\n<p style=""margin: 0; padding-top: 0;"">• PERC SOLVANT, ELECTRIC HEATING, 2 SOLVENT TANK</p>\n<p style=""margin: 0; padding-top: 0;"">• CAPACITY 10 KGS</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: XL8010E, SLIM MODEL</p>\n<p style=""margin: 0; padding-top: 0;"">• One nylon ECOLOGICAL filter</p>\n<p style=""margin: 0; padding-top: 0;"">• Proforma Invoice No: P377-24/UA97/LE/RD Date: 10-Jul-2024</p>\n<p style=""margin: 0; padding-top: 0;"">• PROFORMA INVOICE</p>\n<p style=""margin: 0; padding-top: 0;"">• Floor Safety Tank</p>\n<p style=""margin: 0; padding-top: 0;"">• Lock and micro switch door installed</p>\n<p style=""margin: 0; padding-top: 0;"">• INVERTER, basket electronic speed control</p>\n<p style=""margin: 0; padding-top: 0;"">• Totally closed circuit with heat pump</p>\n<p style=""margin: 0; padding-top: 0;"">• User friendly logica programmable computer</p>\n<p style=""margin: 0; padding-top: 0;"">• Electronic inverter</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel still</p>\n<p style=""margin: 0; padding-top: 0;"">• Double air filter</p>\n<p style=""margin: 0; padding-top: 0;"">• Water saving system with DANFOSS thermostatic valve</p>\n<p style=""margin: 0; padding-top: 0;"">• Soap injector included</p>\n<p style=""margin: 0; padding-top: 0;"">• Air compressor included</p>\n<p style=""margin: 0; padding-top: 0;"">• In line solvent cooler by water</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage: 380v/50hz/3ph</p>\n<p style=""margin: 0; padding-top: 0;"">• Wooden case</p>",,,taxable,,1,,,0,0,,,,,1,,,140702,"Kitchen Equipment, LAUNDRY & DISH WASHER, LAUNDRY & DISH WASHER > Laundry Machines",,,https://mariotstore.com/wp-content/uploads/2024/10/Dry-cleaning-machine-XL-8010-E.png,,,,,,,,,0,,Union,Brand,Union,1,1,,,,,default,1,1,0,,71,0,,,"Dry cleaning machine - XL8010E",,,,,,,,field_60befc9fc0fb7,"XL8010E, SLIM MODEL",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110110110001010011010110010011011010010011001001,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14634,simple,,,"LE PROTEK# PLASTIC LAUNDRY TROLLEY - 1100 X 790 X 840MMH",1,0,visible,"The LE PROTEK# Plastic Laundry Trolley, measuring 1100 x 790 x 840 mm, is a durable and practical solution for transporting laundry in commercial settings. Constructed from high-quality plastic, this trolley is designed to withstand heavy use while remaining lightweight and easy to maneuver. Its spacious interior and ergonomic design make it ideal for carrying large loads of laundry, linens, and other items. The trolley's smooth-rolling wheels and sturdy handles ensure effortless movement across various surfaces, enhancing efficiency and convenience in busy laundries, hotels, and healthcare facilities.","<p style=""margin-bottom: 0; margin-top: 0px;"">• LE PROTEK# PLASTIC LAUNDRY TROLLEY - 1100 X 790 X 840MMH</p>\n<p style=""margin: 0; padding-top: 0;"">• LE PROTEK# PLASTIC LAUNDRY TROLLEY</p>\n<p style=""margin: 0; padding-top: 0;"">• PLASTIC LAUNDRY TROLLEY</p>\n<p style=""margin: 0; padding-top: 0;"">• 5"" CASTERS, 2 FIXED, 2 SWIVEL</p>\n<p style=""margin: 0; padding-top: 0;"">• SIZE: 1100 X 790 X 840MMH</p>\n<p style=""margin: 0; padding-top: 0;"">• COLOUR: WHITE</p>\n<p style=""margin: 0; padding-top: 0;"">• LOAD CAPACITY: 500 KGS</p>\n<p style=""margin: 0; padding-top: 0;"">• MATERIAL: VIRGIN POLYETHYLENE (PE)</p>\n<p style=""margin: 0; padding-top: 0;"">• NET WEIGHT: 26 KGS</p>",,,taxable,,1,,,0,0,,,,,1,,,1750,"ACCESSORIES, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/LE-PROTEK-PLASTIC-LAUNDRY-TROLLEY-1100-X-790-X-840MMH.png,,,,,,,,,0,,Mariot,Brand,Mariot,1,1,,,,,default,1,1,0,,71,0,,,"LE PROTEK# PLASTIC LAUNDRY TROLLEY - 1100 X 790 X 840MMH",,,,,,,,field_60befc9fc0fb7,"1100 X 790 X 840MMH",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011101010001111000001011110100011100110010100110,,,,,,,,,,,,,,,,,