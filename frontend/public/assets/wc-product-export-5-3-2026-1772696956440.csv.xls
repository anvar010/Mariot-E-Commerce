13561,simple,,,"Classic Citrus Juicer - 11A",1,0,visible,"Get inspired with our collection of mouthwatering citrus recipes specifically designed to be made using the Classic Citrus Juicer – 11A.","<p style=""margin-bottom: 0;margin-top: 0px"">• Classic Citrus Juicer - 11A</p>\n<p style=""margin: 0;padding-top: 0"">• Commercial Juicer</p>\n<p style=""margin: 0;padding-top: 0"">• Heavy duty and quiet induction motor.</p>\n<p style=""margin: 0;padding-top: 0"">• Delivered with 3 removable squeezers for oranges, lemons, limes, and grapefruits.</p>\n<p style=""margin: 0;padding-top: 0"">• Average output: 30l/h</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 220-240V - 50/60 Hz - 130W</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: Net 4.9kg</p>\n<p style=""margin: 0;padding-top: 0"">• Packed: 5.7kg</p>\n<p style=""margin: 0;padding-top: 0"">• Dimensions: 23W x 30D x 35H cm</p>\n<p style=""margin: 0;padding-top: 0"">• Packed: 34W x 25D x 40H cm</p>\n<p style=""margin: 0;padding-top: 0"">• Made in France | Santos</p>",,,taxable,,1,,,0,0,,,,,0,,,1550,"COFFEE & BAR LINE, COFFEE & BAR LINE > Juice Maker",,,"https://mariotstore.com/wp-content/uploads/2024/10/1-1-3-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/3-2-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/2-2-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/Santos-Classic-Citrus-Juicer-11A.jpg",,,,,,,,,0,,Santos,Brand,Santos,1,1,,,,,default,1,1,0,,55,0,0,,"Classic Citrus Juicer,assic Citrus Juicer - 11A",,,,,,,,field_60befc9fc0fb7,11A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596293,011000100100111001100011110100100101101101001011,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
