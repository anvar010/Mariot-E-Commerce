13975,simple,,,"Cake Showcase- FCS1200R2M",1,0,visible,"The Cake Showcase FCS1200R2M is a stylish and efficient refrigerated display unit designed specifically for showcasing cakes and pastries. With its sleek design and transparent glass panels, it offers a clear view of your delectable creations while keeping them at the perfect temperature for freshness. The adjustable shelving and interior lighting enhance the visual appeal, making it an ideal choice for bakeries, cafes, and dessert shops to present their treats in an enticing and professional manner.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Cake Showcase- FCS1200R2M</p>\n<p style=""margin: 0; padding-top: 0;"">• Front flat glass with LED light</p>\n<p style=""margin: 0; padding-top: 0;"">• S/S mirror base; Auto defrosting</p>\n<p style=""margin: 0; padding-top: 0;"">• Rear sliding door, with 2 shelves</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature:+2～+8℃；220V/50HZ</p>\n<p style=""margin: 0; padding-top: 0;"">• Embraco / SECOP compressor; Dixell / Carol controller</p>\n<p style=""margin: 0; padding-top: 0;"">• N.G.weight: kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 1200 * 685 * 1300 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• FCS1200R2M</p>",,,taxable,,1,,,0,0,,,,,1,,,4997,"BAKERY LINE > Bakery Display, BAKERY LINE, REFRIGERATION LINE > Display Chiller, Kitchen Equipment, REFRIGERATION LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/Cake-Showcase.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Model,FCS1200R2M,1,1,default,1,1,0,,62,0,0,,"Cake Showcase",,,,,,,,field_60befc9fc0fb7,FCS1200R2M,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596293,110101100101110010100100100100101110110101100100,true,backend,,,,,,,salescountdowntimer,"Type of Product","Cake Showcase",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,