12752,simple,,,"COUNTER TOP ICE CREAM MACHINE MK 220-240v / 50hz -18CTB",1,0,visible,"The COUNTER TOP ICE CREAM MACHINE MK 220-240v / 50hz -18CTB is a versatile and efficient ice cream maker designed for both commercial and home use. Operating on a 220-240V, 50Hz power supply, this machine ensures reliable performance and quick production of high-quality ice cream. Its compact countertop design makes it an excellent addition to any kitchen or small business, offering convenience and ease of use. The 18CTB model features user-friendly controls and durable construction, making it ideal for creating a variety of delicious frozen treats with consistency and ease.","<p style="" margin-bottom: 0; margin-top: 0px;"">• Capacity: 18 liters</p>\n<p style="" margin: 0; padding-top: 0;"">• Rated production: 18 l / h</p>\n<p style="" margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style="" margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50hz</p>\n<p style="" margin: 0; padding-top: 0;"">• Power: 1650w</p>\n<p style="" margin: 0; padding-top: 0;"">• Refrigerant: R22 / R410a / R404a</p>\n<p style="" margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style="" margin: 0; padding-top: 0;"">• Ice cream temperature up to -7 to -8 degrees Celsius</p>\n<p style="" margin: 0; padding-top: 0;"">• DIM: 715*560*780mm</p>\n<p style="" margin: 0; padding-top: 0;"">• MK-18CTB / MKE-MATIC</p>",,,taxable,,0,,,0,0,,,,,0,,,3869,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/Hd84d27dbbf23464b89a9149a33a12f069.jpg,,,,,,,,,0,,MKE-MATIC,"Type of Product","Counter Top Ice Cream Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,65,376,0,,"COUNTER TOP ICE CREAM MACHINE MK 220-240v / 50hz",,,,,,,,field_60befc9fc0fb7,MK-18CTB,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no,,,,,,,,,,,,,1734595488,110100110010110010111001000100101101100111001010,,,