13681,simple,,,"Professional Induction Hob - PIS 30",1,0,visible,"The Professional Induction Hob PIS 30 is a cutting-edge kitchen appliance designed for culinary experts and enthusiasts alike. With its advanced induction technology, this hob delivers precise and efficient cooking performance. The PIS 30 features multiple power levels and temperature settings, allowing you to achieve the perfect cooking conditions for various dishes. Its sleek and durable design, combined with easy-to-use controls, makes it an essential tool for chefs who value precision and speed in their cooking. Whether you're sautéing, boiling, simmering, or searing, the Professional Induction Hob PIS 30 offers the versatility and control needed to elevate your cooking to a professional level.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Professional Induction Hob - PIS 30</p>\n<p style=""margin: 0;padding-top: 0"">• Features: glass-ceramic hob, induction box, ventilator, pro generator, the front panel. Capacitive front panel: On / Off, sound timer and Power cutoff, 20-level power (+/-) selection, digital display of power levels or timer. Robust design and long-life components. Delivered without pan.</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 3 Kw</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 280 x 280 x 4 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 6 kg</p>\n<p style=""margin: 0;padding-top: 0"">• volts: 230-240 V</p>\n<p style=""margin: 0;padding-top: 0"">• In glass ceramic dimensions: 315 x 380 x 102 mm</p>\n<p style=""margin: 0;padding-top: 0"">• PIS 30 / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,2843,"COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 600","Professional Induction Hob",,https://mariotstore.com/wp-content/uploads/2024/10/Professional-Induction-Hob-PIS-30.png,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,82,0,0,,"Professional Induction Hob,موقد الحثي الاحترافي,طباخ يعمل بالاشعة تحت الحمراء",,,,,,,,field_60befc9fc0fb7,"PIS 30",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595599,111101001001110000101101000011010100111100011010,,,,,,,,,,"Type of Product","Induction Plates",1,1,Series,"Series 60 Table Top",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
