11345,simple,,,"TABLE TOP DOUGH SHEETER-500SM",1,0,visible,"The TABLE TOP DOUGH SHEETER-500SM is a compact and efficient machine designed for small to medium-scale dough preparation. It features a table-top design that saves space while offering powerful performance. The 500SM model includes adjustable rollers to control dough thickness and consistency, making it ideal for various baked goods. Its user-friendly controls and durable construction ensure reliable operation and easy maintenance, making it a practical choice for bakeries, pizzerias, and pastry shops.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Pasta thickness: 0.1 28 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dough per cycle: 4 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• folding structure, easily moving and saving space</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 0.37 kw. / 230-V / 50 hz / single phase</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 70 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Close dim: 300 x 827 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Open dim: 827 x 972 x 477 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• EASY 500SM/ GGF s.r.l./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,9266.4,"BAKERY LINE, BAKERY LINE > Rolling Machine",,,https://mariotstore.com/wp-content/uploads/2024/10/TABLE-TOP-DOUGH-SHEETER-500SM.jpg,,,,,,,,,0,,GGF,Brand,GGF,1,1,"Type of Product","Dough Sheeter",1,1,default,1,1,0,index,60,0,0,,"TABLE TOP DOUGH SHEETER-500SM,رقاقة عجين توضع على الطاولة-500سم,فرادة عجين",,,,,,,,field_60befc9fc0fb7,"EASY 500SM",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595494,011010110000111001010011110011001011000010011101,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
11347,simple,,,"On Stand Dough Sheeter - GP 500/1000",1,0,visible,"The On Stand Dough Sheeter - GP 500/1000 is a versatile and efficient machine designed for commercial bakeries and food production facilities. This dough sheeter features a robust stand for stability and ease of use. It can handle a wide range of dough types and thicknesses, thanks to its adjustable rollers. The GP 500/1000 model offers precise control over dough consistency and thickness, ensuring uniform results for various baked goods. Its durable construction and user-friendly design make it an essential tool for high-volume dough processing.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Pasta thickness: 0.1 34 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dough per cycle: 8 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Folding structure, easily moving, and saving space</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 0.55 kw. / 230-V / 50 hz / single phase</p>\n<p style=""margin: 0; padding-top: 0;"">• Speed: 1/2</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 143 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Open dim: 955 x 2450 x 1280 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• GP 500/1000/ GGF s.r.l./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,17099.28,"BAKERY LINE, BAKERY LINE > Rolling Machine",,,"https://mariotstore.com/wp-content/uploads/2024/10/ggf-500-1000.jpg, https://mariotstore.com/wp-content/uploads/2024/10/ON-STAND-DOUGH-SHEETER-GP-500.jpg",,,,,,,,,0,,GGF,Brand,GGF,1,1,"Type of Product","Dough Sheeter",1,1,default,1,1,0,index,54,0,0,,"On Stand Dough Sheeter - GP 500/1000,فرادة العجين على ستاند,فرادة العجين,رقاقة العجين,ماكينة تمديد العجين",,,,,,,,field_60befc9fc0fb7,"GP 500/1000",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595646,110011010010011011001010011001111000111000110001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
11350,variable,,,"SAB ESPRESSO CAPPUCCINO MACHINE",1,0,visible,"The SAB Espresso Cappuccino Machine, also known as MAIK1PM3IL, MAIK1PM3NO, is a professional-grade appliance crafted for espresso and cappuccino aficionados. With its robust design and advanced features, it delivers precise control over the brewing process, ensuring consistently rich espresso and creamy cappuccino. Equipped with advanced functionalities, it's ideal for both home and commercial use. Its user-friendly interface and durable construction make it a reliable choice for those seeking exceptional coffee experiences.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Espresso cappuccino machine</p>\n<p style=""margin: 0; padding-top: 0;"">• 1 group / semi automatic</p>\n<p style=""margin: 0; padding-top: 0;"">• boiler capacity: 1.5 lt</p>\n<p style=""margin: 0; padding-top: 0;"">• Manual portion control</p>\n<p style=""margin: 0; padding-top: 0;"">• Bodywork all stainless steel or w/ painted iron –stainless steel arms</p>\n<p style=""margin: 0; padding-top: 0;"">• Water tank capacity 3 lt</p>\n<p style=""margin: 0; padding-top: 0;"">• Warning to lack the water in tank</p>\n<p style=""margin: 0; padding-top: 0;"">• Thermosiphon system</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight : 17 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• thermal power : 1100 watt</p>\n<p style=""margin: 0; padding-top: 0;"">• voltz : 220-240 V / 1 N / 50-60 hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 250 x 340 x 410 mm ( w+d+h)</p>\n<p style=""margin: 0; padding-top: 0;"">• MAIKA / SAB ESPRESSO\nitaly made</p>",,,taxable,,1,,,0,0,,,,,0,,,,"COFFEE & BAR LINE, COFFEE & BAR LINE > Coffee Machines",,,"https://mariotstore.com/wp-content/uploads/2025/07/MAIK1PM3NO.jpg, https://mariotstore.com/wp-content/uploads/2024/10/MAIKA.png",,,,,,,,,0,,SAB,Brand,SAB,1,1,"Type of Product","Espresso Cappuccino Machine",1,1,default,1,1,125,index,10,0,0,,"SAB ESPRESSO CAPPUCCINO MACHINE-MAIK1PM3IL,ماكينة ساب اسبريسو كابتشينو,ماكينة اسبريسو مجموعة واحد,ماكينة اسبريسو",,,,,,,,field_60befc9fc0fb7,,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595582,110101011010110010010011010100101010000111001011,false,,,,,,,,salescountdowntimer,Color,"Black, Red",1,1,Model,"MAIK1PM3IL, MAIK1PM3NO",1,1,00:00,00:00,,,,,field_60befc9fc0fb7,,,,,
11353,simple,,,"ESPRESSO CAPPUCCINO MACHINE",1,0,visible,"The ESPRESSO CAPPUCCINO MACHINE-1GR-PRESTIGE is a premium espresso and cappuccino maker designed for discerning coffee enthusiasts. With its sleek design and advanced features, it offers precise control over the brewing process, ensuring consistently rich espresso and velvety cappuccino. Equipped with a single group, it's perfect for home or small-scale use. Its user-friendly interface and high-quality construction make it a standout choice for those who appreciate both style and performance in their coffee appliances.","<p style=""margin-bottom: 0;margin-top: 0px"">• Espresso cappuccino machine</p>\n<p style=""margin: 0;padding-top: 0"">• 1 group / automatic</p>\n<p style=""margin: 0;padding-top: 0"">• boiler capacity: 6 lt / / Color: Red, White, Black</p>\n<p style=""margin: 0;padding-top: 0"">• Automatic or semiautomatic coffee &amp; hot water portion control</p>\n<p style=""margin: 0;padding-top: 0"">• Bodywork all S/S w/ painted iron parts (black / white / red)</p>\n<p style=""margin: 0;padding-top: 0"">• Stainless steel steam and water wands</p>\n<p style=""margin: 0;padding-top: 0"">• Coffee pre-infusion system &amp; thermosiphon system</p>\n<p style=""margin: 0;padding-top: 0"">• Copper boiler (Cu 99,5) w/ anti-oxidationtreatment</p>\n<p style=""margin: 0;padding-top: 0"">• The drip tray can be set to two different levels to accommodate different size of cups / glasses</p>\n<p style=""margin: 0;padding-top: 0"">• Weight : 30 kg</p>\n<p style=""margin: 0;padding-top: 0"">• thermal power : 2000 watt</p>\n<p style=""padding-top: 0"">• voltz : 220-240 V / 1 N / 50-60 hz</p>\n•Dim: 430 x 545 x 520 mm ( w+d+h)\n<p style=""margin: 0;padding-top: 0""></p>",,,taxable,,1,,,0,0,,,,,0,,5999,7832.88,"COFFEE & BAR LINE, COFFEE & BAR LINE > Coffee Machines",,,https://mariotstore.com/wp-content/uploads/2024/10/Untitled-4.png,,,,,,,,,0,,SAB,Brand,"SAB, COFEE MACHINE",1,1,"Type of Product","Espresso Cappuccino Machine",1,1,default,1,1,125,index,16,0,0,,"ESPRESSO CAPPUCCINO MACHINE-1GR-PRESTIGE,ماكينة اسبريسو كابتشينو,ماكينة اسبريسو",,,,,,,,field_60befc9fc0fb7,,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596116,110101011110110010100000011110100011010000010111,true,backend,9360734524012036,yes,yes,,product,no,,Color,"Black, Red, White",1,1,,,,,,,,,,,field_60befc9fc0fb7,,,,,
11358,simple,,,"ESPRESSO CAPPUCCINO MACHINE-COMPATTA JOLLY",1,0,visible,"The ""Espreso Cappuccino Machine - Compatta Jolly"" is a sleek and compact appliance designed to bring the delightful flavors of espresso and cappuccino into the comfort of your home or office. This espresso machine combines elegance with functionality, making it an excellent addition to any kitchen or coffee station.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(22px, 117px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• Espresso cappuccino machine</p>\n<p style=""margin: 0; padding-top: 0;"">• 2 group / automatic</p>\n<p style=""margin: 0; padding-top: 0;"">• boiler capacity: 8 lt</p>\n<p style=""margin: 0; padding-top: 0;"">• Automatic or semiautomatic coffee &amp; hot water portion control</p>\n<p style=""margin: 0; padding-top: 0;"">• Bodywork all S/S w/ painted iron parts (black / white / red)</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel steam and water wands</p>\n<p style=""margin: 0; padding-top: 0;"">• Coffee pre-infusion system &amp; thermosiphon system</p>\n<p style=""margin: 0; padding-top: 0;"">• Copper boiler (Cu 99,5) w/ anti-oxidationtreatment</p>\n<p style=""margin: 0; padding-top: 0;"">• The drip tray can be set to two different levels to accommodate different size of cups / glasses</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight : 60 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• thermal power : 3000 watt</p>\n<p style=""margin: 0; padding-top: 0;"">• voltz : 220-240 V / 1 N / 50-60 hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 665 x 540 x 510 mm ( w+d+h)</p>\n<p style=""margin: 0; padding-top: 0;"">• COMPATTA JOLLY/ SAB ESPRESSO/ italy made</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(505px, 14px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,,7171,"COFFEE & BAR LINE, COFFEE & BAR LINE > Coffee Machines