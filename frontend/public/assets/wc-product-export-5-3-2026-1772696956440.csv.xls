• w/ 3+3 shelf &amp; 2 drs
• Temp: +2˚ ~ +8° at 32° C",,,,,,field_60befc9fc0fb7,GN1410TN,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011110100001111100011000110110000111001101001001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12592,simple,,,"DOUGH MIXER DH-20FAS",1,0,visible,"The DOUGH MIXER DH-20FAS is a robust and efficient appliance tailored for both home and professional kitchens. With a 20-liter capacity, it is perfect for mixing large batches of dough for bread, pastries, and more. The DH-20FAS features a powerful motor and multiple speed settings, ensuring thorough and consistent mixing. Its durable stainless steel bowl and attachments are built to withstand heavy use, while the easy-to-use control panel simplifies operation. Ideal for bakers seeking reliable performance and convenience, the DH-20FAS is an essential tool for any baking enthusiast.","[vc_row][vc_column][vc_column_text css=""""]\n<p style=""margin-bottom: 0; margin-top: 0px;"">. bowl cap: 20 ltr\n. flour cap: 8 kg.\n. drawn stainless steel bowl.\n. mixing speed: 101/202 rpm/min.\n. bowl speed: 8/16 rpm / min.\n. voltage: 220 v: 50-60Hz / 1 Ph\n. power: 0.85/1.1 kw.\n. net.weight: 70 kg.\n. dim: 690×380×730 mm.\nDH-20A / DH-20FAS / capinox / France model.</p>\n[/vc_column_text][/vc_column][/vc_row]",,,taxable,,1,,,0,0,,,,,0,,,2381,"BAKERY LINE, BAKERY LINE > Bakery Mixers",,,"https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-DH-FAS1.png, https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-size-DH-FAS.png, https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-side-DH-FAS1.png",,,,,,,,,0,,Capinox,"Type of Product","Dough Mixer",1,1,Brand,Capinox,1,1,default,1,1,129,index,25,259,0,,"DOUGH MIXER DH-20FAS",,,,,,,,field_60befc9fc0fb7,"DH-20A / DH-20FAS",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595659,001101001111011001110011100011000011100110011000,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12596,simple,,,"DOUGH MIXER DH-30A / DH-30FAS",1,0,visible,"The DOUGH MIXER DH-30FAS is a high-capacity, professional-grade appliance designed for demanding baking tasks. With a spacious 30-liter bowl, it is perfect for mixing large quantities of dough, making it ideal for bakeries and large kitchens. The DH-30FAS features a powerful motor with multiple speed settings, ensuring efficient and thorough mixing for a variety of dough types. Its robust construction, including a durable stainless steel bowl and attachments, ensures longevity and reliability. The intuitive control panel makes operation simple and straightforward, making the DH-30FAS an indispensable tool for serious bakers and culinary professionals.","[vc_row][vc_column][vc_column_text css=""""]\n<p style=""margin-bottom: 0; margin-top: 0px;"">. bowl cap: 30 ltr\n. flour cap: 12 kg.\n. drawn stainless steel bowl.\n. mixing speed: 101/202 rpm/min.\n. bowl speed: 8/16 rpm / min.\n. voltage: 220 v: 50-60Hz / 1 Ph\n. power: 0.85/1.1 kw.\n. net.weight: 90 kg.\n. dim: 770×430×810 mm.\nDH-30A / DH-30FAS / capinox / France model .</p>\n[/vc_column_text][/vc_column][/vc_row]",,,taxable,,1,,,0,0,,,,,0,,,2680,"BAKERY LINE, BAKERY LINE > Bakery Mixers",,,"https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-DH-FAS1.png, https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-size-DH-FAS30.png, https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-side-DH-FAS1.png",,,,,,,,,0,,Capinox,"Type of Product","Dough Mixer",1,1,Brand,Capinox,1,1,default,1,1,213,index,65,259,0,,"DOUGH MIXER,DOUGH MIXER DH-30FAS",,,,,,,,field_60befc9fc0fb7,"DH-30A / DH-30FAS",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595665,001101001111011001110011100011000011100110011000,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12598,simple,,,"DOUGH MIXER DH-40A / DH-40FAS",1,0,visible,"The DOUGH MIXER DH-40FAS is an industrial-grade appliance designed for high-volume dough preparation in commercial kitchens and bakeries. With a substantial 40-liter capacity, it is perfect for mixing large batches of dough efficiently and consistently. The DH-40FAS is equipped with a powerful motor and multiple speed settings, allowing for precise control and versatility in handling different types of dough. Its heavy-duty stainless steel bowl and attachments ensure durability and longevity, even with frequent use. The user-friendly control panel facilitates easy operation, making the DH-40FAS a reliable and essential asset for professional bakers and large-scale food production.","[vc_row][vc_column][vc_column_text css=""""]\n<p style=""margin-bottom: 0; margin-top: 0px;"">. bowl cap: 40 ltr\n. flour cap: 16 kg.\n. drawn stainless steel bowl.\n. mixing speed: 101/202 rpm/min.\n. bowl speed: 8/16 rpm / min.\n. voltage: 220 v: 50-60Hz / 1 Ph\n. power: 3 kw.\n. net.weight: 125 kg.\n. dim: 870×480×940 mm.\nDH-40A / DH-40FAS / capinox / France model .</p>\n[/vc_column_text][/vc_column][/vc_row]",,,taxable,,1,,,0,0,,,,,0,,,3796,"BAKERY LINE, BAKERY LINE > Bakery Mixers",,,"https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-DH-FAS1.png, https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-size-DH-FAS40.png, https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-side-DH-FAS1.png, https://mariotstore.com/wp-content/uploads/2024/10/DOUGH-MIXER-DH-40A.jpg",,,,,,,,,0,,Capinox,"Type of Product","Dough Mixer",1,1,Brand,Capinox,1,1,default,1,1,213,index,65,259,0,,"DOUGH MIXER,DOUGH MIXER DH-40FAS",,,,,,,,field_60befc9fc0fb7,"DH-40A / DH-40FAS",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595665,001101001111011001110011100011000011100110