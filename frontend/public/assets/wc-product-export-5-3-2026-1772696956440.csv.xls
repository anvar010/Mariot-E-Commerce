13757,simple,,,"Hamilton Beach Blender -  HBH855",1,0,visible,"The BLENDER BAR - HBH855-UK is a high-performance commercial blender designed for professional use in bars, restaurants, and cafes. It features a powerful motor and advanced blending technology, ensuring smooth and consistent results for a variety of beverages and recipes. The blender is equipped with user-friendly controls, durable construction, and safety features, making it an ideal choice for busy environments that require reliable and efficient blending performance.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Hamilton Beach Blender - HBH855</p>\n<p style=""margin: 0; padding-top: 0;"">• Summit® Edge High Performance Blender</p>\n<p style=""margin: 0; padding-top: 0;"">• 3.5 HP motor</p>\n<p style=""margin: 0; padding-top: 0;"">• 48 oz (1.36 liter) capacity.</p>\n<p style=""margin: 0; padding-top: 0;"">• Stackable polycarbonate container.</p>\n<p style=""margin: 0; padding-top: 0;"">• Built-in sensors.</p>\n<p style=""margin: 0; padding-top: 0;"">• Variable speeds and pulse.</p>\n<p style=""margin: 0; padding-top: 0;"">• Quiet Shield™™, USB port.</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel blades,</p>\n<p style=""margin: 0; padding-top: 0;"">• 230v/50-60/1-ph, cULus, NSF</p>\n<p style=""margin: 0; padding-top: 0;"">• Hamilton Beach Model No. HBH855</p>",,,taxable,,1,,,0,0,,,,,1,,4850,5730,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Kitchen Equipment, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/BAR-BLENDER-–-HBH850UK.png,,,,,,,,,0,,"Hamilton Beach USA",Brand,"Hamilton Beach- USA",1,1,"Type of Product","Bar Blender",1,1,default,1,1,0,,57,0,0,,"Hamilton Beach Blender,Hamilton Beach Blender - HBH855",,,,,,,,field_60befc9fc0fb7,HBH855,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,01100010001011100101