12781,simple,,,"ICE CREAM MACHINE WITH STAND MK-6618C",1,0,visible,"The ICE CREAM MACHINE WITH STAND MK-6618C is a sophisticated and versatile appliance designed to effortlessly create a wide variety of frozen desserts in a commercial setting. This machine combines cutting-edge technology with user-friendly features to deliver consistent and high-quality results. Whether you're running an ice cream parlor, a cafe, or a restaurant, the MK-6618C offers the capability to produce delicious frozen treats that cater to varying customer preferences.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity: 24 L</p>\n<p style=""margin: 0; padding-top: 0;"">• Rated production: 36 l / h</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 2000w</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• Ice cream temperature up to -7 to -8 degrees Celsius</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 770*480*1266mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-6618C / MKE-MATIC</p>",,,taxable,,1,,,0,0,,,,,0,,,6275,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE","ICE CREAM MACHINE WITH STAND",,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Ice Cream Machine With Stand",1,1,Brand,"MKE MATIC",1,1,default,1,1,133,index,64,376,0,,"ICE CREAM MACHINE WITH STAND",,,,,,,,field_60befc9fc0fb7,MK-6618C,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12782,simple,,,"POPSICLE MACHINE MK-PM80",1,0,visible,"The POPSICLE MACHINE MK-PM80 is a high-capacity, efficient appliance designed for commercial use. This machine is perfect for producing large quantities of popsicles quickly and consistently, making it ideal for ice cream shops, cafes, and other food service establishments. The MK-PM80 features user-friendly controls and a durable construction, ensuring reliable performance and ease of operation. Its robust design and powerful cooling system allow for the rapid freezing of popsicles, enabling the creation of a variety of delicious and refreshing treats with minimal effort.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity: 80 pcs</p>\n<p style=""margin: 0; padding-top: 0;"">• Core Components: Motor,Pump,Bearing,Gearbox,Gear</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Lowest temperature (0C): -20~-24</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 1200 w</p>\n<p style=""margin: 0; padding-top: 0;"">• Coolant: R22/R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• N. - G. Weight: 130 - 150 kgs</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 630*800*1260 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-PM80 / MKE-MATIC</p>",,,taxable,,0,,,0,0,,,,,0,,,5500,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Popsicle Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,133,index,64,376,0,,"POPSICLE MACHINE MK-PM80",,,,,,,,field_60befc9fc0fb7,MK-PM80,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,111111110000010100000110101110000011011011001001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
