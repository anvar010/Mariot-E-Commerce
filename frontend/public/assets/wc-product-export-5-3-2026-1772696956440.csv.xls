13503,simple,,,"Vertical Gas Chicken Rotisseries - G8S A",1,0,visible,"The Vertical Gas Chicken Rotisserie - G8S A is a commercial-grade appliance designed for high-capacity poultry roasting. It features a vertical configuration that ensures even and thorough cooking of chicken and other meats. The G8S A model operates on gas, providing consistent heat for perfect results every time. With its spacious interior, it can roast multiple chickens simultaneously, making it ideal for busy restaurants and catering services. The rotisserie is built with durability in mind, offering user-friendly controls and an easy-to-clean design, ensuring both efficiency and convenience in a commercial kitchen setting.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Vertical Gas Chicken Rotisseries - G8S A</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 8 axles</p>\n<p style=""margin: 0; padding-top: 0;"">• Chicken cap: 32 - 40</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 230v/ 1hp /50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Single-phase motor power: 0,48 kW</p>\n<p style=""margin: 0; padding-top: 0;"">• LPG GAS: 3.36 Kg/h</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 144 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1100*480*h.1930 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• G8S A / <a href=""https://mariotstore.comold/brand/ggf/"">GGF</a> s.r.l./ Italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,14080,"COOKING LINE, COOKING LINE > Grills",,,https://mariotstore.com/wp-content/uploads/2024/10/G8S-A.jpg,,,,,,,,,0,,GGF,Brand,GGF,1,1,,,,,default,1,1,129,index,57,138,0,,"Vertical Gas Chicken Rotisseries - G8S A",,,,,,,,field_60befc9fc0fb7,"G8S A",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011000001110011001110010010110010101100111001101,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13505,simple,,,"Pizza Rolling Machine - S 42MR",1,0,visible,"The Pizza Rolling Machine - S 42MR is a high-performance tool designed for efficient pizza dough preparation. This machine features a compact and durable design, ideal for commercial kitchens and pizzerias. It streamlines the dough rolling process with adjustable settings to achieve the desired thickness and consistency. The S 42MR model is built for reliability and ease of use, helping to increase productivity and ensure consistent results. Its robust construction and user-friendly controls make it a valuable addition to any pizza production setup.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Pizza Rolling Machine - S 42MR</p>\n<p style=""margin: 0; padding-top: 0;"">• SINGLE ROLL</p>\n<p style=""margin: 0; padding-top: 0;"">• Dough weight: 210/600 gr</p>\n<p style=""margin: 0; padding-top: 0;"">• Pizza dim: 260/400 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 230v/ 1hp /50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Single-phase motor power: 0,37 kW</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 31 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 540*340*370 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• S 42MR / <a href=""https://mariotstore.comold/brand/ggf/"">GGF</a> / Italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,3062.4,"BAKERY LINE, BAKERY LINE > Rolling Machine",,,https://mariotstore.com/wp-content/uploads/2024/10/S-42MR.jpg,,,,,,,,,0,,GGF,Brand,GGF,1,1,,,,,default,1,1,131,index,67,138,0,,"Pizza Rolling Machine,Pizza Rolling Machine - S 42MR",,"• Pizza Rolling Machine - S 42MR
