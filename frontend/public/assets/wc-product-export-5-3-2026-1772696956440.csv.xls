14487,simple,,,"Double Arc Cake Showcase - FGW1000-C2",1,0,visible,"The Double Arc Cake Showcase - FGW1000-C2 is a sophisticated refrigerated display unit designed to showcase cakes and desserts in style. Featuring a double arc design, this showcase offers an elegant presentation while maintaining optimal temperature for preservation. With its sleek and modern appearance, it's ideal for bakeries, cafes, and dessert shops aiming to impress customers with both aesthetics and functionality.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Double Arc Cake Showcase - FGW1000-C2</p>\n<p style=""margin: 0; padding-top: 0;"">• Double Arc Cake Showcase</p>\n<p style=""margin: 0; padding-top: 0;"">• Front curved with LED light</p>\n<p style=""margin: 0; padding-top: 0;"">• S/S mirror base; Auto defrosting;</p>\n<p style=""margin: 0; padding-top: 0;"">• Rear sliding door, with 2 shelves;</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature:+2~+8°C; 220V/ 50-60 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Embraco / SECOP compressor; Dixell / Carol controller</p>\n<p style=""margin: 0; padding-top: 0;"">• N.G.weight: kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 1000* 685* 1220 mm.</p>\n<p style=""margin: 0; padding-top: 0;"">• FGW1000-C2/ Inofrigo made/Italian Technology</p>",,,taxable,,1,,,0,0,,,,,1,,,3600,"BAKERY LINE > Bakery Display, BAKERY LINE, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/Double-Arc-Cake-Showcase.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,,,,,default,1,1,0,,6,0,,,,,,,,,,,field_60befc9fc0fb7,FGW1000-C2,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596584,011111010010011000000001111111100011110101100000,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14489,variable,,,"Heat Lamp - Black,Silver,Bronze",1,0,visible,"Introducing the epitome of style and functionality, our Heat Lamp series in Black, Silver, and Bronze adds a touch of sophistication to any space while providing efficient heating solutions. Crafted with precision and designed to blend seamlessly with various décor styles, these heat lamps offer both practicality and aesthetics.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Heat Lamp - Black,Silver,Bronze</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 21.5 x 21 x 38 cm</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage220-240 Volts</p>\n<p style=""margin: 0; padding-top: 0;"">• Wattage: 275 Watts</p>\n<p style=""margin: 0; padding-top: 0;"">• Control Type: On/Off</p>\n<p style=""margin: 0; padding-top: 0;"">• Finish black</p>\n<p style=""margin: 0; padding-top: 0;"">• Mounting Style: Bardwire</p>\n<p style=""margin: 0; padding-top: 0;"">• Number Of Bulbs: 1</p>\n<p style=""margin: 0; padding-top: 0;"">• Power Type: Electric</p>",,,taxable,,1,,,0,0,,,,,1,,,,"COOKING LINE, COOKING LINE > Food Warmers, Kitchen Equipment",,,"https://mariotstore.com/wp-content/uploads/2024/10/Heat-Lamp_.png, https://mariotstore.com/wp-content/uploads/2024/10/Heat-Lamp-Black.png, https://mariotstore.com/wp-content/uploads/2024/10/Heat-Lamp-Bronze.png, https://mariotstore.com/wp-content/uploads/2024/10/Heat-Lamp-Silver.png, https://mariotstore.com/wp-content/uploads/2024/10/Heat-Lamp-Silver-1.png, https://mariotstore.com/wp-content/uploads/2024/10/Heat-Lamp-Blac1k.png",,,,,,,,,0,,Mariot,Brand,Mariot,1,1,,,,,default,1,1,0,,74,0,,,"Heat Lamp",,,,,,,,field_60befc9fc0fb7,,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596054,110011100111101100010110001100111001100001001100,,,,,,,,,,,,,,,,,,,,,,,,,,"14491,14492,14493",,,,,,,,,,,,,,,,,,,,,,,,,,,,
