12073,simple,,,"TOPPING WARMERS DISPENSE FUDGE-FSPW-SS 83697",1,0,visible,"The TOPPING WARMER DISPENSE FUDGE - FSPW-SS 83697 is a versatile and efficient appliance designed for keeping toppings warm and dispensing them with ease. Ideal for use in commercial settings such as cafes, restaurants, and ice cream parlors, this warmer features a stainless steel construction for durability and easy maintenance. The unit ensures consistent heating of fudge and other toppings, maintaining their ideal consistency and temperature. With its user-friendly dispensing mechanism, the FSPW-SS 83697 allows for smooth and precise portion control, enhancing the overall efficiency and service quality.","<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• 2.8 L stainless steel jar (included)</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Thermostat ensures accurate heat control Stainless steel pump</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• 30 mL maximum portion, adjusts in 3.7 mL increments</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Spout warmer ensures safety when dispensing potentially hazardous foods</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• (3) magnetic merchandising signs: Fudge, Caramel and Cheese Sauce</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Power: 230V / temp. 500 watt heating element on or off as needed</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(439px, 93px); text-align: left;"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,4600,"COOKING LINE, COOKING LINE > Food Warmers",,,https://mariotstore.com/wp-content/uploads/2024/10/FSPW-SS-83697.jpg,,,,,,,,,0,,"Server USA",Brand,"Server USA",1,1,"Type of Product","Topping Warmers",1,1,default,1,1,0,index,63,0,0,,"TOPPING WARMERS DISPENSE FUDGE,TOPPING WARMERS DISPENSE FUDGE-FSPW-SS 83697",,,,,,,,field_60befc9fc0fb7,"FSPW-SS 83697",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596127,011000110000111000111001111010011101100000111100,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12075,simple,,,"FUDGE SERVER W/ PUMP-FSP 84580",1,0,visible,"<strong>Fudge Server with Pump - FSP 84580</strong>\n\nEffortlessly dispense fudge, caramel, or sauces with the FSP 84580 Fudge Server. Designed for convenience, it features a durable pump mechanism, ensuring precise portion control and easy operation. Perfect for desserts and toppings stations.","S/S water-bath warmer dispenser directly from 3 quarts (2.8L) S/S jar(94009) or food manufacturer #10 can,\npump yields 1 oz (30 ml) w/ collars provided to reduce yield in 1/8 oz (3.7 ml) increments,\nwhen dispensing potentially hazardous foos, a spout warmer is required, jar included, 230/50/1 UK plug.",,,taxable,,1,,,0,0,,,,,1,,,2900,"COOKING LINE, COOKING LINE > Food Warmers, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/FSP-84580.jpg,,,,,,,,,0,,"Server USA",Brand,"Server USA",1,1,"Type of Product","Fudge Server",1,1,default,1,1,0,index,8,0,0,,,,,,,,,,field_60befc9fc0fb7,"FSP 84580",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110000100110111001110011010100110101100101001100,true,backend,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,
12077,simple,,,"SERVER SQUEEZE BOTTLE WARMER-SBW 86925",1,0,visible,"The SERVER SQUEEZE BOTTLE WARMER - SBW 86925 is designed to keep squeeze bottles with sauces, syrups, or other condiments warm and ready for use. This appliance features a durable construction and efficient heating system that ensures even temperature maintenance, keeping your condiments at the perfect serving temperature. The unit is ideal for commercial kitchens, food trucks, and cafes, where quick and easy access to warm condiments enhances service efficiency and quality. Its user-friendly design allows for easy loading and retrieval of squeeze bottles, making it a valuable addition to any busy food service environment.","S/S water-bath warmer dispenser directly from 3 quart (2.8L) S/S jar(94009) or food manufacturer #10 can, pump yields 1 oz (30 ml) w/ collars provided to reduce yeild in 1/8 oz (3.7 ml) increments, when dispensing potentially hazardous foos, a spout warmer is required, jar included, 230/50/1 UK plug.",,,taxable,,1,,,0,0,,,,,0,,,2100,"COOKING LINE, COOKING LINE > Food Warmers",,,https://mariotstore.com/wp-content/uploads/2024/10/SBW-86925.jpg,,,,,,,,,0,,"Server USA",Brand,"Server USA",1,1,"Type of Product","Squeeze Bottle Warmer",1,1,default,1,1,0,index,65,0,0,,"SERVER SQUEEZE BOTTLE WARMER,SERVER SQUEEZE BOTTLE WARMER-SBW 86925",,,,,,,,field_60befc9fc0fb7,"SBW 86925",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596127,110010100110110011000110110100110101100100110010,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12079,simple,,,"TOPPING WARMER WITH LADLE -FSP 84620",1,0,visible,"The TOPPING WARMER WITH LADLE - FSP 84620 is a practical and efficient appliance designed to keep toppings warm and ready for serving. Featuring a durable construction and integrated ladle, this warmer is ideal for use in commercial settings like cafes, restaurants, and food service establishments. The unit ensures even and consistent heating of various toppings, such as sauces and syrups, maintaining their optimal temperature and texture. The included ladle makes serving easy and convenient, allowing for precise portion control and enhancing overall service efficiency.","S/S water-bath warmer dispenser directly from 3 quart (2.8L) S/S jar(94009) or food manufacturer #10 can, pump yields 1 oz (30 ml) w/ collars provided to reduce yeild in 1/8 oz (3.7 ml) increments, when dispensing potentially hazardous foos, a spout warmer is required, jar included, 230/50/1 UK plug.",,,taxable,,1,,,0,0,,,,,0,,,1810,"COOKING LINE, COOKING LINE > Food Warmers",,,https://mariotstore.com/wp-content/uploads/2024/10/FSP-84620.jpg,,,,,,,,,0,,"Server USA",Brand,"Server USA",1,1,"Type of Product","Topping Warmers",1,1,default,1,1,0,index,65,0,0,,"TOPPING WARMER WITH LADLE,TOPPING WARMER WITH LADLE -FSP 84620",,,,,,,,field_60befc9fc0fb7,"FSP 84620",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596127,110011100000110011010010011100110101101100100110,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
