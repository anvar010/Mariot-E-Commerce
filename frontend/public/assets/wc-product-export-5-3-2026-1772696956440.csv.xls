13643,simple,,,"Electric crepe machine - CFE 400",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Electric crepe machine - CFE 400</p>\n<p style=""margin: 0;padding-top: 0"">• The electric crepe machine CFE 400 is equipped with an enameled cast iron plate (Diameter: 400 mm).</p>\n<p style=""margin: 0;padding-top: 0"">• The enameled coating of the plate substantially reduces the seasoning phase.</p>\n<p style=""margin: 0;padding-top: 0"">• The electric crepe maker ensures excellent temperature transfer and real-contact cooking.</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 3.6 kW</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 400 x 200 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 18 kg</p>\n<p style=""margin: 0;padding-top: 0"">• volts: 230 V</p>\n<p style=""margin: 0;padding-top: 0"">• Coating: Fonte émaillée</p>\n<p style=""margin: 0;padding-top: 0"">• CFE 400 / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,1756,"SNACK MAKER > Crepe Maker, SNACK MAKER",,,https://mariotstore.com/wp-content/uploads/2024/10/Electric-crepe-machine-cfe400.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,71,0,0,,"Electric crepe machine - CFE 400,ماكينة كريب كهربائية",,,,,,,,field_60befc9fc0fb7,"CFE 400",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595588,110110001110010010011100001001111000111100110100,,,,,,,,,,"Type of Product","Crepe Maker",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13645,simple,,,"Gas Griddle with Decarbonized Steel Plate - PSR 400 G",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""text-align: left;margin-bottom: 0;margin-top: 0px"">• Gas griddle with decarbonized steel plate - PSR 400 G</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• The professional griddle plate PSR 400 G is equipped with piezo ignition and an adjustment knob.</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• The gas griddle PSR 400 G offers unrivaled safety.</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Features: decarbonized steel plate, star-shaped burner with 8 branches, Piezo ignition, adjustment button with idle position, safety thermocouple.</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Power: 3.2 kW</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Outside dimensions: 400 x 475 x 230 mm</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Baking surface: 400 x 400 mm</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Weight: 22 kg</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• cooking areas: 1</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• PSR 400 G / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""true"">\n<div id=""tippy-1"" style=""z-index: 100000200;position: absolute;margin: 0px"" data-tippy-root="""">\n<div class=""tippy-box"" style=""max-width: 350px"" role=""mtttooltip"" data-state=""visible"" data-theme=""custom"" data-animation=""fade"" data-placement=""top"">\n<div class=""tippy-content"" data-state=""visible""><span dir=""rtl"">• الوزن : 22 كجم</span></div>\n<div class=""tippy-arrow"" style=""position: absolute;left: 0px""></div>\n</div>\n</div>\n</div>",,,taxable,,1,,,0,0,,,,,0,,,2233,"COOKING LINE, COOKING LINE > Grills",,,https://mariotstore.com/wp-content/uploads/2024/10/Gas-griddle-