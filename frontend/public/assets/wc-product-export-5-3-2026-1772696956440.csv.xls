13544,simple,,,"VERTICAL CUTTER MIXER - R20 E",1,0,visible,"The Robot Coupe R20 E Vertical Cutter Mixer is a powerful and efficient food processing machine designed for professional kitchens. It features a 20-liter stainless steel bowl and a robust 4 HP motor, making it ideal for large-volume food preparation tasks such as chopping, mixing, blending, and kneading. The R20 E is equipped with a smooth blade assembly and a variable speed control, allowing for precise processing of a wide variety of ingredients. Its vertical design ensures space efficiency, while the durable construction guarantees long-lasting performance. This cutter mixer is perfect for restaurants, catering services, and other food service establishments that require reliable and high-capacity equipment.","<p style=""margin-bottom: 0;margin-top: 0px"">• VERTICAL CUTTER MIXER - R20 E</p>\n<p style=""margin: 0;padding-top: 0"">• S/S Bowl with smooth ( straight) blade</p>\n<p style=""margin: 0;padding-top: 0"">• Voltage: 400V/50/3 4400 W 2</p>\n<p style=""margin: 0;padding-top: 0"">• Speed: 1500/3000 rpm</p>\n<p style=""margin: 0;padding-top: 0"">• Bowl Cap: 20L</p>\n<p style=""margin: 0;padding-top: 0"">• Gross Weight: 75 kg</p>\n<p style=""margin: 0;padding-top: 0"">• DIM: 380X630X760 mm</p>\n<p style=""margin: 0;padding-top: 0"">• R20 E | Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,29578,34797,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/r20e.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,72,0,0,,"VERTICAL CUTTER MIXER,VERTICAL CUTTER MIXER - R20 E",,,,,,,,field_60befc9fc0fb7,"R20 E",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010011001110011011001100110110010011000011100,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,