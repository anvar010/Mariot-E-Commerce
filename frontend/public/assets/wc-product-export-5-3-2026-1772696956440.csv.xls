13518,simple,,,"Gas cooker S36D",1,0,visible,,"<p style=""text-align: left; margin-bottom: 0; margin-top: 0px;"">• Gas cooker S36D</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• 6 gas range on a large gas oven</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• enameled oven with an isolated chamber and door</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• the temperature is adjustable from 150 to 300 °c</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• lateral grid holders with 3 positions</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• extractable for easy cleaning</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• adjustable legs</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• power cap: 215,000 BTU = 3000 BTU each</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• burner + oven: 35000 btu</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• total power: 63.1 kW = 8.8 kW. * 6+10.3 kw</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• net weight: 300</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• dim: 927 x 1117 x 1512 mm</p>\n<p style=""text-align: left; margin: 0; padding-top: 0;"">• S36D / <a href=""https://mariotstore.comold/brand/southbend-usa/"">SOUTHBEND</a> / USA made</p>",,,taxable,,1,,,0,0,,,,,0,,,10851,"COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 900",,,https://mariotstore.com/wp-content/uploads/2024/10/s36d-600x600-removebg-preview.png,,,,,,,,,0,,"Southbend USA",Electric/Gas,Gas,1,1,Series,"Series 90",1,1,default,1,1,129,index,79,164,0,,"Gas cooker S36D",,"• Gas cooker S36D
