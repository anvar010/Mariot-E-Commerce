13848,simple,,,"Water boiler - WB-40A",1,0,visible,"<strong>WATER BOILER - WB-40A</strong>\nThe WB-40A Water Boiler is a high-capacity solution designed for commercial use. Built with durable stainless steel, it provides consistent hot water for beverages and food preparation. Its user-friendly operation and efficient performance make it ideal for restaurants, cafes, and catering services.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Water boiler - WB-40A</p>\n<p style=""margin: 0; padding-top: 0;"">• cap: 40 ltr.</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 230 v / 50 hz / 3000 w.</p>\n<p style=""margin: 0; padding-top: 0;"">• Gross weight: 5.595 kg / 5.15 kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• Net weight: 4.555 kg / 4.415 kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• Dimensions 390 x 390 x 523 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• WB-40A</p>",,,taxable,,1,,,0,0,,,,,1,,,600,"COOKING LINE, Kitchen Equipment, SNACK MAKER, Special Offer, SNACK MAKER > Water Boiler",,,https://mariotstore.com/wp-content/uploads/2024/10/25.png,,,,,,,,,0,,Mariot,Brand,Mariot,1,1,,,,,default,1,1,0,,60,0,0,,"Water boiler,Water boiler - WB-40A",,,,,,,,field_60befc9fc0fb7,WB-40A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,100111011001100111001001100011001000111110011000,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
