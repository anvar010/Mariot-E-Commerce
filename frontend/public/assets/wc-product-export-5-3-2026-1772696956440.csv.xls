14141,variable,,,"Charcoal oven with table - HJXPROL175WT",1,0,visible,"Charcoal oven with table - HJXPROL175WT Josper is an elegant combination of a grill and an oven in a single machine. It works 100% with\ncharcoal. A unique closed barbecue design. Different levels of grilling. Flexible and robust, easy\nto use, with a front opening door system. Vent system for temperature control.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Charcoal oven with table - HJXPROL175WT</p>\n<p style=""margin: 0; padding-top: 0;"">• Recommended for ± 175 dinners</p>\n<p style=""margin: 0; padding-top: 0;"">• Fire up time: 40 min average</p>\n<p style=""margin: 0; padding-top: 0;"">• Charcoal daily consumtion: 35 to 45 lb</p>\n<p style=""margin: 0; padding-top: 0;"">• Performance: 9h</p>\n<p style=""margin: 0; padding-top: 0;"">• Production per hour: 242.5 lb average</p>\n<p style=""margin: 0; padding-top: 0;"">• Broiling temperature: 482 a 662 ºF</p>\n<p style=""margin: 0; padding-top: 0;"">• Grill rack capacity in Gn trays: 2xGN1/1</p>\n<p style=""margin: 0; padding-top: 0;"">• Nominal heat output: 12.9 hp</p>\n<p style=""margin: 0; padding-top: 0;"">• Flue gas mass flow: 0.83 oz/s</p>\n<p style=""margin: 0; padding-top: 0;"">• Net weight: 683 lb</p>",,,taxable,,1,,,0,0,,,,,0,,,,"COOKING LINE, COOKING LINE > Grills, Kitchen Equipment","Charcoal Oven, CHARCOAL OVEN BURGANDY DOOR (25VC) HJX-PRO-S80, Charcoal Oven HJX-PRO-M120, Charcoal Oven HJX-PRO-S80",,"https://mariotstore.com/wp-content/uploads/2024/10/HJXPROL175-black.png, https://mariotstore.com/wp-content/uploads/2024/10/HJXPROL175-red.png",,,,,,,,,0,,Josper,Brand,Josper,1,1,,,,,default,1,1,0,,5,0,0,,,,,,,,,,field_60befc9fc0fb7,,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595084,110100011011010010111001011100001100110001001101,,,,,,,,,,,,,,,,,,,,,,,,,,"14142,14143",,