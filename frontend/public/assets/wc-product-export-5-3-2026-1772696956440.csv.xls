12407,simple,,,"Juice extractor - CJ8",1,0,visible,"Experience the ultimate in juicing with the CJ8 Juice Extractor. Elevate your health and refreshment game with this powerful appliance that effortlessly transforms a variety of fruits into delicious, nutrient-packed juices. Designed for both efficiency and taste, the CJ8's precision extraction technology ensures you get every drop of goodness, while its sleek and user-friendly design makes juicing a breeze. From zesty citrus to vibrant berries, unlock the full potential of nature's bounty and indulge in revitalizing, homemade juices that elevate your well-being. Energize your day with CJ8 – where freshness meets function in every sip.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(72px, 28px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• Juice extractor - CJ8</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• capacity: 7.5 lt</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• to squeeze watermelon, cantaloupe, apple, pear, orange, pomelo, peach, pineapple, grape, carrot</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• high outlet more than 1 liter/minute</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• motor braking when opening</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• power: 220 – 240v, 50 – 60hz, 700w</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• motor speed: 3000rpm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• net weight: 13.3 kg / gross weight: 15 kg</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• dim: 473 x 253 x 522 mm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• CJ8</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(430px, 28px); text-align: left;"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,2500,"COFFEE & BAR LINE, COFFEE & BAR LINE > Juice Maker",,,"https://mariotstore.com/wp-content/uploads/2024/10/CJ8-1.jpg, https://mariotstore.com/wp-content/uploads/2024/10/CJ8-scaled-1.jpg",,,,,,,,,0,,Mariot,"Type of Product","Orange Juicer",1,1,Brand,Mariot,1,1,default,1,1,125,index,79,185,0,,"Juice extractor",,,,,,,,field_60befc9fc0fb7,CJ8,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011111111001111000010001100100110000111001001100,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12410,simple,,,"Cone Baker - WF-015QW",1,0,visible,"The Cone Baker WF-015QW is an exceptional appliance for creating delectable waffle cones with ease. Its user-friendly design and efficient heating elements ensure that you can craft perfectly golden and crispy cones in no time. Whether for ice cream parlors or dessert shops, this cone baker adds a delightful touch to your offerings, allowing you to serve ice cream and other treats in a delightful homemade cone. Elevate your dessert presentation with the WF-015QW Cone Baker's convenience and quality results.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• Cone Baker</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• single head</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Power : 1 kw</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Voltage : 220 - 240 V</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Dim : 280 x 540 x 180 mm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• WF-015QW</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(241px, 37px); text-align: left;"" aria-expanded=""false""></div>",,,taxable,,0,,,0,0,,,,,1,,1699,2035,"BAKERY LINE, SNACK MAKER > Cone Baker, COOKING LINE, SNACK MAKER, Special Offer","Cone Baker",,"https://mariotstore.com/wp-content/uploads/2024/10/WF-015QW-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/WF-015QW-3-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/WF-015QW-2-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/WF-015QW-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/WF-015QW-1.jpg, https://mariotstore.com/wp-content/uploads/2024/10/WF-015QW-2.jpg, https://mariotstore.com/wp-content/uploads/2024/10/WF-015QW-2-1.jpg, https://mariotstore.com/wp-content/uploads/2024/10/WF-015QW-