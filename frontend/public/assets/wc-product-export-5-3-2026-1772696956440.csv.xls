13540,simple,,,"TABLE TOP CUTTER MIXER - R3D 3000T",1,0,visible,"The R3D 3000T Table Top Cutter Mixer is a versatile, commercial-grade kitchen appliance designed for efficient food preparation. It combines cutting, mixing, and blending functions in a compact, tabletop unit. Features typically include a robust motor for powerful performance, durable stainless steel construction for easy cleaning, and various speed settings to handle different food processing tasks. Ideal for use in restaurants, catering, and other food service settings, the R3D 3000T enhances productivity and consistency in food preparation.","<p style=""margin-bottom: 0;margin-top: 0px"">• TABLE TOP CUTTER MIXER - R3D 3000T</p>\n<p style=""margin: 0;padding-top: 0"">• Cap: 3.7 Liter with stainless steel cutter bowl stainless steel blade knife with removable cap</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 650W-3000rpm-single phase</p>\n<p style=""margin: 0;padding-top: 0"">• Dim: 210X320X400 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Gross Weight: 13.1 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Made by <a href=""https://mariotstore.comold/brand/robot-coupe/"">Robot Coupe</a>, France</p>",,,taxable,,1,,,0,0,,,,,0,,,7298,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING",,,https://mariotstore.com/wp-content/uploads/2024/10/r3d3000.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,64,0,0,,"TABLE TOP CUTTER MIXER - R3D 3000T",,,,,,,,field_60befc9fc0fb7,"R3D 3000T",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595733,011000110000110011010010110110011100110011100110,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
