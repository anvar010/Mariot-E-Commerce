11593,simple,,,"ELECTRIC CONTACT GRILL SE 40 M",1,0,visible,"<p style=""text-align: left; margin-bottom: 0; margin-top: 0px;"">The ELECTRIC CONTACT GRILL SE 40 M is an exceptional kitchen appliance designed to elevate your cooking capabilities. This electric contact grill is equipped with a plethora of features that make it an ideal choice for grilling, toasting, and preparing a variety of delicious dishes.</p>\n\n<div id=""mttContainer"" aria-expanded=""false""></div>","ENCOLOY heating element\n4 pre-set positions of movable grid\nSmooth and comfortable adjustment\nPower / voltage: 2.2 kw / 230V\nN/G Weight: 17.9 -19.7 kg\nDim: 600 x 370 x 380 mm\nSE 40 M / RM GASTRO / italy made",,,taxable,,1,,,0,0,,,,,1,,,1894,"COOKING LINE, COOKING LINE > Grills",,,https://mariotstore.com/wp-content/uploads/2024/10/SE-40-M_Visualization-scaled-1.jpg,,,,,,,,,0,,"RM Gastro",Brand,"RM Gastro",1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,62,0,0,,"ELECTRIC CONTACT GRILL",,,,,,,,field_60befc9fc0fb7,"SE 40 M",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15709,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595076,011111110000111000000011110001111111000000100101,true,backend,,,,,,,,Series,"Table Top",1,1,"Type of Product",Grill,1,1,,,,,,,,,,,,
11595,simple,,,"ELECTRIC Clam contact grill - chromed FTHC 30 ED + KD 30 T",1,0,visible,"<p style=""text-align: left; margin-bottom: 0; margin-top: 0px;"">The ELECTRIC Clam Contact Grill - Chromed FTHC 30 ED + KD 30 T is a versatile and efficient kitchen appliance designed for grilling and cooking a wide range of food items. This specific model, the FTHC 30 ED + KD 30 T, combines a clam-style top and bottom grilling surface with additional features for enhanced cooking control.</p>\n\n<div id=""mttContainer"" style=""transform: translate(572px, 69px);"" aria-expanded=""false""></div>","• 3 pre-set programmes for easy&amp; comfortable choice of operation\n\n• 1 adjustable programme(time and temp)for customized operation\n\n• Separated regulation of upper and bottom plates\n\n• Teflon sheet on the upper plate (easy replacement) (non-sticking surface)\n\n• Power / voltage: 3 kw / 230V / 50 hz\n\n• Net / Gross weight: 41,4 - 48 KG\n\n• Dim: 330 x 660 x 400 mm\n\n• FTHC 30 ED + KD 30 T / RM GASTRO / europe made",,,taxable,,1,,,0,0,,,,,1,,,4567,"COOKING LINE, COOKING LINE > Grills",,,https://mariotstore.com/wp-content/uploads/2024/10/FTHC_30_ED__KD_30_T-removebg-preview.png,,,,,,,,,0,,"RM Gastro",Brand,"RM Gastro",1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,59,0,0,,"ELECTRIC Clam contact grill",,,,,,,,field_60befc9fc0fb7,"chromed FTHC 30 ED + KD 30 T",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15710,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595252,001001001111001001101110011001110001110100110010,true,backend,,,,,,,,Series,"Table Top",1,1,"Type of Product",Grill,1,1,,,,,,,,,,,,
