13844,simple,,,"Water boiler - WB-20A",1,0,visible,"<strong>WATER BOILER - WB-20A</strong>\nThe WB-20A Water Boiler is a compact and efficient solution for providing hot water on demand. With a durable stainless steel design and user-friendly operation, it’s ideal for cafes, small restaurants, and catering services needing reliable hot water for beverages and food preparation.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Water boiler - WB-20A</p>\n<p style=""margin: 0; padding-top: 0;"">• cap: 20 ltr.</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 230 v / 50 hz / 2500 w.</p>\n<p style=""margin: 0; padding-top: 0;"">• Gross weight: 4.625 kg / 4.125 kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• Net weight: 3.885 kg / 3.43 kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• dimensions 310 x 310 x 523 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• WB-20A</p>",,,taxable,,1,,,0,0,,,,,0,,,400,"Kitchen Equipment, Limited Sale, SNACK MAKER, SNACK MAKER > Water Boiler",,,https://mariotstore.com/wp-content/uploads/2024/10/27.png,,,,,,,,,0,,Mariot,Brand,Mariot,1,1,,,,,default,1,1,0,,60,0,0,,"Water boiler,Water boiler - WB-20A",,,,,,,,field_60befc9fc0fb7,WB-20A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,100111011001100110000011100011001010110010111010,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
