12457,simple,,,"HANDWASH BASIN LMASD",1,0,visible,"LMASD: Our sleek Handwash Basin combines functionality with modern design, featuring premium materials for durability and hygiene. With its compact yet efficient design, it's the perfect addition to any space, offering a seamless handwashing experience.""","<p style=""margin-bottom: 0;margin-top: 0px"">• HANDWASH BASIN LMASD</p>\n<p style=""margin: 0;padding-top: 0"">• In AISI 304L stainless steel/p&gt;</p>\n<p style=""margin: 0;padding-top: 0"">• W/ 240 mm high splashback at a 30° angle, flexible connection hose, U-bend, swan’s neck tap, 1/2’’ hot/cold water connector</p>\n<p style=""margin: 0;padding-top: 0"">• Premixed hot/cold water (except LMASD)</p>\n<p style=""margin: 0;padding-top: 0"">• Non-return valve</p>\n<p style=""margin: 0;padding-top: 0"">• Push tap adjusted at the factory to: 6l/min</p>\n<p style=""margin: 0;padding-top: 0"">• Weight 8 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Dim: 384 x 353 x 524 mm</p>\n<p style=""margin: 0;padding-top: 0"">• LMASD / SOFINOR / FRANCE made.</p>",,,taxable,,1,,,0,0,,,,,1,,799,1006,"ACCESSORIES, Limited Sale, sale 11.11, ACCESSORIES > SINK, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/LMASD.jpg,,,,,,,,,0,,Sofinor,Brand,sofinor,1,1,"FILTER BY NAME","Hand Wash",1,0,default,1,1,181,index,63,152,0,,"HANDWASH BASIN LMASD",,,,,,,,field_60befc9fc0fb7,LMASD,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595266,011111001101011000000100101110000101111001100011,,,9356142141115594,yes,yes,,product,no,salescountdowntimer,"Type of Product","Handwash Basin",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12459,simple,,,"KNIFE STERILIZER-MZ10",1,0,visible,"The KNIFE STERILIZER-MZ10 ensures optimal kitchen hygiene with advanced sterilization technology. Designed for both commercial and home kitchens, it provides efficient and safe sterilization of knives, reducing the risk of cross-contamination and enhancing food safety.","<p style=""margin-bottom: 0px;margin-top: 0px;text-align: left"">• In AISI 304L stainless steel</p>\n<p style=""margin: 0px;padding-top: 0px;text-align: left"">• Single phase 220 V - 50 Hz</p>\n<p style=""margin: 0px;padding-top: 0px;text-align: left"">• Germicidal lamp: lifetime 8000 h</p>\n<p style=""margin: 0px;padding-top: 0px;text-align: left"">• Timer: 120 min.</p>\n<p style=""margin: 0px;padding-top: 0px;text-align: left"">• Safety cut out when doors opened</p>\n<p style=""margin: 0px;padding-top: 0px;text-align: left"">• Resistance to solids and water: IP24</p>\n<p style=""margin: 0px;padding-top: 0px;text-align: left"">• Inclined top surface: helps to comply w/ hygien standards</p>\n<p style=""margin: 0px;padding-top: 0px;text-align: left"">• Dim: 580 x 150 x 646 mm</p>\n<p style=""margin: 0px;padding-top: 0px;text-align: left"">• MZ10 / SOFINOR / FRANCE made.</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""text-align: left"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,,1228,"FOOD PROCESSING, FOOD PROCESSING > Knife Sterilizers, Special Offer",,,"https://mariotstore.com/wp-content/uploads/2024/10/MZ10-002.jpg, https://mariotstore.com/wp-content/uploads/2024/10/LMAP1-002.jpg",,,,,,,,,0,,Sofinor,Brand,sofinor,1,1,"Type of Product","Knife Sterilizers",1,1,default,1,1,182,index,65,152,0,,"KNIFE STERILIZER-MZ10",,,,,,,,field_60befc9fc0fb7,MZ10,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011110010110011000010110010100101111000110011010,,,,,,,,,salescountdowntimer,,,,