12198,simple,,,"Slush Machine-OASIS 2-10 STD",1,0,visible,"The OASIS 2-10 STD Slush Machine is a high-capacity, commercial-grade appliance designed for producing delicious frozen beverages. It features two large, transparent tanks, each with a 10-liter capacity, allowing for simultaneous preparation of different flavors. The machine's efficient cooling system ensures quick freezing and consistent slush texture. User-friendly controls and an easy-to-read display make operation simple, while the durable construction guarantees long-lasting performance. Ideal for cafes, bars, and events, the OASIS 2-10 STD Slush Machine delivers refreshing slush drinks with minimal effort and maximum reliability.","<p style=""margin-bottom: 0;margin-top: 0px"">• Slush Machine-OASIS 2-10 STD</p>\n<p style=""margin: 0;padding-top: 0"">• Capacity : 2 x 10 ltr</p>\n<p style=""margin: 0;padding-top: 0"">• 2 Transparent removable bowls</p>\n<p style=""margin: 0;padding-top: 0"">• Total Bowls Capacity: 20 lt</p>\n<p style=""margin: 0;padding-top: 0"">• Mixing system by patented magnetic transmission</p>\n<p style=""margin: 0;padding-top: 0"">• 2 Adjustable thermostat</p>\n<p style=""margin: 0;padding-top: 0"">• Shock proof, non toxic polycarbonate container</p>\n<p style=""margin: 0;padding-top: 0"">• Stainless steel body</p>\n<p style=""margin: 0;padding-top: 0"">• Overload protector</p>\n<p style=""margin: 0;padding-top: 0"">• Noise level lower than 70 dB (A)</p>\n<p style=""margin: 0;padding-top: 0"">• Ele. Power: 850 W/ 230 V/ 50 Hz</p>\n<p style=""margin: 0;padding-top: 0"">• Net weight: 56 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Dimension : 400 x 530 x 840 mm</p>\n<p style=""margin: 0;padding-top: 0"">• OASIS 2-10 STD/ cofrimell / italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,8395,"COFFEE & BAR LINE, COFFEE & BAR LINE > Slush Machine",,,"https://mariotstore.com/wp-content/uploads/2024/10/19.png, https://mariotstore.com/wp-content/uploads/2024/10/20.png, https://mariotstore.com/wp-content/uploads/2024/10/21.png",,,,,,,,,0,,Cofrimell,Brand,Cofrimell,1,1,,,,,default,1,1,125,index,56,171,0,,"Slush Machine-OASIS 2-10 STD",,,,,,,,field_60befc9fc0fb7,"OASIS 2-10 STD",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595655,100111110110100110000110110001100010010001001111,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12202,simple,,,"Slush Machine-OASIS 3-10 STD",1,0,visible,"The Slush Machine Oasis 3-10 STD is a commercial-grade beverage dispenser designed to provide a convenient and visually appealing way to serve slushies, frozen cocktails, and other frozen beverages. This machine is ideal for use in various settings, such as restaurants, cafes, convenience stores, and event venues, where cold and refreshing drinks are in demand.","<p style=""margin-bottom: 0;margin-top: 0px"">• Sluch Machine</p>\n<p style=""margin: 0;padding-top: 0"">• Capacity : 3 x 10 ltr</p>\n<p style=""margin: 0;padding-top: 0"">• 3 Transparent removable bowls</p>\n<p style=""margin: 0;padding-top: 0"">• Total Bowls Capacity: 30 lt</p>\n<p style=""margin: 0;padding-top: 0"">• 3 Adjustable thermostat</p>\n<p style=""margin: 0;padding-top: 0"">• Shock proof, non toxic polycarbonate container</p>\n<p style=""margin: 0;padding-top: 0"">• Easy-to-clean anti-shock tank and lid</p>\n<p style=""margin: 0;padding-top: 0"">• Automatic mixer stop system when opening the lid</p>\n<p style=""margin: 0;padding-top: 0"">• Noise level below 70 dba</p>\n<p style=""margin: 0;padding-top: 0"">• Stainless steel facade</p>\n<p style=""margin: 0;padding-top: 0"">• Ele. Power: 1100 W/ 230 V/ 50 Hz</p>\n<p style=""margin: 0;padding-top: 0"">• N.Weight : 72 Kg</p>\n<p style=""margin: 0;padding-top: 0"">• Dimension : 600 x 530 x 840 mm</p>\n<p style=""margin: 0;padding-top: 0"">• OASIS 3-10 STD/ cofrimell / italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,11642,"COFFEE & BAR LINE, COFFEE & BAR LINE > Slush Machine",,,"https://mariotstore.com/wp-content/uploads/2024/10/13-1.png, https://mariotstore.com/wp-content/uploads/2024/10/14-1.png, https://mariotstore.com/wp-content/uploads/2024/10/15-1.png, https://mariotstore.com/wp-content/uploads/2024/10/Slush-Machine-QASIS-3-10-STD.jpg",,,,,,,,,0,,Cofrimell,Brand,Cofrimell,1,1,,,,,default,1,1,125,index,59,171,0,,"Slush Machine",,,,,,,,field_60befc9fc0fb7,"OASIS 3-10 STD",field_63