13852,simple,,,"XpressChef 2c Series - JET514U",1,0,visible,"<ul class=""no-bullet"">\n 	<li>Perfect baking in a fraction of the time - wide variety of menu items</li>\n 	<li>Bake fresh more often to increase customer satisfaction and sales</li>\n 	<li>Saves time and labor - easy to program, operate, clean and maintain</li>\n 	<li>Menu management app and Smart USB standard equipment</li>\n 	<li>Exceptional ROI: comparatively low cost, high rate of return</li>\n 	<li>Available ventless - place anywhere and lower expenses at the same time</li>\n</ul>","<p style=""margin-bottom: 0;margin-top: 0px"">• XpressChef 2c Series - JET514U</p>\n<p style=""margin: 0;padding-top: 0"">• Auto. Voltage Sensor: No</p>\n<p style=""margin: 0;padding-top: 0"">• Max. Cooking Time: 20:00</p>\n<p style=""margin: 0;padding-top: 0"">• Catalytic Converter: No</p>\n<p style=""margin: 0;padding-top: 0"">• Power Consumption: 2400 W, 11A</p>\n<p style=""margin: 0;padding-top: 0"">• Power Source: 230-240V, 50Hz, 13A, single phase</p>",,,taxable,,1,,,0,0,,,,,0,,,19295,"BAKERY LINE, BAKERY LINE > Bakery Oven, COOKING LINE > Combi Oven, COOKING LINE, Kitchen Equipment",,,"https://mariotstore.com/wp-content/uploads/2024/10/ACP_HighSpeedOven_XC2.max-725x5001-1.png, https://mariotstore.com/wp-content/uploads/2024/10/XpressChef_2c_frontview_doorOpen_extra-RA14-.max-725x5001-1.png, https://mariotstore.com/wp-content/uploads/2024/10/XpressChef_2c_angleLeft_standby_copy.max-725x5001-1.png",,,,,,,,,0,,"Menu Master",Brand,"Menu Master",1,1,,,,,default,1,1,0,,5,0,0,,,,,,,,,,field_60befc9fc0fb7,JET514U,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595935,100000100101000111111100001011010100111111100001,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13856,simple,,,"PLANETARY MIXER - PL12VAR",1,0,visible,"The PL12VAR is a powerful planetary mixer designed to meet all your mixing needs in the kitchen. With its variable speed control, it allows you to achieve the perfect consistency for a wide range of recipes. Its robust construction and durable components ensure reliable performance, making it an essential tool for both professional chefs and home cooks. Whether you're mixing dough, batters, or other culinary delights, the PL12VAR is the ideal companion to make your cooking experience effortless and enjoyable.","""PLANETARY MIXER - PL12VAR\n. Bowl capacity 12 liters,\n. With variable speed.\n. supplied w/ 4 accesorries (1)spiral hook (2)hook crochet (3)beater (4)whip\n. Has speed changer &amp;handy front panel mounts the start/stop pushbutton &amp; timerto regulate speed variationfurther toi improve product processing.\n. Power: 220V / 1 phase / 50hz / 0.75 kw.\n. Net weight: 75 kg.\n. Dim: 530 x 730 x 910 mm.\nPL12VAR / MACPAN / italy made.""",,,taxable,,1,,,0,0,,,,,0,,,10100,"BAKERY LINE, BAKERY LINE > Bakery Mixers, Kitchen Equipment",,,"https://mariotstore.com/wp-content/uploads/2024/10/PLANETARY-MIXER-–-PL12VAR.png, https://mariotstore.com/wp-content/uploads/2024/10/PLANETARY-MIXER-–-PL30VAR.png",,,,,,,,,0,,"Mac Pan",Brand,"Mac Pan",1,1,,,,,default,1,1,0,,81,0,0,,"PLANETARY MIXER",,,,,,,,field_60befc9fc0fb7,PL12VAR,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596550,011000001100011001111001001100100111001110110011,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
