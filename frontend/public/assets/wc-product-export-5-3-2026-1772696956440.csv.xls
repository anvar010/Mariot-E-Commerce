13552,simple,,,"MINI RANGE POWER MIXER - MINI MP160 VV",1,0,visible,"The Mini MP160 VV Mini Range Power Mixer is a compact yet powerful kitchen appliance designed for efficient blending and mixing. With its small footprint, this mixer is perfect for kitchens with limited space. The Mini MP160 VV features a variable speed control that allows for precise blending, making it versatile for various culinary tasks. Its robust motor ensures reliable performance, making it suitable for tasks such as pureeing, emulsifying, and blending. The Mini MP160 VV is an ideal choice for both professional chefs and home cooks looking for a compact and reliable power mixer for their blending needs.","<p style=""margin-bottom: 0; margin-top: 0px;"">• MINI RANGE POWER MIXER - MINI MP160 VV</p>\n<p style=""margin: 0; padding-top: 0;"">• all stainless steel knives, bell discs, and tubes, delivered with 1 stainless steel wall support</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 240 watts Single phase</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 2.4 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Speed: 2000 to 12500 rpm</p>\n<p style=""margin: 0; padding-top: 0;"">• Tube length: 160 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: length 455 mm, Ø 78 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MINI MP160 VV | Made by <a href=""https://mariotstore.comold/brand/robot-coupe/"">Robot Coupe</a>, France</p>",,,taxable,,1,,,0,0,,,,,1,,,1521,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/minimp160.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,65,0,0,,"MINI RANGE POWER MIXER",,,,,,,,field_60befc9fc0fb7,"MINI MP160 VV",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595581,011001001100110011001100110010001101100111100110,true,