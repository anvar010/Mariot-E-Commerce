14347,simple,,,"DOUGH KNEADING MACHINE - HY.5",1,0,visible,"The HY.5 Dough Kneading Machine is a powerful and efficient appliance designed to streamline the process of kneading dough. With its robust construction and advanced features, it effortlessly mixes and kneads dough to perfection, saving time and effort in bakeries and kitchens. Its compact design ensures space-saving convenience while offering high performance, making it an essential tool for any culinary operation.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• DOUGH KNEADING MACHINE - HY.5</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 7 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 0.37 kW - 0.5 Hp - 220 V - 50 HZ</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless Bowl</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless dough fork</p>\n<p style=""margin: 0; padding-top: 0;"">• Easy to use and clean.</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 600 x 340 x 470 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model No. HY.5 / Mestro Horeca / Make in Turkey</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(150px, 280px);"" aria-expanded=""false""></div>",,,taxable,,0,,,0,0,,,,,1,,1242,1657,"BAKERY LINE, BAKERY LINE > Bakery Mixers, Kitchen Equipment, Special Offer",,,"https://mariotstore.com/wp-content/uploads/2024/10/douygh-mixer-hy2.png, https://mariotstore.com/wp-content/uploads/2024/10/douygh-mixer-hy1.png, https://mariotstore.com/wp-content/uploads/2024/10/douygh-mixer-hy.png",,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,default,1,1,0,,71,0,,,"DOUGH KNEADING MACHINE - HY.5,آلة عجن العجين,الة عجن العجينة",,,,,,,,field_60befc9fc0fb7,HY.5,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595659,010001110001