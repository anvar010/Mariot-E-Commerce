14422,simple,,,"COOLING WELLS - TD-1122EC",1,0,visible,"The TD-1122EC Cooling Wells is a versatile refrigeration system engineered for efficient cooling and preservation of food items in commercial environments. Typically utilized in restaurants, catering services, and banquet facilities, this cooling well ensures that perishable items remain fresh and safe for consumption.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(1073px, 186px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• COOLING WELLS - TD-1122EC</p>\n<p style=""margin: 0; padding-top: 0;"">• Gastronorm Pans: 3 x GN 1/1</p>\n<p style=""margin: 0; padding-top: 0;"">• Net capacity: 110 L</p>\n<p style=""margin: 0; padding-top: 0;"">• Embedded on the table for use.</p>\n<p style=""margin: 0; padding-top: 0;"">• Offset design of the unit to maximize the use of space under the platform.</p>\n<p style=""margin: 0; padding-top: 0;"">• Designed according to GN 1/1 batch size</p>\n<p style=""margin: 0; padding-top: 0;"">• S/S structure and Ventilated cooling system</p>\n<p style=""margin: 0; padding-top: 0;"">• High density insulation body</p>\n<p style=""margin: 0; padding-top: 0;"">• Cooling wells are designed to be build into a counter.</p>\n<p style=""margin: 0; padding-top: 0;"">• Europe brand controller &amp; compressor</p>\n<p style=""margin: 0; padding-top: 0;"">• temperature range: +2~+8</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigeration type: Ventilated</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant Type: R134a</p>\n<p style=""margin: 0; padding-top: 0;"">• Related Power (W): 122</p>\n<p style=""margin: 0; padding-top: 0;"">• Net / gross weight (KGS): 42 / 52</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1122 × 688 × 636 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: TD-1122EC / Inofrigo made/Italian Technology</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(1200px, 93px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,3075,3597,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/COOLING-WELLS-TD-2124EC.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,,,,,default,1,1,0,,81,0,,,"COOLING WELLS,وحدة التبريد,آبار تبريد",,,,,,,https://mariotstore.comold/ar/shop/refrigeration-line/freezer-chillers/cooling...,field_60befc9fc0fb7,TD-1122EC,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110111100100111010000110110000101100110100110100,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14423,simple,,,"Cake Showcase - CCS100R3M GOLDEN",1,0,visible,"The Cake Showcase CCS100R3M GOLDEN is a stunning display unit designed to showcase cakes and pastries in style. Crafted with meticulous attention to detail, this showcase combines functionality with elegance, making it a perfect addition to any bakery, cafe, or pastry shop.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(262px, 13px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• Cake Showcase - CCS100R3M GOLDEN</p>\n<p style=""margin: 0; padding-top: 0;"">• Curved glass with LED light</p>\n<p style=""margin: 0; padding-top: 0;"">• S/S GOLDEN MIRROR base; Auto defrosting;</p>\n<p style=""margin: 0; padding-top: 0;"">• Rear sliding door, with 3 shelves;</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature:+2～+8℃；220V/ 50-60 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Embraco / SECOP compressor; Dixell / Carol controller</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 1000 * 685 * 1300 mm.</p>\n<p style=""margin: 0; padding-top: 0;"">• CCS100R3M GOLDEN/ Inofrigo made/Italian Technology""</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(2px, 332px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,,4905,"BAKERY LINE > Bakery Display, BAKERY LINE, REFRIGERATION LINE > Display Chiller, Kitchen Equipment, REFRIGERATION LINE",,,"https://mariotstore.com/wp-content/uploads/2024/10/CAKE-SHOWCASE-GOLD.png, https://mariotstore.com/wp-content/uploads/2024/10/CAKE-SHOWCASE-black.png, https://mariotstore.com/wp-content/uploads/2024/10/CAKE-SHOWCASE-BRONZE.png",,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,,,,,default,1,1,0,,55,0,,,"Cake Showcase - CCS100R3M GOLDEN,ثلاجة عرض حلويات صغيرة,ثلاجة عرض كيك لون اسود",,,,,,,https://mariotstore.comold/ar/shop/bakery-line/bakery-display/cake-showcase-cc...,field_60befc9fc0fb7,"CCS100R3M GOLDEN",field_6387359a51f50,no,field_6540c7c45e610,no,field_649