14563,simple,,,"Glo-Ray Infrared Strip Heater with Lights (GRAHL‐48)",1,0,visible,"The Glo-Ray Infrared Strip Heater with Lights (GRAHL-48) is a high-performance heating solution designed for commercial food service environments. This 48-inch strip heater utilizes advanced infrared technology to deliver even and consistent heat distribution, ensuring food remains at optimal serving temperatures. Equipped with integrated lights, it provides excellent illumination of the food holding area, enhancing both visibility and presentation. Constructed with durable aluminum, it offers superior heat conduction and longevity. Ideal for pass-through stations, buffet lines, and other food service applications, the GRAHL-48 is both reliable and efficient.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Glo-Ray Infrared Strip Heater with Lights (GRAHL‐48)</p>\n<p style=""margin: 0; padding-top: 0;"">• Tubular metalheater rod with lights.</p>\n<p style=""margin: 0; padding-top: 0;"">• Single heater rod housing.</p>\n<p style=""margin: 0; padding-top: 0;"">• Aluminum construction.</p>\n<p style=""margin: 0; padding-top: 0;"">• Built‐in toggle control.</p>\n<p style=""margin: 0; padding-top: 0;"">• High wattage.</p>\n<p style=""margin: 0; padding-top: 0;"">• Elec. Rating: 240v/50/1‐ph/1340w/5.6A.</p>\n<p style=""margin: 0; padding-top: 0;"">• Dimensions: 1219 x 229 x 64 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Gross weight: 7.7Kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• GRAHL‐48/ HATCO/ USA</p>",,,taxable,,1,,,0,0,,,,,1,,,3607,"COOKING LINE, COOKING LINE > Food Warmers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/Glo-Ray-Infrared-Strip-Heater-with-Lights-GRAHL‐24.png,,,,,,,,,0,,Hatco,Brand,Hatco,1,1,,,,,default,1,1,0,,64,0,,,"Glo-Ray Infrared Strip Heater with Lights (GRAHL‐48)",,,,,,,,field_60befc9fc0fb7,GRAHL‐48,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596053,110101101001010010001110100011110100011110010010,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14564,simple,,,"Glo-Ray Infrared Strip Heater with Lights (GRAHL‐60)",1,0,visible,"The Glo-Ray Infrared Strip Heater with Lights (GRAHL-60) is a premium heating solution designed for commercial kitchens and food service environments. This 60-inch strip heater features advanced infrared technology to ensure even and consistent heat distribution, keeping food at the perfect serving temperature. Integrated lights illuminate the food holding area, enhancing visibility and presentation. Built with durable aluminum construction, the GRAHL-60 offers excellent heat conduction and long-lasting performance. Ideal for use in pass-through stations, buffet lines, and other food service applications, this strip heater provides reliable and efficient heating.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Glo-Ray Infrared Strip Heater with Lights (GRAHL‐60)</p>\n<p style=""margin: 0; padding-top: 0;"">• Tubular metalheater rod with lights.</p>\n<p style=""margin: 0; padding-top: 0;"">• Single heater rod housing.</p>\n<p style=""margin: 0; padding-top: 0;"">• Aluminum construction.</p>\n<p style=""margin: 0; padding-top: 0;"">• Built‐in toggle control.</p>\n<p style=""margin: 0; padding-top: 0;"">• High wattage.</p>\n<p style=""margin: 0; padding-top: 0;"">• Elec. Rating: 240v/50/1‐ph/1700w/7.1A.</p>\n<p style=""margin: 0; padding-top: 0;"">• Dimensions: 1524 x 229 x 64 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Gross weight: 9.5Kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• GRAHL‐60/ HATCO/ USA</p>",,,taxable,,1,,,0,0,,,,,1,,,3607,"COOKING LINE, COOKING LINE > Food Warmers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/Glo-Ray-Infrared-Strip-Heater-with-Lights-GRAHL‐24.png,,,,,,,,,0,,Hatco,Brand,Hatco,1,1,,,,,default,1,1,0,,64,0,,,"Glo-Ray Infrared Strip Heater with Lights (GRAHL‐60)",,,,,,,,field_60befc9fc0fb7,GRAHL‐60,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no