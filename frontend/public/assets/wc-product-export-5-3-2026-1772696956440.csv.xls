12775,simple,,,"DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE MK-FP2R-6c",1,0,visible,"The DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE MK-FP2R-6C is a versatile and efficient appliance designed for commercial use. Featuring two pots for frying ice cream and a convenient salad table, this machine offers flexibility and convenience in busy kitchen environments. The MK-FP2R-6C model is equipped with user-friendly controls and durable construction, ensuring reliable performance and easy operation. Its dual functionality allows for the simultaneous production of fried ice cream and preparation of salads, making it an ideal choice for ice cream parlors, dessert shops, and restaurants looking to diversify their menu offerings.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 60hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 2400W</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 1550 X750 X 880 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-FP2R-6c / MKE-MATIC</p>",,,taxable,,1,,,0,0,,,,,0,,,7570,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/MK-FP2R-6c-Ice-Cream-Machine.png,,,,,,,,,0,,MKE-MATIC,"Type of Product","Double Pot Ice Cream Fried Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,66,376,0,,"DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE",,,,,,,,field_60befc9fc0fb7,MK-FP2R-6c,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595488,110101001101110010101100100100101011100100100101,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12776,simple,,,"DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE 50hz MK-FP2R",1,0,visible,"The DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE 50Hz MK-FP2R is a versatile and efficient appliance designed for commercial use. Operating at 50Hz, this machine ensures quick and consistent preparation of fried ice cream, featuring two pots for simultaneous production. The integrated salad table provides additional workspace and convenience, making it ideal for busy settings like ice cream parlors, cafes, and restaurants. The MK-FP2R model is equipped with user-friendly controls and a durable build, enabling the easy creation of a variety of frozen treats and salads. Its multifunctional design enhances productivity and service efficiency.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 2200W</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 1300 X 650 X 880 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-FP2R / MKE-MATIC</p>",,,taxable,,0,,,0,0,,,,,0,,,6191,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Double Pot Ice Cream Fried Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,66,376,0,,"DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE 50hz",,,,,,,,field_60befc9fc0fb7,MK-FP2R,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595488,110101100101011100000011010110000011100011001111,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12777,simple,,,"ICE CREAM MACHINE WITH STAND 60hz MK-FP2R",1,0,visible,"The ICE CREAM MACHINE WITH STAND 60Hz MK-FP2R is a high-performance appliance designed for commercial use. Operating at 60Hz, this machine ensures efficient and consistent ice cream production. The integrated stand provides a stable and convenient setup, ideal for busy environments such as ice cream shops, cafes, and restaurants. The MK-FP2R model boasts user-friendly controls and durable construction, allowing for easy creation of a variety of delicious frozen treats. Its robust design and reliable performance make it a valuable addition to any professional kitchen.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 60hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 2200W</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 1300 X 650 X 880 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-FP2R / MKE-MATIC</p>",,,taxable,,0,,,0,0,,,,,0,,,6191,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Ice Cream Machine With Stand",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,64,376,0,,"ICE CREAM MACHINE WITH STAND 60hz MK",,,,,,,,field_60befc9fc0fb7,MK-FP2R,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110101100101011100000011010110000011100011001111,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12778,simple,,,"COUNTER TOP ICE CREAM MACHINE MK-6618T",1,0,visible,"The COUNTER TOP ICE CREAM MACHINE MK-6618T is a compact and efficient appliance ideal for both commercial and home use. Designed to fit seamlessly on any countertop, this machine offers easy access to freshly made ice cream. The MK-6618T model features user-friendly controls and a robust motor, ensuring rapid and consistent ice cream production. Its durable construction and sleek design make it a perfect addition to kitchens, cafes, and small businesses, allowing for the effortless creation of a variety of delicious frozen treats.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity: 16 LTR</p>\n<p style=""margin: 0; padding-top: 0;"">• Rated production: 36 l / h</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 2000w</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R410a / R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• Ice cream temperature up to -7 to -8 degrees Celsius</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 733*530*828mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-6618T / MKE-MATIC</p>",,,taxable,,1,,,0,0,,,,,0,,,5803,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE","COUNTER TOP ICE CREAM MACHINE",,"https://mariotstore.com/wp-content/uploads/2024/10/COUNTER-TOP-ICE-CREAM-MACHINE-MK-6618T-1.png, https://mariotstore.com/wp-content/uploads/2024/10/Countertop-Soft-Serve-Ice-Cream-Machine-for-sale.jpg",,,,,,,,,0,,MKE-MATIC,"Type of Product","Counter Top Ice Cream Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,133,index,68,376,0,,"COUNTER TOP ICE CREAM MACHINE",,,,,,,,field_60befc9fc0fb7,MK-6618T,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default