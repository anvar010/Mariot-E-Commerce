12757,simple,,,"COUNTER TOP ICE CREAM MACHINE KLS 220-240v / 60hz - F626T",1,0,visible,"The COUNTER TOP ICE CREAM MACHINE KLS 220-240v / 60hz - F626T is a compact and efficient appliance designed for making delicious ice cream in commercial and home settings. This machine features a powerful 220-240V, 60Hz motor, ensuring rapid and consistent ice cream production. Its sleek countertop design fits seamlessly into any kitchen or small business, providing easy access to freshly made ice cream. Ideal for restaurants, cafes, or home use, the F626T model offers user-friendly controls and robust performance for creating a variety of frozen treats with minimal effort.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity: 16 ltr</p>\n<p style=""margin: 0; padding-top: 0;"">• Rated production: 25 l / h</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 60hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 2000w</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• Ice cream temperature up to -7 to -8 degrees Celsius</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight 110kg</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 733*530*828mm</p>\n<p style=""margin: 0; padding-top: 0;"">• KLS-F626T / MKE-MATIC</p>",,,taxable,,0,,,0,0,,,,,0,,,5803,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Counter Top Ice Cream Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,65,376,0,,"COUNTER TOP ICE CREAM MACHINE KLS 220-240v / 60hz",,,,,,,,field_60befc9fc0fb7,KLS-F626T,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595488,011010001011001100101100101110100111110001100001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,