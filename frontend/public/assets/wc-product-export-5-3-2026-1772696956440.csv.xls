14485,simple,,,"2 Doors Upright Cold Showcase - FG828L2-A1 BRONZE",1,0,visible,"The 2 Doors Upright Cold Showcase FG828L2-A1 BRONZE is a premium refrigerated display unit meticulously crafted to provide an elegant presentation of chilled products while maintaining optimal temperature control. With its stylish bronze finish, this showcase adds a touch of sophistication to any retail or hospitality environment.","<p style=""margin-bottom: 0; margin-top: 0px;"">• 2 Doors Upright Cold Showcase - FG828L2-A1 BRONZE</p>\n<p style=""margin: 0; padding-top: 0;"">• ALUMINIUM FRAME （BRONZE)</p>\n<p style=""margin: 0; padding-top: 0;"">• Temp. range：2-8℃</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant/Large injection：R134a/88g</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor : Embraco/Secop</p>\n<p style=""margin: 0; padding-top: 0;"">• Controller Dixell/carel With rolling shelves+fixied shelves</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor cooling: 190W</p>\n<p style=""margin: 0; padding-top: 0;"">• Ele. Power / Current; 205W / 1.4A</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage/Frequency：220V/ 50-60 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• N.G.weight: 182 / 186 kg.</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 1218 x 648 x 1850 mm.</p>\n<p style=""margin: 0; padding-top: 0;"">• FG828L2-A1 BRONZE/ Inofrigo made/Italian Technology""</p>",,,taxable,,1,,,0,0,,,,,1,,,7189,"BAKERY LINE > Bakery Display, BAKERY LINE, REFRIGERATION LINE > Display Chiller, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/2-Doors-Upright-Cold-Showcase-FG828L2-A1-BRONZE.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,,,,,default,1,1,0,,81,0,,,"2 Doors Upright Cold Showcase",,,,,,,,field_60befc9fc0fb7,"FG828L2-A1 BRONZE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,defau