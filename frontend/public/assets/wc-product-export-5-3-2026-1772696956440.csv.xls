13902,simple,,,"VARIO COOKING CENTER- VCC112T",1,0,visible,"The VARIO COOKING CENTER VCC112T is a versatile and advanced cooking solution that brings efficiency and precision to commercial kitchens. With its innovative technology, this unit combines the functionalities of multiple cooking appliances into one compact system. From frying and grilling to simmering and boiling, the VCC112T offers precise temperature control and cooking techniques to consistently create a wide range of dishes. Its user-friendly interface and automated cooking programs simplify the cooking process, allowing chefs to focus on creativity and quality. This cooking center is an indispensable tool for establishments looking to optimize space, save time, and elevate their culinary output to new heights.","<p style=""margin-bottom: 0; margin-top: 0px;"">• VARIO COOKING CENTER- VCC112T</p>\n<p style=""margin: 0; padding-top: 0;"">• steam / floor-mounted/professional</p>\n<p style=""margin: 0; padding-top: 0;"">• Working capacity 100 litres</p>\n<p style=""margin: 0; padding-top: 0;"">• Connected load (electrical) 28,2 kW</p>\n<p style=""margin: 0; padding-top: 0;"">• Connected load (with Ceran) 30,7 kW</p>\n<p style=""margin: 0; padding-top: 0;"">• Goulash, searing 12 kg/batch</p>\n<p style=""margin: 0; padding-top: 0;"">• Goulash, pressure cooking 45 kg/hour</p>\n<p style=""margin: 0; padding-top: 0;"">• Lentils (dried) 20 kg/batch</p>\n<p style=""margin: 0; padding-top: 0;"">• Blancmange 60 l/batch</p>\n<p style=""margin: 0; padding-top: 0;"">• Fish sticks (frozen) 1800 /hour</p>\n<p style=""margin: 0; padding-top: 0;"">• Smoked loin of pork 45 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Rice (dried) 20 kg/batch</p>\n<p style=""margin: 0; padding-top: 0;"">• Tagliatelle (dried) 36 kg/hour</p>\n<p style=""margin: 0; padding-top: 0;"">• Fries (frozen) 70 kg/hour</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 1160 x 910 x 600 mm.</p>\n<p style=""margin: 0; padding-top: 0;"">• VCC112T/Rational</p>",,,taxable,,0,,,0,0,,,,,0,,,38500,"COOKING LINE > Cooker, COOKING LINE, Kitchen Equipment, COOKING LINE > Cooker > Series 900",,,"https://mariotstore.com/wp-content/uploads/2024/10/Rational-4.png, https://mariotstore.com/wp-content/uploads/2024/10/Rational-2.png, https://mariotstore.com/wp-content/uploads/2024/10/Rational-1.png, https://mariotstore.com/wp-content/uploads/2024/10/Rational.png",,,,,,,,,0,,Rational,Brand,Rational,1,1,Model,VCC112T,1,1,default,1,1,0,,79,0,0,,"VARIO COOKING CENTER",,,,,,,,field_60befc9fc0fb7,VCC112T,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110111110011000011100010001010011000111110001010,,,,,,,,,,"Type of Product","VARIO COOKING CENTER",1,1,Series,"Series 90",1,1,,,,,,,,,,,,,,Electric/Gas,Electric,1,1,,,,,,,,,,,,,,1,,,,
13907,simple,,,"COUNTER CHILLER- GN1100TN",1,0,visible,"The COUNTER CHILLER GN1100TN is a compact and efficient cooling solution designed for commercial and professional settings. With its sleek design and advanced cooling technology, it offers a reliable way to keep food items and beverages at the optimal temperature. This chiller is equipped with features such as adjustable temperature controls, spacious interior, and a user-friendly interface, making it an ideal choice for businesses that require precise cooling for ingredients or products. Its compact size allows it to fit seamlessly into various counter spaces, making it a convenient and space-saving option for any establishment.","<p style=""margin-bottom: 0; margin-top: 0px;"">• COUNTER CHILLER- GN1100TN</p>\n<p style=""margin: 0; padding-top: 0;"">• Volume (Ltrs): 260</p>\n<p style=""margin: 0; padding-top: 0;"">• S/S structure, ventilated cooling system, high density insulation body</p>\n<p style=""margin: 0; padding-top: 0;"">• Easy to clean</p>\n<p style=""margin: 0; padding-top: 0;"">• Self-closing door with magnetic gaskets</p>\n<p style=""margin: 0; padding-top: 0;"">• temperature range: 2°C~8°C</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant: Ventilated</p>\n<p style=""margin: 0; padding-top: 0;"">• Power (W): 350</p>\n<p style=""margin: 0; padding-top: 0;"">• Net weight (KGS): 92</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 925*700*850 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• packing size (mm): 985×740×910 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model No. GN1100TN / CHINA</p>",,,taxable,,1,,,0,0,,,,,1,,2929,3449,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/COUNTER-CHILLER-GN1100TN.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Model,GN1100TN,1,1,default,1,1,0,,81,0,0,,"COUNTER CHILLER",,,,,,,,field_60befc9fc0fb7,GN1100TN,field_6387359a51f50,no,field_6540c