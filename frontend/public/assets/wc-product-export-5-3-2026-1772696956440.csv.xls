12161,simple,,,"908 BAR BLENDER-HBB908-UK",1,0,visible,"Delight your customers with creamy and irresistible milkshakes prepared with the 908 Bar Blender. Enjoy classic and creative flavors.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Blended margaritas and other bar drink quickly and consistently in this dependable blender. Our most affordable hamilton beach commercial blender with the versatility of 2 speeds</p>\n<p style=""margin: 0; padding-top: 0;"">• Powerful 1/2 peak Hp motor</p>\n<p style=""margin: 0; padding-top: 0;"">• Durable stainless steel blades</p>\n<p style=""margin: 0; padding-top: 0;"">• Toggle switch</p>\n<p style=""margin: 0; padding-top: 0;"">• Break resistant polycarbonate jar</p>\n<p style=""margin: 0; padding-top: 0;"">• Durable clutch</p>\n<p style=""margin: 0; padding-top: 0;"">• strong&gt;Container Capacity: 44oz /1.25L Polycarbonate Container</p>\n<p style=""margin: 0; padding-top: 0;"">• strong&gt;Controls: High / Low</p>\n<p style=""margin: 0; padding-top: 0;"">• strong&gt;Voltage: 220V-240 V, 50-60 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• strong&gt;Power: 600 W</p>\n<p style=""margin: 0; padding-top: 0;"">• strong&gt;Motor: 1/2 peak Hp</p>\n<p style=""margin: 0; padding-top: 0;"">• strong&gt;Weight: 3.28 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• strong&gt;Size: 20.3x 16.5 x 38.7 cm</p>\n<p style=""margin: 0; padding-top: 0;"">• HBB908-UK/ Hamilton Beach- USA Brand/Assembled in China</p>",,,taxable,,1,,,0,0,,,,,0,,,1100,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/foodservice-equipment-marketing-fem-hamilton-beach-commercial-908-bar-blender.jpg,,,,,,,,,0,,"Hamilton Beach USA",Brand,"Hamilton Beach- USA",1,1,"Type of Product","Bar Blender",1,1,default,1,1,261,index,7,167,0,,,,,,,,,,field_60befc9fc0fb7,HBB908-UK,field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default