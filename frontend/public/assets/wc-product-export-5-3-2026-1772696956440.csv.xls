12441,simple,,,"LA CIMBALI AUTOMATIC GRINDER",1,0,visible,"The La Cimbali Automatic Grinder is a high-quality coffee grinder designed for use in professional coffee shops, cafes, and espresso bars. Known for its precision and reliability, this grinder is a vital component in the coffee preparation process.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Automatic grinder</p>\n<p style=""margin: 0; padding-top: 0;"">• High level of production per hour</p>\n<p style=""margin: 0; padding-top: 0;"">• Output: 6.5kg/hr</p>\n<p style=""margin: 0; padding-top: 0;"">• Hopper capacity: 1.2kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Diameter grinding burrs:64 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dimensions mm_W=194xD=368xH=510</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 220-240v/50Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• sWeight: 10.2 kg</p>",,,taxable,,1,,,0,0,,,,,0,,,3400,"COFFEE & BAR LINE, COFFEE & BAR LINE > Coffee Grinder",,,https://mariotstore.com/wp-content/uploads/2024/10/40683-thickbox_default.jpg,,,,,,,,,0,,LaCimbali,"Type of Product","Automatic Grinder",1,1,Brand,LaCimbali,1,1,default,1,1,125,index,9,276,0,,,,,,,,,,field_60befc9fc0fb7,"LA CIMBALI",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595498,011001100100111001100110010100110001100101001111,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12448,simple,,,"CIMBALI AUTOMATIC EPRESSO COFFEE MACHINE M23UP DT/2 B",1,0,visible,"The Cimbali Automatic Espresso Coffee Machine M23UP DT/2 B is a professional-grade espresso machine renowned for its reliability, advanced features, and the ability to consistently produce high-quality espresso and other coffee beverages.","<p style=""text-align: left;margin-bottom: 0;margin-top: 0px"">• An automatic espresso coffee machine which boasts excellent reliabilityand an all-new design. The M23UP is an ergonomic and extremely accessible machine (with elongated steam wands) which guarantees consistent  quality in the cup</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Available in three colours (black white, red)</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Steam wands: 2</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Movable hotwater wand: 1</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Boiler capacity (liters): 11</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Weight: 63 kg</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Dimensions (mm) 820 W x 518 D x 552 H</p>\n<p style=""text-align: left;margin: 0;padding-top: 0"">• Power at 380-415V3N~50/60Hz (W):4100-4800</p>",,,taxable,,1,,,0,0,,,,,0,,,11500,"COFFEE & BAR LINE, COFFEE & BAR LINE > Coffee Machines",,,"https://mariotstore.com/wp-content/uploads/2024/10/m23_up_2_gruppi_fronte_bianca-removebg-preview-1.png, https://mariotstore.com/wp-content/uploads/2024/10/m23_up_2_gruppi_bianca_trequarti_2-removebg-preview.png",,,,,,,,,0,,LaCimbali,"Type of Product","Coffee Espresso Machine",1,1,Brand,LaCimbali,1,1,default,1,1,125,index,47,276,0,,"CIMBALI AUTOMATIC EPRESSO COFFEE MACHINE",,,,,,,,field_60befc9fc0fb7,"M23UP DT/2 B",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734597087,110100100101010