13667,simple,,,"Electric Fryer – FD 80 D",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Electric Fryer – FD 80 D</p>\n<p style=""margin: 0;padding-top: 0"">• A double safety thermostat with a positive cutoff in each tank.</p>\n<p style=""margin: 0;padding-top: 0"">• In the event of overheating or insufficient oil, the safety thermostat automatically stops the stainless steel fryer.</p>\n<p style=""margin: 0;padding-top: 0"">• Features: 2 regulation thermostats (0 – 180°C) with precise bulbs, 2 safety thermostats, 2 micro-switches, 2 baskets, 2 stainless steel lids, and pilot lights.</p>\n<p style=""margin: 0;padding-top: 0"">• Volume: 2 x 8 L</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 2 x 3.4 kW</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 540 x 425 x 320 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 12 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Volts: 2 x 230 V</p>\n<p style=""margin: 0;padding-top: 0"">• Basket dimensions: 2 x (220 x 260 x 100 mm)</p>\n<p style=""margin: 0;padding-top: 0"">• FD 80 D / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,3326,"COOKING LINE, COOKING LINE > Fryers",,,https://mariotstore.com/wp-content/uploads/2024/10/FD-80-D.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,76,0,0,,"Electric Fryer – FD 80 D,المقلاة الكهربائية,قلاية دبل",,,,,,,,field_60befc9fc0fb7,"FD 80 D",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595588,110101000011010010101100001001110100111110110010,,,,,,,,,,"Type of Product","Electric Fryer, Fryer",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13669,simple,,,"Electric Fryer – FD 50",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(44px, 44px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• Electric Fryer – FD 50</p>\n<p style=""margin: 0; padding-top: 0;"">• In the event of overheating or insufficient oil, the safety thermostat automatically stops the stainless steel fryer.</p>\n<p style=""margin: 0; padding-top: 0;"">• A double safety thermostat with a positive cutoff in each tank.</p>\n<p style=""margin: 0; padding-top: 0;"">• This electric deep fat fryer is equipped with a precise bulb thermostat for the regulation of temperature (0 – 180°C).</p>\n<p style=""margin: 0; padding-top: 0;"">• Features: regulation thermostat (0 – 180°C) with precise bulb, safety thermostat, micro-switch, basket, stainless steel lid, and pilot lights.</p>\n<p style=""margin: 0; padding-top: 0;"">• Volume: 5 L</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 3.2 kW</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 5 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Volts: 230 V</p>\n<p style=""margin: 0; padding-top: 0;"">• Basket dimensions: 140 x 260 x 100 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Outside dimensions: 215 x 425 x 320 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• FD 50 / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(410px, 154px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,1336,"COOKING LINE, COOKING LINE > Fryers",,,https://mariotstore.com/wp-content/uploads/2024/10/FD-50.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,72,0,0,,"Electric Fryer – FD 50,المقلاة الكهربائية,قلاية بطاطس",,,,,,,,field_60befc9fc0fb7,"FD 50",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,d