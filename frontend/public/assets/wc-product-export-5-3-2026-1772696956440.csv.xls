11334,simple,,,"ELECTRIC PIZZA OVEN-BASIC 44",1,0,visible,"The ELECTRIC PIZZA OVEN-BASIC 44 is a compact, efficient oven designed for making delicious pizzas with ease. Featuring a user-friendly interface and rapid heating capabilities, it ensures even cooking for perfectly crispy crusts and melty toppings every time. Ideal for both home and small commercial use.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Baking chamber 2</p>\n<p style=""margin: 0; padding-top: 0;"">• Double deck pizza oven Professional electric ovens provided w/ cooking chamber projected &amp; optimized for pizzas w/ diameter of 30 cm. Control throughout independent mechanical thermostats for both oven top &amp; bedplate, high-density evaporated dried mineral wool insulation, cooking surface in refractory stone, pyrometer &amp; internal halogen illumination</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature: 50/500 c</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 9.6 KW/ 230V/ Single phase</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight 91 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Internal Dim: 700 x 700mm ( 27.6”x 27.6”) deck</p>\n<p style=""margin: 0; padding-top: 0;"">• External dim: 925 x 835 x 545 cm / w,d,h</p>\n<p style=""margin: 0; padding-top: 0;"">• BASIC 44 / GGF s.rl./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,5315.2,"BAKERY LINE, BAKERY LINE > Bakery Oven",,,"https://mariotstore.com/wp-content/uploads/2024/10/ELECTRIC-PIZZA-OVEN-BASIC-44.jpg, https://mariotstore.com/wp-content/uploads/2024/10/ELECTRIC-PIZZA-OVEN-BASIC-44.png",,,,,,,,,0,,GGF,Brand,GGF,1,1,Temp,"50/500 c",1,1,default,1,1,0,index,59,0,0,,"ELECTRIC PIZZA OVEN-BASIC 44,فرن البيتزا الكهربائية,فرن جي جي اف,فرن بيتزا",,,,,,,,field_60befc9fc0fb7,"BASIC 44",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595667,110100011110110010111000010001110110010010110100,false,,,,,,,,,"Type of Product",Oven,1,1,,,,,,,,,,,,,,,,
11337,simple,,,"ELECTRIC PIZZA OVEN E-START 4",1,0,visible,"The ELECTRIC PIZZA OVEN-E-START 4 is a versatile and reliable oven designed for quick and consistent pizza baking. With its compact size and easy-to-use controls, it offers even heat distribution for perfectly baked pizzas. Ideal for beginners and small businesses, it's the perfect starter oven for those looking to make great pizzas with minimal effort.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Baking chamber 1</p>\n<p style=""margin: 0; padding-top: 0;"">• Pizza Cap: 4 / Pizza Dim: 30cm</p>\n<p style=""margin: 0; padding-top: 0;"">• Professional electric ovens provided w/ cooking chamber projected &amp; optimized for pizzas w/ diameter of 30 cm. Fronts available in S/S or rustic version. Control throughout independent mechanical thermostats for both oven top and bedplate, high-density evaporated dried mineral wool insulation, cooking surface in refractory stone, pyrometer &amp; internal halogen illumination</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature: 50/500 c</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 4.2 KW/ 230V/ Single phase</p>\n<p style=""margin: 0; padding-top: 0;"">• Net weight: 78 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Internal Dim: 610 x 610 x 140</p>\n<p style=""margin: 0; padding-top: 0;"">• External dim: 900 x 735 x 420 cm / w,d,h</p>\n<p style=""margin: 0; padding-top: 0;"">• E-START 4 / GGF s.r.l./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,3862.32,"BAKERY LINE, BAKERY LINE > Bakery Oven",,,"https://mariotstore.com/wp-content/uploads/2024/10/ELECTRIC-PIZZA-OVEN-E-START-4.jpg, https://mariotstore.com/wp-content/uploads/2024/10/OVEN-E-START-4.jpg",,,,,,,,,0,,GGF,Brand,GGF,1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,26,0,0,,"ELECTRIC PIZZA OVEN-E-START 4,فرن البيتزا الكهربائي,فرن بيتزا جي جي اف,جي جي اف",,,,,,,,field_60befc9fc0fb7,"E-START 4",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,fie