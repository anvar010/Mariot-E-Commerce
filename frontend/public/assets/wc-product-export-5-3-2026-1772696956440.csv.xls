12462,simple,,,"INSECT KILLER LIGHT TRAP-TMBKG30",1,0,visible,"The LIGHT TRAP-TMBKG30 Insect Killer offers effective pest control with a sleek, modern design. Utilizing advanced UV technology, it attracts and eliminates insects efficiently, making it an ideal solution for maintaining a pest-free environment in both residential and commercial spaces.","<p style=""margin-bottom: 0;margin-top: 0px"">• INSECT KILLER LIGHT TRAP-TMBKG30</p>\n<p style=""margin: 0;padding-top: 0"">• In AISI 304L stainless steel</p>\n<p style=""margin: 0;padding-top: 0"">• All S/S fully removable collection tray</p>\n<p style=""margin: 0;padding-top: 0"">• -3 Possible set ups - Hanging - Wall-mounted, Indoor use</p>\n<p style=""margin: 0;padding-top: 0"">• MONO 220-240V/ 50HZ/ 1PH</p>\n<p style=""margin: 0;padding-top: 0"">• Net weight: 6.5 kg/ 80 M2</p>\n<p style=""margin: 0;padding-top: 0"">• Dim: 510 x 140 x 260 mm</p>\n<p style=""margin: 0;padding-top: 0"">• SET OF 6 GLUE SHEETS FOR TMBK30</p>\n<p style=""margin: 0;padding-top: 0"">• Model : TMBKG30</p>",,,taxable,,1,,,0,0,,,,,1,,,695,"DRY STORE, DRY STORE > Insect Killer, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/TMBK30-002.jpg,,,,,,,,,0,,Sofinor,Brand,sofinor,1,1,"Type of Product","Insect Killer",1,1,default,1,1,278,index,78,152,0,,"INSECT KILLER LIGHT TRAP-TMBKG30",,,,,,,,field_60befc9fc0fb7,TMBKG30,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595776,111101110001110000100110100010010100110100110110,,,9075466702521824,yes,yes,,product,no,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
