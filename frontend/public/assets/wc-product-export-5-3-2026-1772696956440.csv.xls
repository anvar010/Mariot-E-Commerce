12144,simple,,,"COMBI RANGE – POWER MIXER - MP350 ULTRA",1,0,visible,"The RANGE POWER MIXER-MP350 ULTRA is a robust and efficient hand mixer, perfect for professional kitchens and catering services. Designed for heavy-duty use, it features a powerful motor and ergonomic handle for comfortable, extended use. This versatile mixer is ideal for blending, mixing, and pureeing a variety of ingredients directly in the pot or container. Its durable construction and easy-to-clean design ensure long-lasting performance and convenience, making it an essential tool for chefs who require reliable and powerful mixing capabilities.","<p style=""margin-bottom: 0; margin-top: 0px;"">• RANGE POWER MIXER-MP350 ULTRA</p>\n<p style=""margin: 0; padding-top: 0;"">• Motor Base: 440W, Speed: 9500 rpm</p>\n<p style=""margin: 0; padding-top: 0;"">• under load Single Phase</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage:230V/50/1 UK plug Net Weight</p>\n<p style=""margin: 0; padding-top: 0;"">• 6.2 kg Tube length:350 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: Total length 725 mm Ø 125 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,,2855,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2021/01/xStick-Blender-Robot-Coupe-MP350-Ultra-jpg.webp.pagespeed.ic_.QeOiR0Gj_L.webp,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,"Type of Product","Power Mixer",1,1,default,1,1,0,index,42,0,0,,"COMBI RANGE – POWER MIXER",,,,,,,,field_60befc9fc0fb7,"MP350 ULTRA",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595262,001100110011101100110110011100110010011000011001,true,backend,9932110073482029,yes,yes,,product,no,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12147,simple,,,"MINI RANGE POWER MIXER-MINI MP190 VV",1,0,visible,"The Mini MP190 VV Mini Range Power Mixer is a compact and versatile kitchen appliance designed for efficient blending and mixing. Despite its small size, this mixer packs a powerful punch, making it perfect for a variety of culinary tasks. The Mini MP190 VV features variable speed control, allowing for precise blending and customization based on your recipes. With a robust motor, it can handle tasks such as pureeing, emulsifying, and mixing with ease. Its compact design makes it suitable for kitchens with limited space, offering a reliable solution for both professional chefs and home cooks seeking efficiency in their blending needs.","<p style=""margin-bottom: 0; margin-top: 0px;"">• MINI RANGE POWER MIXER</p>\n<p style=""margin: 0; padding-top: 0;"">• all stainless steel knife, bell disc and\ntube, delivered with 1 stainless steel wall\nsupport, and foot with removable bell</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 270 watts Single phase Weight</p>\n<p style=""margin: 0; padding-top: 0;"">• 2.5 kg Speed: 2000 to 12500 rpm</p>\n<p style=""margin: 0; padding-top: 0;"">• Tube length 190 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: length 485 mm, Ø 78 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,,1870,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/MINI-RANGE-POWER-MIXER-MINI-MP190-VV.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,"Type of Product","Power Mixer",1,1,default,1,1,0,index,5,0,0,,,,,,,,,,field_60befc9fc0fb7,"MP190 VV",field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595262,110011011001111001101001100001100100110011001100,true,backend,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,