13632,simple,,,"Electric Boiling Top ELR-2",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Electric Boiling Top</p>\n<p style=""margin: 0;padding-top: 0"">• The ELR 2 professional electric stove is a compact all-stainless-steel model equipped with a 23 cm diameter cooking plate</p>\n<p style=""margin: 0;padding-top: 0"">• this electric stove is used to cook, heat or maintain all types of culinary preparations at temperature</p>\n<p style=""margin: 0;padding-top: 0"">• The ELR 2 professional electric stove fits into all restaurants, food trucks and kiosks</p>\n<p style=""margin: 0;padding-top: 0"">• Powerful: 2kW</p>\n<p style=""margin: 0;padding-top: 0"">• Volts: 230V</p>\n<p style=""margin: 0;padding-top: 0"">• External dimensions: 350 x 400 x 155mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 7kg</p>\n<p style=""margin: 0;padding-top: 0"">• ELR 2/Roller Grill/Made France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,1038,"COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 600",,,https://mariotstore.com/wp-content/uploads/2024/10/Professional-electric-boiling-top-1-burner-2-kW-1.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,63,0,0,,"Electric Boiling Top ELR-2,طباخ كهربائي سيراميك",,,,,,,,field_60befc9fc0fb7,"ELR 2",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595588,111000001101110010111100100010011010010110011001,,,,,,,,,,"Type of Product",Cooker,1,1,Series,"Series 60 Table Top",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13634,simple,,,"Electric Boiling Top ELR-3",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(680px, 177px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• Electric boiling Top</p>\n<p style=""margin: 0; padding-top: 0;"">• The professional electric boiling top ELR 3 is a stainless-steel compact model equipped with two cooking plates of 18 cm diameter each</p>\n<p style=""margin: 0; padding-top: 0;"">• this electric double stove is used to cook, to heat up or to keep warm at right temperature any type of cooking.</p>\n<p style=""margin: 0; padding-top: 0;"">• The professional electric stove ELR 3 fits in all restaurants, food trucks and kiosks</p>\n<p style=""margin: 0; padding-top: 0;"">• Features: 2 commutators with 7 positions, ventilation openings, control lights</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 3 kW (2 x 1,5 kW)</p>\n<p style=""margin: 0; padding-top: 0;"">• volts: 230 V</p>\n<p style=""margin: 0; padding-top: 0;"">• Outside dimensions: 650 x 400 x 155 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 10 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• ELR-3/Roller Grill/Made France</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(332px, 244px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(477px, 3px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,2025,"COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 600",,,https://mariotstore.com/wp-content/uploads/2024/10/Professional-electric-boiling-top-two-burners.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,63,0,0,,"Electric Boiling Top ELR-3,طباخ كهربائية",,,,,,,,field_60befc9fc0fb7,ELR-3,field_6387359a51f50,no,field_6540c7c45e610,no,f