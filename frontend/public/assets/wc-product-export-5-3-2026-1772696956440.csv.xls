11952,simple,,,"UNDERCOUNTER TYPE DISHWASHER  EMP.500",1,0,visible,"The EMP.500 is a high-quality undercounter type dishwasher designed to meet the demands of commercial kitchens. With its compact size and efficient design, it fits seamlessly beneath countertops while delivering powerful performance. This dishwasher offers versatile washing capabilities, effectively cleaning dishes, glassware, and utensils with ease. Ideal for restaurants, cafes, and other food service establishments, the EMP.500 combines reliability and efficiency to streamline dishwashing operations.","<p style=""margin-bottom: 0;margin-top: 0px"">• UNDERCOUNTER TYPE DISHWASHER EMP.500</p>\n<p style=""margin: 0;padding-top: 0"">• cap: 500 plate / hour</p>\n<p style=""margin: 0;padding-top: 0"">• Programmer options: 90O,-120O,-180O C seconds</p>\n<p style=""margin: 0;padding-top: 0"">• Motor Power:0.55 kw 2800 rpm</p>\n<p style=""margin: 0;padding-top: 0"">• Total Power:6 kw 220</p>\n<p style=""margin: 0;padding-top: 0"">• Tank heating power:2.5 kw</p>\n<p style=""margin: 0;padding-top: 0"">• Stainless steel resistance</p>\n<p style=""margin: 0;padding-top: 0"">• Maximum plate diameter:320 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Water consumption: 2.5 lt/time</p>\n<p style=""margin: 0;padding-top: 0"">• Magnetic security switch</p>\n<p style=""margin: 0;padding-top: 0"">• Programmer continues the process by closing of the door</p>\n<p style=""margin: 0;padding-top: 0"">• Full automatic washing operation at 55ºC, rinsing operation with hot water at 80-85ºC.\nN.W: 67 kg Net m3: 0.35</p>\n<p style=""margin: 0;padding-top: 0"">• Dim: 650 x 590 x 830 mm</p>\n<p style=""margin: 0;padding-top: 0"">• EMP.500 / EMPERO turkey made</p>",,,taxable,,1,,,0,0,,,,,0,,,4000,"LAUNDRY & DISH WASHER > Dish Washer Machines, LAUNDRY & DISH WASHER, sale 11.11",,,https://mariotstore.com/wp-content/uploads/2024/10/EMP.500.jpg,,,,,,,,,0,,Empero,Brand,Empero,1,1,,,,,default,1,1,214,index,52,0,0,,"UNDERCOUNTER TYPE DISHWASHER EMP.500",,"shop online dishwasher machine at mariot group delivery all uae",,,,,,field_60befc9fc0fb7,EMP.500,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595241,111101010011111000100011100100101010110001001010,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
11954,simple,,,"HOOD TYPE DISHWASHER  DIGITAL CONTROL 380V EMP.1000-SD",1,0,visible,"The ""HOOD TYPE DISHWASHER EMP.1000"" is a commercial-grade dishwasher designed for use in busy foodservice establishments such as restaurants, hotels, cafeterias, and industrial kitchens.","<p style=""margin-bottom: 0; margin-top: 0px;"">Hood Type Dishwasher Digital Control 380V\n. cap: 1000 plate / hour.\n- 4 different programs: 60/90/120/180 seconds.\n- Economical water, detergent and energy consumption.\n- Basket dimensions 500x500 mm\n- Stainless steel resistances.\n- Stainless steel body.\n- Washing water temperature 55-60°C\n- Rinsing water temperature 80-85°C\n- Engine power: 0.55 kW / 50-60 Hz 2800 RPM\n- Washing tank heater power: 2.5 kW\n- Rinsing tank heater power: 6 kW\n- Maximum power during operation: 6.55 kW\n- N.W: 112 kg Net m3: 0.79\n- Dim: 696 x 765 x 1485 mm.\nEMP.1000-SD / Empero - Capinox</p>",,,taxable,,1,,,0,0,,,,,0,,,6115,"LAUNDRY & DISH WASHER > Dish Washer Machines, Fabrication, LAUNDRY & DISH WASHER",,,https://mariotstore.com/wp-content/uploads/2020/11/n-3560-9335-28-10-2016.jpg,,,,,,,,,0,,Empero,"Type of Product",Dishwasher,1,1,Brand,Empero,1,1,default,1,1,214,index,62,0,0,,"HOOD TYPE DISHWASHER",,,,,,,,field_60befc9fc0fb7,EMP.1000-SD,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595241,110110011010010010010110010100100100110101101101,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
