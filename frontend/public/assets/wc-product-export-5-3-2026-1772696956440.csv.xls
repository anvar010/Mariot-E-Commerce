13879,simple,,,"SALAD BAR DISPLAY - VRX900",1,0,visible,"Introducing the VRX 900 Salad Bar Display, featuring cutting-edge digital temperature control with a user-friendly display. This advanced system empowers you to precisely monitor and adjust the temperature of your salads and toppings, ensuring they remain fresh and at their optimal quality.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Salad Bar Display - VRX 900</p>\n<p style=""margin: 0; padding-top: 0;"">• Standard glass: plain or curve</p>\n<p style=""margin: 0; padding-top: 0;"">• Cap: 3 x GN containers 1/3 size</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature: +2℃～+80 C</p>\n<p style=""margin: 0; padding-top: 0;"">• gas refrigeration: r 134 a</p>\n<p style=""margin: 0; padding-top: 0;"">• power: 220 v / 50 hz / 280 w</p>\n<p style=""margin: 0; padding-top: 0;"">• net. weight: 25 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Digital temperature control with display</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 900 x 395 x 435 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Digital : DIXELL / ITALY MADE</p>\n<p style=""margin: 0; padding-top: 0;"">• compressor : ASPERA / EMBRACO / ITALY</p>\n<p style=""margin: 0; padding-top: 0;"">• VRX 900 / Mariot made / UAE</p>\n<p style=""margin: 0; padding-top: 0;"">• ISO9001, CE&amp;ROHS approved</p>",,,taxable,,1,,,0,0,,,,,0,,,1435,"REFRIGERATION LINE > Display Chiller, Kitchen Equipment, REFRIGERATION LINE",,,"https://mariotstore.com/wp-content/uploads/2024/10/1.png, https://mariotstore.com/wp-content/uploads/2024/10/3.png, https://mariotstore.com/wp-content/uploads/2024/10/2-1-4.png",,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,"Type of Product","Salad Bar Display",1,1,default,1,1,0,,7,0,0,,,,,,,,,,field_60befc9fc0fb7,"VRX 900",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15749,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595985,101