13356,simple,,,"Ice Cream Powder Green Apple Flavour",1,0,visible,,"<p style=""margin-bottom: 0; margin-top: 0px;"">• Ice Cream Powder Green Apple Flavour</p>\n<p style=""margin: 0; padding-top: 0;"">• Quantity: 1kg/ Price for 1kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Ingredients</p>\n<p style=""margin: 0; padding-top: 0;"">• Fat-filled milk powder, Sugar, Stabilizer (Guar gum E 412, Dextrose,</p>\n<p style=""margin: 0; padding-top: 0;"">• Calcium Sulphate E516, Disodium Phosphate E339,</p>\n<p style=""margin: 0; padding-top: 0;"">• Locust bean gum E410,</p>\n<p style=""margin: 0; padding-top: 0;"">• Sodium alginate E401),</p>\n<p style=""margin: 0; padding-top: 0;"">• Tricalcium Phosphate, Green Apple Flavor,</p>\n<p style=""margin: 0; padding-top: 0;"">• allowed colours E133, E102,</p>\n<p style=""margin: 0; padding-top: 0;"">• Creamer Powder.</p>\n<p style=""margin: 0; padding-top: 0;"">• May have an adverse impact on the activity and attention of children.</p>\n<p style=""margin: 0; padding-top: 0;"">Measures:</p>\n<p style=""margin: 0; padding-top: 0;"">• Mix 1 kg of the powder with 3 liters of water and mix it well.</p>\n<p style=""margin: 0; padding-top: 0;"">• Put the mixture in the ice cream machine and follow the machine instructions.</p>\n<p style=""margin: 0; padding-top: 0;"">• Store in a cool place below +4 C. Dry powder storage:</p>\n<p style=""margin: 0; padding-top: 0;"">• Store in a dry place below +25 C.</p>\n<p style=""margin: 0; padding-top: 0;"">• Green Apple Flavour/ <a href=""https://mariotstore.comold/brand/3mf/"">3MF</a> / Mariot.</p>",,,taxable,,1,,,0,0,,,,,0,,,55,"REFRIGERATION LINE > Ice Cream Display, SNACK MAKER > Ice Cream powder, REFRIGERATION LINE, SNACK MAKER",,,"https://mariotstore.com/wp-content/uploads/2024/10/greenapple-icecream-scaled-1.jpg, https://mariotstore.com/wp-content/uploads/2024/10/Ice-Cream-Green-Apple-1.png",,,,,,,,,0,,3MF,Brand,3MF,1,1,,,,,default,1,1,282,index,76,280,0,,"Ice Cream Powder 