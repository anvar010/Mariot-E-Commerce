14574,simple,,,"Ice cream machine WITH STAND - MK-6618C",1,0,visible,"The Ice Cream Machine WITH STAND - MK-6618C is a professional-grade appliance designed for commercial use. Equipped with a sturdy stand, this machine offers stability and convenience in busy kitchen environments such as ice cream parlors, cafes, and restaurants. The MK-6618C model features user-friendly controls and durable construction, ensuring reliable performance and easy operation. Its advanced freezing technology allows for the rapid production of high-quality ice cream, making it an essential addition to any professional kitchen looking to offer a wide range of frozen desserts.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Ice cream machine WITH STAND - MK-6618C</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 18 L/H</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 1800w / UK PLUG</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R404A / 550 g / R134A / 120 g</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: N/G: 95 / 100 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Ice cream temperature up to -7 to -8 degrees Celsius</p>\n<p style=""margin: 0; padding-top: 0;"">• Double puffed air pump; make the ice cream well formed and taste delicate</p>\n<p style=""margin: 0; padding-top: 0;"">• Features a night mode program.</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 480*560*720 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-6618C / MKE-MATIC</p>",,,taxable,,1,,,0,0,,,,,1,,,6176,"REFRIGERATION LINE > Ice Cream Machines, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/Ice-cream-machine-WITH-STAND-MK-6618C.png,,,,,,,,,0,,MKE-MATIC,Brand,"MKE MATIC",1,1,,,,,default,1,1,0,,73,0,,,"Ice cream machine WITH STAND - MK-6618C",,,,,,,,field_60befc9fc0fb7,MK-6618C,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011000001110010001111001001110001111001111001100,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14576,simple,,,"ICE GRANULES MAKER MACHINE - GB1555A",1,0,visible,"The ICE GRANULES MAKER MACHINE - GB1555A is a high-performance appliance designed for commercial use in settings such as restaurants, bars, and cafes. This machine efficiently produces ice granules, ideal for a variety of beverages and food preservation needs. The GB1555A model features user-friendly controls and robust construction, ensuring reliable operation and durability. Its efficient ice-making capabilities provide a consistent supply of high-quality ice granules, enhancing service efficiency and customer satisfaction. This machine is an excellent addition to any establishment requiring a steady production of ice granules for their operations.",". Production: 155 kg\n. Storage cap: 55 kg\n. Cooling system\n(A=Air – W=Water): A / W\n. Refrigerant : R452A\n. Standard Voltage: 220-240/ 50hz\n. Power: 650w\n. Fuse: 10 A /1 phase\n. Water Consumption: A 1 - W 6.4\n. Weight [net/gross]: 94 kg / 105 kg.\n. Finishing: AISI 304 stainless steel\n. Dim: 780 x 735 x 1185 mm\nGB1555A / BREMA / ITALIA",,,taxable,,1,,,0,0,,,,,1,,,12959.1,"REFRIGERATION LINE > ICE MAKER & FLAKES, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/brema.png,,,,,,,,,0,,Brema,Brand,Brema,1,1,,,,,default,1,1,0,,53,0,,,"CE GRANULES MAKER MACHINE - GB1555A",,,,,,,,field_60befc9fc0fb7,GB1555A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011110011011011000111001001110000111000010011100,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14578,simple,,,"ICE CREAM MACHINE - YKF-9238",1,0,visible,"The ICE CREAM MACHINE YKF-9238 is a high-performance appliance designed for both commercial and home use, featuring advanced refrigeration technology for rapid and efficient ice cream production. It boasts a user-friendly digital interface, multiple flavor options, and customizable settings to cater to various preferences. The YKF-9238 ensures consistent texture and quality, making it an ideal choice for ice cream enthusiasts and professionals alike.","<p style=""margin-bottom: 0; margin-top: 0px;"">• ICE CREAM MACHINE - YKF-9238</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 20-28L/H</p>\n<p style=""margin: 0; padding-top: 0;"">• Mix hopper: 6L x 2</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant: R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• Air pump system,</p>\n<p style=""margin: 0; padding-top: 0;"">• Embraco compressor with gas R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Power 220V~ 50Hz 2200W</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 101 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 540 x 680 x 1360 mm.</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: YKF-9238 / MKE-MATIC / CHINA</p>",,,taxable,,1,,,0,0,,,,,1,,,5794,"REFRIGERATION LINE > Ice Cream Machines, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/ICE-CREAM-MACHINE-YKF-9238.png,,,,,,,,,0,,MKE-MATIC,Brand,"MKE MATIC",1,1,,,,,default,1,1,0,,64,0,,,"ICE CREAM MACHINE - YKF-9238",,,,,,,,field_60befc9fc0fb7,YKF-9238,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010011001010011011001100100100110011011010011,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14580,simple,,,"ICE CREAM MACHINE - YKF-8230",1,0,visible,"The ICE CREAM MACHINE YKF-8230 is a versatile and efficient appliance designed for creating smooth and creamy ice cream at home or in small commercial settings. It features an intuitive control panel, adjustable settings, and quick freezing technology, ensuring rapid production of high-quality ice cream. With its durable construction and easy-to-clean components, the YKF-8230 is perfect for ice cream lovers seeking convenience and reliability.","<p style=""margin-bottom: 0; margin-top: 0px;"">• ICE CREAM MACHINE - YKF-8230</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 28-30L/H</p>\n<p style=""margin: 0; padding-top: 0;"">• Mix hopper: 6L x 2</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant: R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• Air pump system</p>\n<p style=""margin: 0; padding-top: 0;"">• Embraco compressor with gas R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 220V~ 50Hz 2300W</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 110 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 540 x 700 x 1400 mm.</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: YKF-8230 / MKE-MATIC / CHINA</p>",,,taxable,,0,,,0,0,,,,,1,,,5794,"REFRIGERATION LINE > Ice Cream Machines, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/ICE-CREAM-MACHINE-YKF-8230.png,,,,,,,,,0,,MKE-MATIC,Brand,"MKE MATIC",1,1,,,,,default,1,1,0,,64,0,,,"ICE CREAM MACHINE - YKF-8230",,,,,,,,field_60befc9fc0fb7,YKF-8230,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010011001101100010110011100100110011001001101,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14582,simple,,,"ICE CREAM MACHINE - YKF-8230T",1,0,visible,"The ICE CREAM MACHINE YKF-8230T is a premium appliance tailored for making high-quality ice cream with ease. It features an advanced digital control panel for precise temperature and consistency adjustments, ensuring perfect results every time. The YKF-8230T is equipped with a powerful compressor for rapid freezing and a durable stainless steel exterior for long-lasting use. Ideal for both home and small commercial environments, this machine combines efficiency, reliability, and user-friendly operation.","<p style=""margin-bottom: 0; margin-top: 0px;"">• ICE CREAM MACHINE - YKF-8230T</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 22-28L/H</p>\n<p style=""margin: 0; padding-top: 0;"">• Mix hopper: 6L x 2</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant: R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• Air pump system</p>\n<p style=""margin: 0; padding-top: 0;"">• One embraco compressor with R404A refrigerant</p>\n<p style=""margin: 0; padding-top: 0;"">• Color: Orange/ silver/ gold</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 220V~ 50Hz 2200W</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 92 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 540 x 825 x 830 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: YKF-8230T / MKE-MATIC / CHINA</p>",,,taxable,,1,,,0,0,,,,,1,,,5351,"REFRIGERATION LINE > Ice Cream Machines, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/ICE-CREAM-MACHINE-YKF-8230T.png,,,,,,,,,0,,MKE-MATIC,Brand,"MKE MATIC",1,1,,,,,default,1,1,0,,71,0,,,"ICE CREAM MACHINE - YKF-8230T",,,,,,,,field_60befc9fc0fb7,YKF-8230T,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110111011000011010001001110100001011001101001011,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14584,simple,,,"ICE CREAM MACHINE - YKF-8240",1,0,visible,"The ICE CREAM MACHINE YKF-8240 is a state-of-the-art appliance designed to produce delicious, creamy ice cream efficiently. It features an advanced digital control system for easy operation, adjustable settings for various ice cream textures, and rapid freezing technology to ensure quick preparation times. With its robust construction and easy maintenance, the YKF-8240 is perfect for both home use and small commercial setups, offering consistent performance and high-quality results.","<p style=""margin-bottom: 0; margin-top: 0px;"">• ICE CREAM MACHINE - YKF-8240</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 22-28L/H</p>\n<p style=""margin: 0; padding-top: 0;"">• Mix hopper: 6L x 2</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant: R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• Air pump system</p>\n<p style=""margin: 0; padding-top: 0;"">• 2 pcs compressor, One embraco compressor and one precooling compressor with R404A refrigerant</p>\n<p style=""margin: 0; padding-top: 0;"">• Color: Orange/ silver/ gold</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 220V~ 50Hz 2700W</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 130 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 540 x 800 x 1530 mm.</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: YKF-8240 / MKE-MATIC / CHINA</p>",,,taxable,,0,,,0,0,,,,,1,,,7496,"REFRIGERATION LINE > Ice Cream Machines, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/ICE-CREAM-MACHINE-YKF-8240.png,,,,,,,,,0,,MKE-MATIC,Brand,"MKE MATIC",1,1,,,,,default,1,1,0,,57,0,,,"ICE CREAM MACHINE - YKF-8240",,,,,,,,field_60befc9fc0fb7,YKF-8240,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011010011010010000010001111110011111000111100001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,