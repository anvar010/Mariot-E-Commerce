14122,simple,,,"Charcoal Oven - HJX-PRO-M120",1,0,visible,"Charcoal Oven - HJX-PRO-M120 Josper is an elegant combination of a grill and an oven in a single machine. It works 100% with\ncharcoal. A unique closed barbecue design. Different levels of grilling. Flexible and robust, easy\nto use, with a front opening door system. Vent system for temperature control.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Charcoal Oven - HJX-PRO-M120</p>\n<p style=""margin: 0; padding-top: 0;"">• Recommended for ± 120 dinners</p>\n<p style=""margin: 0; padding-top: 0;"">• Fire up time: 35 min average</p>\n<p style=""margin: 0; padding-top: 0;"">• Charcoal daily consumtion: 26.5 to 35 lb</p>\n<p style=""margin: 0; padding-top: 0;"">• Performance: 9h</p>\n<p style=""margin: 0; padding-top: 0;"">• Production per hour: 192 lb average</p>\n<p style=""margin: 0; padding-top: 0;"">• Broiling temperature: 482 a 662 ºF</p>\n<p style=""margin: 0; padding-top: 0;"">• Grill rack capacity in Gn trays: 2xGN1/1</p>\n<p style=""margin: 0; padding-top: 0;"">• Nominal heat output: 9.92 hp</p>\n<p style=""margin: 0; padding-top: 0;"">• Flue gas mass flow: 0.54 oz/s</p>\n<p style=""margin: 0; padding-top: 0;"">• Net weight: 551 lb</p>",,,taxable,,1,,,0,0,,,,,0,,,65000,"COOKING LINE, COOKING LINE > Grills, Kitchen Equipment","Charcoal Oven, Charcoal Oven HJX-PRO-M120",,"https://mariotstore.com/wp-content/uploads/2024/10/Josper-HJX-PRO-M120.png, https://mariotstore.com/wp-content/uploads/2024/10/HJX-PRO-M120.png, https://mariotstore.com/wp-content/uploads/2024/10/HJXPROL175.png",,,,,,,,,0,,Josper,Brand,Josper,1,1,,,,,default,1,1,0,,7,0,0,,,,,,,,,,field_60befc9fc0fb7,,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596598,110101100001110000111110000001110001101011001101,true,backend,,,,,,,,,,,,,,,,,,,,,,,,"14123,14125",,,,,,,,,,,,,,,,,,,,,,,,,,,,
