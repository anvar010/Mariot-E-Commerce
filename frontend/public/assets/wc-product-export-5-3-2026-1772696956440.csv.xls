14351,simple,,,"DOUGH KNEADING MACHINE - HY.10",1,0,visible,"The HY.10 Dough Kneading Machine is a versatile and reliable appliance tailored for professional kitchens and bakeries. Engineered for efficiency, it effortlessly kneads large quantities of dough with precision and consistency. Its sturdy build and advanced functionalities ensure durability and optimal performance, while its user-friendly design makes operation intuitive. The HY.10 is the ideal solution for businesses seeking to streamline their dough preparation process, delivering exceptional results every time.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(320px, 43px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• DOUGH KNEADING MACHINE - HY.10</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 13 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 0.37 kW - 0.5 Hp - 220 V - 50 HZ</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless Bowl</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless dough fork</p>\n<p style=""margin: 0; padding-top: 0;"">• Easy to use and clean</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 630 x 410 x 600 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model No. HY.10 / Mestro Horeca / Make in Turkey</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(863px, 29px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,,1819,"BAKERY LINE, BAKERY LINE > Bakery Mixers, Kitchen Equipment",,,"https://mariotstore.com/wp-content/uploads/2024/10/douygh-mixer-hy2.png, https://mariotstore.com/wp-content/uploads/2024/10/douygh-mixer-hy1.png, https://mariotstore.com/wp-content/uploads/2024/10/douygh-mixer-hy.png",,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,default,1,1,0,,52,0,,,"DOUGH KNEADING MACHINE - HY.10,الة عجن العجينة,آلة عجن العجين",,,,,,0,,field_60befc9fc0fb7,HY.10,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe