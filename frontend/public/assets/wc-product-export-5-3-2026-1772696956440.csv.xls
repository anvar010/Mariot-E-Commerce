11962,simple,,,"HOT BANQUET TROLLEY  EMP.BQ2",1,0,visible,"The EMP.BQ2 Hot Banquet Trolley is an essential piece of equipment for catering and hospitality services, designed to keep food warm and ready for service. This trolley features a robust construction with insulated compartments, ensuring optimal temperature retention for extended periods. It is equipped with multiple shelves to accommodate a variety of dishes, making it ideal for large events and banquets. The trolley is easy to maneuver, thanks to its swivel casters and ergonomic handles, allowing for smooth and efficient transport of meals. With its reliable heating system and spacious design, the EMP.BQ2 ensures that food remains at the perfect serving temperature, enhancing the dining experience for guests.","<p style=""margin-bottom: 0; margin-top: 0px;"">• HOT BANQUET TROLLEY EMP.BQ2</p>\n<p style=""margin: 0; padding-top: 0;"">• scap: 2 x 11 x GN2/1 size</p>\n<p style=""margin: 0; padding-top: 0;"">• system with humidity</p>\n<p style=""margin: 0; padding-top: 0;"">• 2 sides handles</p>\n<p style=""margin: 0; padding-top: 0;"">• Magnetic locker</p>\n<p style=""margin: 0; padding-top: 0;"">• temp: 30 ~ 85 °c</p>\n<p style=""margin: 0; padding-top: 0;"">• digital control</p>\n<p style=""margin: 0; padding-top: 0;"">• structure: stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage: 220 - 240 v / 50 hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 3.4 kw</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 200 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• 2 wheels w/ breaks</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 1352 x 888 x 1803 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• EMP.BQ2 / EMPERO turkey made</p>",,,taxable,,1,,,0,0,,,,,0,,,8800,"COOKING LINE, COOKING LINE > Food Warmers",,,https://mariotstore.com/wp-content/uploads/2024/10/EMP.BQ2_.jpg,,,,,,,,,0,,Empero,Brand,Empero,1,1,Electric/Gas,Electric,1,1,default,1,1,129,index,20,0,0,,"HOT BANQUET TROLLEY EMP.BQ2",,,,,,,,field_60befc9fc0fb7,EMP.BQ2,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595951,110100010011110010010110101100100001101111001010,false,,,,,,,,,"Type of Product","Hot Banquet Trolley",1,1,,,,,,,,,,,,,,,,,
11964,simple,,,"HOT BANQUET TROLLEY  EMP.BQ1",1,0,visible,"<strong>HOT BANQUET TROLLEY - EMP.BQ1</strong>\nThe EMP.BQ1 hot banquet trolley is designed for keeping food warm during events, banquets, and catering services. With a durable construction and efficient heating system, it ensures that dishes are served at the ideal temperature for extended periods. Perfect for maintaining the quality of hot food during service.","<p style=""margin-bottom: 0; margin-top: 0px;"">• cap: 11 gn 2/1 size</p>\n<p style=""margin: 0; padding-top: 0;"">• system with humidity</p>\n<p style=""margin: 0; padding-top: 0;"">• 2 sides handles</p>\n<p style=""margin: 0; padding-top: 0;"">• Magnetic locker</p>\n<p style=""margin: 0; padding-top: 0;"">• temp: 30 ~ 85 °c</p>\n<p style=""margin: 0; padding-top: 0;"">• digital control</p>\n<p style=""margin: 0; padding-top: 0;"">• structure: stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage: 220 - 240 v / 50 hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 1.7 kw</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 111 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• 2 wheels w/ breaks</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 720 x 885 x 1810 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• EMP.BQ1 / EMPERO turkey made</p>",,,taxable,,1,,,0,0,,,,,0,,,5287,"COOKING LINE, COOKING LINE > Food Warmers, sale 11.11",,,https://mariotstore.com/wp-content/uploads/2024/10/EMP.BQ1_.jpg,,,,,,,,,0,,Empero,Brand,Empero,1,1,Electric/Gas,Electric,1,1,default,1,1,129,index,61,0,0,,"HOT BANQUET TROLLEY",,,,,,,,field_60befc9fc0fb7,EMP.BQ1,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595951,010000100111011001111000110110011101100001001101,true,backend,,,,,,,,Series,"Series 70",1,1,"Type of Product","Hot Banquet Trolley",1,1,,,,,,,,,,,,,
11966,simple,,,"HOT BANQUET TROLLEY  EMP.BQ3",1,0,visible,"The EMP.BQ3 Hot Banquet Trolley is a premium solution for catering and hospitality services, designed to maintain food at optimal serving temperatures. It features a durable, insulated construction with enhanced heating elements to ensure consistent temperature control. The trolley includes multiple adjustable shelves, providing ample space for a variety of dishes, making it ideal for large-scale events and banquets. Equipped with smooth-rolling casters and ergonomic handles, the EMP.BQ3 offers easy maneuverability for efficient service. Its robust design and reliable heating system ensure that meals remain hot and ready to serve, enhancing the overall dining experience for guests.","<p style=""margin-bottom: 0; margin-top: 0px;"">• HOT BANQUET TROLLEY EMP.BQ3</p>\n<p style=""margin: 0; padding-top: 0;"">• cap: 6 gn 2/1 size</p>\n<p style=""margin: 0; padding-top: 0;"">• system with humidity</p>\n<p style=""margin: 0; padding-top: 0;"">• 2 sides handles</p>\n<p style=""margin: 0; padding-top: 0;"">• Magnetic locker</p>\n<p style=""margin: 0; padding-top: 0;"">• temp: 30 ~ 85 °c</p>\n<p style=""margin: 0; padding-top: 0;"">• digital control</p>\n<p style=""margin: 0; padding-top: 0;"">• structure: stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage: 220 - 240 v / 50 hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 1.7 kw</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 60 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• 2 wheels w/ breaks</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 720 x 885 x 1220 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• EMP.BQ3 / EMPERO turkey made</p>",,,taxable,,1,,,0,0,,,,,0,,,4496,"COOKING LINE, COOKING LINE > Food Warmers",,,https://mariotstore.com/wp-content/uploads/2024/10/EMP.BQ3_.jpg,,,,,,,,,0,,Empero,Brand,Empero,1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,20,0,0,,"HOT BANQUET TROLLEY EMP.BQ3",,,,,,,,field_60bef