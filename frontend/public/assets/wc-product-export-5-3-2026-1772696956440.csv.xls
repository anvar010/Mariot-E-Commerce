13997,simple,,,"Fish Display Chiller 4 shelve- FDC4 S/S",1,0,visible,"The Fish Display Chiller 4 Shelf (FDC4 S/S) is a state-of-the-art refrigeration appliance designed specifically for the preservation and display of seafood in commercial and retail settings. This stainless steel unit combines functionality, aesthetics, and advanced cooling technology to provide an ideal environment for showcasing and maintaining the freshness of fish and other seafood products. Here is a detailed description of the Fish Display Chiller 4 Shelf (FDC4 S/S)","<p style=""margin-bottom: 0; margin-top: 0px;"">• Fish Display Chiller 4 shelve- FDC4 S/S</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature: +2 to +8 C</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 100L</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 230/220V-50/60Hz-1/3Hp 428-472W</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1200x1160x1110 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 107 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Made by Berjaya, Malaysia</p>",,,taxable,,1,,,0,0,,,,,0,,,8000,"SUPERMARKET EQUIPMENT > Fish Display, Kitchen Equipment, SUPERMARKET EQUIPMENT","Fish Display Chiller 4 shelve",,https://mariotstore.com/wp-content/uploads/2024/10/FDC4-S-S-fish-display-chiller-4-shelves-scaled.png,,,,,,,,,0,,Berjaya,Brand,Berjaya,1,1,,,,,default,1,1,0,,72,0,0,,"Fish Display Chiller 4 shelve",,,,,,,,field_60befc9fc0fb7,"FDC4 S/S",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110101001100111010001100000100111010011100010111,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
