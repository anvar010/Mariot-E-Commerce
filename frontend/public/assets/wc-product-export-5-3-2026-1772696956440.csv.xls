17338,simple,,,"CUTTER MIXER SINGLE SPEED - L6DPSME",1,0,visible,"<strong>Cutter Mixer Single Speed - L6DPSME</strong>\nThe L6DPSME Cutter Mixer is a versatile, single-speed kitchen appliance designed for efficiency in food preparation. Ideal for slicing, dicing, and mixing, its robust construction ensures durability, while its user-friendly design allows for seamless operation in both commercial and professional kitchens. Perfect for simplifying meal prep and enhancing productivity.","""CUTTER MIXER SINGLE SPEED\nCap: 6 ltrs\nLiquid cap. 99%\n- IP65 Controls\n- Induction motor\n- Dishwasher safe\n- Thermal relay\n- HummusMaster\n- High power, induction motor.\n- Power: 0,55 kW\n- Speed: 1500 rpm.\n- Volts: 230V 50Hz 1ph\n- Dim: 272 x 285 x 503 mm\nModel: L6DPSME / CAPINOX / KITPRO / TURKEY""",,,taxable,,1,,,0,0,,,,,1,,,2911,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Kitchen Equipment",,,,,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,,1,1,0,,79,0,,,"CUTTER MIXER,CUTTER MIXER SINGLE SPEED - L6DPSME,CUTTER MIXER SINGLE SPEED",,,,,,,,field_60befc9fc0fb7,L6DPSME,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595653,011000011001111001011001001100100110011101100110,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17346,simple,,,"CUTTER MIXER SINGLE SPEED - L9DPSME",1,0,visible,"<strong>Cutter Mixer Single Speed - L9DPSME</strong>\nThe L9DPSME Cutter Mixer is a high-performance, single-speed solution tailored for professional kitchens. Featuring a larger capacity and durable build, it excels in chopping, mixing, and emulsifying tasks with precision. Designed for reliability and ease of use, it ensures consistent results, making it an essential tool for streamlining kitchen operations.","""CUTTER MIXER SINGLE SPEED\nCap: 9 ltrs\nLiquid cap. 99%\n- IP65 Controls\n- Induction motor\n- Dishwasher safe\n- Thermal relay\n- HummusMaster\n- High power, induction motor.\n- Power: 0,75 kW\n- Speed: 1500 rpm.\n- Volts: 230V 50Hz 1ph\n- Dim: 272 x 285 x 563 mm\nModel: L9DPSME / CAPINOX / KITPRO / TURKEY""",,,taxable,,1,,,0,0,,,,,1,,,3327,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Kitchen Equipment",,,,,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,,1,1,0,,79,0,,,"CUTTER MIXER,CUTTER MIXER SINGLE SPEED,CUTTER MIXER SINGLE SPEED - L9DPSME",,,,,,,,field_60befc9fc0fb7,L9DPSME,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595653,110000011001010010111001011100101111001001101100,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17348,simple,,,"CUTTER MIXER SINGLE SPEED - L12DPSME",1,0,visible,"<strong>Cutter Mixer Single Speed - L12DPSME</strong>\nThe L12DPSME Cutter Mixer offers a powerful single-speed operation with a spacious capacity, perfect for handling larger volumes in professional kitchens. Built for efficiency and durability, it delivers exceptional performance in chopping, blending, and emulsifying tasks. Its user-friendly design ensures ease of operation, making it a reliable choice for high-demand food preparation environments.","""CUTTER MIXER SINGLE SPEED\nCap: 12 ltrs\nLiquid cap. 99%\n- IP65 Controls\n- Induction motor\n- Dishwasher safe\n- Thermal relay\n- HummusMaster\n- High power, induction motor.\n- Power:0,75 kW\n- Speed: 1500 rpm.\n- Volts: 230V 50Hz 1ph\n- Dim: 272 x 285 mm\nModel: L12DPSME / CAPINOX / KITPRO / TURKEY""",,,taxable,,1,,,0,0,,,,,1,,,3648,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Kitchen Equipment",,,,,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,,1,1,0,,79,0,,,"CUTTER MIXER,CUTTER MIXER SINGLE SPEED - L12DPSME",,,,,,,,field_60befc9fc0fb7,L12DPSME,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595653,110000011001010010111001011110001111001001100101,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17350,simple,,,"CUTTER MIXER VARIABLE SPEED - L6DIV VARIABLE",1,0,visible,"<strong>Cutter Mixer Variable Speed - L6DIV Variable</strong>\nThe L6DIV Variable Cutter Mixer is a compact and versatile appliance with adjustable speed settings for precise food preparation. Ideal for chopping, blending, and emulsifying, its durable construction ensures long-lasting performance. Perfect for professional kitchens requiring control and flexibility in processing smaller quantities.","""CUTTER MIXER VARIABLE SPEED\nCap: 6 ltrs\nLiquid cap. 99%\n- IP65 Controls\n- Induction motor\n- Dishwasher safe\n- Thermal relay\n- HummusMaster\n- High power, induction motor.\n- Power: 0,75 kW\n1.1 kW\n- Speed: 600-3500 rpm.\n- Volts: 110V 60Hz 1ph\n- Dim: 255 x 502 x 338 mm\nModel: L6DIV VARIABLE / CAPINOX / KITPRO / TURKEY""",,,taxable,,1,,,0,0,,,,,1,,,4539,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Kitchen Equipment",,,,,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,,1,1,0,,79,0,,,"CUTTER MIXER,CUTTER MIXER VARIABLE SPEED - L6DIV VARIABLE",,,,,,,,field_60befc9fc0fb7,"L6DIV VARIABLE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595653,011000011001110000111001001110001111011001100110,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17352,simple,,,"CUTTER MIXER VARIABLE SPEED - L9DIV VARIABLE",1,0,visible,"<strong>Cutter Mixer Variable Speed - L9DIV Variable</strong>\nThe L9DIV Variable Cutter Mixer offers advanced versatility with adjustable speed settings, allowing for precise control over chopping, mixing, and emulsifying. Designed for high-capacity tasks, it ensures efficient processing with consistent results. Its robust build and user-friendly features make it a reliable choice for professional kitchens, enhancing productivity and precision in food preparation.","""CUTTER MIXER VARIABLE SPEED\nCap: 9 ltrs\nLiquid cap. 99%\n- IP65 Controls\n- Induction motor\n- Dishwasher safe\n- Thermal relay\n- HummusMaster\n- High power, induction motor.\n- Power: 1,1 kW\n1.5 kW\n- Speed: 600-3500 rpm.\n- Volts: 110V 60Hz 1ph\n- Dim: 255 x 562 x 338 mm\nModel: L9DIV VARIABLE / CAPINOX / KITPRO / TURKEY""",,,taxable,,1,,,0,0,,,,,1,,,5310,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Kitchen Equipment",,,,,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,,1,1,0,,79,0,,,"CUTTER MIXER,CUTTER MIXER VARIABLE SPEED,CUTTER MIXER VARIABLE SPEED - L9DIV VARIABLE",,,,,,,,field_60befc9fc0fb7,"L9DIV VARIABLE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595653,011000011001010010011001001110001111100011100111,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17356,simple,,,"CUTTER MIXER VARIABLE SPEED - L12DIV VARIABLE",1,0,visible,"<strong>Cutter Mixer Variable Speed - L12DIV Variable</strong>\nThe L12DIV Variable Cutter Mixer is a high-capacity, versatile kitchen appliance designed for precision and efficiency. With variable speed control, it offers optimal performance for chopping, mixing, and emulsifying a wide range of ingredients. Built for durability and ease of use, it is perfect for large-scale food preparation in professional kitchens, ensuring consistent results and enhanced productivity.","""CUTTER MIXER VARIABLE SPEED\nCap: 12 ltrs\nLiquid cap. 99%\n- IP65 Controls\n- Induction motor\n- Dishwasher safe\n- Thermal relay\n- HummusMaster\n- High power, induction motor.\n- Power: 1,5 kW\n2.2 kW\n- Speed: 600-3500 rpm.\n- Volts: 110V 60Hz 1ph\n- Dim: 255 x 642 x 368 mm\nModel: L12DIV VARIABLE /CAPINOX / KITPRO / TURKEY""",,,taxable,,1,,,0,0,,,,,1,,,5999,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Kitchen Equipment",,,,,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,,1,1,0,,79,0,,,"CUTTER MIXER,CUTTER MIXER VARIABLE SPEED,CUTTER MIXER VARIABLE SPEED - L12DIV VARIABLE",,,,,,,,field_60befc9fc0fb7,"L12DIV VARIABLE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595653,011000011000110010111001011110001111000011000111,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17359,simple,,,"CUTTER MIXER VARIABLE SPEED SCRAPER - L20IV VARIABLE",1,0,visible,"Cutter Mixer Variable Speed Scraper - L20IV Variable\nThe L20IV Variable Cutter Mixer with Scraper is a high-performance kitchen appliance designed for precision and efficiency. Featuring adjustable speed control and an integrated scraper, it ensures thorough mixing and chopping, even with thick or sticky ingredients. Built for heavy-duty use, it is ideal for large-scale food preparation in professional kitchens, offering consistency, durability, and ease of use for optimal results.","""CUTTER MIXER VARIABLE SPEED SCRAPER\nCap: 20 ltrs\nLiquid cap. 99%\n- IP65 Controls\n- Induction motor   \n- Dishwasher safe   \n- Thermal relay   \n- HummusMaster\n- High power, induction motor.\n- Power: 2,2 kW\n- Speed:  600-3000 rpm.\n- Volts: 220V 1ph\n- Dim: 731 x 482 x 1092 mm\nModel: L20IV VARIABLE /CAPINOX /  KITPRO / TURKEY""\n",,,taxable,,1,,,0,0,,,,,1,,,11350,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Kitchen Equipment",,,,,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,,1,1,0,,79,0,,,"CUTTER MIXER VARIABLE SPEED SCRAPER,CUTTER MIXER VARIABLE SPEED SCRAPER - L20IV VARIABLE",,,,,,,,field_60befc9fc0fb7,"L20IV VARIABLE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,,1734595316,011110001101111001011100000110000011101001001011,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17360,simple,,,"CUTTER MIXER VARIABLE SPEED SCRAPER - L30IV VARIABLE",1,0,visible,"<strong>Cutter Mixer Variable Speed Scraper - L30IV Variable</strong>\nThe L30IV Variable Cutter Mixer with Scraper is a top-tier kitchen appliance designed for heavy-duty food processing. With variable speed settings and a built-in scraper, it ensures thorough and consistent mixing, chopping, and emulsifying, even with the most challenging ingredients. Its high-capacity design and durable construction make it perfect for large-scale commercial kitchens, delivering efficiency, precision, and reliability in every task.","""CUTTER MIXER VARIABLE SPEED SCRAPER\nCap: 30 ltrs\nLiquid cap. 99%\n- IP65 Controls\n- Induction motor   \n- Dishwasher safe   \n- Thermal relay   \n- HummusMaster\n- High power, induction motor.\n- Power:5.5 kW\n- Speed:  600-3000 rpm.\n- Volts: 380V 3ph\n- Dim: 730 x 480 x 1090 mm\nModel: L30IV VARIABLE /CAPINOX /  KITPRO / TURKEY""\n",,,taxable,,1,,,0,0,,,,,1,,,17025,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Kitchen Equipment",,,,,,,,,,,,0,,Capinox,Brand,Capinox,1,1,,,,,,1,1,0,,79,0,,,"CUTTER MIXER VARIABLE SPEED SCRAPER,CUTTER MIXER VARIABLE SPEED SCRAPER - L30IV VARIABLE",,,,,,,,field_60befc9fc0fb7,"L30IV VARIABLE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,,1734595316,011110001101111001011100000110000011101001001011,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17510,simple,,,"ELECTRIC OVEN - MA/18-02-00-01",1,0,visible,"<strong>ELECTRIC OVEN - MA/18-02-00-01</strong>\nThe EN-100 oven is an electric oven, but with a traditional dome shape made of a special highly refractory cement.\nThe dome has a special internal design that improves heat circulation.\nThe rotating bedplate is made of natural stone and allows pizzas (and more) to be cooked evenly, even under the harshest working conditions.\n\nThe EN-100 oven represents an innovative yet user-friendly oven. The heat transmission modes: conduction - convection and radiation have been properly implemented, developed and managed with a state-of-the-art control (PID).\n\nYou will be able to perfectly integrate the new EN-100 oven in your pizzeria or franchise; choose the finish of the covering from the many colours available, both normal and metallic.\n\nIf you prefer a more classic look, you can have EN-100 covered with mosaic tiles in a wide range of shades and colours. If, on the other hand, you want a minimalist, almost invisible oven, the solution for you is one integrated in the wall!","<strong>ELECTRIC OVEN - MA/18-02-00-01</strong>\n. Capacity: 7 pizzas ø33cm\n- The EN-100 oven is an electric oven, but with a traditional dome shape made of a special highly refractory cement.\n- The dome has a special internal design that improves heat circulation.\n- The rotating bedplate is made of natural stone and allows pizzas (and more) to be cooked evenly, even under the harshest working conditions.\n- The EN-100 oven represents an innovative yet user-friendly oven.\n- The heat transmission modes: conduction - convection and radiation have been properly implemented, developed and managed with a state-of-the-art control (PID).\n- Voltage: 380-415 V 3N 50/60 Hz\n- Max kW: 21 kW\n- Max temperature: 450°C\n- Mouth opening: 530 X 220 mm\n- Net / Gross Weight: 890 / 950 kg\n- Dim: 1580 x 1820 x 1920 mm.\nMA/18-02-00-01 / PASTALINE / Italy made.""",,,taxable,,1,,,0,0,,,,,1,,,80784,"BAKERY LINE, BAKERY LINE > Bakery Oven, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/12/pastaline-oven.webp,,,,,,,,,0,,Pastaline,Brand,Pastaline,1,1,,,,,,1,1,0,,62,0,,,"ELECTRIC OVEN,ELECTRIC OVEN - MA/18-02-00-01",,,,,,,,field_60befc9fc0fb7,MA/18-02-00-01,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595830,011100001111111000011110000110000100001111001101,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17514,simple,,,"DOUGH ROUNDER - MA/05-04-00-01",1,0,visible,"<strong>DOUGH ROUNDER - MA/05-04-00-01</strong>\n<em>Everything is simpler!</em>\nSIMPLE AND ALWAYS READY FOR USE\nSAFE AND RELIABLE\nELIMINATES REPETITIVE MOVEMENTS\nThe KALI rounder is capable of rounding dough portions ranging from 20g to 1000g without requiring any adjustment or the replacement of any parts. The KALI rounder is designed for use with various different types of dough, as follows:\n\nPizza dough: spiral A with 60-ridge cylinder\nBread dough: spiral B with either 4-ridge or 12-ridge cylinder\nVery moist and greasy mixes: Teflon-coated spiral B with 12-ridge cylinder\n\nThe technical solution whereby the dough only comes into contact\nwith the spiral and cylinder enables the KALI rounder to comply with European and American health regulations (NSF and ETL Sanitation).\n\nThe innovative cooling technology, whereby the pressure in the mo- tor housing is reduced, helps to keep the dough portions being processed at room temperature in both in the spiral and the cylin- der.This cooling solution enables the transmission components to work for long periods without any maintenance.","<strong>DOUGH ROUNDER - MA/05-04-00-01</strong>\n. Hourly production: 2400 portions/h\n- Its allows you to transform all portions of dough from 20 g to 1000 g into balls. Without having to make adjustments or replace parts.\n- The dough portions are introduced through the upper mouth of the rounder.\n- The dough pieces are then rolled through the helical rounding system (internal spiral) and fed to the upper stainless steel output shelf in perfectly rolled balls, ready to be placed and stored in your dough bins.\n- Rounder with all-stainless steel body.\n- Disassembly and cleaning of the device is quick and easy.\n- Voltage: 230 V / 50 Hz\n- Power : 370 (W)\n- Net / Gross Weight: 65 / 77 kg\n- Dim: 350 x 540 x 850 mm.\nMA/05-04-00-01 / PASTALINE / Italy made.""",,,taxable,,1,,,0,0,,,,,1,,,17477,"BAKERY LINE, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/12/822.jpg,,,,,,,,,0,,Pastaline,Brand,Pastaline,1,1,,,,,,1,1,0,,65,0,,,"DOUGH ROUNDER,DOUGH ROUNDER - MA/05-04-00-01",,,,,,,,field_60befc9fc0fb7,MA/05-04-00-01,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011100001111011000111110000110001111010011100000,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17517,simple,,,"TOP pizza rolling mill 45 cm GIOTTO D45 - MA/10-00-00-02",1,0,visible,"<strong>TOP pizza rolling mill 45 cm GIOTTO D45 - MA/10-00-00-02</strong>\nThe Giotto D30 and D45 dough sheeters are designed to process dough for pizzas, breads, flat- breads, “focaccia” bread, cakes, samoosas, etc.\n\nManufactured entirely from stainless steel, with a detailed framework, these machines are equipped with foodstuff-grade resin rollers that comply with the most stringent workplace health and safety regulations.Thanks to the suction-pad feet supplied as standard equipment, the dough sheeters can easily be repositioned on the worktop in a safe and stable manner.The Giotto D30 and D45 dough sheeters enable the operator to work quickly and accurately, both when selecting the dough-thickness for processing purposes and when disassembling the rollers for cleaning purposes.Neither of these dough sheeters requires any formal day-to-day maintenance whatsoever.The Giotto D30 and D45 dough sheeters with two pair of rollers and a specially inclined lower pair of rollers enable the user to roll out dough circles up to 30 and 45cm in diameter respectively.","""TOP pizza rolling mill 45 cm GIOTTO D45\n. Diameter 45 cm\n. Min/max dough weight: 30-800g\n. Pasta weight: 30 to 800g\n. Outlet diameter (cm): 10 to 45 cm\n- Pizza rolling mill with two adjustable oblique rollers that allow you to obtain the desired thickness with millimeter precision.\n- This moulder is designed to roll out and extend cold dough for pizza bases, breads, pastas, cakes.\n- Made with specific materials to be in contact with food products: AISI 304 stainless steel and certified plastics.\n- Pizza sheeter ergonomically designed to facilitate the activity carried out by the operator and make cleaning easier at the end of use.\n- The underside of the appliance is accessible for cleaning without handling.\n- Voltage: 220 V / 50 Hz\n- Power : 0.37 kW\n- Net / Gross Weight: 35.8 / 39 kg\n- Dim: 520 x 290 x H720/750 mm (30mm feet)\nMA/10-00-00-02 / PASTALINE / Italy made.""",,,taxable,,1,,,0,0,,,,,1,,,7200,"BAKERY LINE, Kitchen Equipment, BAKERY LINE > Rolling Machine",,,https://mariotstore.com/wp-content/uploads/2024/12/MA10-00-00-02E.webp,,,,,,,,,0,,Pastaline,Brand,Pastaline,1,1,,,,,,1,1,0,,59,0,,,"TOP pizza rolling mill 45 cm GIOTTO D45,TOP pizza rolling mill 45 cm GIOTTO D45 - MA/10-00-00-02",,,,,,,,field_60befc9fc0fb7,MA/10-00-00-02,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010110010110010110011010110011000110001001101,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17521,simple,,,"IDEA TEMPERING MACHINE - MA/17-00-00-01",1,0,visible,"<strong>IDEA TEMPERING MACHINE - MA/17-00-00-01 </strong>\nIDEA is a defroster and cooler that utilises “Bain Marie” technology and is not only ideal for the chocolate manufacturing sector but also for confectionery kitchens, ice-cream parlours, etc.IDEA has been patented due to:\n\nthe design of its tray, which is perfect for processing small to medium-size batches\nits integrated temperature control system\nIDEA offers targeted solutions that make it SIMPLE, EASY and CONVENIENT to use in any workshop, even for small batches or limited production runs.","<strong>IDEA TEMPERING MACHINE - MA/17-00-00-01</strong>\n. Tank capacity: Max 10 Lt\n- IDEA is a device for melting and cooling chocolate.\n- Tempering machine Idea utilises “Bain Marie” technology, this is ideal for the chocolate industry as well as pastry, ice cream, and similar sectors. Idea is patented for:\n- The design of the tank for processing small and medium quantities.\n- The integrated temperature control system Idea is equipped with a removable metal flap that ensures perfect mixing of the chocolate as it melts.\n- Voltage: 220 V / 50 Hz\n- Power : 1.65 Kw\n- Temperature Max: 85° C\n- Net / Gross Weight: 29 / 34 kg\n- Dim: 520 x 480 x 530 mm\nMA/17-00-00-01 / PASTALINE / Italy made.""",,,taxable,,1,,,0,0,,,,,1,,,21542,"FOOD PROCESSING, Kitchen Equipment, SNACK MAKER",,,https://mariotstore.com/wp-content/uploads/2024/12/Tempering-Machine-IDEA.jpg,,,,,,,,,0,,Pastaline,Brand,Pastaline,1,1,,,,,,1,1,0,,65,0,,,"IDEA TEMPERING MACHINE,IDEA TEMPERING MACHINE - MA/17-00-00-01",,,,,,,,field_60befc9fc0fb7,MA/17-00-00-01,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011111100011011010000011111100001011010001001001,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17781,simple,,,"DOUGH KNEADING MACHINE - HY.05.k",1,0,visible,"<strong>DOUGH KNEADING MACHINE - HY.05.K</strong>\nThe HY.05.K Dough Kneading Machine is a high-capacity, durable machine designed for efficient kneading of large quantities of dough. With a powerful motor and robust construction, it ensures smooth, consistent mixing, making it ideal for bakeries, pizzerias, and large-scale food production.","""<strong>DOUGH KNEADING MACHINE</strong>\n- flour cap : 30 kg.\n- capacity : 50 ltr.\n- Motor Power:0.75 Kw 1400 rpm / 220V - 380V / 50-60 Hz\n- Bowl dim(diameter/depth): 600 mm*290 mm\n- S/S bowl and dough mixer arm.\n- N.W.: 106 kg. Net m3 : 0.49\n- dim : 646 x 955 x 794 mm.\nHY.05.k / Empero - Capinox.""",,,taxable,,1,,,0,0,,,,,1,,,4200,"BAKERY LINE, BAKERY LINE > Bakery Mixers, BAKERY LINE > Bread Maker, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/12/HY.05.K.jpg.webp,,,,,,,,,0,,Empero,,,,,,,,,,1,1,0,,54,0,,,"DOUGH KNEADING MACHINE - HY.05.K",,,,,,,,field_60befc9fc0fb7,HY.05.k,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110111111001110010000000110000111100110001100110,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17784,simple,,,"DOUGH KNEADING MACHINE - HY.07.k",1,0,visible,"<strong>DOUGH KNEADING MACHINE - HY.07.K</strong>\nThe HY.07.K Dough Kneading Machine is designed for heavy-duty kneading, providing efficient mixing for various types of dough. With a sturdy build and powerful motor, it ensures consistent results, making it ideal for bakeries, pizza parlors, and large food establishments.","""<strong>DOUGH KNEADING MACHINE</strong>\n- flour cap : 50 kg.\n- capacity : 75 ltr.\n- Motor Power: 1.10 kW 1400 rpm / 220V - 380V / 50-60 Hz\n- Bowl dim(diameter/depth): 750 mm* 350 mm\n- S/S bowl and dough mixer arm.\n- N.W.: 140 kg. Net m3 : 0.78\n- dim : 815 x 1130 x 882 mm.\nHY.07.k / Empero - Capinox.""",,,taxable,,1,,,0,0,,,,,1,,,5200,"BAKERY LINE, BAKERY LINE > Bakery Mixers, BAKERY LINE > Bread Maker, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/12/HY.05.K.jpg.webp,,,,,,,,,0,,Empero,,,,,,,,,,1,1,0,,54,0,,,"DOUGH KNEADING MACHINE,DOUGH KNEADING MACHINE - HY.07.k",,,,,,,,field_60befc9fc0fb7,HY.07.k,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110111111001110010000000110000111100110001100110,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17787,simple,,,"Worktop Purpose - EMP.PLS.7TS010",1,0,visible,"<strong>Worktop Purpose - EMP.PLS.7TS010</strong>\nThe EMP.PLS.7TS010 Worktop is designed for versatility in commercial kitchens. With a durable stainless steel surface and spacious design, it provides a reliable space for food preparation, chopping, and assembly. Its sturdy construction ensures long-lasting performance in busy food service environments.","""Worktop Purpose\n. one under shelf: 1 mm thickness.\n. top: 1.2 mm thickness.\n. leg: 40 x 40 mm squire / 1.5 mm thickness.\n. height adjustable plastic feet.\n. construction scotch bright finish 18/10 aisi 304.\n. dimension: 400 x 730 x 300 mm.\nEMP.PLS.7TS010 / Empero - Capinox""",,,taxable,,1,,,0,0,,,,,1,,,634,"COOKING LINE > Cooker, COOKING LINE, Kitchen Equipment, COOKING LINE > Cooker > Series 700",,,https://mariotstore.com/wp-content/uploads/2024/12/EMP.webp,,,,,,,,,0,,Empero,Brand,Empero,1,1,,,,,,1,1,0,,65,0,0,,"Worktop Purpose,Worktop Purpose - EMP.PLS.7TS010",,,,,,,,field_60befc9fc0fb7,EMP.PLS.7TS010,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,111100011000111000101100110100110110011001001100,true,backend,8566306656789451,yes,yes,,product,no,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17792,simple,,,"SHAWARMA MACHINES, GAS (MOTOR AT BOTTOM) - EMP.DN.150-LPG",1,0,visible,"<strong>SHAWARMA MACHINES, GAS (MOTOR AT BOTTOM) - EMP.DN.150-LPG</strong>\nThe EMP.DN.150-LPG gas shawarma machine features a bottom-mounted motor for stability and smooth operation. Designed for high-performance grilling, it offers even heat distribution for perfectly cooked shawarma every time. Ideal for commercial kitchens and food establishments requiring reliable, efficient equipment.","<strong>SHAWARMA MACHINES, GAS (MOTOR AT BOTTOM)</strong>\n- Cap: 3 burners\n- Magnet safety valve.\n- Sliding bottom housing of the spear provides shawarma meat to get closer to burner.\n- Adjustable spear / Dual direction option.\n- Hygienic and safe / Stainless steel body\n- power voltage: 8.3 kw/ 220V-50-60 Hz\n- weight: 30 kg. net m3: 0.40\n- dim: 737 x 619 x 978 mm.\nEMP.DN.150-LPG / Empero - Capinox\n""",,,taxable,,1,,,0,0,,,,,1,,,1914,"COOKING LINE, Kitchen Equipment, COOKING LINE > Shawarma Machines",,,https://mariotstore.com/wp-content/uploads/2024/12/455.jpg,,,,,,,,,0,,Empero,Brand,Empero,1,1,,,,,,1,1,0,,65,0,,,"SHAWARMA MACHINES,GAS (MOTOR AT BOTTOM),GAS (MOTOR AT BOTTOM) - EMP.DN.150-LPG",,,,,,,,field_60befc9fc0fb7,EMP.DN.150-LPG,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110011110001110011000110010110010100111001100001,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17795,simple,,,"LAMB OVEN - EMP.KFR.01",1,0,visible,"<strong>LAMB OVEN - EMP.KFR.01</strong>\nThe EMP.KFR.01 Lamb Oven is a high-performance, durable oven designed for slow-cooking lamb to perfection. With efficient heat distribution and robust construction, it ensures tender and flavorful results. Perfect for Middle Eastern cuisine and commercial kitchens specializing in lamb dishes.","""<strong>LAMB OVEN</strong>\n- Working system with electrical resistance and gas burner at the same time.\n- 2 pieces of 1.5 kW electrical resistances on the oven and gas burner heating system at the bottom.\n- Adaptable LPG or NG - Magnet Safety valves.\n- Piezo lighter ignition system.\n- Easy to clean and hygienic. S/S Body.\n- Gas Consumption (ng): 1.72 m3/h; (lpg): 1.29 kg/h\n- Power: 16.5 kW / 50-60 Hz . Weight. : 165 kg. . Net m3: 1\n- Dim: 1210 x 973 x 850 mm\nEMP.KFR.01 / Empero - Capinox """,,,taxable,,1,,,0,0,,,,,1,,,8560,"COOKING LINE > Combi Oven, COOKING LINE, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/12/LAMB-OVEN-–-EMP.KFR_.01.jpg,,,,,,,,,0,,Empero,Brand,Empero,1,1,,,,,,1,1,0,,65,0,0,,"LAMB OVEN,LAMB OVEN - EMP.KFR.01",,,,,,,,field_60befc9fc0fb7,EMP.KFR.01,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010111000101111010001110101100100011000000011111,true,backend,8961431847281133,yes,yes,,product,no,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
17920,simple,,,"LA MARZOCCO Linea Mini White R",1,0,visible,"The design of the Linea Mini is based on the most iconic La Marzocco machine ever built, the Linea Classic. Loved by thousands of professional baristas, the Linea Classic truly helped launch the speciality coffee movement of the early 1990’s. With the Linea Mini, we hope to help you create an espresso revolution in your kitchen. Made in Italy.","LA MARZOCCO Linea Mini White R\n<strong>Weight</strong> 30 kg\n<strong>Dimensions</strong> 45.3 × 35.7 × 37.7 cm\n<strong>ABOUT BRAND:</strong> Since 1927, La Marzocco has been manufacturing high quality and state-of-the-art espresso machines. The company originated from Florence, Italy, and has become a leader in innovative brewing equipment. The company has helped shaped the specialty coffee of today and aided business owners in serving signature beverages. La Marzocco products and parts are made durable to keep these machines last for a long time. Also, their parts are replaceable and accessible to provide speedy repair. Dedicated to serving, restaurant, cafe owners, and the community by providing reliable equipment and supporting coffee farms around the world.",,,taxable,,1,,,0,0,,,,,1,,,21000,"COFFEE & BAR LINE, COFFEE & BAR LINE > Coffee Machines, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/12/PRODUCT-IMAGE-news.webp,,,,,,,,,0,,"La Marzocco",Brand,"La Marzocco",1,1,,,,,,1,1,0,,58,0,,,"LA MARZOCCO Linea Mini White R",,,,,,,,field_60befc9fc0fb7,"Linea Mini White R",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110111110000010010000011111110001001100000101111,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
18178,simple,,,"Gas Pizza Oven With Stand - PLF.PLS.D3-LPG-S/Empero",1,0,visible,"<strong>Gas Pizza Oven with Stand - PLF.PLS.D3-LPG-S/Empero</strong>\nA high-performance gas pizza oven designed for efficiency and precision. Comes with a durable stand, perfect for professional kitchens. Ideal for creating perfectly baked pizzas every time!","Gas Pizza Oven With Stand - Adaptable LPG or NG - Adjustable cooking temperature between: 0/400 °C - Independent top and bottom burners. - Magnet Safety valves. - Special stone floor. - Stainless Steel oven inside. - Gas Consumption (ng): 3,20 m3/h - Gas Consumption (lpg): 1.48 kg/h - Interior Dimensions mm: 750xбоо - Net m3: 0.88 - Power kw: 30.40 .Net weight: 169 kg. . dim: 1062 x 1037 x 800 mm. PLF.PLS.D3-LPG-S/Empero - Capinox",,,taxable,,1,,,0,0,,,,,1,,,6900,"BAKERY LINE, BAKERY LINE > Bakery Oven, COOKING LINE > Combi Oven, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2025/01/pizza-oven-23424.jpg,,,,,,,,,0,,"Capinox, Empero",,,,,,,,,,1,1,0,,65,0,,,"Gas Pizza Oven With Stand",,,,,,,,field_60befc9fc0fb7,PLF.PLS.D3-LPG-S/Empero,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011101011011111000101110010100000010001101001011,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
18181,simple,,,"Blast Chiller / Freezer - AT05ISO",1,0,visible,"<strong>Blast Chiller / Freezer - AT05ISO</strong>\nEfficiently preserve food quality and freshness with the AT05ISO Blast Chiller/Freezer. Designed for rapid cooling and freezing, it's an essential addition to professional kitchens.","Blast Chiller / Freezer ⚫ capacity of 5 x GN 1/1 or 600 x 400 mm • cooling space dim: 610 x 410 x 410 mm • cooling temperature: +3/-18°C cooling capacity +70°C&gt; +3°C: 20 kg • freezing capacity +70°C 18°C: 15 kg • product operation to temp.+ 43°C/electronic thermostat. • inner &amp; outer sheath made of stainless steel AISI 304 • insulation CFC/insulation thickness of 60 mm. • Automatic operation /automatic defrost / dynamic cooling • rounded corners to HACCP standard • Replaceable tires at the door / adjustable feet. • Dimensions 750 x 740 x 850/880 mm AT05ISO / Tecnodom / Italy made.",,,taxable,,1,,,0,0,,,,,1,,,7912,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2025/01/Blast-Chiller-AT05ISO.webp,,,,,,,,,0,,Tecnodom,,,,,,,,,,1,1,0,,55,0,,,"Blast Chiller,Blast Chiller / Freezer,Blast Chiller / Freezer - AT05ISO",,,,,,,,field_60befc9fc0fb7,"AT05ISO / ATT05",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010111110000111100000011101110000000111001101101,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
18199,simple,,,"Cellulose particle filter - 1 box = 100 pcs - VITO 50 / 80",1,0,visible,"<strong>Cellulose Particle Filter (1 Box = 100 pcs) - VITO 50/80</strong>\nEfficiently trap impurities with these high-quality cellulose particle filters, designed for use with VITO 50 and VITO 80 oil filtration systems. Each box contains 100 durable filters, ensuring superior performance and extended oil life in commercial kitchens.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Cellulose particle filter - 1 box = 100 pcs - VITO 50 / 80 </p>\n<p style=""margin: 0; padding-top: 0;"">• VITO Particle filters</p>\n<p style=""margin: 0; padding-top: 0;"">• The VITO particle filters keep all particles that are filtered out of the oil by the frying oil filter machines.\nThey are placed inside the unit and can be used for several filtration cycles.\nThe filters are made of cellulose and are therefore biodegradable.</p>",,,taxable,,1,,,0,0,,,,,1,,,1300,"ACCESSORIES, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/1305_oiltester-1.png,,,,,,,,,0,,"Vito Oil Filter System",Brand,"Vito Oil Filter System",1,1,,,,,default,1,1,0,,12,0,0,,"Cellulose particle filter - 1 box = 100 pcs - VITO 30,فلاتر ورق,ورق فلاتر",,,,,,,,field_60befc9fc0fb7,"VITO 50 / 80 ",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596598,100010100110100011010001111001110100111000011101,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
18281,simple,,,"Single-Door Upright Chiller = BS1FDUC/G-83",1,0,visible,"<strong>Single-Door Upright Chiller - BS1FDUC/G-83</strong>\nThe BS1FDUC/G-83 Single-Door Upright Chiller is a reliable solution for preserving perishable items. Designed with ample storage capacity, it ensures consistent cooling performance for optimal freshness. Crafted from durable materials, this energy-efficient chiller is perfect for commercial kitchens and food service establishments.","Single-Door Upright Chiller = BS1FDUC/G-83 MODEL: BS1FDUC/G-83 S/S upright single door (magnetic) chiller w/ blower system (1 full door) Cap:650 L Temperature: 2-8°C Power: 230V-50Hz Dim 805x840x2060 mm Weight: 132 kg, Made by Berjaya, Malaysia",,,taxable,,1,,,0,0,,,,,1,,,4925,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2025/01/upright-chiller-Singke-Door-berjayah-scaled.jpg-1200x1200-1.webp,,,,,,,,,0,,Berjaya,Brand,Berjaya,1,1,,,,,,1,1,0,,59,0,0,,"Single-Door Upright Chiller",,,,,,,,field_60befc9fc0fb7,BS1FDUC/G-83,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110000100100111000110110100100111100111001001101,true,backend,8996389927103267,yes,yes,,product,no,,,,,,,,,,,,,,,,,,,8996389747103285,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
18284,simple,,,"Single-Door Upright Freezer - BS1FDUF/G-83",1,0,visible,"<strong>Single-Door Upright Freezer - BS1FDUF/G-83</strong>\nThe BS1FDUF/G-83 Single-Door Upright Freezer offers dependable freezing performance for preserving food and ingredients. With a spacious interior, energy-efficient design, and durable construction, it’s ideal for commercial kitchens and food service operations, ensuring long-lasting freshness and reliability.","<strong>Single-Door Upright Freezer - BS1FDUF/G-83</strong>\n\nMODEL: BS1FDUF/G-83 S/S\n\nupright single door (magnetic) freezer w/blower system (1 full door)\n\nCap 650 L\n\nTemperature:-10-18°C\n\nPower: 230V-50Hz\n\nDim 805x840x2060 mm\n\nWeight: 132 kg. Made by Berjaya, Malaysia",,,taxable,,1,,,0,0,,,,,1,,,5550,"REFRIGERATION LINE > Display Chiller, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2025/01/upright-chiller-Singke-Door-berjayah-scaled.jpg-1200x1200-1.webp,,,,,,,,,0,,Berjaya,Brand,Berjaya,1,1,,,,,,1,1,0,,60,0,0,,"Single-Door Upright Freezer,Single-Door Upright Freezer - BS1FDUF/G-83",,,,,,,,field_60befc9fc0fb7,BS1FDUF/G-83,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110000100100111000110110100100111100111001001101,true,backend,8691478374314368,yes,yes,,product,no,,,,,,,,,,,,,,,,,,,8691478077647731,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
18286,simple,,,"Double-Door Upright Freezer – BS1FDUF/G-83",1,0,visible,"<strong>Double-Door Upright Freezer – BS2FDUF/G-83</strong>\nThe BS2FDUF/G-83 Double-Door Upright Freezer provides exceptional freezing capacity with its spacious dual-door design. Engineered for efficiency and durability, it ensures consistent temperature control to preserve food and ingredients. Perfect for commercial kitchens and large-scale storage needs.","Double-Door Upright Freezer – BS1FDUF/G-83\n\nMODEL: BS2FDUF/G-83\n\nS/S upright double door (magnetic) freezer w/blower system (2 full door)\n\nCap 1400 L\n\nTemperature: -10 to-18°C\n\nPower: 230V-50Hz\n\nDim 1480x830x2060 mm\n\nWeight: 196 kg,\n\nMade by Berjaya, Malaysia",,,taxable,,1,,,0,0,,,,,1,,,8000,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2025/01/Doubl-Door-Upright-Freezer-–-BS1FDUF-G-83-1024x1024.jpg.webp,,,,,,,,,0,,Berjaya,Brand,Berjaya,1,1,,,,,,1,1,0,,15,0,0,,"Doubl-Door Upright Freezer",,,,,,,,field_60befc9fc0fb7,BS1FDUF/G-83,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011110011010010010000111101100100100110111000011,true,backend,9921638347852622,yes,yes,,product,no,,,,,,,,,,,,,,,,,,,9921638214519302,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
18288,simple,,,"Double-Door Upright Chiller – BS2FDUC/G-83",1,0,visible,"<strong>Double-Door Upright Chiller – BS2FDUC/G-83</strong>\nThe BS2FDUC/G-83 Double-Door Upright Chiller is designed for efficient and reliable cooling, offering ample storage space for perishable items. Its durable construction and energy-efficient performance make it an excellent choice for commercial kitchens and food service establishments.","Double-Door Upright Chiller – BS2FDUC/G-83\n\nMODEL: BS2FDUC/G-83\n\nS/S upright double door (magnetic) chiller w/ blower system (2 full door)\n\nCap 1400 L\n\nTemperature: 2-8'C\n\nPower: 230V-50Hz\n\nDim 1480x830x2060 mm\n\nWeight: 196 kg,\n\nMade by Berjaya, Malaysia",,,taxable,,1,,,0,0,,,,,1,,,6800,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2025/01/Doubl-Door-Upright-Freezer-–-BS1FDUF-G-83-1024x1024.jpg.webp,,,,,,,,,0,,Berjaya,Brand,Berjaya,1,1,,,,,,1,1,0,,59,0,0,,"Double-Door Upright Chiller,Double-Door Upright Chiller – BS2FDUC/G-83",,,,,,,,field_60befc9fc0fb7,BS2FDUC/G-83,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011110011010010010000111101100100100110111000011,true,backend,9024733550948816,yes,yes,,product,no,,,,,,,,,,,,,,,,,,,9024733390948832,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
18302,simple,,,"COMBI RANGE POWER MIXER – MP450 COMBI ULTRA",1,0,visible,"<h5 class=""serp-title"">COMBI RANGE POWER MIXER – MP450 COMBI ULTRA</h5>\nEven better performance and ergonomics!\nFor intensive use, Institutions and caterers.\nWith a maximum batch capacity of 100L, the MP 450 Combi Ultra can mix, blend, beat, knead and emulsify in no time at all.","Single phase<img src=""https://www.robot-coupe.com/bundles/rbc/build/static/images/icons/couverts.svg"" alt=""Picto couverts"" /> 100 - 300\n\nEven better performance and ergonomics!\nFor intensive use, Institutions and caterers.\nWith a maximum batch capacity of 100L, the MP 450 Combi Ultra can mix, blend, beat, knead and emulsify in no time at all.\n<h4>Performance</h4>\nHigh-power motor: +20% for greater efficiency.\nIncreased performance to optimise blending time.\n<h4>Sturdiness</h4>\nAll stainless steel foot, bell, motor cover and attachments - to make the immersion blender last longer.\nWhisk metal gear box: gears contained within 2 separate metal casings which make the gearbox very strong and resistant under heavy processing.\n<h4>Cleaning</h4>\nMoulded whisks for optimal hygiene\nThe bell and blade can be removed for easy cleaning, perfect hygiene and easy maintenance - an exclusive Robot Coupe patented system.",,,taxable,,1,,,0,0,,,,,1,,,4293,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2025/01/Robot-Coupe-MP-450-Combi-Ultra-Power-Mixer.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,,1,1,0,,65,0,0,,"COMBI RANGE POWER MIXER",,,,,,,,field_60befc9fc0fb7,"MP450 COMBI ULTRA",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,001100001100001100110110011011100110011001101101,true,backend,26536094665985525,yes,yes,,product,no,,,,,,,,,,,,,,,,,,,26536094529318872,,,,,,,,,,,,,,,,,,,,,,