14322,simple,,,"AUTOMATIC ORANGE JUICER - 09965 ARA ORANGE",1,0,visible,"Effortlessly enjoy freshly squeezed orange juice with our Automatic Orange Juicer. This innovative appliance combines convenience with efficiency, providing a quick and mess-free solution for extracting the natural goodness of oranges. Designed for ease of use, it delivers consistent results at the touch of a button, ensuring a refreshing and vitamin-rich beverage in seconds. Elevate your mornings and events with the convenience of our Automatic Orange Juicer – your go-to appliance for a burst of citrus freshness.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(88px, 100px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(2px, 190px);"" aria-expanded=""false""></div>","VERSATILE PRO\nOrange juicer fruits\nFruits per minute 22 fruits/min\nDiameter: 65-81 mm,\nCapacity: 10 kg\nPower: 220-240V/50-60HZ/50W\nConsumption 2.7A,\nDim 48x55x85.5 cm.\nNet Weight 54 kg\nMODEL: 09965 ARA ORANGE\nMade by: Zumex, Spain",,,taxable,,1,,,0,0,,,,,1,,,20350,"COFFEE & BAR LINE, COFFEE & BAR LINE > Juice Maker, Kitchen Equipment, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/01/507.jpg,,,,,,,,,0,,Zumex,Brand,Zumex,1,1,,,,,default,1,1,0,,60,0,0,,"AUTOMATIC ORANGE JUICER,عصارة برتقال أوتوماتيكية",,,,,,,,field_60befc9fc0fb7,"09965 ARA ORANGE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010010110011111001111001101100110110010010010000,true,backend,8902716996483336,yes,yes,,product,no,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14324,simple,,,"UPRIGHT DISPLAY CHILLER 4 SIDE GLASS",1,0,visible,"Experience sophistication and efficiency with our Upright Display Chiller featuring 4-side glass. Showcase your products in style while providing easy access and visibility. This sleek and modern chiller is designed for maximum visibility, ensuring your merchandise captures attention from all angles. With its spacious interior and energy-efficient features, our Upright Display Chiller is the perfect solution for displaying and preserving your products at their best. Elevate your presentation and keep things cool with this innovative and attractive display solution.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(919px, 207px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• UPRIGHT DISPLAY CHILLER 4 SIDE GLASS</p>\n<p style=""margin: 0; padding-top: 0;"">• Product Specifications:</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 420 liter/ 6 Layer shelf</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 220v/50hz/ 650w&lt;/p</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigeration Gas : 404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 700x680x1900mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Brand : Longoni&lt;/p</p>\n<p style=""margin: 0; padding-top: 0;"">• Origin : italy</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(815px, 31px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,,6825,"BAKERY LINE > Bakery Display, BAKERY LINE, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/UPRIGHT-DISPLAY-CHILLER-4-SIDE-GLASS.png,,,,,,,,,0,,Longoni,Brand,Longoni,1,1,,,,,default,1,1,0,,72,0,0,,"UPRIGHT DISPLAY CHILLER 4 SIDE GLASS,شاشة عرض عمودية مبرد 4 زجاج جانبي,4 زجاج جانبي شفاف زجاج بار الثلاجة مصنوعة في الصين",,,,,,,,field_60befc9fc0fb7,,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_657017