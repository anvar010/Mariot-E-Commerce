13888,simple,,,"MARBLE TOP CHILLER- PS902",1,0,visible,"The MARBLE TOP CHILLER - PS902 is an elegant and efficient refrigerated unit that combines style and functionality. With its luxurious marble top, it provides a sophisticated presentation for desserts, pastries, and other chilled delicacies. The refrigerated storage underneath keeps the items fresh and ready for serving. Perfect for bakeries, cafes, and upscale food establishments, this chiller adds a touch of luxury to your culinary display while maintaining optimal freshness.","<p style=""margin-bottom: 0; margin-top: 0px;"">• MARBLE TOP CHILLER- PS902</p>\n<p style=""margin: 0; padding-top: 0;"">• w/ 5 pcs. 1/3 gn container for salad</p>\n<p style=""margin: 0; padding-top: 0;"">• AISI 304 18/10 S/S exterior, except rear panel &amp; part of bottom</p>\n<p style=""margin: 0; padding-top: 0;"">• AISI 304 18/10 S/S interior, w/ water line for colecting condensing water. Magnetic gasket</p>\n<p style=""margin: 0; padding-top: 0;"">• injected polyurethane insulation, CFC free, density: 40 kgs / m3</p>\n<p style=""margin: 0; padding-top: 0;"">• Cap: 250 ltr / w/ 2 shelf &amp; 2 drs.</p>\n<p style=""margin: 0; padding-top: 0;"">• working Temp: +2˚ ~ +8° at 32° temp.</p>\n<p style=""margin: 0; padding-top: 0;"">• Power Supply: 230v / 50 Hz / 1Ph.</p>\n<p style=""margin: 0; padding-top: 0;"">• frige power: 266 Watt</p>\n<p style=""margin: 0; padding-top: 0;"">• refrigerant : R134a</p>\n<p style=""margin: 0; padding-top: 0;"">• Net Weight: 97 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1045 x 700 x 850 mm (WxDxH)</p>\n<p style=""margin: 0; padding-top: 0;"">• Digital : DIXELL / ITALY MADE</p>\n<p style=""margin: 0; padding-top: 0;"">• compressor : ASPERA / EMBRACO / ITALY</p>\n<p style=""margin: 0; padding-top: 0;"">• PS902 / mariot made</p>\n<p style=""margin: 0; padding-top: 0;"">• ISO9001, CE&amp;ROHS approved</p>",,,taxable,,1,,,0,0,,,,,1,,2738,2966,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/MARBLE-TOP-CHILLER-PS902.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,"Type of Product","MARBLE TOP CHILLER",1,1,default,1,1,0,,65,0,0,,"MARBLE TOP CHILLER",,,,,,,,field_60befc9fc0fb7,PS902,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15753,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010111100001110010000110101110100101101011100001,false,,,,,,,,salescountdowntimer,Model,PS902,1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13890,simple,,,"Marble Top Chiller - PS903",1,0,visible,"The MARBLE TOP CHILLER - PS903 is an elegant and efficient refrigerated unit that combines style and functionality. With its luxurious marble top, it provides a sophisticated presentation for desserts, pastries, and other chilled delicacies. The refrigerated storage underneath keeps the items fresh and ready for serving. Perfect for bakeries, cafes, and upscale food establishments, this chiller adds a touch of luxury to your culinary display while maintaining optimal freshness.","<p style=""margin-bottom: 0; margin-top: 0px;"">• MARBLE TOP CHILLER- S903</p>\n<p style=""margin: 0; padding-top: 0;"">• w/ 7 pcs. 1/6 gn container for salad</p>\n<p style=""margin: 0; padding-top: 0;"">• condensing water. Magnetic gasket</p>\n<p style=""margin: 0; padding-top: 0;"">• injected polyurethane insulation</p>\n<p style=""margin: 0; padding-top: 0;"">• CFC free, density: 40 kgs / m3</p>\n<p style=""margin: 0; padding-top: 0;"">• w/ 2 shelf &amp; 3 drs.</p>\n<p style=""margin: 0; padding-top: 0;"">• working Temp: +2˚ ~ +8° at 32° temp.</p>\n<p style=""margin: 0; padding-top: 0;"">• Power Supply: 230v / 50 Hz / 1Ph.</p>\n<p style=""margin: 0; padding-top: 0;"">• frige power: 266 Watt</p>\n<p style=""margin: 0; padding-top: 0;"">• refrigerant : R134a</p>\n<p style=""margin: 0; padding-top: 0;"">• Net Weight: 97 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1360 x 700 x 850 mm (WxDxH)</p>\n<p style=""margin: 0; padding-top: 0;"">• Digital : DIXELL / ITALY MADE</p>\n<p style=""margin: 0; padding-top: 0;"">• compressor : ASPERA / EMBRACO / ITALY</p>\n<p style=""margin: 0; padding-top: 0;"">• PS903/G/ mariot made</p>\n<p style=""margin: 0; padding-top: 0;"">• ISO9001, CE&amp;ROHS approved</p>",,,taxable,,1,,,0,0,,,,,1,,,4362,"REFRIGERATION LINE > Freezer & Chillers, Kitchen Equipment, REFRIGERATION LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/Marble-Top-Chiller1-–-PS903.png,,,,