14464,simple,,,"Bar Cooler - GN1100TN/W",1,0,visible,"The Bar Cooler GN1100TN/W is a sleek and efficient refrigeration unit designed specifically for bar settings, offering reliable cooling for beverages and perishables. With its compact yet spacious design, it seamlessly integrates into bar counters, providing easy access to chilled drinks and ingredients while maximizing available space.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Bar Cooler - GN1100TN/W</p>\n<p style=""margin: 0; padding-top: 0;"">• Single s/s door frame.</p>\n<p style=""margin: 0; padding-top: 0;"">• Double layer glazed with outside thoughened glass hinge door.</p>\n<p style=""margin: 0; padding-top: 0;"">• Two levels of shelving plus floor</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature:+2～+8℃</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 600*520*850 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• GN1100TN/W / Inofrigo made/Italian Technology""</p>",,,taxable,,1,,,0,0,,,,,1,,,1719,"BAKERY LINE > Bakery Display, BAKERY LINE, REFRIGERATION LINE > Display Chiller, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/Bar-Cooler-GN1100TN-W.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,,,,,default,1,1,0,,74,0,,,"Bar Cooler",,,,,,,,field_60befc9fc0fb7,GN1100TN/W,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,111100100001111000110110000110001111011001000011,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
