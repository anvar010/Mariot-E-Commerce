13550,simple,,,"AUTOMATIC CENTRIFUGAL JUICER - J100 ULTRA",1,0,visible,"The Robot Coupe J100 Ultra Automatic Centrifugal Juicer is a powerful and efficient juicing machine designed for professional use. It features a robust 1.4 HP motor, capable of producing large quantities of juice quickly and continuously. The automatic feed system allows for non-stop juicing without the need for manual intervention, and its large feed chute accommodates whole fruits and vegetables, reducing prep time. Constructed with durable stainless steel, the J100 Ultra includes a large capacity pulp container and is designed for easy cleaning and maintenance, making it ideal for high-demand environments such as juice bars, restaurants, and catering services.","<p style=""margin-bottom: 0; margin-top: 0px;"">• AUTOMATIC CENTRIFUGAL JUICER with removable stainless steel basket for easy cleaning &amp; stainless steel bowl</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 160Liters/ h Container</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 7.2 L</p>\n<p style=""margin: 0; padding-top: 0;"">• Motor Base: 1000Watts</p>\n<p style=""margin: 0; padding-top: 0;"">• Speed: 3000 rpm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 596x235 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 54.4 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• J100 ULTRA | Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,,8853,"FOOD PROCESSING, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/j100.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,54,0,0,,"AUTOMATIC CENTRIFUGAL JUICER,AUTOMATIC CENTRIFUGAL JUICER - J100 ULTRA,J100 ULTRA",,,,,,,,field_60befc9fc0fb7,"J100 ULTRA",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596259,110011110000110011000110010110011000111001100011,true,backend,,,,,