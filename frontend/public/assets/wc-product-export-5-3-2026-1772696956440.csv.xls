13868,simple,,,"Gas Fryer OFG 342 - 8000",1,0,visible,"The Henny Penny Gas Fryer OFG 342 - 8000 is a top-of-the-line commercial fryer designed to deliver efficient and consistent frying performance. This gas-powered fryer is built with precision and reliability in mind, allowing for fast and high-capacity frying of delicious, crispy food items. Its advanced features and durable construction make it an ideal choice for restaurants, food establishments, and catering businesses looking to enhance their frying capabilities and deliver exceptional results to their customers.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Henny Penny 342 - 8000</p>\n<p style=""margin: 0; padding-top: 0;"">• Henny Penny High volume gas two well open Fryer</p>\n<p style=""margin: 0; padding-top: 0;"">• full (2) basket size, 90 lb (43 liter) oil capacity per vat, Builtin filtration with over-the-top oil return to flush remnants</p>\n<p style=""margin: 0; padding-top: 0;"">• computron 8000 control Proportional control,16- character digital display with multiple language settings</p>\n<p style=""margin: 0; padding-top: 0;"">• 4 heavy-duty casters, 2 locking, without direct connect system</p>\n<p style=""margin: 0; padding-top: 0;"">• 6 burners, 240,000 BTU/HR. 230V/50Hz/1Ph. LPG</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1131 x 1042 x 1270 mm (H)</p>\n<p style=""margin: 0; padding-top: 0;"">• OFG 342 - 8000 / HENNY PENNY / USA</p>",,,taxable,,1,,,0,0,,,,,0,,,99989,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/11-3-scaled.png,,,,,,,,,0,,"Henny Penny",Brand,"Henny Penny",1,1,,,,,default,1,1,0,,70,0,0,,"Gas Fryer",,,,,,,,field_60befc9fc0fb7,"OFG 342 - 8000",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15744,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596418,110101011100111000101000001100101000011101001111,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13870,simple,,,"Gas Fryer OFG 323 - 8000",1,0,visible,"The Henny Penny Gas Fryer OFG 323 – 8000 is a high-quality commercial fryer designed for efficient and reliable frying operations. This gas-powered fryer offers excellent performance, allowing users to prepare large batches of crispy and delicious fried food quickly. With its advanced features and sturdy construction, it is an ideal choice for restaurants, food establishments, and catering businesses seeking to enhance their frying capabilities.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Gas Fryer OFG 323 - 8000</p>\n<p style=""margin: 0; padding-top: 0;"">• Henny Penny stainless steel Three well gas open fryer</p>\n<p style=""margin: 0; padding-top: 0;"">• built in filtration, with computron control</p>\n<p style=""margin: 0; padding-top: 0;"">• 12 programmable cook cycles</p>\n<p style=""margin: 0; padding-top: 0;"">• digital time and temperature display, dual timers to time half baskets separately, idle and melt modes</p>\n<p style=""margin: 0; padding-top: 0;"">• load compensation feature, cook cycle completion signal, easy basket set and release</p>\n<p style=""margin: 0; padding-top: 0;"">• product capacity 20.4 Kg. Shortening capacity 88.5 Kg. Fryer throughput 98.1Kg/hr. 255,000 BTU/HR. LPG</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1254 x 949 x 1118 mm (H)</p>\n<p style=""margin: 0; padding-top: 0;"">• OFG 323 - 8000 / HENNY PENNY / USA</p>",,,taxable,,1,,,0,0,,,,,0,,,99959,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/mariot-all-product-scaled-1.jpg,,,,,,,,,0,,"Henny Penny",Brand,"Henny Penny",1,1,Electric/Gas,Gas,1,1,default,1,1,0,,84,0,0,,"Gas Fryer",,,,,,,,field_60befc9fc0fb7,"OFG 323 - 8000",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15745,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596418,011100011001110010001001111110000001101001100111,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13872,simple,,,"Gas Fryer OFG 322 - 8000",1,0,visible,"The Henny Penny Gas Fryer OFG 322 - 8000 is a high-performance commercial fryer designed to deliver efficient frying results. Powered by gas, this fryer offers quick and reliable frying for a variety of food items. Its top-notch features and sturdy construction make it a dependable choice for restaurants, food service establishments, and catering businesses aiming to elevate their frying capabilities. With the OFG 322 - 8000, you can achieve crispy and delicious fried dishes to satisfy your customers' appetites.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Gas Fryer OFG 322 - 8000</p>\n<p style=""margin: 0; padding-top: 0;"">• Henny penny stainless steel Gas operated 2 wells open fryer built in filtration</p>\n<p style=""margin: 0; padding-top: 0;"">• with computron control, with 2 basket support</p>\n<p style=""margin: 0; padding-top: 0;"">• idle and melt modes, load compensation feature</p>\n<p style=""margin: 0; padding-top: 0;"">• built-in filter system, 13.6 Kg product capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• 59 Kg pot capacity for shortening capacity, LPG gas</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 847 x 949 x 1118 mm (H)</p>\n<p style=""margin: 0; padding-top: 0;"">• OFG 322 - 8000 / HENNY PENNY / USA</p>",,,taxable,,1,,,0,0,,,,,0,,,75999,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/mariot-all-product-scaled-1.jpg,,,,,,,,,0,,"Henny Penny",Brand,"Henny Penny",1,1,Electric/Gas,Gas,1,1,default,1,1,0,,84,0,0,,"Gas Fryer",,,,,,,,field_60befc9fc0fb7,"OFG 322 - 8000",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15746,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596418,011100011001110010001001111110000001101001100111,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13873,simple,,,"Electric Pressure Fryer PFE 500 - 8000",1,0,visible,"The Electric Pressure Fryer PFE 500/8000 is a state-of-the-art commercial fryer designed to deliver exceptional frying performance. This innovative fryer utilizes pressure cooking technology to achieve faster cooking times and retain the natural flavors and moisture of the food. With its electric-powered operation, it ensures consistent and efficient frying of various food items, making it a perfect choice for restaurants, foodservice establishments, and catering businesses. The PFE 500/8000's advanced features and sturdy construction guarantee reliable and delicious results, providing customers with crispy and succulent fried dishes.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Electric Pressure Fryer PFE 500 - 8000</p>\n<p style=""margin: 0; padding-top: 0;"">• Henny Penny stainless steel electric pressure fryer with computer control pane</p>\n<p style=""margin: 0; padding-top: 0;"">• with filtration stainless steel 4 tier basket and 6.4 kg food product capacity (4-head chicken capacity)</p>\n<p style=""margin: 0; padding-top: 0;"">• cleaning accessories (1 tube of Molycote lube) 21.7 kg shortening capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• 13.5 KW., 380V/50Hz/3P</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 486 x 968 x 1219 mm (H)</p>\n<p style=""margin: 0; padding-top: 0;"">• PFE 500 – 8000 / HENNY PENNY / USA</p>",,,taxable,,1,,,0,0,,,,,0,,,67999,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/11-scaled-1.jpg,,,,,,,,,0,,"Henny Penny",Brand,"Henny Penny",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,72,0,0,,"Electric Pressure Fryer",,,,,,,,field_60befc9fc0fb7,"PFE 500 - 8000",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15747,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010010000011000111100111001100100111101001101,,,,,,,,,,"Type of Product","Electric Pressure Fryer",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13875,simple,,,"Gas Pressure Fryer PFG 600 - 8000",1,0,visible,"The Gas Pressure Fryer PFG 600 - 8000 is a high-quality commercial fryer designed to deliver outstanding frying results. This fryer utilizes pressure cooking with gas-powered operation to achieve faster cooking times while ensuring the food retains its natural flavors and moisture. With its advanced features and sturdy construction, it offers efficient and consistent frying for various food items. Ideal for restaurants, foodservice establishments, and catering businesses, the PFG 600 - 8000 guarantees deliciously crispy and flavorful fried dishes that will delight customers.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Gas Pressure Fryer PFG 600 - 8000</p>\n<p style=""margin: 0; padding-top: 0;"">• Henny Penny stainless steel Gas pressure fryer complete with built-in filter</p>\n<p style=""margin: 0; padding-top: 0;"">• computer control panel</p>\n<p style=""margin: 0; padding-top: 0;"">• stainless steel 3 tier basket with handle, short frame with 4 casters</p>\n<p style=""margin: 0; padding-top: 0;"">• cleaning accessories 1 tube of Molycote lube 5.7 kg food product capacity (4 head chicken capacity)</p>\n<p style=""margin: 0; padding-top: 0;"">• 19.5 kg shortening capacity, LPG, 80,000 BTU/hr</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 486 x 968 x 1219 mm (H)</p>\n<p style=""margin: 0; padding-top: 0;"">• PFG 600 - 8000 / HENNY PENNY / USA</p>",,,taxable,,1,,,0,0,,,,,0,,,73188,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/11-scaled-1.jpg,,,,,,,,,0,,"Henny Penny",Brand,"Henny Penny",1,1,Electric/Gas,Gas,1,1,default,1,1,0,,72,0,0,,"Gas Pressure Fryer",,,,,,,,field_60befc9fc0fb7,"PFG 600 - 8000",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15748,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010010000011000111100111001100100111101001101,,,,,,,,,,"Type of Product","gas pressure fryer",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13876,simple,,,"Gas Fryer PH155CSE",1,0,visible,"The Frymaster Gas Fryer PH155CSE is a top-of-the-line commercial fryer designed to deliver exceptional frying performance. With its advanced features and sturdy construction, this fryer ensures efficient and consistent frying of various food items. The PH155CSE model from Frymaster is known for its reliability and user-friendly design, making it an ideal choice for restaurants, food establishments, and catering businesses looking to enhance their frying capabilities and serve delicious, crispy fried dishes to their customers.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Gas Fryer PH155CSE</p>\n<p style=""margin: 0; padding-top: 0;"">• Frymaster high efficiency gas fryer, floor model, 50 lb. capacity each</p>\n<p style=""margin: 0; padding-top: 0;"">• CM3.5 controllers, includes: rack-type basket support</p>\n<p style=""margin: 0; padding-top: 0;"">• basket hanger &amp; twin baskets, (SE finish)</p>\n<p style=""margin: 0; padding-top: 0;"">• stainless steel fry pot, end &amp; sides, legs, 80,000 BTU, LPG, 230V/50Hz/1Ph.</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 397 x 753 x 1158 mm (H)</p>",,,taxable,,1,,,0,0,,,,,0,,,31800,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment, Top Brands",,,https://mariotstore.com/wp-content/uploads/2024/10/1-13-scaled-1.jpg,,,,,,,,,0,,Frymaster,Brand,Frymaster,1,1,,,,,default,1,1,0,,9,0,0,,,,,,,,,,field_60befc9fc0fb7,PH155CSE,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595055,011000001100110011011100110110011111000101001001,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13878,simple,,,"Electric Fryer RE117 SE",1,0,visible,"The Electric Fryer RE117 SE is a high-quality fryer made in the USA. This commercial electric fryer is designed to deliver excellent frying performance with its advanced features and reliable construction. It offers efficient and consistent frying of various food items, making it a top choice for restaurants, food establishments, and catering businesses. With its ""Made in USA"" quality and craftsmanship, the RE117 SE electric fryer ensures that you can serve delicious and crispy fried dishes to your customers with confidence.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Electric Fryer RE117 SE</p>\n<p style=""margin: 0; padding-top: 0;"">• Frymaster high efficiency electric fryer</p>\n<p style=""margin: 0; padding-top: 0;"">• Digital Controller</p>\n<p style=""margin: 0; padding-top: 0;"">• Floor model 50 lb capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• Open frypot design</p>\n<p style=""margin: 0; padding-top: 0;"">• Automatic melt cycle</p>\n<p style=""margin: 0; padding-top: 0;"">• Boil out temperature control</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature probe</p>\n<p style=""margin: 0; padding-top: 0;"">• Includes: rack-type basket support</p>\n<p style=""margin: 0; padding-top: 0;"">• Basket hanger &amp; twin baskets</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel frypot &amp; door, cabinet</p>\n<p style=""margin: 0; padding-top: 0;"">• 17 KW 380V/50Hz/3Ph</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 397 x 786 x 1152 mm (H)</p>",,,taxable,,1,,,0,0,,,,,0,,,30600,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment, Top Brands",,,https://mariotstore.com/wp-content/uploads/2024/10/111-2-scaled.png,,,,,,,,,0,,Frymaster,Brand,Frymaster,1,1,Electric/Gas,Electric,1,1,default,1,1,0,,9,0,0,,,,,,,,,,field_60befc9fc0fb7,"RE117 SE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,def