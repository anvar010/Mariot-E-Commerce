11601,simple,,,"ELECTRIC BAIN MARIE BM-30 EL",1,0,visible,"The ELECTRIC BAIN MARIE BM-30 EL is a versatile and efficient kitchen appliance designed to facilitate precise temperature control for various cooking and food preparation tasks. This particular model, the BM-30 EL, offers a range of features and benefits that make it a valuable addition to commercial kitchens, catering businesses, or even home kitchens where consistent and controlled heating is required.\n<div id=""mttContainer"" aria-expanded=""false""></div>","• GN 1/1 - 150\n\n• Input / Power: 1.5 kw\n\n• Voltage 230 V / 50 HZ\n\n• Weight 14 kg\n\n• Dim: 330 x 600 x 290 mm\n\n• BM-30 EL / RM GASTRO / Europe made",,,taxable,,1,,,0,0,,,,,1,,,1476,"COOKING LINE, COOKING LINE > Food Warmers",,,https://mariotstore.com/wp-content/uploads/2024/10/BM-30-EL.jpg,,,,,,,,,0,,"RM Gastro",Brand,"RM Gastro",1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,62,0,0,,"ELECTRIC BAIN MARIE",,,,,,,,field_60befc9fc0fb7,"BM-30 EL",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15711,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595072,110011011001011000011001111100111000110000111000,true,backend,29006269112305101,yes,yes,,product,no,,Series,"Table Top",1,1,"Type of Product","Bin Marrie",1,1,,,,,,,,,,,,
11603,simple,,,"ELECTRIC BAIN MARIE BM-60 EL",1,0,visible,"The ELECTRIC BAIN MARIE BM-60 EL is a versatile and essential piece of kitchen equipment designed to facilitate the precise and controlled heating of various culinary ingredients, making it ideal for commercial kitchens, catering services, and restaurants. This specific model, the BM-60 EL, offers a range of features and functionalities that make it a valuable addition to any professional kitchen.\n<div id=""mttContainer"" aria-expanded=""false""></div>","• GN 1/1 - 150\n\n• Input / Power: 3 kw\n\n• Heat Temp: 30 - 900C\n\n• Power / voltage: 3 kw / 230V /1N\n\n• Gross weight: 35,9 kg\n\n• Net weight: 22,8 kg\n\n• Dim: 660 x 600 x 290 mm\n\n• BM-60 EL / RM GASTRO / europe made",,,taxable,,1,,,0,0,,,,,1,,,3470.6,"COOKING LINE, COOKING LINE > Food Warmers, Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/BM-60-EL_Visualization-scaled-1.jpg,,,,,,,,,0,,"RM Gastro",Brand,"RM Gastro",1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,62,0,0,,"ELECTRIC BAIN MARIE",,,,,,,,field_60befc9fc0fb7,"BM-60 EL",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15712,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595562,010111110100111010001000110100001101101100011100,true,backend,,,,,,,salescountdowntimer,Series,"Table Top",1,1,"Type of Product","Bin Marrie",1,1,10:00,10:00,,,,,,,,,2602.95,
