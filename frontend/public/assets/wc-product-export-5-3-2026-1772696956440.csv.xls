13745,simple,,,"ELECTRIC COOKER - SPL 740 E",1,0,visible,"The ELECTRIC COOKER SPL 740 E is a versatile and modern kitchen appliance designed to streamline your cooking process and help you prepare a wide range of delicious meals. This electric cooker comes equipped with numerous features and functions, making it an indispensable addition to your kitchen.\n<div id=""mttContainer"" style=""transform: translate(226px, 146px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(727px, 201px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(511px, 52px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(682px, 201px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(308px, 70px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","ELECTRIC COOKER - SPL 740 E\nBoiling unit 2 x 3 kW on a neutral cabinet, with a door as an option\nInternal thermostatic protection inside each plate\nPressed upper plate for comfortable maintenance\nPower / Voltage : 6kW\nDim : 440 x 800 x 1080\nNet-Gross Weight : 60\nSPL 740 E / RM GASTRO / Made in Europe",,,taxable,,1,,,0,0,,,,,1,,,3742,"COOKING LINE > Cooker, COOKING LINE, Kitchen Equipment, COOKING LINE > Cooker > Series 700",,,https://mariotstore.com/wp-content/uploads/2024/10/SPL-740-E.png,,,,,,,,,0,,"RM Gastro",Brand,"RM Gastro",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,56,0,0,,"ELECTRIC COOKER,طباخ كهربائي – SPL 740 E,طباخ كهربائي",,,,,,,,field_60befc9fc0fb7,"SPL 740 E",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15739,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596343,001101101100101100000100110011001001101101100111,true,