13528,simple,,,"VEGETABLE PREPARATION MACHINE - CL 50E",1,0,visible,"The CL 50E Vegetable Preparation Machine is a high-performance kitchen essential, engineered for swift and precise vegetable processing. With its robust design and cutting-edge technology, this machine effortlessly slices, dices, grates, and juliennes a variety of vegetables. Its user-friendly interface, adjustable settings, and durable construction make it an ideal choice for commercial kitchens. Elevate your culinary efficiency and consistency with the CL 50E Vegetable Preparation Machine.","<p style=""margin-bottom: 0; margin-top: 0px;"">• VEGETABLE PREPARATION MACHINE - CL 50E</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 550W-1Ph-1</p>\n<p style=""margin: 0; padding-top: 0;"">• Speed-375rpm Voltage: 230V/ 50/1 UK plug</p>\n<p style=""margin: 0; padding-top: 0;"">• Induction Motor: Magnetic safety system &amp; motor brake Motor base made in Polycarbonate</p>\n<p style=""margin: 0; padding-top: 0;"">• Automatic restart of the machine with a pusher.</p>\n<p style=""margin: 0; padding-top: 0;"">• With a metal bowl and lid. Removable bowl</p>\n<p style=""margin: 0; padding-top: 0;"">• Equipped with hoppers - 1 large hopper</p>\n<p style=""margin: 0; padding-top: 0;"">• area - 139 cm² 1 cylindrical hopper (0-58 mm dia)</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 380x305x595 mm Weight 19.8 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• CL 50E | Made by <a href=""https://mariotstore.comold/brand/robot-coupe/"">Robot Coupe</a></p>",,,taxable,,1,,,0,0,,,,,1,,7950,8880,"FOOD PROCESSING, Special Offer, FOOD PROCESSING > Vegtable Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/cl50.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,57,0,0,,"VEGETABLE PREPARATION MACHINE - CL 50E",,,,,,,,field_60befc9fc0fb7,"CL 50E",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,de