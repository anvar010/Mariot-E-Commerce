13548,simple,,,"FOOD PROCESSOR CUTTER & VEGETABLE SLICER - R301 D",1,0,visible,"The Robot Coupe R301 D is a versatile and robust food processor and vegetable slicer, designed for professional kitchens. It features a powerful 1 HP motor, making it efficient for a wide range of food processing tasks, including chopping, slicing, grating, and pureeing. The R301 D comes with a 3.5-liter stainless steel bowl, a smooth blade assembly, and various cutting discs for different types of cuts. Its ergonomic design ensures ease of use and quick assembly, while the high-quality construction ensures durability and reliability for heavy-duty use in restaurants, catering services, and other food service operations.","<p style=""margin-bottom: 0; margin-top: 0px;"">• FOOD PROCESSOR CUTTER &amp; VEGETABLE SLICER - R301 D</p>\n<p style=""margin: 0; padding-top: 0;"">• Cap: 3.7 Liters</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 650W-1Ph-230V-1500rpm pulse control</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 325X300X550 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 16.1 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• PACK 5pcs DISC slicers 2mm 4mm</p>\n<p style=""margin: 0; padding-top: 0;"">• grater 2mm julienne 4x4mm 8x8mm</p>\n<p style=""margin: 0; padding-top: 0;"">• R301 D | Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,,8712,"FOOD PROCESSING, Special Offer, FOOD PROCESSING > Vegtable Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/R301-D.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,60,0,0,,"FOOD PROCESSOR,FOOD PROCESSOR CUTTER & VEGETABLE SLICER - R301 D",,,,,,,,field_60befc9fc0fb7,"R301 D",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595316,011110100100111001100110110110000101101101000001,true,backend,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,