13117,simple,,,"ISLAND TYPE SUPERMARKET FREEZER - CL 700 MDSL",1,0,visible,"The ISLAND TYPE SUPERMARKET FREEZER – CL 700 MDSL is a versatile and spacious freezer designed to meet the freezing needs of supermarkets and grocery stores. With its island-style layout, this freezer offers ample storage space for a wide variety of frozen products, allowing for efficient organization and display. Its modern design and transparent glass lids provide visibility to the items inside, enticing customers and making it easier for them to locate their desired products. The CL 700 MDSL freezer is an essential addition to any retail environment, ensuring that frozen goods are stored in optimal conditions while enhancing the overall shopping experience.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• Volume: 698 Ltr</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Horizontal LED illumination</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Embraco compressor</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Electronic thermostat</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Lock and key</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Low-e coasted Glass</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Temperature: -15 / -23°C</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Net Weight: 171 kg</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Voltage: 230V/ 1 Phase</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Internal Dim: 2110 x 870 x 930 mm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• CL 700 MDSL / MARIOT/ Turkey made</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(122px, 40px); text-align: left;"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,6494,7640,"SUPERMARKET EQUIPMENT > Fish Display, Special Offer, SUPERMARKET EQUIPMENT",,,"https://mariotstore.com/wp-content/uploads/2024/10/ISLAND-TYPE-SUPERMARKET-FREEZER-CL-700-MDSL.png, https://mariotstore.com/wp-content/uploads/2024/10/ISLAND-TYPE-SUPERMARKET-FREEZER.jpg",,,,,,,,,0,,Mariot,Brand,Mariot,1,1,,,,,default,1,1,130,index,68,185,0,,"ISLAND TYPE SUPERMARKET FREEZER",,,,,,,,field_60befc9fc0fb7,"CL 700 MDSL",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596105,001111001110111100001100000010000000111110011111,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13120,simple,,,"Super Runner Gas Fryer - SR42G",1,0,visible,"<strong>Designed For All-Purpose Usage</strong>\nFry a wide variety of products with Dean’s Super Runner fryers which easily accommodate items from French fries to main entree menu selections. The fryers are available in three oil capacities utilizing 43 lbs., 50 lbs. and 75 lbs. of oil.\n\nMake the most of your energy dollars with Dean’s exclusive Thermo-Tube design. The heating tubes provide a large oil contact surface. Flow-tube baffles control the transfer of heat into the oil. Dean’s wide cold zone frypot protects oil integrity by trapping debris under the cooking area, preventing carbonization of particles and wasteful oil deterioration.\n\nDean’s durable temperature probe assures prompt recovery which reduces time lost between loads and requires no electrical hookup.\n\nDean’s Super Runner gas fryers achieve dependability through simplicity of design, durable stainless steel baffles and rugged cast iron burners.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Dean pro-gas-operated single tank fryer</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel pot</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel door</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel two half baskets</p>\n<p style=""margin: 0; padding-top: 0;"">• Millivolt pilot system</p>\n<p style=""margin: 0; padding-top: 0;"">• LPG Gas</p>\n<p style=""margin: 0; padding-top: 0;"">• Oil Cap: 21ltr</p>\n<p style=""margin: 0; padding-top: 0;"">• 105,000 BTU/hr</p>\n<p style=""margin: 0; padding-top: 0;"">• Basket Dim: 35 x 34.9 x 10.7 cm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight 150 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 394 x 740 x 1140 mm(H)</p>\n<p style=""margin: 0; padding-top: 0;"">• Model: SR142G/ DEAN By Frymaster / USA Made</p>",,,taxable,,1,,,0,0,,,,,0,,,7550,"COOKING LINE, COOKING LINE > Fryers, Top Brands",,,https://mariotstore.com/wp-content/uploads/2024/10/SR42G-Super-Runner-Gas-Fryer.png,,,,,,,,,0,,Frymaster,Electric/Gas,Gas,1,1,Brand,Frymaster,1,1,default,1,1,201,index,8,146,0,,"Gas Fryer - SR142G",,,,,,,,field_60befc9fc0fb7,SR142G,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no,,,,,,,,,,,,,,010010011001111001111000110100110100110001011001,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
