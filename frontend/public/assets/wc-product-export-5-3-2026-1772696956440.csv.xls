12149,simple,,,"TABLE TOP CUTTER MIXER-R5A / 230",1,0,visible,"The TABLE TOP CUTTER MIXER-R5A / 230 is a versatile, high-performance kitchen appliance designed for professional use. Ideal for restaurants, catering services, and culinary schools, this cutter mixer features a powerful 230V motor and a robust stainless steel bowl with a large capacity. It excels in chopping, grinding, kneading, and emulsifying various ingredients, ensuring consistent and precise results every time. Its compact, tabletop design saves space while providing the efficiency and reliability needed in busy kitchen environments.","<p style=""margin-bottom: 0;margin-top: 0px"">• MIXER Cap: 5.5 Liter</p>\n<p style=""margin: 0;padding-top: 0"">• w/ stainless steel bowl, 2 stainless steel\nstraight blade knife</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 1100W-single phase-230V-1500 rpm UK plug</p>\n<p style=""margin: 0;padding-top: 0"">• Dim: 280 X 350 X 490 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Gross Weight: 23.5 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,,12207,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING, Special Offer, Top Brands",,,https://mariotstore.com/wp-content/uploads/2024/10/r5-plus-scaled.png,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,"Type of Product","Table Top Cutter Mixer",1,1,default,1,1,0,index,60,0,0,,"TABLE TOP CUTTER MIXER-R5A / 230",,,,,,,,field_60befc9fc0fb7,"R5A / 230",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595733,110000110000110010111101100100111100110101100001,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12151,simple,,,"MICROMIX POWER MIXER-MICROMIX",1,0,visible,"The Micromix Power Mixer is a compact and efficient kitchen tool designed for quick and easy blending tasks. With its powerful motor and ergonomic design, this mixer is perfect for creating smooth soups, sauces, and purees. The Micromix is equipped with a reliable and durable blade, ensuring consistent results every time. Its compact size makes it ideal for small kitchens or busy culinary environments where space is a premium. The Micromix Power Mixer is a reliable choice for chefs and home cooks seeking a versatile and space-saving solution for their blending needs.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Blade, Aeromix and Tube are 100%</p>\n<p style=""margin: 0; padding-top: 0;"">• stainless steel and detachable</p>\n<p style=""margin: 0; padding-top: 0;"">• delivered with 1 stainless steel wall support</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 220 watts 240V / 50 / 1 UK plug</p>\n<p style=""margin: 0; padding-top: 0;"">• Single phase</p>\n<p style=""margin: 0; padding-top: 0;"">• Speed: 1500 to 14000 rpm</p>\n<p style=""margin: 0; padding-top: 0;"">• Tube length: 165 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 1.4 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: length 430 mm, Ø 61 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,,1307,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/MICROMIX-POWER-MIXER.jpg,,,,,,,,,0,,"Robot Coupe","Type of Product","Power Mixer",1,1,Brand,"Robot Coupe",1,1,default,1,1,0,index,61,0,0,,"MICROMIX POWER MIXER,MICROMIX POWER MIXER-MICROMIX",,,,,,,,field_60befc9fc0fb7,MICROMIX,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595262,011001001100111001101100