12754,simple,,,"ICE CREAM MACHINE WITH STAND KLS-F626",1,0,visible,"The ICE CREAM MACHINE WITH STAND KLS-F626 is a powerful and versatile appliance designed for commercial use. This machine, equipped with a sturdy stand, provides a stable and convenient setup for any ice cream production environment. It operates on a 220-240V power supply, ensuring efficient and consistent ice cream making. The KLS-F626 model features user-friendly controls and a robust build, ideal for producing a variety of delicious frozen treats with ease. Its integrated stand allows for optimal placement and accessibility, making it a perfect addition to ice cream shops, cafes, and restaurants.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity:36 liters</p>\n<p style=""margin: 0; padding-top: 0;"">• Rated production:36 l / h</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor:EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage:220-240v / 50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power:2400w</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant:R22 / R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise:48db</p>\n<p style=""margin: 0; padding-top: 0;"">• Ice cream temperature up to -7 to -8 degrees Celsius</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight 130kg</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM:715*560*1380mm</p>\n<p style=""margin: 0; padding-top: 0;"">• KLS-F626 / MKE-MATIC</p>",,,taxable,,0,,,0,0,,,,,0,,,6036,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Ice Cream Machine With Stand",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,64,376,0,,"ICE CREAM MACHINE WITH STAND KLS-F626",,,,,,,,field_60befc9fc0fb7,KLS-F626,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011010011011011010010011001100100100110001100111,