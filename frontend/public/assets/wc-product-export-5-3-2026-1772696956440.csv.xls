13574,simple,,,"Juice Extractor Miracle Edition - 68A",1,0,visible,,"<p style=""margin-bottom: 0;margin-top: 0px"">• Juice Extractor Miracle Edition - 68A</p>\n<p style=""margin: 0;padding-top: 0"">• Commercial juicer Full stainless steel</p>\n<p style=""margin: 0;padding-top: 0"">• The Miracle edition offers high efficiency and is adapted to intensive use.</p>\n<p style=""margin: 0;padding-top: 0"">• Perfect filtration for high-quality juice: large basket heavy-duty quiet induction motor.</p>\n<p style=""margin: 0;padding-top: 0"">• This new-generation juice extractor ""Miracle Edition"" 68 is the result of Santos 60 years of worldwide experience.</p>\n<p style=""margin: 0;padding-top: 0"">• Powerful, robust, and easy to clean, it is the must-have</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 220-240 V-50/60 Hz-1300 W</p>\n<p style=""margin: 0;padding-top: 0"">• Average output: 140 l/h</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: Net 26 kg Packed: 28.8 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Dimensions: 32W x 48D x 58H cm Packed: 37W x 66Dx 59 cm</p>\n<p style=""margin: 0;padding-top: 0"">• Made in France | Santos Brand</p>",,,taxable,,1,,,0,0,,,,,1,,,11080,"COFFEE & BAR LINE, COFFEE & BAR LINE > Juice Maker, Special Offer",,,"https://mariotstore.com/wp-content/uploads/2024/10/SANTOS_68_Juice-Extractor_G_hd.jpg, https://mariotstore.com/wp-content/uploads/2024/10/1-3-1.png",,,,,,,,,0,,Santos,Brand,Santos,1,1,,,,,default,1,1,0,,9,0,0,,,,,,,,,,field_60befc9fc0fb7,68A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110110100100110010010110100100110101101101000110,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
