13554,simple,,,"MINI RANGE POWER MIXER - MINI MP240 VV",1,0,visible,"The MINI MP240 VV is a miniature power mixer that combines performance and portability. With its compact design, it is suitable for small venues, home studios, or on-the-go audio mixing needs. Despite its size, this mixer is equipped with powerful features to deliver high-quality sound control.","<p style=""margin-bottom: 0; margin-top: 0px;"">• MINI RANGE POWER MIXER - MINI MP240 VV</p>\n<p style=""margin: 0; padding-top: 0;"">• all stainless steel knife, bell disc, and tube, delivered with 1 stainless steel wall support, and a foot with removable bell</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 290 watts Single phase</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 2.5 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Speed: 2000 to 12500 rpm</p>\n<p style=""margin: 0; padding-top: 0;"">• Tube length: 240 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: length 535 mm, Ø 78 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MINI MP240 VV | Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,,2250,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/mini-mp-240.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,5,0,0,,,,,,,,,,field_60befc9fc0fb7,"MINI MP240 VV",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595581,011001001100110011001001100110011001100110110011,true,backend,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13556,simple,,,"COMBI RANGE POWER MIXER - MP550 ULTRA",1,0,visible,"The RANGE POWER MIXER - MP550 ULTRA is a powerful and versatile hand mixer engineered for professional kitchens and large-scale food preparation. Equipped with a high-performance motor, this mixer is capable of handling heavy-duty tasks such as blending, mixing, and pureeing a variety of ingredients directly in pots or containers. Its ergonomic design ensures comfortable and safe operation, even during prolonged use. The MP550 ULTRA features durable construction and easy-to-clean components, making it an essential tool for chefs and food service professionals who demand reliability and efficiency in their kitchen equipment.","<p style=""margin-bottom: 0; margin-top: 0px;"">• RANGE POWER MIXER - MP550 ULTRA</p>\n<p style=""margin: 0; padding-top: 0;"">• Motor Base: 750W, Speed: 9000 rpm under load</p>\n<p style=""margin: 0; padding-top: 0;"">• Volatge:230V/50/1 UK plug</p>\n<p style=""margin: 0; padding-top: 0;"">• Net Weight: 6.6 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Tube length:550 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: Total length 925 mm Ø 125 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MP550 ULTRA | Made by Robot Coupe, France</p>",,,taxable,,1,,,0,0,,,,,1,,,4832,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/mp-550-ultra-1.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,54,0,0,,"RANGE POWER MIXER - MP550 ULTRA",,,,,,,,field_60befc9fc0fb7,"MP550 ULTRA",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595581,011011001100100110011001100100110011001100110110,true,backend,9150175318361506,yes,yes,,product,no,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
