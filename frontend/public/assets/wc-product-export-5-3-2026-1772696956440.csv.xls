13636,simple,,,"Double professional induction hob - PID 30",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(34px, 65px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• Double professional induction hob - PID 30</p>\n<p style=""margin: 0; padding-top: 0;"">• Features: large glass ceramic hob, 2 induction boxes, 2 ventilators, 2 professional generators, the front panel. Capacitive front panel: On / Off, sound timer and Power cutoff, 20-level power (+/-) selection, digital display of power levels or timer.</p>\n<p style=""margin: 0; padding-top: 0;"">• Robust design and long-life components. Delivered without pan.</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 2 x 3 kW</p>\n<p style=""margin: 0; padding-top: 0;"">• Outside dimensions: 590 x 380 x 102 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 11 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• volts: 2 cordons 230-240 V</p>\n<p style=""margin: 0; padding-top: 0;"">• In glass ceramic dimensions: 555 x 280 x 4 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• PID 30 / Roller Grill / Made France</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(330px, 120px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,5535,"COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 600",,,https://mariotstore.com/wp-content/uploads/2024/10/Double-professional-induction-hob-3-kW.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,72,0,0,,"Double professional induction hob - PID 30,موقد حثي احترافي مزدوج,موقد كهربائي",,,,,,,,field_60befc9fc0fb7,"PID 30",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595588,011110011001011000001001100001110101101111001010,,,,,,,,,,"Type of Product