12962,simple,,,"WAFFLE MAKER FISH JE-DYB-380",1,0,visible,"Waffle Maker Fish JE-DYB-380:\nCreate delicious, fish-shaped waffles with the JE-DYB-380. Perfect for cafes and dessert shops, this durable waffle maker ensures even cooking and crispy results every time. Easy to use and clean, it's a great addition to your kitchen equipment lineup.","• WAFFLE BAKER\n• 6 fish shape\n• w/ pilot light &amp; timer for reminder\n• temp: 50 ~ 300 °c\n• power: 220-240 v / 50 hz / 1.5 kw\n• N.G.weight: 11.7 – 13 kg\n• dim: 280 x 340 x 225 mm\n• JE-DYB-380",,,taxable,,1,,,0,0,,,,,0,,,1000,"SNACK MAKER, SNACK MAKER > Waffle Maker",,,"https://mariotstore.com/wp-content/uploads/2024/10/JE-DYB-380-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/JE-DYB-380-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/JE-DYB-380-2-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/H0fd1796d29c24eb4bbed4555f26722a1e.webp",,,,,,,,,0,,Stilco,"Type of Product","Waffle Baker",1,1,Brand,Stilco,1,1,default,1,1,228,index,65,380,0,,"WAFFLE MAKER FISH,WAFFLE MAKER FISH JE-DYB-380",,,,,,,,field_60befc9fc0fb7,JE-DYB-380,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010001100110011011001110001100111000110110010,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12967,simple,,,"ELECTRIC  HOT PLATE COOKER E-DS-2",1,0,visible,"The ELECTRIC HOT PLATE COOKER E-DS-2 is a compact and efficient kitchen appliance designed for versatile cooking. With its dual heating elements, this hot plate provides quick and even heat distribution, allowing you to prepare a variety of dishes with ease. The sleek and portable design makes it ideal for small kitchens, dorm rooms, or as an additional cooking option. The E-DS-2 is user-friendly, featuring temperature control knobs for precise cooking adjustments. Whether you need an extra burner for cooking or want a convenient solution for outdoor events, the Electric Hot Plate Cooker E-DS-2 is a reliable choice.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(463px, 88px);"" aria-expanded=""false""></div>","• ELECTRIC HOT PLATE COOKER E-DS-2\n• Counter Top\n• Cap : 2 round hot plate\n• Power : 2 kw *1+1.5.kw*1= 3.5kw\n• Voltage : 230V / 50 hz\n• Net weight : 14 kg\n• Dim : 500 * 270 *105 mm\n• E-DS-2",,,taxable,,1,,,0,0,,,,,0,,,918,"Uncategorized, COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 600",,,https://mariotstore.com/wp-content/uploads/2024/10/E-DS-2.png,,,,,,,,,0,,Stilco,"Type of Product","Electric Hot Plate Cooker",1,1,Brand,Stilco,1,1,default,1,1,15,index,6,380,0,,,,,,,,,,field_60befc9fc0fb7,E-DS-2,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596777,111101101100010000100100001010111110111001010100,,,,,,,,,,Electric/Gas,Electric,1,1,Series,"Series 60 Table Top",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12969,simple,,,"GLASS COVER BAIN MARIE BM-3S",1,0,visible,"The Glass Cover Bain Marie BM-3S is a sleek and efficient kitchen appliance designed for precise temperature control and elegant food presentation. With three individual compartments, this bain marie allows for simultaneous warming of different dishes. The transparent glass cover not only adds a touch of sophistication but also enables easy monitoring of the contents. The BM-3S is equipped with precise temperature controls, making it suitable for various culinary applications, such as buffets, banquets, or catering events. Easy to use and maintain, this bain marie ensures that your dishes are kept at the optimal serving temperature while enhancing the visual appeal of your food presentation.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(244px, 0px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• GLASS COVER BAIN MARIE BM</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• without drainage Valve</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• 4* G/N 1/3 PAN +1 *G/N 1/2 PAN</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• power: 220V / 50HZ / 1.8 kw</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• dim: 910 x 350 x 320 mm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• BM-3S</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(373px, 37px); text-align: left;"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,722,850,"COOKING LINE, COOKING LINE > Food Warmers, Special Offer",,,"https://mariotstore.com/wp-content/uploads/2024/10/GLASS-COVER-BAIN-MARIE-BM-3S.png, https://mariotstore.com/wp-content/uploads/2024/10/D-DT-4-1.png, https://mariotstore.com/wp-content/uploads/2024/10/E-DT-3.png",,,,,,,,,0,,Stilco,"Type of Product","Glass Cover Bain Marie",1,1,Brand,Stilco,1,1,default,1,1,389,index,5,380,0,,,,,,,,,,field_60befc9fc0fb7,BM-3S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,111101100111011000100110001000111010000110110001,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12973,simple,,,"GLASS COVER BAIN MARIE BM-4S",1,0,visible,"The Glass Cover Bain Marie BM-4S is a versatile and stylish kitchen appliance designed to keep your food at the ideal serving temperature. With a sleek glass cover, this bain marie features four individual compartments, allowing for simultaneous warming of different dishes. The transparent glass cover not only adds a touch of sophistication but also allows for easy monitoring of the contents. The BM-4S is equipped with precise temperature controls, making it suitable for a variety of culinary applications, from buffets to catering events. Effortless to use and maintain, the Glass Cover Bain Marie BM-4S is an essential tool for keeping your dishes warm and ready for service.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(131px, 81px);"" aria-expanded=""false""></div>","• GLASS COVER BAIN MARIE BM\n\n• without drainage Valve\n\n• 4* G/N PAN 6*G/N 1/3 PAN\n\n• power: 220V / 50HZ / 1.8 kw\n\n• dim: 1175 x 350 x 320 mm\n\n• BM-4S",,,taxable,,1,,,0,0,,,,,1,,,1100,"COOKING LINE, COOKING LINE > Food Warmers, Special Offer",,,"https://mariotstore.com/wp-content/uploads/2024/10/GLASS-COVER-BAIN-MARIE-BM-4S.png, https://mariotstore.com/wp-content/uploads/2024/10/bm-4-tt-bg-500x500-1.jpg, https://mariotstore.com/wp-content/uploads/2024/10/GLASS-COVER-BAIN-MARIE-BM-3S.png",,,,,,,,,0,,Stilco,"Type of Product","Glass Cover Bain Marie",1,1,Brand,Stilco,1,1,default,1,1,389,index,7,380,0,,,,,,,,,,field_60befc9fc0fb7,BM-4S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,111111100110011000100110001000110100001110111000,false,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12976,simple,,,"Pastry (Croissant) Sheeter - TSP380",1,0,visible,"The Pastry (Croissant) Sheeter - TSP380 is a high-precision dough sheeter designed for professional bakeries and pastry shops. It efficiently rolls and flattens dough to the perfect thickness for croissants, pastries, and other baked goods. Featuring adjustable rollers, a user-friendly interface, and a space-saving design, this sheeter enhances productivity, ensures uniform dough consistency, and simplifies the preparation of laminated dough, making it an essential tool for pastry chefs.","[vc_row][vc_column][vc_column_text css=""""]\n<p style=""margin-bottom: 0; margin-top: 0px;"">. width of conveyor belt / roller: 360 mm\n. speed of cveyor belt: 110 / 198 min\n. oil immersed design.\n. the pressing wheel is specially treated.\n. not sticking to dough, and not easily being scratched.\n. minimum thickness of dough can reach 1 mm.\n. folding structure, easily moving and saving space.\n. 1n / 220 v / 50-60 hz / 0.55 kw.\n. weight: 95 kg.\n. dim: 1700 x 430 x 610 mm.\nTSP380 / capinox / France model</p>\n[/vc_column_text][/vc_column][/vc_row]",,,taxable,,1,,,0,0,,,,,0,,,7893,"BAKERY LINE",,,,,,,,,,,,0,,Capinox,"Type of Product","Pastry (Croissant) Sheeter",1,1,Brand,Capinox,1,1,default,1,1,131,index,62,259,0,,"Pastry (Croissant) Sheeter - TSP380,Pastry (Croissant) Sheeter",,,,,,,,field_60befc9fc0fb7,TSP380,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595709,011001111100011001100000110011100111110001000110,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
