12831,simple,,,"COUNTER TOP ICE CREAM MACHINE XY-25FTP",1,0,visible,"The COUNTER TOP ICE CREAM MACHINE XY-25FTP is a compact and efficient appliance designed for producing delicious ice cream in various settings. With its user-friendly controls and compact size, it's perfect for small businesses, cafes, or even home use. The XY-25FTP model offers consistent performance and quick production of frozen treats, making it an ideal choice for those looking to add ice cream to their menu or enjoy homemade desserts.","<p style="" margin-bottom: 0; margin-top: 0px;"">• Capacity: 25 - 28 L/H</p>\n<p style="" margin: 0; padding-top: 0;"">• Lavor: 2+1 mixed flavors</p>\n<p style="" margin: 0; padding-top: 0;"">• Frezze Cylinder Cap: 2.0*2 ltr</p>\n<p style="" margin: 0; padding-top: 0;"">• Hopper Cap: 6.5 ltr * 2</p>\n<p style="" margin: 0; padding-top: 0;"">• Cylinder &amp; Hopper Material: 304 S/S food grade</p>\n<p style="" margin: 0; padding-top: 0;"">• Displayer: LCD</p>\n<p style="" margin: 0; padding-top: 0;"">• Compressor: EMBRACO</p>\n<p style="" margin: 0; padding-top: 0;"">• Compressor: HP: 1.25 HP</p>\n<p style="" margin: 0; padding-top: 0;"">• Power/Voltage : 2200w / 220-240V / 50hz</p>\n<p style="" margin: 0; padding-top: 0;"">• Refrigerant : R404a / R134a</p>\n<p style="" margin: 0; padding-top: 0;"">• N./G.weight: 140 - 150 kg</p>\n<p style="" margin: 0; padding-top: 0;"">• DIM: 555*760*780 mm</p>\n<p style="" margin: 0; padding-top: 0;"">• Model: XY-25FTP</p>",,,taxable,,0,,,0,0,,,,,0,,,6190,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Counter Top Ice Cream Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,133,index,65,376,0,,"COUNTER TOP ICE CREAM MACHINE XY-25FTP",,,,,,,,field_60befc9fc0fb7,XY-25FTP,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,17345954