11986,simple,,,"BUFFET SALAD BAR -COLD EMP.SB.04",1,0,visible,"The BUFFET SALAD BAR - COLD EMP.SB.04 is a versatile and efficient solution for presenting a variety of fresh salads and cold dishes at any event or dining establishment. With its innovative design and ample chilled storage space, this salad bar ensures that your offerings stay crisp and delicious for your guests. The adjustable components allow for easy customization and arrangement of salads, making it a perfect addition to buffets, restaurants, and catering services looking to enhance their cold food presentation with style and convenience.","<p style=""margin-bottom: 0; margin-top: 0px;"">• cap: 4 x 1/1 GN</p>\n<p style=""margin: 0; padding-top: 0;"">• 40 kg/m3 density polyurathane isolation</p>\n<p style=""margin: 0; padding-top: 0;"">• Serpentine cooling system, lightining system</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant gas:R-134 A</p>\n<p style=""margin: 0; padding-top: 0;"">• Optional wooden body colour</p>\n<p style=""margin: 0; padding-top: 0;"">• Lift-Up Safety Glass Breath Shield</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel well</p>\n<p style=""margin: 0; padding-top: 0;"">• Power/ Voltage: : 1.3 kw./ 220V 50Hz</p>\n<p style=""; margin: 0; padding-top: 0;"">• N. weight: 146 kg / net m3: 0.28</p>\n<p style=""; margin: 0; padding-top: 0;"">• Dim: 1500 x 890 x 870 / 1370 mm</p>\n<p style=""; margin: 0; padding-top: 0;"">• EMP.SB.04 / EMPERO/ turkey made</p>",,,taxable,,1,,,0,0,,,,,0,,,7500,"REFRIGERATION LINE > Display Chiller, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/BUFFET-SALAD-BAR-COLD-EMP.SB_.04.png,,,,,,,,,0,,Empero,Brand,Empero,1,1,"Type of Product","Buffet Salad Bar",1,1,default,1,1,0,index,68,0,0,,"BUFFET SALAD BAR",,,,,,,,field_60befc9fc0fb7,EMP.SB.04,field_6387359a51f50,yes,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,