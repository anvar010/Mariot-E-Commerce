20241,simple,,,"CONVECTION OVEN DIGITAL CONTROL - T043DIHAAD",1,0,visible,"The CONVECTION OVEN DIGITAL CONTROL - T043DIHAAD is a high-performance commercial oven designed for professional kitchens and bakeries. It features digital controls for precise temperature and time adjustments, ensuring consistent and efficient cooking or baking results. With advanced convection technology, it ensures even heat distribution, making it ideal for a wide range of dishes, including bread, pastries, and roasted meats. The user-friendly interface enhances ease of use, while its energy-efficient design contributes to reduced operating costs.","""<strong>CONVECTION OVEN DIGITAL CONTROL - T043DIHAAD</strong>\n. Tray capacity: 4 450×340\n. Distance between tray:\n. Frequency (Hz):\n. Voltage:\n. Power (kW) :\n. Steam selector:\n. Max cooking temperature:\n- Oven weight (kg):\n. Dimension: WxDxH\nT043DIHAAD / VENIX / Italy made.""",,,taxable,,0,,,0,0,,,,,1,,,4324,"BAKERY LINE, BAKERY LINE > Bakery Oven",,,,,,,,,,,,0,,Venix,,,,,,,,,,1,1,0,,62,0,,,"CONVECTION OVEN DIGITAL CONTROL,CONVECTION OVEN DIGITAL CONTROL - T043DIHAAD",,,,,,,,field_60befc9fc0fb7,T043DIHAAD,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010111100000111110000111100110101010100101001001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
20244,simple,,,"S/S Stand for Ovens - TA6054H80S",1,0,visible,"The S/S Stand for Ovens - TA6054H80S is a sturdy and reliable stainless steel stand designed to support commercial ovens in professional kitchens. Crafted from high-quality stainless steel, it offers excellent durability and corrosion resistance, making it ideal for demanding kitchen environments. This stand provides a secure and elevated platform for ovens, optimizing space and improving workflow in the kitchen. Its easy-to-clean surface ensures maintenance is hassle-free, making it a practical addition to any commercial kitchen setup.","""S/S Stand for Ovens;\nModel suitable for ovens:\nB043 – T043 – T033 – VE043\n– Load capacity: 7 460×340 – 450X340 – GN 2/3\n– Space between trays: 80\n– Outside dimension WxDxH mm: 600x540x800\n* Weight: 16 kg\nTA6054H80S / VENIX / Italy made.""",,,taxable,,1,,,0,0,,,,,1,,,1687,"ACCESSORIES, ACCESSORIES > Tables",,,,,,,,,,,,0,,Venix,,,,,,,,,,1,1,0,,62,0,,,"S/S Stand for Ovens,S/S Stand for Ovens - TA6054H80S",,,,,,,,field_60befc9fc0fb7,TA6054H80S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011101100111011100110110000100001001100101110010,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
20247,simple,,,"S/S Stand for Ovens - TA8058H80S",1,0,visible,"The S/S Stand for Ovens - TA8058H80S is a durable and reliable stainless steel stand designed to support commercial ovens in professional kitchens. Made from high-quality stainless steel, it offers exceptional strength, stability, and corrosion resistance. This stand is designed to elevate ovens, improving workflow and optimizing kitchen space. With an easy-to-clean surface, it helps maintain a hygienic environment while ensuring a secure and stable platform for ovens, making it an essential addition to any commercial kitchen setup.","""<strong>S/S Stand for Ovens - TA8058H80S</strong>\nModel suitable for ovens: \nB04 – T04 – T03 – VE04 – VE03\n– Load capacity: 7 600×400 - GN1/1\n– Space between trays: 80\n– Outside dimension WxDxH mm: 800x580x800\n* Weight: 18.6 kg\nTA8058H80S / VENIX / Italy made.""\n",,,taxable,,1,,,0,0,,,,,1,,,1830,"ACCESSORIES, ACCESSORIES > Tables, ACCESSORIES > Tray",,,,,,,,,,,,0,,Venix,,,,,,,,,,1,1,0,,66,0,,,"S/S Stand for Ovens,S/S Stand for Ovens - TA8058H80S",,,,,,,,field_60befc9fc0fb7,TA8058H80S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,,,000111000010010110010011011101000001110111111001,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
20249,simple,,,"S/S Stand for Ovens - TA8274H80S",1,0,visible,"The S/S Stand for Ovens - TA8274H80S is a robust and high-quality stainless steel stand designed to support commercial ovens in professional kitchen settings. Constructed from durable stainless steel, it provides exceptional strength and stability, ensuring that your oven remains securely positioned. Its corrosion-resistant properties make it ideal for demanding kitchen environments. The stand also features an easy-to-clean surface, simplifying maintenance and ensuring hygiene. This stand is perfect for optimizing kitchen space and improving workflow in busy culinary operations.","""S/S Stand for Ovens;\nModel suitable for ovens:\nCP12 – 10 – 07 – 06 – 05 – 04 DG0/DGC – M0N0\n– Load capacity: 7 GN 1/1 600 X 400\n– Space between trays: 80\n– Outside dimension WxDxH mm: 820 x 740 x 800\n* Weight: 23 kg\nTA8274H80S / VENIX / Italy made.""",,,taxable,,1,,,0,0,,,,,1,,,2004,"ACCESSORIES, ACCESSORIES > Tables, ACCESSORIES > Tray",,,,,,,,,,,,0,,Venix,,,,,,,,,,1,1,0,,62,0,,,"S/S Stand for Ovens,S/S Stand for Ovens - TA8274H80S",,,,,,,,field_60befc9fc0fb7,TA8274H80S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,100111100010010010110110101100100011100011110100,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
20251,simple,,,"S/S Stand for Ovens - TA7984H80S",1,0,visible,"The S/S Stand for Ovens - TA7984H80S is a durable and practical stainless steel stand designed to provide stable support for commercial ovens in professional kitchens. Made from high-quality stainless steel, it ensures strength, durability, and resistance to corrosion, making it perfect for heavy-duty use. The stand helps optimize kitchen space, elevating ovens for better accessibility and improved workflow. With its easy-to-clean surface, this stand ensures hygiene and simplifies maintenance, making it an ideal addition to any commercial kitchen.","""S/S Stand for Ovens;\nModel suitable for ovens: SG04 / SG06 / SM05 / SM07\n– Load capacity: 7 GN 1/1 / 7 600 X 400 GN 1/1\n– Space between trays: 80\n– Outside dimension WxDxH mm: 790 x 840 x 800\n* Weight: 25 kg\nTA7984H80S / VENIX / Italy made.""",,,taxable,,1,,,0,0,,,,,1,,,2170,"ACCESSORIES, ACCESSORIES > Tables, ACCESSORIES > Tray",,,,,,,,,,,,0,,Venix,,,,,,,,,,1,1,0,,62,0,,,"S/S Stand for Ovens,S/S Stand for Ovens - TA7984H80S",,,,,,,,field_60befc9fc0fb7,TA7984H80S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,111101100011010110110110001100001011100001001010,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
20253,simple,,,"S/S Stand for Ovens - T8SL",1,0,visible,"The S/S Stand for Ovens - T8SL is a high-quality stainless steel stand designed to provide sturdy and reliable support for commercial ovens. Built for durability, it offers excellent stability, corrosion resistance, and easy maintenance, making it ideal for professional kitchens. This stand helps optimize workspace by elevating the oven to a comfortable working height, improving efficiency and workflow. Its robust construction and easy-to-clean surface ensure long-lasting performance in demanding kitchen environments.","<strong>S/S Stand for Ovens - T8SL</strong>\nModel suitable for ovens:\nT04DIS - T04DI - T04MIS - T04MI - T04MP - T04M\n* Space between trays : 80 mm\n* Weight: 22,60 kg\n* Dimensions: 792 x 570 x 600 WxDxH\nT8SL / VENIX / italy made.""",,,taxable,,1,,,0,0,,,,,1,,,2162,"BAKERY LINE, BAKERY LINE > Bakery Oven",,,,,,,,,,,,0,,Venix,,,,,,,,,,1,1,0,,62,0,,,"S/S Stand for Ovens,S/S Stand for Ovens - T8SL",,,,,,,,field_60befc9fc0fb7,T8SL,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,001111000110010110110110101101000011100101100100,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
20255,simple,,,"S/S Stand for Ovens  - T9S",1,0,visible,"The S/S Stand for Ovens - T9S is a durable and sturdy stainless steel stand designed to provide reliable support for commercial ovens in professional kitchens. Made from high-quality stainless steel, it offers excellent stability, corrosion resistance, and easy maintenance. This stand helps elevate ovens to an ergonomic working height, optimizing kitchen workflow and space efficiency. Its robust construction and easy-to-clean surface ensure long-lasting performance, making it an essential addition to any commercial kitchen setup.","""S/S Stand for Ovens;\nModel suitable for ovens:\nL06D - L06M / L04D - L04M\n* Space between trays : 80 mm\n* Weight: 12 kg\n* Dimensions: 920 x 620 x 800 WxDxH\nT9S / VENIX / italy made.""",,,taxable,,1,,,0,0,,,,,1,,,2352,"ACCESSORIES, ACCESSORIES > Tables, ACCESSORIES > Tray",,,,,,,,,,,,0,,Venix,,,,,,,,,,1,1,0,,66,0,,,"S/S Stand for Ovens,S/S Stand for Ovens - T9S",,,,,,,,field_60befc9fc0fb7,T9S,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,001111000110010110110110101101000011100101100100,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
