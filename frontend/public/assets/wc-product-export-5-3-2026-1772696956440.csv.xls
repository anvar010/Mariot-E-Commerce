11400,simple,,,"ICE CUBE MAKER MACHINE CB1265A",1,0,visible,"The ICE CUBE MAKER MACHINE CB1265A is a powerful and efficient appliance designed to produce an impressive 130 kilograms of ice per day. With a storage capacity of 65 kilograms, it ensures a constant supply of ice for various commercial applications. Whether it's a bustling restaurant, a busy bar, or any other business requiring a large amount of ice, this machine is capable of meeting high-demand scenarios. Its reliable performance and generous ice production capacity make it a valuable addition to any establishment, providing convenience and meeting the needs of customers and staff alike.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Production: kg. 130 kg/day.</p>\n<p style=""margin: 0; padding-top: 0;"">• Storage cap: kg. 65.</p>\n<p style=""margin: 0; padding-top: 0;"">• Air condensing system</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage: 220-240/ 50hz/ 1 phase/ kw 1.05</p>\n<p style=""margin: 0; padding-top: 0;"">• Made in AISI 304 18/10 stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Nett weight: 113kg</p>\n<p style=""margin: 0; padding-top: 0;"">• CB1265A / BREMA / ITALIA</p>",,,taxable,,1,,,0,0,,,,,0,,,12027.4,"REFRIGERATION LINE > ICE MAKER & FLAKES, REFRIGERATION LINE",,,"https://mariotstore.com/wp-content/uploads/2024/10/cb-1265.jpg, https://mariotstore.com/wp-content/uploads/2024/10/cb-1265a.jpg",,,,,,,,,0,,Brema,Brand,Brema,1,1,"Type of Product","Ice Cube Maker Machine",1,1,default,1,1,130,index,59,0,0,,"ICE CUBE MAKER MACHINE,آلة صنع مكعبات الثلج,ماكينة صنع مكعبات الثلج",,,,,,,,field_60befc9fc0fb7,CB1265A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595356,011000011011011000111001001110011111000110011000,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
11403,simple,,,"ICE CUBE MAKER MACHINE CB1565A",1,0,visible,"The ICE CUBE MAKER MACHINE CB1565A is a high-performance appliance capable of producing 155 kilograms of ice per day. With a storage capacity of 65 kilograms, it ensures a steady and reliable supply of ice at all times. This machine is perfect for busy commercial establishments such as restaurants, bars, hotels, and more, where a large amount of ice is required to meet customer demands. Its efficient production and ample storage capacity make it an essential addition to any business seeking a dependable solution for their ice needs.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Production: kg. 155 kg/day</p>\n<p style=""margin: 0; padding-top: 0;"">• Storage cap: kg. 65</p>\n<p style=""margin: 0; padding-top: 0;"">• Air condensing system</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage: 220-240/ 50hz/ 1 phase/ kw 1.4</p>\n<p style=""margin: 0; padding-top: 0;"">• Made in AISI 304 18/10 stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 840 x 740 x 1075 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight (net/gross) 118 / 138 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• CB1565A / BREMA / ITALIA</p>",,,taxable,,1,,,0,0,,,,,1,,,12959.1,"REFRIGERATION LINE > ICE MAKER & FLAKES, REFRIGERATION LINE",,,"https://mariotstore.com/wp-content/uploads/2024/10/cb-1265.jpg, https://mariotstore.com/wp-content/uploads/2024/10/cb-1265a.jpg",,,,,,,,,0,,Brema,Brand,Brema,1,1,"Type of Product","Ice Cube Maker Machine",1,1,default,1,1,130,index,50,0,0,,"ICE CUBE MAKER MACHINE,آلة صنع مكعبات الثلج,ماكينة صنع مكعبات الثلج",,,,,,,,field_60befc9fc0fb7,CB1565A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595274,011000011011011000111001001110011111000110011000,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
