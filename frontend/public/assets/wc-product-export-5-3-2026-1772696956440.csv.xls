13837,simple,,,"Silent Shop Coffee Grinder With Bag Holder - 43NA",1,0,visible,,"<p style=""margin-bottom: 0;margin-top: 0px"">• </p>\n<p style=""margin: 0;padding-top: 0"">• Easy to use and efficient, this coffee grinder will give you a high quality grinding.</p>\n<p style=""margin: 0;padding-top: 0"">• Bag Holder: 360 mm (11"") high. Accepts bags from 250 gr to 1 kg.</p>\n<p style=""margin: 0;padding-top: 0"">• Grinding adjustments: from extra fine to extra coarse.</p>\n<p style=""margin: 0;padding-top: 0"">• Horizontal axis grinding discs, with feeding screw.</p>\n<p style=""margin: 0;padding-top: 0"">• Simple direct dispensing of the coffee: fresh ground coffee.</p>\n<p style=""margin: 0;padding-top: 0"">• Precision grinding: Ø 63,5 mm grinding dics which are designed and manufactured by Santos for a high quality grinding, precise and fine.</p>\n<p style=""margin: 0;padding-top: 0"">• Powerful: commercial reliable induction motor.</p>\n<p style=""margin: 0;padding-top: 0"">• Silent: 70.4 dBA</p>\n<p style=""margin: 0;padding-top: 0"">• Hopper: 1.7 Kg.</p>\n<p style=""margin: 0;padding-top: 0"">• Motor Single phase: 220 - 240 V - 50/60 Hz - 600 W</p>\n<p style=""margin: 0;padding-top: 0"">• Speed: 1800 rpm (60 Hz)</p>\n<p style=""margin: 0;padding-top: 0"">• Net Weight: 20,6 kg (44 lbs)</p>\n<p style=""margin: 0;padding-top: 0"">• Dimensions Net : D: 335 mm (14"") W: 190 mm (7,5"") H: 690 mm (27"")</p>\n<p style=""margin: 0;padding-top: 0"">• 43NA / Santos / Made in France</p>",,,taxable,,1,,,0,0,,,,,0,,,5910,"COFFEE & BAR LINE, COFFEE & BAR LINE > Coffee Grinder, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/43na.png,,,,,,,,,0,,Santos,Brand,Santos,1,1,"Type of Product","Coffee Grinder",1,1,default,1,1,0,,6,0,0,,,,,,,,,,field_60befc9fc0fb7,43NA,field_6387359a51f50,no,field_6540c7c45e610,,field_6492d8387acaf,,field_6517fe43bc95f,,field_6570174679980,,,,,,,,,,,,,,,001101110110101100100011000011001001100110110011,,,,,,,,,,,,,,,,,,,,,,,,,,,,