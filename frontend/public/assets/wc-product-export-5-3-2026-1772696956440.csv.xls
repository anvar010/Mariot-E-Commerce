12687,simple,,,"ELECTRIC FERMENTER AFF-16A",1,0,visible,"The ELECTRIC FERMENTER AFF-16A is a professional-grade fermentation unit designed for bakeries and food production facilities. It provides precise temperature and humidity control, ensuring optimal conditions for dough fermentation and proofing. With its energy-efficient design and user-friendly interface, this fermenter enhances consistency, improves dough texture, and streamlines the baking process, making it an essential tool for high-quality bread and pastry production.","[vc_row][vc_column][vc_column_text css=""""]\n<p style=""margin-bottom: 0; margin-top: 0px;"">. cap: 16 trays.\n. tray size: 400 x 600 or 500 x 700 mm.\n. temp: 0 - 50°c.\n. humidity: 80 ~ 100 %.\n. power: 220 v / 50-60 hz / 2.5 kw.\n. Net Weight: 40 kg\n. dim: 490 x 690 x 1880 mm.\nAFF-16A</p>\n[/vc_column_text][/vc_column][/vc_row]",,,taxable,,1,,,0,0,,,,,0,,1552,1824,ACCESSORIES,,,https://mariotstore.com/wp-content/uploads/2024/10/H2f05d39b41ff4014a32b12fea2a9e30en_300x300.jpg,,,,,,,,,0,,Capinox,"Type of Product","Electric Fermenter",1,1,Brand,Capinox,1,1,default,1,1,15,index,68,259,0,,"ELECTRIC FERMENTER AFF-16A",,,,,,,,field_60befc9fc0fb7,AFF-16A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595665,110011011001010011001101100110010010011000110011,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
