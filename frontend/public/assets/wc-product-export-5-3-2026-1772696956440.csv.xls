14035,simple,,,"Venarro Dori DYTF - 118 M Fermenter Cabinet",1,0,visible,"The Venarro Dori DYTF-118 M Fermenter Cabinet is a professional-grade piece of bakery equipment designed to optimize the fermentation process for dough and other baked goods. This fermenter cabinet offers a range of features and capabilities that make it an indispensable tool for commercial bakeries and foodservice establishments.","Venarro Dori DYTF - 118 M Fermenter Cabinet\n\n2.4” LCD screen control panel\nIlluminated and touch button\nAutomatic working feature with real time clock\nAdjustable temperature and humidification feature\n\nTechnical specifications\nModel: DYTF - 118 M\nDimensions: 1675x1270x810 mm\nInner Dimensions: 40x60 cm - 12 Trays\nPower: 3 KW - 220 V\nElectric Input: 220 V\nCable Cross Section: 3x1.5 mm2\nWeight: 90 Kg\nFeatures\nTray Capacity: 12\nWorking Type:Electric\nTray Size: 40x60 cm",,,taxable,,1,,,0,0,,,,,1,,47685,56100,"BAKERY LINE, BAKERY LINE > Bakery Oven, COOKING LINE, Kitchen Equipment, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/Venarro-Dori-DYTF-118-M-Fermenter-Cabinet.png,,,,,,,,,0,,Venarro,Brand,Venarro,1,1,,,,,default,1,1,0,,81,0,0,,"Venarro Dori",,,,,,,,field_60befc9fc0fb7,"DYTF - 118 M",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595935,101001110000000111101100101001011100111010010110,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14037,simple,,,"Venarro Dwalin DYTF - 117 M Fermenter Cabinet",1,0,visible,"The Venarro Dwalin DYTF-117 M Fermenter Cabinet is a specialized piece of equipment designed for professional bakeries and foodservice establishments to facilitate and optimize the fermentation process for dough and other baked goods. This fermenter cabinet offers a range of features and capabilities that make it an indispensable tool for commercial baking operations.","Venarro Dwalin DYTF - 117 M Fermenter Cabinet\n\n2.4” LCD screen control panel\nIlluminated and touch button\nAutomatic working feature with real time clock\nAdjustable temperature and humidification feature\n\nTechnicial Specifications\nModel: DYTF - 117 M\nDimensions: 1100x1320x745 mm\nInner Dimensions: 40x60 cm\nPower: 3 KW - 220 V\nElectric Input: 220 V\nCable Cross Section: 5x4 mm2\nWeight: 50 Kg\nFeatures\nTray Capacity:6\nWorking Type:Electric\nTray Size: 40x60 cm",,,taxable,,1,,,0,0,,,,,1,,36890,43400,"BAKERY LINE, BAKERY LINE > Bakery Oven, COOKING LINE, Kitchen Equipment, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/Venarro-Dwalin-DYTF-117-M-Fermenter-Cabinet.png,,,,,,,,,0,,,,,,,,,,,default,1,1,0,,76,0,0,,"Venarro Dwalin",,,,,,,,field_60befc9fc0fb7,"DYTF - 117 M",field_6387359a51f50,no,field_6540c7c45e610,,field_6492d8387acaf,,field_6517fe43bc95f,yes,field_6570174679980,,,,,,,,,,,,,,1734595935,101101110000001101101100110001111000111000011010,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
