14876,simple,,,"4 Burner Gas Boiling Top - E7GCGH4C00 371001",1,0,visible,"The 4 Burner Gas Boiling Top - E7GCGH4C00 371001 is a high-performance cooking appliance designed for professional kitchens. Featuring four powerful burners, it ensures fast and even cooking for high-demand environments. Its durable stainless steel construction, precise control knobs, and easy-to-clean design make it a reliable and efficient choice for restaurants, hotels, and catering businesses.","<ul>\n 	<li><strong>4 Burner Gas Boiling Top- E7GCGH4C00 371001</strong></li>\n 	<li>Model: E7GCGH4C00</li>\n 	<li>WxDxH mm: 800x730x250 mm</li>\n 	<li>Weight: 38 Kg</li>\n 	<li>Alias: 9PDX371001</li>\n 	<li>Factory Model: E7GCGH4C00</li>\n 	<li>Customs_Class: 8419818090</li>\n 	<li>Country of origin: Italy</li>\n 	<li>Net Weight: 38.25 kg</li>\n 	<li>Net Width: 800</li>\n</ul>",,,taxable,,1,,,0,0,,,,,1,,,5179,"Kitchen Equipment, Uncategorized",,,https://mariotstore.com/wp-content/uploads/2024/10/PH_415x415_PH_371001_1_3_371001.jpg,,,,,,,,,0,,Electrolux,Brand,Electrolux,1,1,,,,,default,1,1,0,,70,0,,,"4 Burner Gas Boiling Top",,,,,,,,field_60befc9fc0fb7,"E7GCGH4C00 371001",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010101001010111010101101010110101001000010110101,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14878,simple,,,"2 Burner Gas Boiling Top- E7GCGD2C00 371000",1,0,visible,"The 2 Burner Gas Boiling Top - E7GCGD2C00 371000 is a powerful and compact cooking solution designed for professional kitchens. It features high-efficiency burners for fast and even cooking, a durable stainless steel body for long-lasting performance, and precise control knobs for easy heat adjustment. Ideal for restaurants, cafes, and catering businesses, this gas boiling top ensures reliability and efficiency in daily cooking operations.","<strong>2 Burner Gas Boiling Top- E7GCGD2C00 371000</strong>\n<ul>\n 	<li>2 Burner Gas Boiling Top</li>\n 	<li>Model: E7GCGD2C00</li>\n 	<li>WxDxH mm: 400x730x250 mm</li>\n 	<li>Weight: 20 Kg</li>\n 	<li>Alias: 9PDX371000</li>\n 	<li>Factory Model: E7GCGD2C00</li>\n 	<li>Customs_Class: 8419818090</li>\n 	<li>Country of origin: Italy</li>\n 	<li>Net Weight: 22.95 kg</li>\n 	<li>Net Width: 400</li>\n</ul>",,,taxable,,1,,,0,0,,,,,1,,,3532,"Kitchen Equipment, Uncategorized",,,https://mariotstore.com/wp-content/uploads/2024/10/E7GCGD2C00-371000.webp,,,,,,,,,0,,Electrolux,Brand,Electrolux,1,1,,,,,default,1,1,0,,64,0,,,"2 Burner Gas Boiling Top",,,,,,,,field_60befc9fc0fb7,"E7GCGD2C00 371000",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010111011011011010001001001100100101100011001011,true,backend,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
