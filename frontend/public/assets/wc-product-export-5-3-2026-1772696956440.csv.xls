13638,simple,,,"Professional gas stove - GST 7",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Professional gas stove - GST 7</p>\n<p style=""margin: 0;padding-top: 0"">• The professional gas stove GAR 7 fits into all restaurants, food trucks, kiosks, and bakeries.</p>\n<p style=""margin: 0;padding-top: 0"">• This gas stove is easy to clean: the cast iron grid, the burner crown, and the stainless steel plate are completely removable.</p>\n<p style=""margin: 0;padding-top: 0"">• Features: Piezo ignition, adjustment button with idle position, cast-iron grid, stainless steel reducer. Mounted in LPG and delivered with injectors for natural gas.</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 7 kW</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 370 x 510 x 195 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 13 kg</p>\n<p style=""margin: 0;padding-top: 0"">• GST 7 / Roller Grill / Made France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,2107,"COOKING LINE > Cooker, COOKING LINE, COOKING LINE > Cooker > Series 600",,,https://mariotstore.com/wp-content/uploads/2024/10/Professional-gas-stove-1-burner-7-kW.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Gas,1,1,default,1,1,0,,72,0,0,,"Professional gas stove - GST 7,موقد غاز,طباخ غاز",,,,,,,,field_60befc9fc0fb7,"GST 7",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595599,111000001101010011011100101011011000110000011011,,,,,,,,,,"Type of Product","Gas Cooker",1,1,Series,"Series 60 Table Top",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13641,simple,,,"Gas gyros Grill – GR 80 G",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Gas gyros Grill – GR 80 G</p>\n<p style=""margin: 0;padding-top: 0"">• The vertical gas grill GR 80 G can cook or reheat a spit of 40-kg-kebab or gyros meat thanks to 4 infrared burners with safety thermocouples.</p>\n<p style=""margin: 0;padding-top: 0"">• The independent regulation of each gas burner enables you to vary the cooking from a low position to a large flame.</p>\n<p style=""margin: 0;padding-top: 0"">• This vertical gas grill is equipped with an 800-mm-high spit.</p>\n<p style=""margin: 0;padding-top: 0"">• Features: on / off switch, 800-mm-high spit, 4 gas burners with safety thermocouple, pilot lights. Delivered in LPG with a set of natural gas injectors. Supplied without accessories.</p>\n<p style=""margin: 0;padding-top: 0"">• Capacity: 40 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 14 kW</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 580 x 660 x 1035 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 38 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Spindle height: 800 mm</p>\n<p style=""margin: 0;padding-top: 0"">• GR 80 G / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,7326,"COOKING LINE, COOKING LINE > Shawarma Machines",,,https://mariotstore.com/wp-content/uploads/2024/10/Gas-gyros-Grill-–-800-mm-high-spit-40-kg-of-meat.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Gas,1,1,default,1,1,0,,68,0,0,,"Gas gyros Grill – GR 80 G,ماكينة شاورما غاز",,,,,,,,field_60befc9fc0fb7,"GR 80 G",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595594,010110100100111011010