11382,simple,,,"FIXED HEAD SPIRAL MIXER IM 22",1,0,visible,"The FIXED HEAD SPIRAL MIXER-IM 22 is a robust and efficient dough mixer designed for small to medium-sized bakeries. With its fixed head and spiral mixing mechanism, it ensures thorough kneading and perfect dough consistency every time. Ideal for producing high-quality bread, pizza, and pastry doughs, this mixer is a reliable choice for consistent, professional results.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Fixed Head Spiral Mixer</p>\n<p style=""margin: 0; padding-top: 0;"">• Bowl volume: 22 ltr</p>\n<p style=""margin: 0; padding-top: 0;"">• Dough Capacity: 18 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Power/voltage: 230V / 50 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Absorption: 1.2 hp MONOFASE</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 75 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• External dim: 400*690*630 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• IM 22/ GGF s.r.l./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,4466.88,"BAKERY LINE, BAKERY LINE > Bakery Mixers",,,https://mariotstore.com/wp-content/uploads/2024/10/MIXER-IM22.jpg,,,,,,,,,0,,GGF,Brand,GGF,1,1,"Type of Product","Fixed Head Spiral Mixer",1,1,default,1,1,0,index,67,0,0,,"FIXED HEAD SPIRAL MIXER,FIXED HEAD SPIRAL MIXER-IM 22",,,,,,,,field_60befc9fc0fb7,"IM 22",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595917,011100011000011000011100000111001101001110101111,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
11384,simple,,,"FIXED HEAD SPIRAL MIXER-IM33",1,0,visible,"The FIXED HEAD SPIRAL MIXER-IM33 is a powerful and durable dough mixer tailored for medium-sized bakeries and pizzerias. With a 33 kg capacity and a fixed head design, it offers superior mixing performance for a variety of doughs, ensuring uniform texture and consistency. Ideal for high-volume production, this mixer is essential for achieving professional-quality results with every batch.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Fixed Head Spiral Mixer</p>\n<p style=""margin: 0; padding-top: 0;"">• Bowl volume: 33 ltr</p>\n<p style=""margin: 0; padding-top: 0;"">• Dough Capacity: 25 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Power/voltage: 230V / 50 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Absorption: 2 hp MONOFASE</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 104 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• External dim: 440*830*720 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• IM 33/ GGF s.r.l./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,5005.44,"BAKERY LINE, BAKERY LINE > Bakery Mixers",,,https://mariotstore.com/wp-content/uploads/2024/10/MIXER-IM22.jpg,,,,,,,,,0,,GGF,Brand,GGF,1,1,,,,,default,1,1,0,index,62,0,0,,"FIXED HEAD SPIRAL MIXER,FIXED HEAD SPIRAL MIXER-IM33",,,,,,,,field_60befc9fc0fb7,IM33,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595288,011100011000011000011100000111001101001110101111,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
11385,simple,,,"FIXED HEAD SPIRAL MIXER-IM42",1,0,visible,"The FIXED HEAD SPIRAL MIXER-IM42 is a high-performance dough mixer designed for heavy-duty use. It features a fixed head and a spiral mixing action, which ensures efficient and thorough mixing of dough, making it ideal for bakeries and food production facilities. With its robust construction and reliable motor, this mixer handles large batches with ease, delivering consistent results every time. Its user-friendly controls and durable build make it a valuable addition to any commercial kitchen.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Fixed Head Spiral Mixer</p>\n<p style=""margin: 0; padding-top: 0;"">• Bowl volume: 42 ltr</p>\n<p style=""margin: 0; padding-top: 0;"">• Dough Capacity: 38 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Power/voltage: 230V / 50 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Absorption: 2 hp MONOFASE</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 107 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• External dim: 470*850*720 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• IM 42/ GGF s.r.l./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,6161.76,"BAKERY LINE, BAKERY LINE > Bakery Mixers",,,https://mariotstore.com/wp-content/uploads/2024/10/MIXER-IM22.jpg,,,,,,,,,0,,GGF,Brand,GGF,1,1,"Type of Product","Fixed Head Spiral Mixer",1,1,default,1,1,0,index,62,0,0,,"FIXED HEAD SPIRAL MIXER,FIXED HEAD SPIRAL MIXER-IM42",,,,,,,,field_60befc9fc0fb7,IM42,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595661,011100011000011000011100000111001101001110101111,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
11386,simple,,,"FIXED HEAD SPIRAL MIXER-IM53T",1,0,visible,"The FIXED HEAD SPIRAL MIXER-IM53T is a versatile and robust dough mixer designed for commercial baking applications. Featuring a fixed head and spiral mixing mechanism, it ensures efficient and uniform dough mixing, making it perfect for handling large volumes of dough. The IM53T model boasts a powerful motor and durable construction, offering reliable performance for busy kitchens and bakeries. Its user-friendly controls and high-capacity bowl make it an excellent choice for producing consistent and high-quality dough with ease.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Fixed Head Spiral Mixer</p>\n<p style=""margin: 0; padding-top: 0;"">• Bowl volume: 53 ltr</p>\n<p style=""margin: 0; padding-top: 0;"">• Dough Capacity: 44 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Power/voltage: 400V/ 50 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Absorption: 2 hp / 3 PHASE</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 110 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• External dim: 530*860*720 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• IM 53T/ GGF s.r.l./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,6739.92,"BAKERY LINE, BAKERY LINE > Bakery Mixers",,,https://mariotstore.com/wp-content/uploads/2024/10/MIXER-IM22.jpg,,,,,,,,,0,,GGF,Brand,GGF,1,1,"Type of Product","Fixed Head Spiral Mixer",1,1,default,1,1,0,index,62,0,0,,"FIXED HEAD SPIRAL MIXER,FIXED HEAD SPIRAL MIXER-IM53T",,,,,,,,field_60befc9fc0fb7,IM53T,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595917,011100011000011000011100000111001101001110101111,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
11387,simple,,,"PIZZA ROLLING MACHINE S 42A",1,0,visible,"The PIZZA ROLLING MACHINE-S42A is a reliable and efficient tool designed for commercial pizza dough preparation. It features a robust and compact design, ideal for busy pizzerias and bakeries. The S42A model allows for precise adjustment of dough thickness, ensuring consistent results every time. Its user-friendly controls and durable construction make it easy to operate and maintain, enhancing productivity in dough rolling and streamlining the pizza-making process.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Pizza Rolling Machine</p>\n<p style=""margin: 0; padding-top: 0;"">• Dough weight: 210/600 gr</p>\n<p style=""margin: 0; padding-top: 0;"">• Pizza dim: 260/400 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 230v/ 1hp /50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Single-phase motor power: 0,37 kw</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 33 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 540*390*740 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• S 42A / GGF s.r.l./ italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,4514.4,"BAKERY LINE, BAKERY LINE > Rolling Machine",,,https://mariotstore.com/wp-content/uploads/2024/10/GGF-S42A-e1605348641865.jpg,,,,,,,,,0,,GGF,Brand,GGF,1,1,"Type of Product","Pizza Rolling Machine",1,1,default,1,1,0,index,27,0,0,,"PIZZA ROLLING MACHINE-S42A,ماكينة لف البيتزا",,,,,,,,field_60befc9fc0fb7,"S 42A",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595833,110110100100110010011001001100101110001111100010,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
