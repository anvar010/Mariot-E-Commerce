12523,simple,,,"Insect killer CR-CRI / ART307",1,0,visible,"The Insect Killer CR-CRI / ART307 is a highly efficient and effective device designed to eliminate insects in indoor spaces. With its advanced technology, it efficiently attracts and captures insects, ensuring quick and reliable eradication. This insect killer is suitable for use in homes, offices, commercial establishments, and public areas, providing a clean and insect-free environment. Upgrade your insect control with the CR-CRI / ART307 Insect Killer for a more comfortable and pest-free space.","<p style=""margin-bottom: 0; margin-top: 0px;"">• bulb life: 3000 h.</p>\n<p style=""margin: 0; padding-top: 0;"">• discharging voltage: 5000 v</p>\n<p style=""margin: 0; padding-top: 0;"">• coverage: 200 m2</p>\n<p style=""margin: 0; padding-top: 0;"">• consumption: 65 w</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 8.9 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• power: 220 v / 50 hz /2 x 20 w</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 8.9 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 690 x 210 x 400 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• CR-CRI / ART307 / moel / italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,544,"DRY STORE, DRY STORE > Insect Killer",,,"https://mariotstore.com/wp-content/uploads/2024/10/download-2.jpg, https://mariotstore.com/wp-content/uploads/2024/10/moel-cricri-307a-3071-elektro-insektenfalle-bug-zapper.jpg, https://mariotstore.com/wp-content/uploads/2024/10/307E_ist_alta2.jpg",,,,,,,,,0,,MOEL,"Type of Product","Insect Killer",1,1,Brand,MOEL,1,1,default,1,1,181,index,65,349,0,,"Insect killer",,,,,,,,field_60befc9fc0fb7,"CR-CRI / ART307",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011110110001111010010011100010011000110010011010,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12527,simple,,,"Insect killer CR-CRI / ART309",1,0,visible,"The Insect Killer CR-CRI / ART309 is a powerful and effective device designed to eliminate insects in indoor spaces. This smartly designed device efficiently attracts and captures insects, ensuring quick and reliable eradication. With its advanced and efficient technology, it provides an ideal solution for homes, offices, commercial establishments, and public areas facing insect problems. Get a clean and insect-free environment with the Insect Killer CR-CRI / ART309.","<p style=""margin-bottom: 0; margin-top: 0px;"">• bulb life: 1500 h.</p>\n<p style=""margin: 0; padding-top: 0;"">• discharging voltage: 5000 v</p>\n<p style=""margin: 0; padding-top: 0;"">• coverage: 12-14 m / 350 mq</p>\n<p style=""margin: 0; padding-top: 0;"">• consumption: 45 w</p>\n<p style=""margin: 0; padding-top: 0;"">• power: 220 v / 50 hz /2 x 15 w</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 4.9 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 355 x 150 x 320 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• CR-CRI / ART309 / moel / italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,384,"DRY STORE, DRY STORE > Insect Killer",,,"https://mariotstore.com/wp-content/uploads/2024/10/CRI-CRI-PROF-304.jpg, https://mariotstore.com/wp-content/uploads/2024/10/309-ist-alta3.jpg, https://mariotstore.com/wp-content/uploads/2024/10/CRI-CRI-PROF-309-1.jpg",,,,,,,,,0,,MOEL,"Type of Product","Insect Killer, MOEL",1,1,Brand,MOEL,1,1,default,1,1,181,index,65,349,0,,"Insect killer",,,,,,,,field_60befc9fc0fb7,"CR-CRI / ART309",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595776,011110110001111000010010110110011100110000110010,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12531,simple,,,"Insect killer WALL MOUNT CRI-CRI 398",1,0,visible,"The Insect Killer WALL MOUNT CRI-CRI 398 is a highly effective device designed to eliminate insects and pests in indoor spaces. With its wall-mountable design, it offers convenience and efficiency in targeting flying insects. Equipped with powerful ultraviolet (UV) light, it attracts insects towards the device, where they are trapped and controlled safely. This insect killer is ideal for homes, offices, and commercial establishments, providing a hygienic and pest-free environment. Upgrade your insect control with the WALL MOUNT CRI-CRI 398 for a more comfortable and bug-free space.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Power supply: 220-240V ~ 50-60Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Total Consumption: 20W</p>\n<p style=""margin: 0; padding-top: 0;"">• Range of action: 3-4 m of linear range</p>\n<p style=""margin: 0; padding-top: 0;"">• Insulating class: I</p>\n<p style=""margin: 0; padding-top: 0;"">• Master Box / Pallet q.: 1/72</p>\n<p style=""margin: 0; padding-top: 0;"">• Lamp: 1x20 UV-A Actinic Lamp</p>\n<p style=""margin: 0; padding-top: 0;"">• Lamp Life: 2000 h</p>\n<p style=""margin: 0; padding-top: 0;"">• Glue boards: 150x380 mm/4 units</p>\n<p style=""margin: 0; padding-top: 0;"">• Dimensions in mm: 400 x 170 x 270 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MOUNT CRI-CRI 398</p>\n<p style=""margin: 0; padding-top: 0;"">• CRI-CRI 398 / moel / italy made</p>",,,taxable,,1,,,0,0,,,,,0,,,689,"DRY STORE, DRY STORE > Insect Killer",,,"https://mariotstore.com/wp-content/uploads/2024/10/398.jpg, https://mariotstore.com/wp-content/uploads/2024/10/6041470398_1.jpg, https://mariotstore.com/wp-content/uploads/2024/10/10037-041470398.jpg",,,,,,,,,0,,MOEL,"Type of Product","Insect Killer",1,1,Brand,MOEL,1,1,default,1,1,278,index,65,349,0,,"Insect killer WALL MOUNT",,,,,,,,field_60befc9fc0fb7,"CRI-CRI 398",field_6387359a51f50,no,field_6540c7c45e610,no,field_64