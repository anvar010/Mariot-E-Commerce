12140,simple,,,"COMBI RANGE POWER MIXER - MP450 ULTRA",1,0,visible,"The COMBI RANGE POWER MP450 ULTRA is a high-performance, multifunctional hand mixer designed for professional culinary environments. It combines a powerful motor with ergonomic design, ensuring efficient and comfortable operation even during extended use. The mixer features interchangeable attachments, allowing it to handle a wide range of tasks including blending, mixing, and pureeing with ease. Its robust construction and easy-to-clean components make it a durable and reliable choice for busy kitchens, offering versatility and consistent results for chefs and food service professionals.","<p style=""margin-bottom: 0; margin-top: 0px;"">• COMBI RANGE - POWER MIXER</p>\n<p style=""margin: 0; padding-top: 0;"">• Self regulating speed system, all</p>\n<p style=""margin: 0; padding-top: 0;"">• stainless steel knife, bell whisk and tube,\ndelivered with 1 stainless steel wall</p>\n<p style=""margin: 0; padding-top: 0;"">• support,and foot with removable bell</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 8.2 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 500 watts 230V /50 /1 UK plug Single phase Speed</p>\n<p style=""margin: 0; padding-top: 0;"">• 1500 to 9000 rpm in mixer function</p>\n<p style=""margin: 0; padding-top: 0;"">• Speed: 250 to 1500 rpm in whisk function</p>\n<p style=""margin: 0; padding-top: 0;"">• Length with tube 890 mm / with whisk 805 mm Ø 125 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Made by Robot Coupe, France</p>\n<p style=""margin: 0; padding-top: 0;"">• MP450 ULTRA (code: 34871L)</p>",,,taxable,,1,,,0,0,,,,,1,,,3208,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/MP-450-ULTRA.png,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,"Type of Product","Power Mixer",1,1,default,1,1,0,index,54,0,0,,"COMBI RANGE POWER MIXER",,,,,,,,field_60befc9fc0fb7,"MP450 ULTRA",field_6387359a51