12548,simple,,,"HAMBURGER PRESS MANUAL HF-130",1,0,visible,"<strong>HAMBURGER PRESS MANUAL - HF-130</strong>\nThe HF-130 Manual Hamburger Press is designed for creating larger, perfectly shaped burger patties effortlessly. With its sturdy hand-operated construction and consistent performance, it’s an ideal choice for restaurants, food trucks, and catering services aiming to produce uniform, high-quality burgers.","<p style=""margin-bottom: 0; margin-top: 0px;"">• press diameter:Ø 130 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• weight: 5.2 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• gross weight: 6.7 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• packing size: 275 × 220 × 295 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Anodized aluminium casing, parts in contact w/ the meat in S/S</p>\n<p style=""margin: 0; padding-top: 0;"">• Machine dim: 320 x 250 x 300h mm</p>\n<p style=""margin: 0; padding-top: 0;"">• HF-130/ Easyline By Fimar</p>",,,taxable,,1,,,0,0,,,,,0,,,818.4,"FOOD PROCESSING, FOOD PROCESSING > Hamburger Press",,,"https://mariotstore.com/wp-content/uploads/2021/07/HF-130.webp, https://mariotstore.com/wp-content/uploads/2024/10/2-1-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/3-1-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/65599-1.jpg, https://mariotstore.com/wp-content/uploads/2024/10/unnamed.jpg",,,,,,,,,0,,Easyline,"Type of Product","Hamburger Press Manual",1,1,Brand,Easyline,1,1,default,1,1,353,index,67,344,0,,"HAMBURGER PRESS MANUAL,HAMBURGER PRESS MANUAL HF-130",,,,,,,,field_60befc9fc0fb7,HF-130,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,111001101110010001101100111010011000100101011000,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
