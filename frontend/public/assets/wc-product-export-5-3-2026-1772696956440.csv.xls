11295,simple,,,"UNDERCOUNTER DISHWASHER-LS506M",1,0,visible,"The LS506M Undercounter Dishwasher is a powerful and efficient kitchen appliance designed to simplify and expedite the dishwashing process, making it an indispensable addition to both residential and commercial kitchens.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Electric connection = 3.5 KW/ 230 V - 1N - 50 Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Total power = 3,5 KW (P)</p>\n<p style=""margin: 0; padding-top: 0;"">• Construction = 18/10 stainless steel (AISI 304)</p>\n<p style=""margin: 0; padding-top: 0;"">• Double wash &amp; rinse arm in stainless steel (M.L.R)</p>\n<p style=""margin: 0; padding-top: 0;"">• High load capacity = door clearance 365 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Micro - switch stops cycle</p>\n<p style=""margin: 0; padding-top: 0;"">• Wash tank filter designed for easy cleaning</p>\n<p style=""margin: 0; padding-top: 0;"">• Was tank welded by robot to prevent the building up of deposits</p>\n<p style=""margin: 0; padding-top: 0;"">• Incoloy corrosion-proof stainless steel heating element</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: mm 575 x 610 x 820 h</p>\n<p style=""margin: 0; padding-top: 0;"">• LS506M / MBM / italy made</p>",,,taxable,,0,,,0,0,,,,,0,,,6135,"LAUNDRY & DISH WASHER > Dish Washer Machines, LAUNDRY & DISH WASHER","UNDERCOUNTER DISHWASHER",,https://mariotstore.com/wp-content/uploads/2024/10/Undercounter-DishWasher.jpg,,,,,,,,,0,,MBM,Brand,MBM,1,1,"Type of Product","Undercounter Dishwasher",1,1,default,1,1,214,index,61,0,0,,"UNDERCOUNTER DISHWASHER,غسالة أطباق,غسالة صحون,جلاية صحون",,,,,,,,field_60befc9fc0fb7,LS506M,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595416,010111011011001100000011000100110110011011101001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,
