13028,simple,,,"WORK TOP CHILLER-GN3100TN",1,0,visible,"<strong>WORK TOP CHILLER - GN3100TN</strong>\nThe GN3100TN Work Top Chiller offers a spacious stainless steel work surface combined with high-capacity refrigerated storage. Engineered for commercial kitchens, it ensures consistent cooling to keep ingredients fresh while optimizing workspace efficiency. Ideal for demanding food preparation operations.","• AISI 304 18/10 S/S interior &amp; exterior w/ sanitary corner except rear panel &amp; part of bottom\n\n• Automatic closing door w/ magnetic gasket, 90° reversible w/ 4 castor wheels\n\n• Injected polyurethane insulation, CFC free, density: 40 kgs / m3\n\n• Cap: 400 ltr\n\n• w/ 3 shelf &amp; 3 drs\n\n• Working Temp: +2˚ ~ +8° at 32° temp\n\n• Power Supply: 230v / 50 Hz / 1Ph\n\n• Frige power: 360 Watt\n\n• Refrigerant : R134a\n\n• Net Weight: 113 Kg\n\n• Dim: 1795 x 700 x 850 mm (WxDxH)\n\n• Digital : DIXELL / ITALY MADE\n\n• Compressor : ASPERA / EMBRACO / ITALY\n\n• GN3100TN / Inofrigo / mariot made\n\n• ISO9001, CE&amp;ROHS approved",,,taxable,,1,,,0,0,,,,,0,,,3886,"REFRIGERATION LINE > Freezer & Chillers, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/WhatsApp-Image-2022-03-31-at-5.43.16-PM-1-1.jpeg,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Series,"Work Top",1,1,default,1,1,0,index,63,0,0,,"WORK TOP CHILLER,WORK TOP CHILLER-GN3100TN",,,,,,,,field_60befc9fc0fb7,GN3100TN,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011111110000011010000011110010010100011010010111,false,,,,,,,,,"Type of Product","Chillers & Freezers, Work Top Chiller",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13030,simple,,,"WORK TOP FREEZER-GN3100BT",1,0,visible,"<strong>WORK TOP FREEZER - GN3100BT</strong>\nThe GN3100BT Work Top Freezer combines a robust stainless steel work surface with spacious freezing storage, ensuring reliable temperature control for ingredient preservation. Designed for efficiency and durability, it's ideal for busy commercial kitchens.","• AISI 304 18/10 S/S interior &amp; exterior w/ sanitary corner except rear panel &amp; part of bottom.\n\n• Automatic closing door w/ magnetic gasket, 90° reversible w/ 4 castor wheels.\n\n• Injected polyurethane insulation, CFC free, density:40 kgs / m3\n\n• Cap: 400 ltr.\n\n• w/ 3 shelf &amp; 3 drs.\n\n• Working Temp: -15˚ ~ -20° at 32° temp.\n\n• Power Supply: 230v / 50 Hz / 1Ph.\n\n• Fridge power: 465 Watt\n\n• Refrigerant : R404a\n\n• Net Weight: 114 Kg\n\n• Dim: 1795 x 700 x 850 mm (WxDxH)\n\n• Digital : DIXELL / ITALY MADE.\n\n• Compressor : ASPERA / EMBRACO / ITALY.\n\n• GN3100BT / Inofrigo / mariot made\n\n• ISO9001, CE&amp;ROHS approved",,,taxable,,1,,,0,0,,,,,1,,,4704,"REFRIGERATION LINE > Freezer & Chillers, REFRIGERATION LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/WhatsApp-Image-2022-03-31-at-5.43.16-PM-1-1.jpeg,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Series,"Work Top",1,1,default,1,1,0,index,63,0,0,,"WORK TOP FREEZER,WORK TOP FREEZER-GN3100BT",,,,,,,,field_60befc9fc0fb7,GN3100BT,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011111110000011010000011110010010100011010010111,false,,,,,,,,salescountdowntimer,"Type of Product","Chillers & Freezers, Work Top Freezer",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13031,simple,,,"Saladette Preparation CHILLER S902 STD",1,0,visible,"The SALADETTE PREPARATION CHILLER - S900 STD is a compact and versatile refrigerated unit designed for efficient food preparation and storage. With its convenient worktop and refrigerated storage underneath, it allows chefs and food handlers to have easy access to ingredients while keeping them fresh and safe. Ideal for restaurants, cafes, and food service establishments, this saldette chiller enhances productivity and ensures the quality of your food preparation.","<p style=""margin-bottom: 0; margin-top: 0px;"">• AISI 304 18/10 S/S exterior, except rear panel &amp; part of the bottom.</p>\n<p style=""margin: 0; padding-top: 0;"">• AISI 304 18/10 S/S interior, w/ water line for collecting condensing water.</p>\n<p style=""margin: 0; padding-top: 0;"">• Magnetic gasket.</p>\n<p style=""margin: 0; padding-top: 0;"">• Injected polyurethane insulation, CFC free, density: 40 kgs / m3</p>\n<p style=""margin: 0; padding-top: 0;"">• Cap: 250 ltr w/ 1/1 gn container for salad or by choice.</p>\n<p style=""margin: 0; padding-top: 0;"">• w/ 2 shelf &amp; 2 drs.</p>\n<p style=""margin: 0; padding-top: 0;"">• working Temp: +2˚ ~ +8° at 32° temp.</p>\n<p style=""margin: 0; padding-top: 0;"">• Power Supply: 230v / 50 Hz / 1Ph.</p>\n<p style=""margin: 0; padding-top: 0;"">• fridge power: 266 Watt</p>\n<p style=""margin: 0; padding-top: 0;"">• refrigerant: R134a</p>\n<p style=""margin: 0; padding-top: 0;"">• Net Weight: 69 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Digital : DIXELL / ITALY MADE</p>\n<p style=""margin: 0; padding-top: 0;"">• compressor : ASPERA / EMBRACO / ITALY</p>\n<p style=""margin: 0; padding-top: 0;"">• S902 STD / mariot made</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 1045 x 700 x 850 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• ISO9001, CE&amp;ROHS approved""</p>",,,taxable,,1,,,0,0,,,,,0,,,2865,"REFRIGERATION LINE > Freezer & Chillers, REFRIGERATION LINE",