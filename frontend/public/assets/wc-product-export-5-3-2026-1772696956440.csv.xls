12585,simple,,,"COFFEE GRINDER -MDXS",1,0,visible,"The MDXS Coffee Grinder is a professional-grade grinding solution designed to elevate your coffee experience. With its precision grinding technology, it ensures consistent and uniform coffee grounds for optimal flavor extraction. This grinder offers adjustable settings to cater to various brewing methods, from espresso to drip coffee. Its durable construction and user-friendly design make it a reliable choice for coffee enthusiasts and cafes alike. The MDX Coffee Grinder delivers the perfect grind every time, allowing you to enjoy the true essence of your favorite coffee beans.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(366px, 17px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• COFFEE GRINDER</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Capacity : 9 Kg / Hour</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Bean Hoper Capacity : 1 Kg</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Micrometric Grinding Adjustment</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• 230 Volt / 50 - 60 Hz / 1 Ph / 300 Watts</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Dim : 190 x 360 x 590 mm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Model/ MDX/ Nuova Simonelli/ Made in Italy</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(293px, 98px); text-align: left;"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,2468,"COFFEE & BAR LINE, COFFEE & BAR LINE > Coffee Grinder",,,https://mariotstore.com/wp-content/uploads/2024/10/COFFEE-GRINDER-MDX.png,,,,,,,,,0,,"Nuova Simonelli",Brand,"Nuova Simonelli",1,1,,,,,default,1,1,125,index,68,364,0,,"COFFEE GRINDER",,,,,,,,field_60befc9fc0fb7,MDXS,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc9