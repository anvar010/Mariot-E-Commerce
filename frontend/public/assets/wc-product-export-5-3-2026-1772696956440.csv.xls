13824,simple,,,"Juice dispenser-CAPRI S2",1,0,visible,,"<p style=""margin-bottom: 0;margin-top: 0px"">• Juice Dispenser - Capri S2</p>\n<p style=""margin: 0;padding-top: 0"">• cap: 2 x 10 ltr</p>\n<p style=""margin: 0;padding-top: 0"">• bowl and cover: polycarbonate.</p>\n<p style=""margin: 0;padding-top: 0"">• double cover for better insulation of the product.</p>\n<p style=""margin: 0;padding-top: 0"">• mixing system: electromagnetic pump.</p>\n<p style=""margin: 0;padding-top: 0"">• compressor: hermetic, France-made.</p>\n<p style=""margin: 0;padding-top: 0"">• temperature control: adjustable thermostatic system.</p>\n<p style=""margin: 0;padding-top: 0"">• tap two pieces: no-drip, all stainless steel.</p>\n<p style=""margin: 0;padding-top: 0"">• chassis and panels: all stainless steel.</p>\n<p style=""margin: 0;padding-top: 0"">• power: 230 v / 50 hz / 280 w.</p>\n<p style=""margin: 0;padding-top: 0"">• weight: 24 kg.</p>\n<p style=""margin: 0;padding-top: 0"">• dim: 270 x 400 x 680 mm.</p>\n<p style=""margin: 0;padding-top: 0"">• Capri-S2 / cofrimell / italy made.</p>",,,taxable,,1,,,0,0,,,,,0,,,2850,"COFFEE & BAR LINE, COFFEE & BAR LINE > Juice Maker, Kitchen Equipment",,,"https://mariotstore.com/wp-content/uploads/2024/10/18.png, https://mariotstore.com/wp-content/uploads/2024/10/17.png, https://mariotstore.com/wp-content/uploads/2024/10/16.png",,,,,,,,,0,,Cofrimell,Brand,Cofrimell,1,1,"Type of Product","Juice Dispenser",1,1,default,1,1,0,,7,0,0,,,,,,,,,,field_60befc9fc0fb7,Capri-S2,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,100111110000100110000010110001101011001110110110,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13828,simple,,,"Price Computing / Counting Platform Scale - TCS-JC62WS-300kg",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(33px, 84px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• Price Computing / Counting Platform Scale - TCS-JC62WS-300kg</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Capacity: 300 kg , Division: 100 g, Min. weight: 2000 g</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• LCD with white backlight (JC)</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• High precision strain gauge technology</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Stainless steel indicator</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Water resistant panel</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• New design with stainless steel construciton</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Reliable performance in high humidity or dusty environments</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Dual display: weight, unit price, sum</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Tare / Zero / Add-up / Total display / Clear total</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Low voltage display / Overcharge protection</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Automatic energy saving mode</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Built-in 4V/4Ah rechargeable battery</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Power: AC/DC charger</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Platform dimension: 42 x 52 cm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• TCS-JC62WS-300kg/100g</p>\n\n<div id=""mttContainer"" class=""no