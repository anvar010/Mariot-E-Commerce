11827,simple,,,"ELECTRIC BAIN MARIE  BMPK 2120",1,0,visible,"<p style=""text-align: left; margin-bottom: 0; margin-top: 0px;"">The Electric Bain Marie BMPK 2120 is a versatile and essential piece of kitchen equipment designed to keep food items at a consistent temperature, making it an ideal addition to commercial kitchens, catering services, and buffet setups. This appliance is carefully engineered to provide precise temperature control and even heating, ensuring that your dishes remain warm and ready to serve. Below is a detailed description of the Electric Bain Marie BMPK 2120:</p>\n\n<div id=""mttContainer"" style=""transform: translate(350px, 97px);"" aria-expanded=""false""></div>","• Cap: 2 x GN 1/1 - 200\n\n• Control panel on short side, on castor wheels\n\n• Heat Temp: 30 - 900C\n\n• Power / voltage: 1.4 kw / 230V /1N\n\n• N/G weight: 42 - 51.6 kg\n\n• Dim: 650 x 900 x 900 mm\n\n• BMPK 2120/ RM GASTRO / europe made",,,taxable,,1,,,0,0,,,,,1,,,3173,"COOKING LINE, COOKING LINE > Food Warmers",,,https://mariotstore.com/wp-content/uploads/2024/10/BMPK-2120_Visualization.jpg,,,,,,,,,0,,"RM Gastro",Brand,"RM Gastro",1,1,Electric/Gas,Electric,1,1,default,1,1,0,index,62,0,0,,"ELECTRIC BAIN MARIE",,,,,,,,field_60befc9fc0fb7,"BMPK 2120",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15716,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596764,011110011010011000011001001110010110000110011110,true,backend,,,,,,,,"Type of Product","Bin Marrie",1,1,,,,,,,,,,,,,,,,
