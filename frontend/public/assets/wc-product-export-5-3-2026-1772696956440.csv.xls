13647,simple,,,"Gas Griddle with Decarbonized Steel Plate - PSR 600 G",1,0,visible,"<p style=""text-align: center"">The Gas Griddle with Decarbonized Steel Plate - PSR 600 G is a robust and efficient cooking appliance designed for commercial kitchens. Featuring a high-quality decarbonized steel plate, it ensures even heat distribution for perfectly cooked food. The gas-powered system offers quick heat-up times and precise temperature control, making it ideal for a variety of cooking tasks, from grilling meats to cooking breakfast items. Durable and reliable, the PSR 600 G is perfect for busy food service environments, providing consistent performance and easy maintenance.</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Gas Griddle with Decarbonized Steel Plate - PSR 600 G</p>\n<p style=""margin: 0;padding-top: 0"">• The steel plate of the gas griddle PSR 600 G is 10 mm thick.</p>\n<p style=""margin: 0;padding-top: 0"">• The temperature rise of this gas griddle is less than 10 minutes.</p>\n<p style=""margin: 0;padding-top: 0"">• Features: decarbonized steel plate, 2 star-shaped burners with 6 - 8 branches, Piezo ignition, 2 adjustment buttons with idle position, 2 safety thermocouples.</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 6.4 kW.</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 600 x 475 x 230 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Baking surface: 600 x 400 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 32 kg</p>\n<p style=""margin: 0;padding-top: 0"">• cooking areas: 2</p>\n<p style=""margin: 0;padding-top: 0"">• PSR 600 G / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,3326,"COOKING LINE, COOKING LINE > Grills, Top Brands",,,https://mariotstore.com/wp-content/uploads/2024/10/Gas-Griddle-with-Decarbonized-Steel-Plate-PSR-600-G.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Gas,1,1,default,1,1,0,,73,0,0,,"Gas Griddle with Decarbonized Steel Plate - PSR 600 G,شواية غاز مع لوح فولاذي منزوع الكربون,شواية غاز مع لوح فولاذي,شواية غاز مع صاج مسطح من الفولاذ المقاوم للصدأ",,,,,,,,field_60befc9fc0fb7,"PSR 600 G",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595594,011101011110011000001001010000011101101010011101,,,,,,,,,,"Type of Product","Gas Style Griddle / Chromed Plated",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13649,simple,,,"Electric Gyros Grill – GR 80 E",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Electric Gyros Grill – GR 80 E</p>\n<p style=""margin: 0;padding-top: 0"">• A set of 12 barbecue skewers (BG 4) to grill shashliks, meat skewers, or fish</p>\n<p style=""margin: 0;padding-top: 0"">• A set of 4 specific spits (BG 1) to roast chickens</p>\n<p style=""margin: 0;padding-top: 0"">• The kebab knife cuts the meat easily and calibrates the pieces of meat.</p>\n<p style=""margin: 0;padding-top: 0"">• Stainless steel side reflectors concentrate the heat on the spit of meat.</p>\n<p style=""margin: 0;padding-top: 0"">• Stainless steel protection to recover the excess meat juice and cut meat.</p>\n<p style=""margin: 0;padding-top: 0"">• The meat shovel to make portions of gyros or kebab meat.</p>\n<p style=""margin: 0;padding-top: 0"">• Features: on / off switch, 800-mm-high spit, 5 Incoloy heating elements, pilot lights. Supplied without accessories.</p>\n<p style=""margin: 0;padding-top: 0"">• Capacity: 40 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 7,2 kW</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 580 x 660 x 1035 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 35 kg</p>\n<p style=""margin: 0;padding-top: 0"">• volts: 380 V</p>\n<p style=""margin: 0;padding-top: 0"">• Spindle height: 800 mm</p>\n<p style=""margin: 0;padding-top: 0"">• GR 80 E / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,6653,"COOKING LINE, COOKING LINE > Shawarma Machines, Top Brands",,,https://mariotstore.com/wp-content/uploads/2024/10/GR-80-E.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,,,,,default,1,1,0,,68,0,0,,"Electric Gyros Grill – GR 80 E,ماكينة شاورما كهرباء",,,,,,,,field_60befc9fc0fb7,"GR 80 E",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595593,110011110011110011000011000110110010011000110100,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13651,simple,,,"Waffle Maker - GES 80",1,0,visible,"The Waffle Maker GES 80 is a kitchen appliance designed for effortlessly creating delicious waffles at home. With its user-friendly design and advanced heating technology, it allows you to prepare golden-brown, crispy waffles with ease. The GES 80 features a non-stick cooking surface that ensures easy waffle release and quick cleanup. Its adjustable temperature settings and indicator lights make it simple to achieve your desired level of waffle doneness. Whether you're a seasoned chef or a novice cook, the Waffle Maker GES 80 offers a convenient way to enjoy homemade waffles for breakfast or any time you're craving a sweet treat.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(148px, 24px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• Waffle Maker - GES 80</p>\n<p style=""margin: 0; padding-top: 0;"">• Stainless steel display stand (P08002Z03) for waffles on sticks</p>\n<p style=""margin: 0; padding-top: 0;"">• A batch of 500 special sticks for waffles on sticks</p>\n<p style=""margin: 0; padding-top: 0;"">• Set of 10 kg of waffle mix</p>\n<p style=""margin: 0; padding-top: 0;"">• Waffle size: 155 x 40 x 40 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 1.6 kW</p>\n<p style=""margin: 0; padding-top: 0;"">• Outside dimensions: 305 x 440 x 230 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 22 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• volts: 230 V</p>\n<p style=""margin: 0; padding-top: 0;"">• GES 80 / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(688px, 190px);"" aria-expanded=""true"">\n<div id=""tippy-1"" style=""z-index: 100000200; visibility: visible; position: absolute; inset: auto auto 0px 0px; margin: 0px; transform: translate(399px, -20px);"" data-tippy-root="""">\n<div class=""tippy-box"" style=""max-width: 350px; transition-duration: 300ms;"" tabindex=""-1"" role=""mtttooltip"" data-state=""visible"" data-theme=""custom"" data-animation=""fade"" data-placement=""top"">\n<div class=""tippy-content"" style=""transition-duration: 300ms;"" data-state=""visible""><span dir=""rtl"">• الأبعاد الخارجية: 305 × 440 × 230 ملم</span></div>\n<div class=""tippy-arrow"" style=""position: absolute; left: 0px; transform: translate(92px, 0px);""></div>\n</div>\n</div>\n</div>",,,taxable,,1,,,0,0,,,,,0,,,3105,"COOKING LINE, SNACK MAKER, SNACK MAKER > Waffle Maker","Waffle Maker",,https://mariotstore.com/wp-content/uploads/2024/10/GES-80.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,,,,,default,1,1,0,,84,0,0,,"Waffle Maker,صانع الوافل,الة وافل",,,,,,,,field_60befc9fc0fb7,"GES 80",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595673,011001100110111001100110010100110101110010011000,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13653,simple,,,"Pizza Oven – PZ 430 S",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• Pizza Oven – PZ 430 S</p>\n<p style=""margin: 0; padding-top: 0;"">• A thermostat regulates the chamber and the infrared quartz in the upper part</p>\n<p style=""margin: 0; padding-top: 0;"">• A power regulator for the bottom, that is to say, the firestone and infrared quartz in the lower part.</p>\n<p style=""margin: 0; padding-top: 0;"">• Features: 2 firestones for even cooking, 2 pieces of 15-minute-sound-timer lock position for non-stop use, 2 double thermic controls (Thermostat 0-350 ° + power regulator), control lights. Double insulated door with tempered glass in each chamber.</p>\n<p style=""margin: 0; padding-top: 0;"">• Inside dimensions: 430 x 430 x 110 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 3 Kw</p>\n<p style=""margin: 0; padding-top: 0;"">• Outside dimensions: 670 x 580 x 270 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight: 32 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• volts: 230 V</p>\n<p style=""margin: 0; padding-top: 0;"">• Capacity: 1 pizza Ø 41 cm (16’)</p>\n<p style=""margin: 0; padding-top: 0;"">• PZ 430 S / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(78px, 360px);"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,3564,"BAKERY LINE, BAKERY LINE > Bakery Oven",,,https://mariotstore.com/wp-content/uploads/2024/10/PZ-430-S.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,,,,,default,1,1,0,,72,0,0,,"Pizza Oven – PZ 430 S,فرن بيتزا",,,,,,,,field_60befc9fc0fb7,"PZ 430 S",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595599,110100100100110010110110100011010010010111100011,false,,,,,,,,,,,,,,,,