13665,simple,,,"Electric Griddle With Decarbonised Steel Plate - PSR 900 E",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Electric Griddle With Decarbonised Steel Plate - PSR 900 E</p>\n<p style=""margin: 0;padding-top: 0"">• The steel plate provides a good contact cooking for a direct heat transfer to the food to be cooked.</p>\n<p style=""margin: 0;padding-top: 0"">• The juices and grease are drained into the fully removable drawer.</p>\n<p style=""margin: 0;padding-top: 0"">• The stainless steel collecting tray can be cleaned in a dishwasher.</p>\n<p style=""margin: 0;padding-top: 0"">• Features: decarbonized steel plate, 3 Incoloy heating elements, 3 commutator-thermostats 0 – 300°C, pilot lights.</p>\n<p style=""margin: 0;padding-top: 0"">• Cooking surface: 900 x 400 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 9 kW or 3 x 3 kW (3 cords)</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 900 x 475 x 230 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 44 kg</p>\n<p style=""margin: 0;padding-top: 0"">• volts: 380 V ou 230 V mono</p>\n<p style=""margin: 0;padding-top: 0"">• cooking areas: 3</p>\n<p style=""margin: 0;padding-top: 0"">• PSR 900 E / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,3841,"COOKING LINE, COOKING LINE > Grills",,,https://mariotstore.com/wp-content/uploads/2024/10/PSR-900-E.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,Electric/Gas,Electric,1,1,default,1,1,0,,68,0,0,,"Electric Griddle With Decarbonised Steel Plate - PSR 900 E,شواية كهربائية مع لوح فولاذية",,,,,,,,field_60befc9fc0fb7,"PSR 900 E",field_6387359a51f50,no,field_6540c7c45e61