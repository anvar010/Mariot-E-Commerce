14719,simple,,,"Soft ice cream machine - 6240/spaceman",1,0,visible,"The Soft Ice Cream Machine 6240 by Spaceman is a high-performance, user-friendly appliance designed for producing smooth and creamy soft serve ice cream. Ideal for commercial use, this machine features efficient refrigeration and easy-to-use controls, ensuring consistent quality and optimal output. With its durable construction and advanced technology, the 6240 model is perfect for businesses looking to offer delicious soft serve treats to their customers.","Soft ice cream machine.\noutput: 290 cups/hour\nfreezing cylinder: two, 1.7 Liter\nmix hopper: two, 12 Liters (12.68 quarts).\npower: 198-242 v/50hz / 14 amps.\ndim: 550 x 650 x 1350 mm\n6240/spaceman / USA Brand",,,taxable,,1,,,0,0,,,,,1,,,16800,"REFRIGERATION LINE > Ice Cream Machines, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/spaceman-icecream.png,,,,,,,,,0,,Spaceman,Brand,Spaceman,1,1,,,,,default,1,1,0,,72,0,,,"Soft ice cream machine,Soft ice cream machine - 6240/spaceman",,,,,,,,field_60befc9fc0fb7,6240/spaceman,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011000001100111001101100110110011010001101100110,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14721,simple,,,"LA MINERVA MEAT MINCER - A/22L",1,0,visible,"The MEAT MINCER A/22L is a robust and efficient appliance designed for grinding meat with ease and precision. This heavy-duty mincer is ideal for both commercial and home use, featuring a powerful motor and high-quality blades for consistent and fine meat processing. Its durable construction ensures long-lasting performance, making it an essential tool for butchers, chefs, and cooking enthusiasts looking to prepare ground meat and sausages with professional results.","• MEAT MINCER 22\n• Output: kg/h (kg/min): 300 (5)\n• Casing and feed pan in AISI 304 stainless steel\n• Internal AISI 304 stainless steel head equipped with:\n• Enterprise: 1 plate and 1 self-sharpening knife in stainless steel\n• Removable mincing group for an easy and fast cleaning\n• Forced ventilation motor\n• Forward run, stop and reverse controls.\n• Motor power TPH kW (HP): 1,1 (1,5)\n• Motor power SPH kW (HP): 1,1 (1,5)\n• Weight : 41 kg\n• Voltage: 220/1/50Hz\n• Dim: 260 x 286 x 440 / 540 mm\n• A/22L | MINERVA | ITALY""",,,taxable,,1,,,0,0,,,,,1,,5465,6072,"FOOD PROCESSING, Kitchen Equipment, FOOD PROCESSING > Meat Mincer, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/mEAT-MINCER-A22L.png,,,,,,,,,0,,"LA MINERVA",Brand,"LA MINERVA",1,1,,,,,default,1,1,0,,81,0,,,"MEAT MINCER,MEAT MINCER - A/22L",,,,,,,,field_60befc9fc0fb7,A/22L,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595653,011100011001011000110001110100101011001101100011,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14723,simple,,,"LA MINERVA MEAT MINCER 3HP - A/32L",1,0,visible,"The MEAT MINCER 3HP - A/32L is a powerful and reliable meat grinding machine designed for high-volume processing. Equipped with a 3-horsepower motor, this heavy-duty mincer ensures efficient and consistent meat grinding, making it ideal for commercial kitchens, butcher shops, and meat processing facilities. Its robust construction and high-quality blades provide long-lasting durability and excellent performance, allowing for the production of fine and coarse ground meat, sausages, and other meat products with ease.","• MEAT MINCER 32\n• Output: kg/h (kg/min): 500 (8,3)\n• Casing and feed pan in AISI 304 stainless steel\n• Internal AISI 304 stainless steel head equipped with:\n• Enterprise: 1 plate and 1 self-sharpening knife in stainless steel\n• Removable mincing group for an easy and fast cleaning\n• Forced ventilation motor\n• Forward run, stop and reverse controls.\n• Motor power TPH kW (HP): 2,2 (3)\n• Motor power SPH kW (HP): 1,7 (2,3)\n• Weight : 49 kg\n• Voltage: 380/3/50Hz\n• Dim: 290 x 334 x 474 / 566 mm\n• A/32L | 3 HP | MINERVA | ITALY""",,,taxable,,1,,,0,0,,,,,1,,6426,7140,"FOOD PROCESSING, Kitchen Equipment, FOOD PROCESSING > Meat Mincer, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/mEAT-MINCER-A32L.png,,,,,,,,,0,,"LA MINERVA",Brand,"LA MINERVA",1,1,,,,,default,1,1,0,,81,0,,,"MEAT MINCER,MEAT MINCER 3HP - A/32L",,,,,,,,field_60befc9fc0fb7,A/32L,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595653,011100011000011000110001111100101000111101100011,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
