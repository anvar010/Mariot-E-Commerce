20273,simple,,,"Bolbol Ufo Burger",1,0,visible,"<strong>About this item</strong>\n<strong>Bolbol Ufo Burger</strong> \nUFO Shape Burgermaker to make UFO Shape burgers from Slice Breads, Burgers Breads Paninis etc\n2 side heating to make crispy bread\nMade from high quality stainless steel material\nCan make in 2 minutes\nYou an put stuffing inside the bread and make wonderful burgers\nSimilar to Waffle machine where there is 2 side heating\nBest to make crispy UFO burgers","Bolbol Ufo Burger \nSpecial Feature	Excellent Finish, Non Stick Coating\nColour	Silver\nMaterial	Stainless Steel\nBrand	Mariot\nProduct Dimensions	36D x 51W x 29H Centimeters\nWattage	1300 Watts\nItem Weight	15 Kilograms\nIncluded Components	UFO Burger maker\nStyle	Compact\nVoltage	220 Volts (AC)",,,taxable,,1,,,0,0,,,,,1,,,1350,"SNACK MAKER",,,,,,,,,,,,0,,Mariot,,,,,,,,,,1,1,0,,59,0,,,"Bolbol Ufo Burger",,,,,,,,field_60befc9fc0fb7,"Bolbol Ufo Burger ",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,,,011001110001110011000011100110010000011110110011,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
