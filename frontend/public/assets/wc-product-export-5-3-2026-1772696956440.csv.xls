13532,simple,,,"VEGETABLE PREPARATION MACHINE - CL40",1,0,visible,"The Robot Coupe CL40 is a high-performance vegetable preparation machine, designed for efficient and versatile food processing in professional kitchens. It features a powerful 1 HP motor and is capable of processing large quantities of vegetables quickly and uniformly. The CL40 comes with a variety of cutting discs, allowing for precise slicing, dicing, grating, and julienning. Its ergonomic design ensures ease of use, while the robust construction ensures durability and longevity. The machine is ideal for restaurants, catering services, and other food service establishments that require consistent and high-volume vegetable preparation.","<p style=""margin-bottom: 0;margin-top: 0px"">• VEGETABLE PREPARATION MACHINE - CL40</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 500W-1Ph-1 speed-500rpm</p>\n<p style=""margin: 0;padding-top: 0"">• Voltage: 230V/ 50/1 UK plug</p>\n<p style=""margin: 0;padding-top: 0"">• Gross weight:15.2</p>\n<p style=""margin: 0;padding-top: 0"">• kg Dim: 345 x 330 x 590 mm</p>\n<p style=""margin: 0;padding-top: 0"">• CL 40 | Made by <a href=""https://mariotstore.comold/brand/robot-coupe/"">Robot Coupe</a>, France</p>",,,taxable,,1,,,0,0,,,,,1,,5838,6868,"FOOD PROCESSING, Special Offer, FOOD PROCESSING > Vegtable Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/cl40.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,72,0,0,,"VEGETABLE PREPARATION,VEGETABLE PREPARATION MACHINE - CL40",,,,,,,,field_60befc9fc0fb7,"CL 40",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011001011100110010011100110110011001001001001011,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13534,simple,,,"TABLE TOP CUTTER MIXER - R2B",1,0,visible,"The Robot Coupe R2B Table Top Cutter Mixer is a versatile and compact food processor designed for professional use in kitchens. It features a 3.0-liter polycarbonate bowl and a powerful 1 HP motor, making it suitable for various food preparation tasks such as chopping, mixing, emulsifying, and kneading. The R2B comes with a smooth blade assembly and offers simple control for precise processing. Its durable construction and compact design make it easy to use and store, while the transparent lid allows for convenient monitoring of the food processing. This cutter mixer is ideal for restaurants, cafes, and catering services that need efficient and reliable equipment for small to medium-sized batches.","<p style=""margin-bottom: 0;margin-top: 0px"">• TABLE TOP CUTTER MIXER - R2B</p>\n<p style=""margin: 0;padding-top: 0"">• Cap: 2.9 Liter with polycarbonate bowl</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 550W-1500rpm-230V-single phase</p>\n<p style=""margin: 0;padding-top: 0"">• Dim: 200X280X350 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Net Weight: 10.5 kg</p>\n<p style=""margin: 0;padding-top: 0"">• R2B | Made by <a href=""https://mariotstore.comold/brand/robot-coupe/"">Robot Coupe</a>, France</p>",,,taxable,,1,,,0,0,,,,,0,,,3900,"FOOD PROCESSING > Cutter Mixer, FOOD PROCESSING",,,"https://mariotstore.com/wp-content/uploads/2024/10/3-3-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/4-3-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/1-2-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/2-3-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/r2b.jpg",,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,72,0,0,,"TABLE TOP CUTTER MIXER,TABLE TOP CUTTER MIXER - R2B",,,,,,,,field_60befc9fc0fb7,R2B,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,defaul