12789,simple,,,"JUICE DISPENSER DOUBLE CYLINDER MK-JD216SD",1,0,visible,"The JUICE DISPENSER DOUBLE CYLINDER MK-JD216SD is a robust and efficient appliance designed for commercial use in cafes, restaurants, and buffets. Featuring two large cylinders, this dispenser allows for the simultaneous serving of different beverages, providing versatility and convenience. The MK-JD216SD model is equipped with user-friendly controls and a durable build, ensuring consistent cooling and easy operation. Its sleek design and reliable performance make it an ideal solution for serving chilled juices and other cold drinks, enhancing service efficiency and customer satisfaction.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Bowl Capacity: 16*2 ltr</p>\n<p style=""margin: 0; padding-top: 0;"">• Material: Stainless Steel +PC</p>\n<p style=""margin: 0; padding-top: 0;"">• Lowest temperature (0C): -0~-6</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50-60hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 235 w refridgeration</p>\n<p style=""margin: 0; padding-top: 0;"">• Coolant: R410a</p>\n<p style=""margin: 0; padding-top: 0;"">• N. - G. Weight: 26 - 28 kgs</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 420*450*680 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-JD216SD / MKE-MATIC</p>",,,taxable,,0,,,0,0,,,,,0,,,1702,"COFFEE & BAR LINE, COFFEE & BAR LINE > Juice Maker",,,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Juice Dispenser Double Cyclinder",1,1,Brand,"MKE MATIC",1,1,default,1,1,236,index,65,376,0,,"JUICE DISPENSER DOUBLE CYLINDER MK-JD216SD",,,,,,,,field_60befc9fc0fb7,MK-JD216SD,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110100110000110010011001011111001001001011101100,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12791,simple,,,"Dough Mixer 10 KG – VHE.HYK.10M-K",1,0,visible,"<p style=""margin-bottom: 0px; margin-top: 0px; text-align: right;"">• Cap: 10 to 15 Kg / h</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• It can knead the dough with fork mixer w/o warming</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Contact points of food are made of stainless Steel</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Cleaning with removable bowl and movable fork</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Elegant and ergonomic design</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Non-vibrating operation with strengthened rubber tips</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Easy carriage due to special handles on bod</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Bowl Ø : 36 cm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Supply: 220V / 1N / 50Hz</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Power : 0.37 kW</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• N.weight: 50 Kg</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• Dimension: 44 x 72 x 60 cm</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: right;"">• VHE.HYK.10M-K / Mariot Turkey / Turkey made</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(119px, 55px);"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• Cap: 10 to 15 Kg / h</p>\n<p style=""margin: 0; padding-top: 0;"">• It can knead the dough with fork mixer w/o warming</p>\n<p style=""margin: 0; padding-top: 0;"">• Contact points of food are made of stainless Steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Cleaning with removable bowl and movable fork</p>\n<p style=""margin: 0; padding-top: 0;"">• Elegant and ergonomic design<