12029,simple,,,"WORK TOP FREEZER-GN2100BT",1,0,visible,"<strong>WORK TOP FREEZER - GN2100BT</strong>\nThe GN2100BT Work Top Freezer is a dual-purpose solution featuring a durable stainless steel work surface and reliable freezing storage. Designed for commercial kitchens, it maintains consistent low temperatures to preserve ingredients while maximizing workspace efficiency. Perfect for high-volume food preparation environments.","• AISI 304 18/10 S/S interior &amp; exterior w/ sanitary corner except rear panel &amp; part of bottom\n\n• automatic closing door w/ magnetic gasket, 90° reversible w/ 4 castor wheels\n\n• injected polyurethane insulation, CFC free, density: 40 kgs / m3\n\n• Cap: 260 ltr\n\n• w/ 2 shelf &amp; 2 drs\n\n• working Temp: -15˚ ~ -20° at 32° temp\n\n• Power Supply: 230v / 50 Hz / 1Ph\n\n• frige power: 588 Watt\n\n• refrigerant : R404a\n\n• Net Weight: 96 Kg\n\n• Dim: 1365 x 700 x 850 mm (WxDxH)\n\n• Digital : DIXELL / ITALY MADE\n\n• compressor : ASPERA / EMBRACO / ITALY / GN2100BT / Inofrigo / mariot made\n\n• ISO9001, CE&amp;ROHS approved",,,taxable,,1,,,0,0,,,,,0,,,4172,"REFRIGERATION LINE > Freezer & Chillers, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/WhatsApp-Image-2022-03-31-at-5.43.16-PM-1.jpeg,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Series,"Work Top",1,1,default,1,1,0,index,63,0,0,,"WORK TOP FREEZER,WORK TOP FREEZER-GN2100BT",,,,,,,,field_60befc9fc0fb7,GN2100BT,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596764,011111110000011000000010110110000100110110110111,false,,,,,,,,,"Type of Product","Work Top Freezer",1,1,,,,,,,,,,,,,,,,,
12032,simple,,,"SALADETTE PREPARATION CHILLER- S900 STD",1,0,visible,"The SALADETTE PREPARATION CHILLER - S900 STD is a compact and versatile refrigerated unit designed for efficient food preparation and storage. With its convenient worktop and refrigerated storage underneath, it allows chefs and food handlers to have easy access to ingredients while keeping them fresh and safe. Ideal for restaurants, cafes, and food service establishments, this saldette chiller enhances productivity and ensures the quality of your food preparation.","• AISI 304 18/10 S/S exterior, except rear panel &amp; part of bottom\n\n• AISI 304 18/10 S/S interior, w/ water line for colecting condensing water. Magnetic gasket\n\n• injected polyurethane insulation, CFC free, density: 40 kgs / m3\n\n• Cap: 250 ltr. G/N container for salad by choice\n\n• w/ 2 shelf &amp; 2 drs\n\n• working Temp: +2˚ ~ +8° at 32° temp\n\n• Power Supply: 230v / 50 Hz / 1Ph\n\n• frige power: 204 Watt\n\n• refrigerant : R134a\n\n• Net Weight: 66 Kg\n\n• Dim: 900 x 700 x 850 mm (WxDxH)\n\n• Digital : DIXELL / ITALY MADE\n\n• compressor : ASPERA / EMBRACO / ITALY\n\n• S900 STD / mariot made\n\n• ISO9001, CE&amp;ROHS approved",,,taxable,,1,,,0,0,,,,,1,,2383,2763,"REFRIGERATION LINE > Freezer & Chillers, REFRIGERATION LINE, Special Offer",,,"https://mariotstore.com/wp-content/uploads/2024/10/SALADETTE-PREPARATION-CHILLER-S900-STD.png, https://mariotstore.com/wp-content/uploads/2024/10/S900-STD.jpg",,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Series,"Salad Preparation",1,1,default,1,1,0,index,7,0,0,,,,,,,,,,field_60befc9fc0fb7,"S900 STD",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15729,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011111001101110010001100110110000001001011100101,false,,,,,,,,salescountdowntimer,"Type of Product","Saladette Preparation Chiller",1,1,,,,,,,,,,,,,,,,,
12035,simple,,,"WORK TOP SALADETTE PREP W/ 4DRAWER CHILLER-S901 S-S TOP 4G",1,0,visible,"The WORK TOP SALADETTE PREP W/ 4DRAWER CHILLER-S901 S-S TOP 4G is a high-quality commercial kitchen unit designed for efficient food preparation and storage. It features a durable stainless steel work surface and four refrigerated drawers, providing ample space for keeping ingredients fresh and organized. Ideal for busy kitchen environments, this prep station ensures optimal convenience and hygiene for food handling tasks.","• 4xGN1/2 Drawer Refrigerated Saladette Counter w/ S/S Top\n\n• 304 S/Sl construction interior and exterior\n\n• Famouse brand compressor\n\n• Temperature +2~+8\n\n• Static cooling User friendly controls and digital display(Dixell)\n\n• Auto defrost\n\n• Walls and door 35mm thick insulation\n\n• Dimensions 900 x 700 x 850mm (WxDxH)\n\n• Digital : DIXELL / ITALY MADE\n\n• compressor : ASPERA / EMBRACO / ITALY\n\n• S901 S-S TOP 4G / mariot made\n\n• ISO9001, CE&amp;ROHS approved",,,taxable,,1,,,0,0,,,,,0,,,4459,"REFRIGERATION LINE > Freezer & Chillers, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/WORK-TOP-SALADETTE-PREP-W-4DRAWER-CHILLER-S901-S-S-TOP-4G.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Series,"Salad Preparation",1,1,default,1,1,0,index,60,0,0,,"WORK TOP SALADETTE PREP W/ 4DRAWER CHILLER-S901 S-S TOP",,,,,,,,field_60befc9fc0fb7,"S901 S-S TOP 4G",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,010111110000011110011100000101101001001011001110,false,,,,,,,,,"Type of Product","Chillers & Freezers",1,1,,,,,,,,,,,,,,,,,
12037,simple,,,"WORK TOP CHILLER- S901 S/S TOP",1,0,visible,"<strong>WORK TOP CHILLER - S901 S/S TOP</strong>\nA durable, stainless steel worktop chiller designed for efficient cooling and convenient food preparation. Ideal for commercial kitchens, this chiller combines robust performance with easy-to-clean surfaces, ensuring your ingredients stay fresh and accessible.","• AISI 304 18/10 S/S exterior, except rear panel &amp; part of the bottom\n\n• AISI 304 18/10 S/S interior, w/ water line for collecting condensing water. Magnetic gasket\n\n• injected polyurethane insulation, CFC free, density: 40 kgs / m3\n\n• Cap: 250 ltr\n\n• w/ 2 shelf &amp; 2 drs\n\n• working Temp: ˚ ~ -20° at 32° temp\n\n• Power Supply: 230v / 50 Hz / 1Ph\n\n• frige power: 204 Watt\n\n• refrigerant : R134a\n\n• Net Weight: 63 Kg\n\n• Dim: 900 x 700 x 850 mm (WxDxH)\n\n• Digital : DIXELL / ITALY MADE\n\n• compressor : ASPERA / EMBRACO / ITALY\n\n• S901 S/S TOP / mariot made\n\n• ISO9001, CE&amp;ROHS approved",,,taxable,,1,,,0,0,,,,,0,,,2708,"REFRIGERATION LINE > Freezer & Chillers, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/S901-S-S-TOP.jpg,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Model,"S901 S/S TOP",1,1,default,1,1,130,index,60,0,,,"WORK TOP CHILLER",,,,,,,,field_60befc9fc0fb7,"S901 S/S TOP",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15758,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011110110010110010011100110100110101100101000100,false,,,,,,,,,"Type of Product","Work Top Chiller",1,1,,,,,,,,,,,,,,,,,
12039,simple,,,"SALAD BAR DISPLAY - VRX 1200",1,0,visible,"Introducing the VRX 1200 Salad Bar Display, featuring cutting-edge digital temperature control with a user-friendly display. This advanced system empowers you to precisely monitor and adjust the temperature of your salads and toppings, ensuring they remain fresh and at their optimal quality.","• SALAD BAR DISPLAY-VRX1200\n\n• Standard glass: plain or curve\n\n• cap: 5 x GN containers 1/3 size. containers not include\n\n• Temperature: +2℃～+80 C\n\n• gas refrigeration: r 134 a\n\n• power: 220 v / 50 hz / 280 w\n\n• net. weight: 36 kg\n\n• Digital temperature control with display\n\n• dim: 1200 x395x 435 mm\n\n• Digital : DIXELL / ITALY MADE\n\n• compressor : ASPERA / EMBRACO / ITALY\n\n• VRX 1200 / mariot made / uae\n\n• ISO9001, CE&amp;ROHS approved",,,taxable,,1,,,0,0,,,,,0,,,1646,"REFRIGERATION LINE > Display Chiller, Limited Sale, REFRIGERATION LINE","Salad bar",,"https://mariotstore.com/wp-content/uploads/2024/10/1.png, https://mariotstore.com/wp-content/uploads/2024/10/3.png, https://mariotstore.com/wp-content/uploads/2024/10/4.png",,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,Series,"Salad Preparation",1,1,default,1,1,0,index,7,0,0,,,,,,,,,,field_60befc9fc0fb7,"VRX 1200",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15730,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595985,101000001111100111110100100100111010100001100011,false,,,,,,,,,"Type of Product","Salad Bar Display",1,1,,,,,,,,,,,,,,,,,
