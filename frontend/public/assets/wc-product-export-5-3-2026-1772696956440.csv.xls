14338,simple,,,"VEGETABLE PREPARATION MACHINE - CL50",1,0,visible,"The CL50 Vegetable Preparation Machine is a versatile kitchen appliance designed to streamline vegetable processing. With its efficient slicing, grating, and dicing capabilities, this machine simplifies food preparation tasks, saving time and ensuring consistent results. The user-friendly design, durable construction, and adjustable settings make the CL50 a reliable choice for commercial kitchens, enhancing efficiency and culinary precision. Upgrade your kitchen with the convenience and performance of the CL50 Vegetable Preparation Machine.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• VEGETABLE PREPARATION MACHINE - CL50</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 500W-1Ph-1 speed- 375 rpm</p>\n<p style=""margin: 0;padding-top: 0"">• Voltage: 230V/ 50/1 UK plug</p>\n<p style=""margin: 0;padding-top: 0"">• Gross weight: 22 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Dim: 390 x 340 x 610 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Made by Robot Coupe, France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,8850,10409,"FOOD PROCESSING, Kitchen Equipment, Special Offer, FOOD PROCESSING > Vegtable Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/VEGETABLE-PREPARATION-CL50.png,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,64,0,0,,"VEGETABLE PREPARATION MACHINE - CL50,آلة تحضير الخضار,قطاعة الخضار الكهربائية",,,,,,,,field_60befc9fc0fb7,CL50,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110000001001110010111100110110010010011011001101,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14340,simple,,,"VEGETABLE PREPARATION  MACHINE - CL52 E",1,0,visible,"The CL52 E Vegetable Preparation Machine is a versatile and efficient kitchen appliance designed to streamline the process of preparing vegetables. This machine features a powerful motor and a range of cutting discs, allowing for quick and precise slicing, dicing, grating, and julienning of various vegetables. Its user-friendly design ensures easy operation and cleaning, making it an essential tool for professional kitchens seeking to enhance efficiency and consistency in vegetable preparation.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• VEGETABLE PREPARATION MACHINE - CL52 E</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 750W-1Ph-1 speed 375rpm</p>\n<p style=""margin: 0;padding-top: 0"">• Voltage: 230V/ 50/1 UK plug</p>\n<p style=""margin: 0;padding-top: 0"">• Net / Gross weight: 25.5 / 28 kg</p>\n<p style=""margin: 0;padding-top: 0"">• Dim: 360x340x690 mm</p>\n<p style=""margin: 0;padding-top: 0"">• (without disc)</p>\n<p style=""margin: 0;padding-top: 0"">• Made by Robot Coupe, France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,10080,11859,"FOOD PROCESSING, Kitchen Equipment, Special Offer, FOOD PROCESSING > Vegtable Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/VEGETABLE-PREPARATION-MACHINE-–-CL52-E.png,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,64,0,0,,"VEGETABLE PREPARATION MACHINE - CL52 E,آلة تحضير الخضار,قطاعة الخضار الكهربائية",,,,,,,,field_60befc9fc0fb7,"CL52 E",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110010110001110010110110110110010010010101001100,,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
14342,simple,,,"COMPACT RANGE – POWER  MIXER - CMP300VV",1,0,visible,"The CMP300VV Compact Range Power Mixer is a high-performance kitchen appliance designed for blending and mixing tasks with ease. With its powerful motor and ergonomic design, this mixer is ideal for a variety of culinary applications, from pureeing soups to emulsifying sauces. The compact size makes it suitable for kitchens with limited space, while the variable speed control allows precise blending and processing. The CMP300VV Power Mixer is a reliable and versatile tool, perfect for chefs and culinary enthusiasts looking to achieve consistent and smooth results in their food preparation.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• COMPACT RANGE – POWER MIXER - CMP300VV</p>\n<p style=""margin: 0; padding-top: 0;"">• Power: 350 watts</p>\n<p style=""margin: 0; padding-top: 0;"">• Variable Speed: 2300-9600 rpm</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage:230V/50/1 UK plug</p>\n<p style=""margin: 0; padding-top: 0;"">• Net Weight: 3.9 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim:Tube length: 300 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Total length 660 mm Ø 94 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Made by Robot Coupe, France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,1,,,2442,"BAKERY LINE, BAKERY LINE > Bakery Mixers, COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Kitchen Equipment, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/CMP300VV.jpg,,,,,,,,,0,,"Robot Coupe",Brand,"Robot Coupe",1,1,,,,,default,1,1,0,,53,0,0,,"COMPACT RANGE – POWER MIXER - CMP300VV,خلاط كهربائي",,,,,,,,field_60befc9fc0fb7,CMP300VV,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0