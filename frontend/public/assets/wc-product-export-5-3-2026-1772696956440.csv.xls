11513,simple,,,"BONE SAWS MACHINE SE1830",1,0,visible,"The <strong>BONE SAWS MACHINE SE1830</strong> is likely an industrial or commercial-grade appliance designed for cutting through bones and hard materials in meat processing or butchery applications.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Anodized or painted aluminum structure</p>\n<p style=""margin: 0; padding-top: 0;"">• CE version with low voltage controls</p>\n<p style=""margin: 0; padding-top: 0;"">• Emergency button, microswitch on machine closing cover, motor brake - cutting thickness adjustment - cutting height adjustment - portioning device, worktop, blade guide and stainless steel pusher</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 0.75 kW (1 HP)</p>\n<p style=""margin: 0; padding-top: 0;"">• SUPPLY 230V / 1N / 50Hz - 230-400V / 3 / 50Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• N.Weight 39 Kg / G. Weight : 47 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• BLADE DEVELOPMENT 1830 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Sealing bar 400 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Useful cut dim : 200 x 225h (mm)</p>\n<p style=""margin: 0; padding-top: 0;"">• Work plan: 410 x 410 (mm)</p>\n<p style=""margin: 0; padding-top: 0;"">• Tripod dim : 550 x 570 x 650h (mm)</p>\n<p style=""margin: 0; padding-top: 0;"">• Dimension: 630 x 450 x 970h (mm)</p>\n<p style=""margin: 0; padding-top: 0;"">• SE1830 / fimar/ italy made</p>",,,taxable,,1,,,0,0,,,,,1,,,6842.88,"FOOD PROCESSING, FOOD PROCESSING > Meat Slicer & Bone Saw, Special Offer",,,"https://mariotstore.com/wp-content/uploads/2024/10/SE1830-1.jpg, https://mariotstore.com/wp-content/uploads/2024/10/SE1830.jpg",,,,,,,,,0,,Fimar,Brand,Fimar,1,1,"Type of Product","Bone Saws",1,1,default,1,1,0,index,59,0,0,,"BONE SAWS MACHINE SE1830",,,,,,,,field_60befc9fc0fb7,SE1830,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,defaul