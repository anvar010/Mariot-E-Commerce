13655,simple,,,"Infrared Salamander Grill with Movable Top – SEM 600 Q",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Infrared Salamander Grill with Movable Top – SEM 600 Q</p>\n<p style=""margin: 0;padding-top: 0"">• The professional salamander grill SEM 600 Q can defrost, heat, brown, glaze, gratin dishes, grill toasts, gratins, and onion soups very quickly.</p>\n<p style=""margin: 0;padding-top: 0"">• Features: 2 sets of 4 infrared quartz, commutator with 4 positions, grid, and bottom tray.</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 3 kW</p>\n<p style=""padding-top: 0"">• Outside dimensions: 600 x 640 x 590 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Baking surface: 495 x 375 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 49 kg</p>\n<p style=""margin: 0;padding-top: 0"">• volts: 230 V</p>\n<p style=""margin: 0;padding-top: 0"">• SEM 600 Q / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,8237,"COOKING LINE, COOKING LINE > Salamander, Top Brands",,,https://mariotstore.com/wp-content/uploads/2024/10/SEM-600-Q.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,,,,,default,1,1,0,,71,0,0,,"Infrared Salamander Grill with Movable Top – SEM 600 Q,شواية السلمندر بالأشعة تحت الحمراء مع سطح متحرك,تسخين الطعام سلمندر,سلمندر تسخين الطعام,تسخين طعام",,,,,,,,field_60befc9fc0fb7,"SEM 600 Q",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595055,110100110110110010110010010110000110011100011100,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13657,simple,,,"Infrared Conveyor Toaster for Breakfast - CT 540",1,0,visible,"&nbsp;\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0;margin-top: 0px"">• Infrared Conveyor Toaster for Breakfast - CT 540</p>\n<p style=""margin: 0;padding-top: 0"">• A switch selects the quartz ramps on top and bottom</p>\n<p style=""margin: 0;padding-top: 0"">• The speed of the conveyor belt is regulated according to the product to be cooked or to be reheated. The minimum pass-through time is 47 seconds. The maximum pass-through time is 2 minutes and 30 seconds.</p>\n<p style=""margin: 0;padding-top: 0"">• Features: 2 ramps of 4 quartz tubes (1550 W at the top, 1450 W at the bottom), heating selector, variable speed drive, conveyor belt made of flexible stainless steel mesh, 15 cm front and rear trays, pilot lights, ventilated motor, adjustable feet.</p>\n<p style=""margin: 0;padding-top: 0"">• Inside dimensions: 85 mm (hauteur)</p>\n<p style=""margin: 0;padding-top: 0"">• Power: 2,65 kW</p>\n<p style=""margin: 0;padding-top: 0"">• Outside dimensions: 510 x 680 x 455 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Baking surface: 330 x 335 mm</p>\n<p style=""margin: 0;padding-top: 0"">• Weight: 20 kg</p>\n<p style=""margin: 0;padding-top: 0"">• volts: 230 V</p>\n<p style=""margin: 0;padding-top: 0"">• CT 540 / Roller Grill / Made in France</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,5829,"BAKERY LINE, COOKING LINE, BAKERY LINE > Toaster",,,https://mariotstore.com/wp-content/uploads/2024/10/CT-540.jpg,,,,,,,,,0,,"Roller Grill",Brand,"Roller Grill",1,1,,,,,default,1,1,0,,68,0,0,,"Infrared Conveyor Toaster for Breakfast - CT 540,فرن تسخين الكرواسون,فرن تسخين المعجنات,فرن تحميص الخبز والكروسان",,,,,,,,field_60befc9fc0fb7,"CT 540",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,d