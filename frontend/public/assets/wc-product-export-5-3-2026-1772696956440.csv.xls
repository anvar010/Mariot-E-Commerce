12946,simple,,,"Electric Lifting Salamander EB-450A",1,0,visible,"<strong>Electric Lifting Salamander EB-450A</strong>\n\nThe EB-450A Electric Lifting Salamander combines versatility and power, featuring adjustable heat settings and a lifting mechanism for precise cooking. Ideal for grilling, browning, and finishing dishes, it’s perfect for commercial kitchens and foodservice operations.",". Electric Lifting Salamander EB-450A\n. 1 upper heating element.\n. power: 2.8 kw\n. Voltage: 220-240V / 50hz.\n. Weight: 25 kg\n. dim: 450 x 450 x 500 mm.\n. EB-450A""",,,taxable,,1,,,0,0,,,,,1,,,2300,"COOKING LINE, COOKING LINE > Salamander",,,https://mariotstore.com/wp-content/uploads/2024/10/EB-450A.png,,,,,,,,,0,,Stilco,"Type of Product","Electric Lifting Salamander",1,1,Brand,Stilco,1,1,default,1,1,386,index,72,380,0,,"Electric Lifting Salamander,Electric Lifting Salamander EB-450A",,,,,,,,field_60befc9fc0fb7,EB-450A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011111100101111000000110100100101000111000110101,false,,,,,,,,salescountdowntimer,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12949,simple,,,"ELECTRIC LIFTING SALAMANDER EB-600A",1,0,visible,"The Electric Lifting Salamander EB-600A is a high-performance kitchen appliance designed for professional broiling and finishing of dishes. With a convenient lifting mechanism, this salamander allows for easy adjustment of the heating element to achieve precise cooking results. The EB-600A features a powerful electric heating element, making it suitable for tasks like browning, melting, and gratinating dishes quickly and efficiently. Ideal for commercial kitchens, it provides user-friendly controls for enhanced precision in cooking. The durable construction ensures longevity, and the ease of use makes the Electric Lifting Salamander EB-600A a reliable choice for chefs and food establishments aiming for precise and efficient broiling in their culinary operations.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(13px, 33px);"" aria-expanded=""false""></div>",". ELECTRIC LIFTING SALAMANDER EB-600A\n. 1 upper heating element.\n. power: 2.8 kw\n. Voltage: 220-240V / 50hz.\n. Weight: 30 kg\n. dim: 600 x 450 x 500 mm.\n. EB-600A""",,,taxable,,1,,,0,0,,,,,0,,,2635,"COOKING LINE, COOKING LINE > Salamander",,,https://mariotstore.com/wp-content/uploads/2024/10/EB-600A.png,,,,,,,,,0,,Stilco,"Type of Product","Electric Lifting Salamander",1,1,Brand,Stilco,1,1,default,1,1,386,index,72,380,0,,"ELECTRIC LIFTING SALAMANDER,ELECTRIC LIFTING SALAMANDER EB-600A",,,,,,,,field_60befc9fc0fb7,EB-600A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011111100101111000000110100100101000111000110101,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
