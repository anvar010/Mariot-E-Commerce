12095,simple,,,"MILK SHAKER-DME20MK",1,0,visible,"The MILK SHAKER-DME20MK is a high-performance appliance designed for creating perfectly blended milkshakes, smoothies, and other beverages. Ideal for both home and commercial use, this milk shaker features a powerful motor that ensures smooth and consistent results every time. Its sleek, stainless steel design is both durable and easy to clean, while the user-friendly controls make operation simple and intuitive. The DME20MK is equipped with adjustable speed settings to accommodate various mixing needs, making it a versatile addition to any kitchen or café. Enjoy delicious, creamy drinks with ease using the MILK SHAKER-DME20MK.","• cup capacity: 0.8 ltr\n\n• one head\n\n• 2-speed drink mixer\n\n• 2 agitators\n\n• power: 230 v / 50-60 hz / 1 Ph\n\n• DME20MK/WARING / USA made",,,taxable,,0,,,0,0,,,,,0,,,1700,"COFFEE & BAR LINE, COFFEE & BAR LINE > Juice Maker",,,https://mariotstore.com/wp-content/uploads/2024/10/DME20MK.jpg,,,,,,,,,0,,"Waring USA",Brand,"Waring USA",1,1,"Type of Product","Milk Shaker",1,1,default,1,1,0,index,65,0,0,,"MILK SHAKER-DME20MK",,,,,,,,field_60befc9fc0fb7,DME20MK,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,110011001100110011001100110100110101000101100101,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12097,simple,,,"HEAVY DUTY JUICE EXTRACTOR-6001XK",1,0,visible,"<p style=""margin-bottom: 0px; margin-top: 0px; text-align: left;"">• Rapidly converts fruits and vegetables into rich pulp-free juice</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Floating action stainless steel blade speeds up juice flow with the faster distribution of pulp</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Stainless steel extraction basket, bowl, and cover</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• Polycarbonate motor housing</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• power: 230 v / 50-60 hz / 1 Ph</p>\n<p style=""margin: 0px; padding-top: 0px; text-align: left;"">• WARING / 6001XK / USA made</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(427px, 15px); text-align: left;"" aria-expanded=""false""></div>","• Rapidly converts fruits and vegetables into rich pulp-free juice\n\n• Floating action stainless steel blade speeds up juice flow with the faster distribution of pulp\n\n• Stainless steel extraction basket, bowl, and cover\n\n• Polycarbonate motor housing\n\n• power: 230 v / 50-60 hz / 1 Ph\n\n• WARING / 6001XK / USA made",,,taxable,,1,,,0,0,,,,,0,,,2613,"COFFEE & BAR LINE, COFFEE & BAR LINE > Juice Maker",,,"https://mariotstore.com/wp-content/uploads/2024/10/1-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/2-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/3-1-scaled.png, https://mariotstore.com/wp-content/uploads/2024/10/6001c-waring-juicer-main_preview.png",,,,,,,,,0,,"Waring USA",Brand,"Waring USA",1,1,"Type of Product","Heavy Duty Juice Extractor",1,1,default,1,1,0,index,10,0,0,,,,,,,,,,field_60befc9fc0fb7,6001XK,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,11001