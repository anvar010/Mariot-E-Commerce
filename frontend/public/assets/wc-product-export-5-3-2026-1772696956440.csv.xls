14780,simple,,,"Roasting and baking tray 2/3 GN - TriLax coated	Rational",1,0,visible,"<strong>Rational Roasting and baking tray</strong>\nThe universal genius for baking: Bread rolls, croissants, danish pastries and much more with uniform browning, crispy crusts and fluffy interior.","<ul>\n 	<li class=""fw-bold fs-44"">Aluminium Roasting and Baking Tray.</li>\n 	<li>2/3 GN (325 × 354 mm) *</li>\n 	<li>standard size for compatibility with various gastronorm equipment.</li>\n 	<li>ideal for roasting meats and baking.</li>\n 	<li>long-lasting performance.</li>\n 	<li>Rational</li>\n</ul>",,,taxable,,1,,,0,0,,,,,1,,,426,"ACCESSORIES, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/Roasting-and-baking-tray.png,,,,,,,,,0,,Rational,Brand,Rational,1,1,,,,,default,1,1,0,,74,0,,,"Roasting and baking tray",,,,,,,,field_60befc9fc0fb7,60.73.671,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,100110011001000110001001101110011101101100011010,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
