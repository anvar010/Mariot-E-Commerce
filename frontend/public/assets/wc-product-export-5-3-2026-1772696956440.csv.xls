13772,simple,,,"GAS FLOOR FRYER - SSH55TC-2FD",1,0,visible,"The SSH55TC-2FD Gas Floor Fryer is a top-of-the-line commercial kitchen appliance designed to meet the high demands of professional kitchens. With its advanced features and capacity for high-volume frying, this fryer is an essential addition for restaurants, food service establishments, and catering businesses.\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• GAS FLOOR FRYER - SSH55TC-2FD</p>\n<p style=""margin: 0; padding-top: 0;"">• (C) INTELLIFRY Computer controller</p>\n<p style=""margin: 0; padding-top: 0;"">• Solstice Supreme High-Efficiency Fryer Gas 82)</p>\n<p style=""margin: 0; padding-top: 0;"">• 20 - 25 Lb oil capacity, twin tanks boil out and melt cycle, drain valve interlock matchless ignition, self-clean burners, downdraft protection, s/s tank front &amp; sides, total 80,000 BTU Lp gas</p>\n<p style=""margin: 0; padding-top: 0;"">• 240V/ 50 Hz / 1Ph, 0.4 AMPS cord &amp; plug</p>\n<p style=""margin: 0; padding-top: 0;"">• FD-SSH-2 Solstice Supreme Filter Drawer System, Filter Drawer Design</p>\n<p style=""margin: 0; padding-top: 0;"">• SSH55TC-2FD /PITCO / USA made</p>\n\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,0,,,0,0,,,,,0,,,59842,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment",,,"https://mariotstore.com/wp-content/uploads/2024/10/SSH55TC-2FD4.png, https://mariotstore.com/wp-content/uploads/2024/10/SSH55TC-2FD3.png, https://mariotstore.com/wp-content/uploads/2024/10/SSH55TC-2FD2.png, https://mariotstore.com/wp-content/uploads/2024/10/SSH55TC-2FD1.png",,,,,,,,,0,,Pitco,Brand,Pitco,1,1,Electric/Gas,Gas,1,1,default,1,1,0,,62,0,0,,"GAS FLOOR FRYER,مقلاة غاز – SSH55TC-2FD,مقلاة غاز",,,,,,,,field_60befc9fc0fb7,SSH55TC-2FD,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,100111011010000111101100011001100000111000110011,false,,,,,,,,,"Type of Product","Fryer, Gas Fryer",1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13777,simple,,,"GAS FLOOR FRYER - SSH55C",1,0,visible,"The SSH55C Gas Floor Fryer is a versatile and high-performance commercial kitchen appliance designed for frying various food items quickly and efficiently. Whether you're operating a busy restaurant, a concession stand, or a catering business, this fryer is an excellent choice for meeting your frying needs.","<p style=""margin-bottom: 0; margin-top: 0px;"">• GAS FLOOR FRYER - SSH55C</p>\n<p style=""margin: 0; padding-top: 0;"">• (C) INTELLIFRY Computer controller</p>\n<p style=""margin: 0; padding-top: 0;"">• Number of Fry Baskets: 2</p>\n<p style=""margin: 0; padding-top: 0;"">• Number of fry pots: 1</p>\n<p style=""margin: 0; padding-top: 0;"">• Oil cap: 40 - 50 lbs</p>\n<p style=""margin: 0; padding-top: 0;"">• Frying area: 356 x 356 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Electric power: 240V / 1 hp / 50Hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Ship weight: 208 lbs. (94.3 kg)</p>\n<p style=""margin: 0; padding-top: 0;"">• Legs: 9"" (228.6 mm) stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 397 x 875.5 x 1197 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• Model No. SSH55C /PITCO / USA made</p>",,,taxable,,1,,,0,0,,,,,0,,,27653,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment",,,"https://mariotstore.com/wp-content/uploads/2023/04/SSH55c-pitco.webp, https://mariotstore.com/wp-content/uploads/2024/10/ssh55c1.png, https://mariotstore.com/wp-content/uploads/2024/10/ssh55c3.png, https://mariotstore.com/wp-content/uploads/2024/10/ssh55c4.png, https://mariotstore.com/wp-content/uploads/2024/10/ssh55c5.png",,,,,,,,,0,,Pitco,Brand,Pitco,1,1,Electric/Gas,Gas,1,1,default,1,1,0,,70,0,0,,"GAS FLOOR FRYER",,,,,,,,field_60befc9fc0fb7,SSH55C,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,0011001101100011001111011000011001011001110