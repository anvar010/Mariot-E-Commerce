13747,simple,,,"GAS COOKER WITH STATIC OVEN - SPST 780/21 GE",1,0,visible,"&nbsp;\n<div id=""mttContainer"" style=""transform: translate(5px, 93px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(941px, 179px);"" aria-expanded=""false""></div>","• GAS COOKER WITH STATIC OVEN - SPST 780/21 GE\n\n• Double boiling unit 1 x 4 + 3 x 8,5 kW\n\n• Powerful brass burners with unique flame spreader\n\n• Electric oven GN 2/1 with static heat inside the cabinet\n\n• SPST 780/21 GE / RM GASTRO / Made in Europe",,,taxable,,1,,,0,0,,,,,1,,,10000,"COOKING LINE > Cooker, COOKING LINE, Kitchen Equipment, COOKING LINE > Cooker > Series 700",,,https://mariotstore.com/wp-content/uploads/2024/10/SPST-780-21-GE.png,,,,,,,,,0,,"RM Gastro",Brand,"RM Gastro",1,1,"Type of Product","Gas Cooker",1,1,default,1,1,0,,56,0,0,,"GAS COOKER WITH STATIC OVEN - SPST 780/21 GE,طباخ غاز مع فرن ثابت – SPST 780/21 GE,طباخ غاز مع فرن ثابت",,,,,,,,field_60befc9fc0fb7,"SPST 780/21 GE",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,001001011001001101101001101110011101100011100001,true,backend,,,,,,,,Series,"Series 70",1,1,Electric/Gas,Gas,1,1,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13749,simple,,,"ICE CUBE MAKER MACHINE - CB640A",1,0,visible,"The ICE CUBE MAKER MACHINE – CB640A is a high-capacity ice-making appliance designed to produce 67 kilograms of ice per day. With a storage capacity of 40 kilograms, it ensures a continuous and reliable supply of ice for various commercial applications. This efficient machine is perfect for businesses that require a steady and substantial ice production to meet their customers' needs.\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(34px, 46px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>","<p style=""margin-bottom: 0; margin-top: 0px;"">• ICE CUBE MAKER MACHINE - CB640A</p>\n<p style=""margin: 0; padding-top: 0;"">• Production: 67 kg/day</p>\n<p style=""margin: 0; padding-top: 0;"">• Storage cap: 40 kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Cooling system (A=Air – W=Water): A /W</p>\n<p style=""margin: 0; padding-top: 0;"">• Type of cube: D-13g, A - 18g, C - 33g, E - 42g</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant: R452A, . Fuse: 10 A</p>\n<p style=""margin: 0; padding-top: 0;"">• Water consumption: A 2.8 - W 12.8</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage: 220-240/ 50hz/ 1 phase/ kw 0.7</p>\n<p style=""margin: 0; padding-top: 0;"">• Made in AISI 304 18/10 stainless steel</p>\n<p style=""margin: 0; padding-top: 0;"">• Weight (N/G) : 67 / 79 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• Dim: 735 x 603 x h.850 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• CB640A / BREMA / ITALIA</p>\n\n<div id=""mttContainer"" class=""notranslate"" style=""transform: translate(938px, 299px);"" aria-expanded=""false""></div>\n<div id=""mttContainer"" class=""notranslate"" aria-expanded=""false""></div>",,,taxable,,1,,,0,0,,,,,0,,,8031.1,"REFRIGERATION LINE > ICE MAKER & FLAKES, Kitchen Equipment, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/ICE-CUBE-MAKER-MACHINE-CB640A.png,,,,,,,,,0,,Brema,Brand,Brema,1,1,,,,,default,1,1,0,,64,0,0,,"ICE CUBE MAKER MACHINE,ماكينة صنع مكعبات الثلج,ماكينة صنع مكعبات الثلج – CB640A",,,,,,,,field_60befc9fc0fb7,CB640A,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,001001110011001101101011001110010001101100011001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13751,simple,,,"BAR BLENDER - HBH455‐UK (replaces HBH450R)",1,0,visible,"The <strong>HBH455-UK Bar Blende</strong>r is a powerful and durable commercial blender, designed for high-volume blending of smoothies, cocktails, and frozen beverages. Replacing the HBH450R, it features a strong motor, stainless steel blades, and multiple speed settings for precision blending. Ideal for bars, cafés, and restaurants, it ensures consistent performance and long-lasting reliability.","<strong>BAR BLENDER - HBH455‐UK (replaces HBH450R)</strong>\n(International) Tango® High Performance Bar Blender,\n. Two speeds motor,\n. 48 oz (1.36 liter) capacity\n. Stackable polycarbonate container,\n. Variable timer, pulse switch, auto shutoff,\n. Wave‐Action® System,\n. Sure Grip™ feet,\n. Stainless steel blades,\n. 2‐2/5 HP, 220‐240v/50/60/1‐ph, 1200 watt, 10 amp,\nHamilton Beach Model No. HBH455‐UK (replaces\nHBH450R)",,,taxable,,1,,,0,0,,,,,0,,,2170,"COFFEE & BAR LINE > Blenders, COFFEE & BAR LINE, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/BAR-BLENDER-HBH455‐UK.png,,,,,,,,,0,,"Hamilton Beach USA",Brand,"Hamilton Beach- USA",1,1,,,,,default,1,1,0,,57,0,0,,"BAR BLENDER - HBH455‐UK,خلاط بار – HBH455‐UK,خلاط كهربائي",,,,,,,,field_60befc9fc0fb7,"HBH455‐UK (replaces HBH450R)",field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,15740,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595388,100110100110001110010110011011001011001100011001,false,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
13753,simple,,,"GAS FLOOR FRYER - SG14T",1,0,visible,"<span style=""color: red; font-size: 18px; background-color: green;""><a title=""PITCO"" href=""https://www.youtube.com/shorts/eLjFEMaNmbA"">Click Here See Video of the product</a> </span>\n\nThe SG14T Gas Floor Fryer is a reliable and efficient commercial kitchen appliance designed for frying a wide range of foods quickly and consistently. Whether you're operating a restaurant, food truck, or catering business, this fryer is a valuable addition to your kitchen equipment lineup.","<p style=""margin-bottom: 0; margin-top: 0px;"">• GAS FLOOR FRYER - SG14T</p>\n<p style=""margin: 0; padding-top: 0;"">• Solstice Fryer, Gas, Floor Model, Split Frypot</p>\n<p style=""margin: 0; padding-top: 0;"">• Oil Capacity: 20-25 lb each</p>\n<p style=""margin: 0; padding-top: 0;"">• BTUS: 50000 each</p>\n<p style=""margin: 0; padding-top: 0;"">• Cook Area: 14”x 14” W x D</p>\n<p style=""margin: 0; padding-top: 0;"">• Tanks Millivolt Control only, includes drain line cleanout road and drain extension</p>\n<p style=""margin: 0; padding-top: 0;"">• S/S tank, front door and sides</p>\n<p style=""margin: 0; padding-top: 0;"">• LP Gas</p>\n<p style=""margin: 0; padding-top: 0;"">• 9"" leg standard</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 165 x 146 x 336.5 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• SG14T / MIDDLEBY XME, S.L.U. / USA made</p>",,,taxable,,1,,,0,0,,,,,0,,,21997,"COOKING LINE, COOKING LINE > Fryers, Kitchen Equipment",,,https://mariotstore.com/wp-content/uploads/2024/10/GAS-FLOOR-FRYER-SG14T.png,,,,,,,,,0,,Pitco,Brand,Pitco,1,1,Electric/Gas,Gas,1,1,default,1,1,0,,15,0,0,,,,,,,,,,field_60befc9fc0fb7,SG14T,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,100111110011001100101001101001100100110010011001,,,,,,,,,,"Type of Product","Gas Fryer",1,1,,,,,,,,,,,,,,,,,