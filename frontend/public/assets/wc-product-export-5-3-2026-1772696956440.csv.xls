12770,simple,,,"ICE CREAM MACHINE MK 220-240v / 50hz -FP1R-6C",1,0,visible,"The ICE CREAM MACHINE MK 220-240v / 50hz -FP1R-6C is a robust and efficient appliance designed for commercial ice cream production. Operating on a 220-240V power supply with a frequency of 50Hz, this machine ensures reliable performance in various international power environments. The FP1R-6C model features six cylinders, allowing for simultaneous production of multiple flavors or batches of ice cream, making it ideal for high-demand settings such as ice cream parlors and dessert shops. With its user-friendly controls and durable construction, this machine offers consistent results and ease of operation, making it a valuable addition to any professional kitchen.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 1300W</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• Net Weight 98 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 1050 X 750 X 880 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-FP1R-6C / MKE-MATIC</p>",,,taxable,,1,,,0,0,,,,,0,,,4991,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/71b6Dn72wpL._SL1500_.jpg,,,,,,,,,0,,MKE-MATIC,"Type of Product","Ice Cream Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,59,376,0,,"ICE CREAM MACHINE MK 220-240v / 50hz -FP1R-6C",,,,,,,,field_60befc9fc0fb7,MK-FP1R-6C,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,011101101101110100101100100101100100111001100000,,,,,,,,,,,,,,,,,,,,