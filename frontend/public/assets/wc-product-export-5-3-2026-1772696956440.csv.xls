12772,simple,,,"ICE CREAM MACHINE MK 220-240v / 60hz - FP1R-6C",1,0,visible,"The ICE CREAM MACHINE MK 220-240v / 60hz - FP1R-6C is a powerful and versatile appliance tailored for commercial ice cream production. Operating on a 220-240V power supply with a frequency of 60Hz, this machine ensures efficient and consistent performance. The FP1R-6C model features six cylinders, enabling simultaneous production of multiple flavors or batches of ice cream, ideal for high-demand settings like ice cream parlors and dessert shops. With user-friendly controls and durable construction, this machine offers reliability and ease of operation, making it a valuable asset for businesses looking to expand their frozen treat offerings.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 60hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 1300W</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• Net Weight 98 Kg</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 1050 X 750 X 880 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-FP1R-6C / MKE-MATIC</p>",,,taxable,,1,,,0,0,,,,,0,,,4991,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,,,,,,,,,,0,,MKE-MATIC,"Type of Product","Ice Cream Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,64,376,0,,"ICE CREAM MACHINE MK 220-240v / 60hz",,,,,,,,field_60befc9fc0fb7,MK-FP1R-6C,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,,
12773,simple,,,"DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE 50hz - MK-FP2R-6c",1,0,visible,"The DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE 50Hz - MK-FP2R-6C is a versatile and efficient appliance designed for commercial use. With its two pots for frying ice cream and a built-in salad table, this machine offers a comprehensive solution for diverse kitchen needs. Operating at 50Hz, it ensures reliable performance in environments with this power frequency. The MK-FP2R-6C model is equipped with user-friendly controls and durable construction, facilitating easy operation and long-lasting use. Its dual functionality allows for simultaneous ice cream frying and salad preparation, making it an excellent choice for ice cream parlors, dessert shops, and restaurants seeking to expand their menu offerings.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Capacity</p>\n<p style=""margin: 0; padding-top: 0;"">• Compressor: EMBRACO / ASPERA</p>\n<p style=""margin: 0; padding-top: 0;"">• Voltage : 220-240v / 50hz</p>\n<p style=""margin: 0; padding-top: 0;"">• Power : 2400W</p>\n<p style=""margin: 0; padding-top: 0;"">• Refrigerant : R22 / R404a</p>\n<p style=""margin: 0; padding-top: 0;"">• Noise: 48db</p>\n<p style=""margin: 0; padding-top: 0;"">• DIM: 1550 X750 X 880 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• MK-FP2R-6c / MKE-MATIC</p>",,,taxable,,1,,,0,0,,,,,0,,,7570,"REFRIGERATION LINE > Ice Cream Machines, REFRIGERATION LINE",,,https://mariotstore.com/wp-content/uploads/2024/10/MK-FP2R-6c-Ice-Cream-Machine.png,,,,,,,,,0,,MKE-MATIC,"Type of Product","Double Pot Ice Cream Fried Machine",1,1,Brand,"MKE MATIC",1,1,default,1,1,130,index,66,376,0,,"DOUBLE POT ICE CREAM FRIED MACHINE WITH SALAD TABLE 50hz",,,,,,,,field_60befc9fc0fb7,MK-FP2R-6c,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734595488,110101001101