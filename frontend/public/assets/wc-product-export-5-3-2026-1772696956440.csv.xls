13985,simple,,,"Cake Showcase- FCS1000R3M/GOLD",1,0,visible,"The Cake Showcase FCS1000R3M/GOLD is a premium display unit designed to elegantly present and preserve cakes and pastries. With its exquisite gold-accented design, this showcase combines aesthetic appeal with advanced cooling technology, ensuring your delectable creations stay fresh and visually appealing. Its spacious interior and adjustable shelving provide ample space for arranging various confectionery items attractively. The FCS1000R3M/GOLD Cake Showcase is a perfect blend of style and functionality, making it an ideal choice for bakeries, cafes, and dessert shops aiming to showcase their treats in a sophisticated manner.","<p style=""margin-bottom: 0; margin-top: 0px;"">• Cake Showcase- FCS1000R3M/GOLD</p>\n<p style=""margin: 0; padding-top: 0;"">• Front flat glass with LED light</p>\n<p style=""margin: 0; padding-top: 0;"">• S/S Golden Mirror base; Auto defrosting</p>\n<p style=""margin: 0; padding-top: 0;"">• Rear sliding door, with 3 shelves</p>\n<p style=""margin: 0; padding-top: 0;"">• Temperature:+2～+8℃；220V/50HZ</p>\n<p style=""margin: 0; padding-top: 0;"">• Embraco / SECOP compressor; Dixell / Carol controller</p>\n<p style=""margin: 0; padding-top: 0;"">• N.G.weight: kg</p>\n<p style=""margin: 0; padding-top: 0;"">• dim: 1000 * 685 * 1300 mm</p>\n<p style=""margin: 0; padding-top: 0;"">• FCS100R3M / GOLDEN</p>",,,taxable,,1,,,0,0,,,,,1,,3999,4776,"BAKERY LINE > Bakery Display, BAKERY LINE, REFRIGERATION LINE > Display Chiller, Kitchen Equipment, REFRIGERATION LINE, Special Offer",,,https://mariotstore.com/wp-content/uploads/2024/10/Cake-Showcase-FCSR3M-GOLD.png,,,,,,,,,0,,Inofrigo,Brand,Inofrigo,1,1,,,,,default,1,1,0,,74,0,0,,"Cake Showcase",,,,,,,,field_60befc9fc0fb7,FCS1000R3M/GOLD,field_6387359a51f50,no,field_6540c7c45e610,no,field_6492d8387acaf,,field_6517fe43bc95f,no,field_6570174679980,no," ",0,default,default,default,default,default,default,default,0,0,default,1734596375,01011